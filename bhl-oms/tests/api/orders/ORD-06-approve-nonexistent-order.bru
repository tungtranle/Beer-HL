meta {
  name: ORD-06 - Approve non-existent order returns 404
  type: http
  seq: 21
}

post {
  url: {{base_url}}/v1/orders/00000000-0000-0000-0000-000000000000/approve
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accountant_token}}
}

assert {
  res.status: eq 404
}

docs {
  ## POST /v1/orders/:id/approve — UUID không tồn tại → 404
  
  Kiểm tra error handling khi đơn không tồn tại.
  Không được crash với 500.
}
