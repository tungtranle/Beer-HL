meta {
  name: TRIP-02 - Get trip not found
  type: http
  seq: 31
}

get {
  url: {{base_url}}/v1/trips/00000000-0000-0000-0000-000000000000
  body: none
  auth: bearer
}

auth:bearer {
  token: {{dispatcher_token}}
}

assert {
  res.status: eq 404
}

docs {
  ## GET /v1/trips/:id — UUID không tồn tại → 404
}
