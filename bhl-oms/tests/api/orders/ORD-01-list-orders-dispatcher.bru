meta {
  name: ORD-01 - List orders requires auth
  type: http
  seq: 10
}

get {
  url: {{base_url}}/v1/orders
  body: none
  auth: bearer
}

auth:bearer {
  token: {{dispatcher_token}}
}

assert {
  res.status: in [200, 204]
  res.body: isDefined
}

docs {
  ## GET /v1/orders — dispatcher có quyền xem
  
  Response: { data: [...], total: N, page: 1 }
  Dispatcher cần xem đơn để lên lịch chuyến.
}
