meta {
  name: 00 - Login as dispatcher
  type: http
  seq: 4
}

post {
  url: {{base_url}}/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "dispatcher01",
    "password": "dispatch123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("dispatcher_token", res.body.data?.token || res.body.token);
  }
}
