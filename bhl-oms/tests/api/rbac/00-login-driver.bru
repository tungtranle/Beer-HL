meta {
  name: 00 - Login as driver
  type: http
  seq: 1
}

post {
  url: {{base_url}}/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "driver01",
    "password": "driver123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("driver_token", res.body.data?.token || res.body.token);
  }
}
