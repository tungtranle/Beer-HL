meta {
  name: R-RBAC-09 - DVKH cannot access reconciliation
  type: http
  seq: 21
}

get {
  url: {{base_url}}/v1/reconciliation
  body: none
  auth: bearer
}

auth:bearer {
  token: {{dvkh_token}}
}

assert {
  res.status: eq 403
}

docs {
  ## RBAC: dvkh → GET /reconciliation
  
  DVKH KHÔNG được xem dữ liệu đối soát tài chính.
  Chỉ accountant/admin mới được.
}
