meta {
  name: R-RBAC-03 - Driver cannot create orders
  type: http
  seq: 12
}

post {
  url: {{base_url}}/v1/orders
  body: json
  auth: bearer
}

auth:bearer {
  token: {{driver_token}}
}

body:json {
  {
    "customer_id": "00000000-0000-0000-0000-000000000000",
    "warehouse_id": "00000000-0000-0000-0000-000000000000",
    "delivery_date": "2099-01-01",
    "total_amount": 1000000,
    "items": []
  }
}

assert {
  res.status: eq 403
}

docs {
  ## RBAC Rule: driver → POST /orders
  
  Driver KHÔNG được tạo đơn hàng. Chỉ dvkh và admin mới được.
  Expected: HTTP 403 Forbidden
}
