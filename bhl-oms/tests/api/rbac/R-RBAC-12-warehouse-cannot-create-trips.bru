meta {
  name: R-RBAC-12 - Warehouse cannot create trips
  type: http
  seq: 41
}

post {
  url: {{base_url}}/v1/trips
  body: json
  auth: bearer
}

auth:bearer {
  token: {{warehouse_token}}
}

body:json {
  {
    "driver_id": "00000000-0000-0000-0000-000000000000",
    "vehicle_id": "00000000-0000-0000-0000-000000000000",
    "order_ids": [],
    "planned_date": "2099-01-01"
  }
}

assert {
  res.status: eq 403
}

docs {
  ## RBAC: warehouse_handler → POST /trips
  
  Warehouse handler KHÔNG được tạo/dispatch chuyến xe.
  Chỉ dispatcher/admin mới được.
}
