meta {
  name: 00 - Login as accountant
  type: http
  seq: 5
}

post {
  url: {{base_url}}/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "accountant01",
    "password": "accountant123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accountant_token", res.body.data?.token || res.body.token);
  }
}
