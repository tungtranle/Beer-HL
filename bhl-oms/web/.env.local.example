# ─────────────────────────────────────────────────────────
# BHL Frontend — Local Environment
# Copy file này thành .env.local và điền các giá trị thật
# File .env.local KHÔNG được commit vào git
# ─────────────────────────────────────────────────────────

# Backend API URL (local dev)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Microsoft Clarity ───────────────────────────────────
# Lấy tại: https://clarity.microsoft.com → Project → Settings → Setup → ID
# Ví dụ: NEXT_PUBLIC_CLARITY_ID=abc123xyz
NEXT_PUBLIC_CLARITY_ID=

# ─── Môi trường ──────────────────────────────────────────
# "development" | "staging" | "production"
NEXT_PUBLIC_ENV=development

# ─── Synthetic monitoring accounts ──────────────────────
# Tài khoản riêng cho automated testing — KHÔNG dùng data thật
# Tạo trong bhl.symper.us/admin → Users → Create synthetic users
NEXT_PUBLIC_SYNTHETIC_DISPATCHER=synthetic_dispatcher
NEXT_PUBLIC_SYNTHETIC_DRIVER=synthetic_driver
NEXT_PUBLIC_SYNTHETIC_WAREHOUSE=synthetic_warehouse
