nter px-4 py-3 font-medium text-gray-600\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n              <th className=\"text-center px-4 py-3 font-medium text-gray-600\">Thao tв”ңГӯc</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody className=\"divide-y\">\r\n            {filteredDrivers.map(d => {\r\n              const initials = d.full_name.split(' ').slice(-2).map(n => n[0]).join('').toUpperCase()\r\n              return (\r\n                <tr key={d.id} className=\"hover:bg-gray-50 transition\">\r\n                  <td className=\"px-4 py-3\">\r\n                    <div className=\"flex items-center gap-3\">\r\n                      <div className=\"w-8 h-8 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center text-xs font-bold flex-shrink-0\">\r\n                        {initials}\r\n                      </div>\r\n                      <span className=\"font-medium text-gray-900\">{d.full_name}</span>\r\n                    </div>\r\n                  </td>\r\n                  <td className=\"px-4 py-3 text-gray-600\">{d.phone}</td>\r\n                  <td className=\"px-4 py-3 font-mono text-xs text-gray-500\">{d.license_number || 'О“ГҮГ¶'}</td>\r\n                  <td className=\"px-4 py-3 text-center\">\r\n                    <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[d.status] || 'bg-gray-100 text-gray-600'}`}>\r\n                      {statusLabels[d.status] || d.status}\r\n                    </span>\r\n                  </td>\r\n                  <td className=\"px-4 py-3 text-center\">\r\n                    <Link href={`/dashboard/drivers-list/${d.id}/documents`} className=\"text-brand-500 hover:underline text-xs mr-2\">GiГҹв•‘Г‘y tГҹв•—ВҘ</Link>\r\n                    <button onClick={() => openEdit(d)} className=\"text-brand-500 hover:underline text-xs mr-2\">SГҹв•—ВЎa</button>\r\n                    <button onClick={() => handleDelete(d.id, d.full_name)} className=\"text-red-600 hover:underline text-xs\">Xв”ңв”Ӯa</button>\r\n                  </td>\r\n                </tr>\r\n              )\r\n            })}\r\n          </tbody>\r\n        </table>\r\n        {filteredDrivers.length === 0 && (\r\n          <div className=\"text-center py-8 text-gray-400\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y tв”ңГЎi xГҹв•‘в”җ nв”ңГЎo</div>\r\n        )}\r\n      </div>\r\n\r\n      {/* Modal */}\r\n      {modal && (\r\n        <div className=\"fixed inset-0 bg-black/40 flex items-center justify-center z-50\">\r\n          <div className=\"bg-white rounded-xl shadow-xl w-full max-w-md p-6\">\r\n            <h2 className=\"text-lg font-bold mb-4\">{modal === 'create' ? 'Thв”ңВ¬m tв”ңГЎi xГҹв•‘в”җ' : 'SГҹв•—ВЎa tв”ңГЎi xГҹв•‘в”җ'}</h2>\r\n            <div className=\"grid grid-cols-2 gap-4\">\r\n              <div className=\"col-span-2\">\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">HГҹв•—Г¬ tв”ңВ¬n</label>\r\n                <input value={form.full_name} onChange={e => setForm({ ...form, full_name: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi</label>\r\n                <input value={form.phone} onChange={e => setForm({ ...form, phone: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">SГҹв•—ГҰ GPLX</label>\r\n                <input value={form.license_number || ''} onChange={e => setForm({ ...form, license_number: e.target.value || null })} className=\"w-full border rounded-lg px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div className=\"col-span-2\">\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">TrГҹв•‘Гӯng thв”ңГӯi</label>\r\n                <select value={form.status} onChange={e => setForm({ ...form, status: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\">\r\n                  {Object.entries(statusLabels).map(([val, lbl]) => (\r\n                    <option key={val} value={val}>{lbl}</option>\r\n                  ))}\r\n                </select>\r\n              </div>\r\n            </div>\r\n            <div className=\"flex justify-end gap-3 mt-6\">\r\n              <button onClick={() => setModal(null)} className=\"px-4 py-2 border rounded-lg text-sm\">HГҹв•—Вәy</button>\r\n              <button onClick={handleSave} disabled={saving} className=\"px-4 py-2 bg-brand-500 text-white rounded-lg text-sm font-medium hover:bg-brand-600 disabled:opacity-50\">\r\n                {saving ? 'в”ҖГүang lв•һв–‘u...' : 'Lв•һв–‘u'}\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\eod\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":15,"column":16,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":15,"endColumn":19,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[382,385],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[382,385],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":56,"column":52,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":56,"endColumn":55,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1741,1744],