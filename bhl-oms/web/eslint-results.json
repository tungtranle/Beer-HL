ib/useToast'\r\nimport { handleError } from '@/lib/handleError'\r\n\r\ninterface TimelineEvent {\r\n  id: string\r\n  event_type: string\r\n  actor_type: string\r\n  actor_id?: string\r\n  actor_name: string\r\n  title: string\r\n  detail: Record<string, any>\r\n  created_at: string\r\n}\r\n\r\ninterface InlineNote {\r\n  id: string\r\n  content: string\r\n  note_type: string\r\n  user_name: string\r\n  is_pinned: boolean\r\n  created_at: string\r\n}\r\n\r\n// Merged timeline entry: event or note\r\ntype TimelineEntry = \r\n  | { kind: 'event'; data: TimelineEvent }\r\n  | { kind: 'note'; data: InlineNote }\r\n\r\n// Event configuration: icon, bg color, ring color, category\r\nconst eventConfig: Record<string, { icon: string; bg: string; ring: string; category: string }> = {\r\n  'order.created':              { icon: 'вүЎЖ’ГҙВҘ', bg: 'bg-blue-500',   ring: 'ring-blue-100',   category: 'lifecycle' },\r\n  'order.confirmed_by_customer':{ icon: 'О“ВЈГ ', bg: 'bg-green-500',  ring: 'ring-green-100',  category: 'lifecycle' },\r\n  'order.rejected_by_customer': { icon: 'О“ВҘГ®', bg: 'bg-red-500',    ring: 'ring-red-100',    category: 'lifecycle' },\r\n  'order.auto_confirmed':       { icon: 'О“Г…в–‘', bg: 'bg-amber-500',  ring: 'ring-amber-100',  category: 'lifecycle' },\r\n  'order.approved':             { icon: 'вүЎЖ’Г¶Гҙ', bg: 'bg-green-600',  ring: 'ring-green-100',  category: 'lifecycle' },\r\n  'order.cancelled':            { icon: 'вүЎЖ’ГңВҪ', bg: 'bg-red-600',    ring: 'ring-red-100',    category: 'lifecycle' },\r\n  'order.updated':              { icon: 'О“ВЈГ…вҲ©в••Г…', bg: 'bg-gray-500',   ring: 'ring-gray-100',   category: 'edit' },\r\n  'order.status_changed':       { icon: 'вүЎЖ’Г¶ГӨ', bg: 'bg-purple-500', ring: 'ring-purple-100', category: 'lifecycle' },\r\n  'order.delivery_confirmed':   { icon: 'вүЎЖ’ГҙВӘ', bg: 'bg-teal-500',   ring: 'ring-teal-100',   category: 'delivery' },\r\n  'order.delivery_disputed':    { icon: 'О“ГңГЎвҲ©в••Г…', bg: 'bg-orange-500', ring: 'ring-orange-100', category: 'delivery' },\r\n  'order.note_added':           { icon: 'вүЎЖ’ГҶВј', bg: 'bg-gray-400',   ring: 'ring-gray-100',   category: 'note' },\r\n  'order.zalo_sent':            { icon: 'вүЎЖ’Гҙв–’', bg: 'bg-blue-400',   ring: 'ring-blue-100',   category: 'notification' },\r\n  'order.confirmation_expired': { icon: 'О“Г…в”Ӯ', bg: 'bg-gray-500',   ring: 'ring-gray-100',   category: 'lifecycle' },\r\n  'order.planned':              { icon: 'вүЎЖ’Г№в•‘вҲ©в••Г…', bg: 'bg-indigo-500', ring: 'ring-indigo-100', category: 'logistics' },\r\n  'order.picking':              { icon: 'вүЎЖ’ГҙГҜ', bg: 'bg-indigo-500', ring: 'ring-indigo-100', category: 'logistics' },\r\n  'order.loaded':               { icon: 'вүЎЖ’ГңВў', bg: 'bg-violet-500', ring: 'ring-violet-100', category: 'logistics' },\r\n  'order.in_transit':           { icon: 'вүЎЖ’ГңГң', bg: 'bg-purple-500', ring: 'ring-purple-100', category: 'logistics' },\r\n  'order.delivered':            { icon: 'О“ВЈГ ', bg: 'bg-teal-500',   ring: 'ring-teal-100',   category: 'delivery' },\r\n  'order.partial_delivered':    { icon: 'О“ГңГЎвҲ©в••Г…', bg: 'bg-orange-500', ring: 'ring-orange-100', category: 'delivery' },\r\n  'order.delivery_rejected':    { icon: 'О“ВҘГ®', bg: 'bg-red-500',    ring: 'ring-red-100',    category: 'delivery' },\r\n  'order.redelivery_created':   { icon: 'вүЎЖ’Г¶ГӨ', bg: 'bg-rose-500',   ring: 'ring-rose-100',   category: 'lifecycle' },\r\n}\r\n\r\nconst defaultConfig = { icon: 'вүЎЖ’ГҙГ®', bg: 'bg-gray-400', ring: 'ring-gray-100', category: 'other' }\r\n\r\nconst actorIcons: Record<string, string> = {\r\n  user: 'вүЎЖ’ГҰГұ', system: 'О“ГңГ–вҲ©в••Г…', customer: 'вүЎЖ’Г…В¬', cron: 'О“Г…в–‘',\r\n}\r\n\r\n// Vietnamese label for actor type\r\nconst actorTypeLabels: Record<string, string> = {\r\n  user: 'Nhв”ңГіn viв”ңВ¬n',\r\n  system: 'HГҹв•—Г§ thГҹв•—ГҰng',\r\n  customer: 'Khв”ңГӯch hв”ңГЎng',\r\n  cron: 'TГҹв•—в–’ в”ҖГҰГҹв•—Г–ng',\r\n}\r\n\r\nconst NOTE_STYLE: Record<string, { border: string; bg: string; label: string }> = {\r\n  internal:     { border: 'border-l-4 border-amber-400', bg: 'bg-amber-50', label: 'вүЎЖ’Г¶ГҶ NГҹв•—Г–i bГҹв•—Г–' },\r\n  npp_feedback: { border: 'border-l-4 border-blue-400',  bg: 'bg-blue-50',  label: 'PhГҹв•‘Гәn hГҹв•—Гҙi NPP' },\r\n  driver_note:  { border: 'border-l-4 border-green-400', bg: 'bg-green-50', label: 'Tв”ңГЎi xГҹв•‘в”җ ghi' },\r\n  system:       { border: 'border-l-4 border-stone-300', bg: 'bg-stone-50', label: 'HГҹв•—Г§ thГҹв•—ГҰng' },\r\n}\r\n\r\nexport function OrderTimeline({ orderId }: { orderId: string }) {\r\n  const [events, setEvents] = useState<TimelineEvent[]>([])\r\n  const [notes, setNotes] = useState<InlineNote[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [filter, setFilter] = useState<'all' | 'lifecycle' | 'delivery' | 'note'>('all')\r\n  \r\n  // Note composer state\r\n  const [newNote, setNewNote] = useState('')\r\n  const [noteType, setNoteType] = useState<'internal' | 'npp_feedback'>('internal')\r\n  const [saving, setSaving] = useState(false)\r\n  const submitted = useRef(false)\r\n\r\n  const loadData = () => {\r\n    setLoading(true)\r\n    Promise.all([\r\n      apiFetch<any>(`/orders/${orderId}/timeline`).then(r => setEvents(r.data || [])),\r\n      apiFetch<any>(`/orders/${orderId}/notes`).then(r => setNotes(r.data || [])),\r\n    ])\r\n      .catch(err => handleError(err))\r\n      .finally(() => setLoading(false))\r\n  }\r\n\r\n  useEffect(() => { loadData() }, [orderId])\r\n\r\n  // Save note\r\n  const handleSaveNote = async () => {\r\n    if (!newNote.trim() || submitted.current) return\r\n    submitted.current = true\r\n    setSaving(true)\r\n    try {\r\n      await apiFetch(`/orders/${orderId}/notes`, {\r\n        method: 'POST',\r\n        body: { content: newNote.trim(), note_type: noteType },\r\n      })\r\n      setNewNote('')\r\n      toast.success('в”ҖГүв”ңГә lв•һв–‘u ghi chв”ңв•‘')\r\n      loadData()\r\n    } catch (err: any) {\r\n      submitted.current = false\r\n      toast.error(err.message)\r\n    } finally {\r\n      setSaving(false)\r\n      submitted.current = false\r\n    }\r\n  }\r\n\r\n  // Pin/unpin note\r\n  const handleTogglePin = async (noteId: string, isPinned: boolean) => {\r\n    try {\r\n      await apiFetch(`/orders/${orderId}/notes/${noteId}/pin`, {\r\n        method: isPinned ? 'DELETE' : 'PUT',\r\n      })\r\n      loadData()\r\n    } catch (err: any) {\r\n      toast.error(err.message)\r\n    }\r\n  }\r\n\r\n  // Merge events + notes into one timeline sorted by timestamp DESC\r\n  const mergedEntries: TimelineEntry[] = [\r\n    ...events.map(e => ({ kind: 'event' as const, data: e })),\r\n    // Only include notes that are NOT already in events (avoid duplicate note_added events)\r\n    ...notes\r\n      .filter(n => !events.some(e => e.event_type === 'order.note_added' && e.detail?.content === n.content && Math.abs(new Date(e.created_at).getTime() - new Date(n.created_at).getTime()) < 60000))\r\n      .map(n => ({ kind: 'note' as const, data: n })),\r\n  ].sort((a, b) => new Date(b.data.created_at).getTime() - new Date(a.data.created_at).getTime())\r\n\r\n  // Format time О“ГҮГ¶ absolute + relative\r\n  const formatTime = (dateStr: string) => {\r\n    const d = new Date(dateStr)\r\n    return d.toLocaleString('vi-VN', {\r\n      day: '2-digit', month: '2-digit', year: 'numeric',\r\n      hour: '2-digit', minute: '2-digit', second: '2-digit',\r\n    })\r\n  }\r\n\r\n  const formatRelative = (dateStr: string) => {\r\n    const d = new Date(dateStr)\r\n    const now = new Date()\r\n    const diffMs = now.getTime() - d.getTime()\r\n    const diffMins = Math.floor(diffMs / 60000)\r\n    if (diffMins < 1) return 'VГҹв•—ВҪa xong'\r\n    if (diffMins < 60) return `${diffMins} phв”ңв•‘t trв•һв–‘Гҹв•—Вўc`\r\n    const diffHours = Math.floor(diffMins / 60)\r\n    if (diffHours < 24) return `${diffHours} giГҹв•—ВҘ trв•һв–‘Гҹв•—Вўc`\r\n    const diffDays = Math.floor(diffHours / 24)\r\n    if (diffDays < 7) return `${diffDays} ngв”ңГЎy trв•һв–‘Гҹв•—Вўc`\r\n    return ''\r\n  }\r\n\r\n  // Calculate duration between consecutive entries + color coding (в”¬Вә21)\r\n  const getDuration = (idx: number): { text: string; color: string } | null => {\r\n    if (idx >= mergedEntries.length - 1) return null\r\n    const current = new Date(mergedEntries[idx].data.created_at)\r\n    const prev = new Date(mergedEntries[idx + 1].data.created_at)\r\n    const diffMs = current.getTime() - prev.getTime()\r\n    const mins = Math.floor(diffMs / 60000)\r\n    if (mins < 1) return null\r\n    let text: string\r\n    if (mins < 60) text = `${mins} phв”ңв•‘t`\r\n    else {\r\n      const hours = Math.floor(mins / 60)\r\n      const remainMins = mins % 60\r\n      if (hours < 24) text = remainMins > 0 ? `${hours}g ${remainMins}p` : `${hours} giГҹв•—ВҘ`\r\n      else {\r\n        const days = Math.floor(hours / 24)\r\n        const remainHours = hours % 24\r\n        text = remainHours > 0 ? `${days}d ${remainHours}g` : `${days} ngв”ңГЎy`\r\n      }\r\n    }\r\n    // Color coding: <30min gray, 30m-2h amber, >2h red\r\n    const color = mins < 30 ? 'text-gray-400' : mins < 120 ? 'text-amber-500 font-medium' : 'text-red-500 font-bold'\r\n    return { text, color }\r\n  }\r\n\r\n  // Filtered entries\r\n  const filtered = mergedEntries.filter(entry => {\r\n    if (filter === 'all') return true\r\n    if (entry.kind === 'note') return filter === 'note'\r\n    const cfg = eventConfig[entry.data.event_type] || defaultConfig\r\n    if (filter === 'delivery') return ['delivery', 'logistics'].includes(cfg.category)\r\n    return cfg.category === filter\r\n  })\r\n\r\n  // Group entries by date\r\n  const groupByDate = (entries: TimelineEntry[]) => {\r\n    const groups: { date: string; label: string; entries: TimelineEntry[] }[] = []\r\n    let currentDate = ''\r\n    for (const entry of entries) {\r\n      const d = new Date(entry.data.created_at)\r\n      const dateStr = d.toLocaleDateString('vi-VN', { weekday: 'long', day: '2-digit', month: '2-digit', year: 'numeric' })\r\n      if (dateStr !== currentDate) {\r\n        currentDate = dateStr\r\n        const today = new Date()\r\n        const isToday = d.toDateString() === today.toDateString()\r\n        const yesterday = new Date(today); yesterday.setDate(yesterday.getDate() - 1)\r\n        const isYesterday = d.toDateString() === yesterday.toDateString()\r\n        const label = isToday ? 'Hв”ңв”Өm nay' : isYesterday ? 'Hв”ңв”Өm qua' : dateStr\r\n        groups.push({ date: dateStr, label, entries: [] })\r\n      }\r\n      groups[groups.length - 1].entries.push(entry)\r\n    }\r\n    return groups\r\n  }\r\n\r\n  const groups = groupByDate(filtered)\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"py-8 text-center\">\r\n        <div className=\"animate-spin w-8 h-8 border-3 border-brand-500 border-t-transparent rounded-full mx-auto mb-3\"></div>\r\n        <p className=\"text-gray-400 text-sm\">в”ҖГүang tГҹв•‘Гәi lГҹв•—ГҜch sГҹв•—ВЎ в”ҖГҰв•һГӯn hв”ңГЎng...</p>\r\n      </div>\r\n    )\r\n  }\r\n\r\n  if (events.length === 0) {\r\n    return (\r\n      <div className=\"py-12 text-center text-gray-400\">\r\n        <p className=\"text-5xl mb-3\">вүЎЖ’ГҙВЈ</p>\r\n        <p className=\"font-medium text-gray-500\">Chв•һв–‘a cв”ңв”Ӯ lГҹв•—ГҜch sГҹв•—ВЎ</p>\r\n        <p className=\"text-sm mt-1\">Cв”ңГӯc hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng cГҹв•—Вәa в”ҖГҰв•һГӯn hв”ңГЎng sГҹв•‘в•ң в”ҖГҰв•һв–‘Гҹв•—Гәc ghi nhГҹв•‘ВЎn tГҹв•‘Гӯi в”ҖГҰв”ңГіy</p>\r\n      </div>\r\n    )\r\n  }\r\n\r\n  return (\r\n    <div>\r\n      {/* Filter tabs */}\r\n      <div className=\"flex gap-2 mb-5 flex-wrap\">\r\n        {[\r\n          { key: 'all' as const, label: 'TГҹв•‘Г‘t cГҹв•‘Гә', count: mergedEntries.length },\r\n          { key: 'lifecycle' as const, label: 'вүЎЖ’Г¶ГӨ TrГҹв•‘Гӯng thв”ңГӯi', count: mergedEntries.filter(e => e.kind === 'event' && (eventConfig[e.data.event_type] || defaultConfig).category === 'lifecycle').length },\r\n          { key: 'delivery' as const, label: 'вүЎЖ’ГңГң Giao hв”ңГЎng', count: mergedEntries.filter(e => e.kind === 'event' && ['delivery', 'logistics'].includes((eventConfig[e.data.event_type] || defaultConfig).category)).length },\r\n          { key: 'note' as const, label: 'вүЎЖ’ГҶВј Ghi chв”ңв•‘', count: notes.length },\r\n        ].filter(t => t.count > 0).map(tab => (\r\n          <button\r\n            key={tab.key}\r\n            onClick={() => setFilter(tab.key)}\r\n            className={`px-3 py-1.5 rounded-lg text-xs font-medium transition ${\r\n              filter === tab.key\r\n                ? 'bg-amber-100 text-amber-700 ring-1 ring-amber-300'\r\n                : 'bg-gray-100 text-gray-500 hover:bg-gray-200'\r\n            }`}\r\n          >\r\n            {tab.label}\r\n            <span className=\"ml-1.5 px-1.5 py-0.5 rounded-full bg-white/60 text-xs\">{tab.count}</span>\r\n          </button>\r\n        ))}\r\n      </div>\r\n\r\n      {/* Summary banner */}\r\n      {mergedEntries.length > 1 && (\r\n        <div className=\"flex items-center gap-3 px-4 py-2.5 bg-gradient-to-r from-amber-50 to-orange-50 rounded-lg mb-5 text-xs\">\r\n          <span className=\"font-medium text-amber-700\">вүЎЖ’ГҙГЁ TГҹв•—ГІng quan:</span>\r\n          <span className=\"text-gray-600\">{events.length} hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng в”¬в•– {notes.length} ghi chв”ңв•‘</span>\r\n          {events.length > 0 && (\r\n            <>\r\n              <span className=\"text-gray-300\">|</span>\r\n              <span className=\"text-gray-600\">\r\n                TГҹв•—ВҪ {new Date(events[events.length - 1].created_at).toLocaleDateString('vi-VN')} в”ҖГҰГҹв•‘в”җn {new Date(events[0].created_at).toLocaleDateString('vi-VN')}\r\n              </span>\r\n            </>\r\n          )}\r\n        </div>\r\n      )}\r\n\r\n      {/* Timeline grouped by date */}\r\n      {groups.map((group) => (\r\n        <div key={group.date} className=\"mb-6\">\r\n          {/* Date header */}\r\n          <div className=\"flex items-center gap-3 mb-3\">\r\n            <div className=\"h-px flex-1 bg-gray-200\"></div>\r\n            <span className=\"text-xs font-semibold text-gray-400 uppercase tracking-wider\">{group.label}</span>\r\n            <div className=\"h-px flex-1 bg-gray-200\"></div>\r\n          </div>\r\n\r\n          {/* Entries in this date */}\r\n          <div className=\"relative ml-1\">\r\n            <div className=\"absolute left-[15px] top-4 bottom-4 w-0.5 bg-gradient-to-b from-gray-200 via-gray-200 to-transparent\"></div>\r\n\r\n            {group.entries.map((entry, idx) => {\r\n              const globalIdx = mergedEntries.indexOf(entry)\r\n              const duration = getDuration(globalIdx)\r\n              const relative = formatRelative(entry.data.created_at)\r\n\r\n              // О“Г¶ГҮО“Г¶ГҮ Inline Note Card О“Г¶ГҮО“Г¶ГҮ\r\n              if (entry.kind === 'note') {\r\n                const n = entry.data\r\n                const style = NOTE_STYLE[n.note_type] || NOTE_STYLE.internal\r\n                return (\r\n                  <div key={`note-${n.id}`}>\r\n                    {duration && idx > 0 && (\r\n                      <div className=\"relative flex items-center py-1 pl-2 ml-[6px]\">\r\n                        <div className=\"w-[18px] flex justify-center\"><span className=\"text-[10px] text-gray-300\">О“ГҜВ«</span></div>\r\n                        <span className={`ml-4 text-[10px] bg-gray-50 px-2 py-0.5 rounded-full ${duration.color}`}>О“Г…в–’ {duration.text} sau</span>\r\n                      </div>\r\n                    )}\r\n                    <div className=\"relative flex items-start gap-4 py-2.5 pl-0 group\">\r\n                      <div className=\"relative z-10 flex items-center justify-center w-8 h-8 rounded-full text-sm shrink-0 bg-amber-400 ring-4 ring-amber-100 shadow-sm\">\r\n                        вүЎЖ’ГҶВј\r\n                      </div>\r\n                      <div className={`flex-1 min-w-0 ${style.bg} ${style.border} rounded-lg p-3`}>\r\n                        <div className=\"flex items-start justify-between gap-2\">\r\n                          <div>\r\n                            <span className=\"text-[10px] font-medium text-gray-500 uppercase tracking-wider\">{style.label}</span>\r\n                            <p className=\"text-sm text-gray-800 mt-1\">{n.content}</p>\r\n                          </div>\r\n                          <div className=\"flex items-center gap-1\">\r\n                            {relative && <span className=\"text-[10px] text-gray-400 whitespace-nowrap\">{relative}</span>}\r\n                            <button\r\n                              onClick={() => handleTogglePin(n.id, n.is_pinned)}\r\n                              className={`text-xs px-1 transition ${n.is_pinned ? 'text-amber-500' : 'text-gray-300 hover:text-amber-400'}`}\r\n                              title={n.is_pinned ? 'BГҹв•—Г… ghim' : 'Ghim'}\r\n                            >\r\n                              вүЎЖ’ГҙГ®\r\n                            </button>\r\n                          </div>\r\n                        </div>\r\n                        <div className=\"flex items-center gap-2 mt-1.5\">\r\n                          <span className=\"text-[11px] text-gray-500\">вүЎЖ’ГҰГұ {n.user_name}</span>\r\n                          <span className=\"text-[11px] text-gray-400\">{formatTime(n.created_at)}</span>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                )\r\n              }\r\n\r\n              // О“Г¶ГҮО“Г¶ГҮ Event Card О“Г¶ГҮО“Г¶ГҮ\r\n              const evt = entry.data\r\n              const cfg = eventConfig[evt.event_type] || defaultConfig\r\n\r\n              return (\r\n                <div key={evt.id}>\r\n                  {duration && idx > 0 && (\r\n                    <div className=\"relative flex items-center py-1 pl-2 ml-[6px]\">\r\n                      <div className=\"w-[18px] flex justify-center\"><span className=\"text-[10px] text-gray-300\">О“ГҜВ«</span></div>\r\n                      <span className={`ml-4 text-[10px] bg-gray-50 px-2 py-0.5 rounded-full ${duration.color}`}>О“Г…в–’ {duration.text} sau</span>\r\n                    </div>\r\n                  )}\r\n\r\n                  <div className=\"relative flex items-start gap-4 py-2.5 pl-0 group\">\r\n                    <div className={`relative z-10 flex items-center justify-center w-8 h-8 rounded-full text-sm shrink-0 ${cfg.bg} ring-4 ${cfg.ring} shadow-sm group-hover:scale-110 transition-transform`}>\r\n                      {cfg.icon}\r\n                    </div>\r\n\r\n                    <div className=\"flex-1 min-w-0 bg-white border border-gray-100 rounded-lg p-3 hover:border-gray-200 hover:shadow-sm transition group-hover:bg-gray-50/50\">\r\n                      <div className=\"flex items-start justify-between gap-2\">\r\n                        <p className=\"text-sm font-medium text-gray-900 leading-snug\">{evt.title}</p>\r\n                        {relative && <span className=\"text-[10px] text-gray-400 whitespace-nowrap shrink-0 mt-0.5\">{relative}</span>}\r\n                      </div>\r\n\r\n                      <div className=\"flex items-center gap-2 mt-1.5 flex-wrap\">\r\n                        <span className=\"inline-flex items-center gap-1 px-2 py-0.5 bg-gray-100 rounded-full text-[11px] text-gray-600\">\r\n                          {actorIcons[evt.actor_type] || 'вүЎЖ’ГҰГұ'}\r\n                          <span className=\"font-medium\">{evt.actor_name || 'HГҹв•—Г§ thГҹв•—ГҰng'}</span>\r\n                          <span className=\"text-gray-400\">в”¬в•– {actorTypeLabels[evt.actor_type] || evt.actor_type}</span>\r\n                        </span>\r\n                        <span className=\"text-[11px] text-gray-400\">{formatTime(evt.created_at)}</span>\r\n                      </div>\r\n\r\n                      {/* Note content with note_type styling */}\r\n                      {evt.event_type === 'order.note_added' && evt.detail?.content && (() => {\r\n                        const nt = evt.detail?.note_type || 'internal'\r\n                        const ns = NOTE_STYLE[nt] || NOTE_STYLE.internal\r\n                        return (\r\n                          <div className={`mt-2 p-2.5 rounded-lg text-sm text-gray-700 ${ns.bg} ${ns.border}`}>\r\n                            <span className=\"text-[10px] font-medium text-gray-500 uppercase\">{ns.label}</span>\r\n                            <p className=\"mt-0.5\">вүЎЖ’ГҶВј {evt.detail.content}</p>\r\n                          </div>\r\n                        )\r\n                      })()}\r\n\r\n                      {evt.detail?.reason && evt.event_type !== 'order.note_added' && (\r\n                        <div className=\"mt-2 p-2 bg-red-50 rounded-lg text-xs text-red-700 border-l-3 border-red-400\">\r\n                          <span className=\"font-medium\">Lв”ңв•ң do:</span> {evt.detail.reason}\r\n                        </div>\r\n                      )}\r\n\r\n                      {evt.detail?.old_status && evt.detail?.new_status && (\r\n                        <div className=\"mt-2 inline-flex items-center gap-2 px-2.5 py-1 bg-purple-50 rounded-lg text-xs\">\r\n                          <span className=\"px-1.5 py-0.5 bg-gray-200 rounded text-gray-600\">\r\n                            {orderStatusLabels[evt.detail.old_status] || evt.detail.old_status}\r\n                          </span>\r\n                          <span className=\"text-purple-400\">О“ГҘГҶ</span>\r\n                          <span className=\"px-1.5 py-0.5 bg-purple-200 rounded text-purple-700 font-medium\">\r\n                            {orderStatusLabels[evt.detail.new_status] || evt.detail.new_status}\r\n                          </span>\r\n                        </div>\r\n                      )}\r\n\r\n                      {evt.detail?.total_amount && (\r\n                        <div className=\"mt-2 text-xs text-gray-600\">\r\n                          вүЎЖ’ГҶв–‘ Giв”ңГӯ trГҹв•—ГҜ: <span className=\"font-medium text-gray-800\">{Number(evt.detail.total_amount).toLocaleString('vi-VN')}в”ҖГҰ</span>\r\n                        </div>\r\n                      )}\r\n\r\n                      {evt.detail?.customer_name && evt.event_type === 'order.created' && (\r\n                        <div className=\"mt-2 text-xs text-gray-600\">\r\n                          вүЎЖ’Г…В¬ Khв”ңГӯch hв”ңГЎng: <span className=\"font-medium\">{evt.detail.customer_name}</span>\r\n                        </div>\r\n                      )}\r\n\r\n                      {evt.detail?.attempt_number && (\r\n                        <div className=\"mt-2 inline-flex items-center gap-1.5 px-2 py-1 bg-rose-50 rounded-lg text-xs text-rose-700\">\r\n                          вүЎЖ’Г¶ГӨ LГҹв•‘Вәn giao lГҹв•‘Гӯi thГҹв•—вҢҗ <span className=\"font-bold\">{evt.detail.attempt_number}</span>\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              )\r\n            })}\r\n          </div>\r\n        </div>\r\n      ))}\r\n\r\n      {/* Note Composer О“ГҮГ¶ always at bottom (в”¬Вә18 v5) */}\r\n      <div className=\"mt-6 pt-4 border-t border-gray-100\">\r\n        <div className=\"flex gap-2 mb-2\">\r\n          <button\r\n            onClick={() => setNoteType('internal')}\r\n            className={`px-3 py-1.5 rounded-lg text-xs font-medium transition ${\r\n              noteType === 'internal' ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-500'\r\n            }`}\r\n          >\r\n            вүЎЖ’Г¶ГҶ NГҹв•—Г–i bГҹв•—Г–\r\n          </button>\r\n          <button\r\n            onClick={() => setNoteType('npp_feedback')}\r\n            className={`px-3 py-1.5 rounded-