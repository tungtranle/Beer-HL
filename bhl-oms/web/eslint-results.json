useState<UserItem[]>([])\r\n  const [roles, setRoles] = useState<RoleItem[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [tab, setTab] = useState<'users' | 'roles' | 'sessions' | 'seasonal'>('users')\r\n  const [seasonalMode, setSeasonalMode] = useState<{ enabled: boolean; label: string; vrp_buffer_pct: number } | null>(null)\r\n  const [seasonalSaving, setSeasonalSaving] = useState(false)\r\n  const [filterRole, setFilterRole] = useState('')\r\n  const [search, setSearch] = useState('')\r\n\r\n  // Create/Edit user modal\r\n  const [showModal, setShowModal] = useState(false)\r\n  const [editUser, setEditUser] = useState<UserItem | null>(null)\r\n  const [form, setForm] = useState({ username: '', full_name: '', password: '', role: 'dvkh', email: '', is_active: true })\r\n  const [saving, setSaving] = useState(false)\r\n  const [error, setError] = useState('')\r\n\r\n  // Reset password modal\r\n  const [showResetModal, setShowResetModal] = useState(false)\r\n  const [resetUserId, setResetUserId] = useState('')\r\n  const [resetUserName, setResetUserName] = useState('')\r\n  const [newPassword, setNewPassword] = useState('')\r\n\r\n  // Sessions\r\n  interface SessionItem {\r\n    id: string; user_id: string; user_name: string; role: string\r\n    ip_address: string; user_agent: string; last_active: string; created_at: string\r\n  }\r\n  const [sessions, setSessions] = useState<SessionItem[]>([])\r\n  const [sessionsLoading, setSessionsLoading] = useState(false)\r\n\r\n  const loadSeasonalMode = async () => {\r\n    try {\r\n      const res: any = await apiFetch('/admin/seasonal-mode')\r\n      setSeasonalMode(res.data || { enabled: false, label: 'TГҹв•‘в”җt Nguyв”ңВ¬n в”ҖГүв”ңГӯn', vrp_buffer_pct: 20 })\r\n    } catch { setSeasonalMode({ enabled: false, label: 'TГҹв•‘в”җt Nguyв”ңВ¬n в”ҖГүв”ңГӯn', vrp_buffer_pct: 20 }) }\r\n  }\r\n\r\n  const handleSaveSeasonalMode = async () => {\r\n    if (!seasonalMode) return\r\n    setSeasonalSaving(true)\r\n    try {\r\n      await apiFetch('/admin/seasonal-mode', { method: 'PUT', body: seasonalMode })\r\n      toast.success(seasonalMode.enabled ? 'в”ҖГүв”ңГә bГҹв•‘ВЎt ChГҹв•‘в”җ в”ҖГҰГҹв•—Г– mв”ңв•Јa vГҹв•—Г‘' : 'в”ҖГүв”ңГә tГҹв•‘В»t ChГҹв•‘в”җ в”ҖГҰГҹв•—Г– mв”ңв•Јa vГҹв•—Г‘')\r\n    } catch { toast.error('Khв”ңв”Өng lв•һв–‘u в”ҖГҰв•һв–‘Гҹв•—Гәc cв”ңГЎi в”ҖГҰГҹв•‘в•–t mв”ңв•Јa vГҹв•—Г‘') }\r\n    finally { setSeasonalSaving(false) }\r\n  }\r\n\r\n  useEffect(() => {\r\n    if (user?.role !== 'admin') {\r\n      router.replace('/dashboard')\r\n      return\r\n    }\r\n    loadData()\r\n  }, [])\r\n\r\n  const loadData = async () => {\r\n    setLoading(true)\r\n    try {\r\n      const [usersRes, rolesRes]: any[] = await Promise.all([\r\n        apiFetch('/admin/users'),\r\n        apiFetch('/admin/roles'),\r\n      ])\r\n      setUsers(usersRes.data || [])\r\n      setRoles(rolesRes.data || [])\r\n    } catch (err) { handleError(err, { userMessage: 'Khв”ңв”Өng tГҹв•‘Гәi в”ҖГҰв•һв–‘Гҹв•—Гәc danh sв”ңГӯch user/role' }) }\r\n    finally { setLoading(false) }\r\n  }\r\n\r\n  const loadSessions = async () => {\r\n    setSessionsLoading(true)\r\n    try {\r\n      const res: any = await apiFetch('/admin/sessions')\r\n      setSessions(res.data || [])\r\n    } catch (err) { handleError(err, { userMessage: 'Khв”ңв”Өng tГҹв•‘Гәi в”ҖГҰв•һв–‘Гҹв•—Гәc danh sв”ңГӯch phiв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp' }) }\r\n    finally { setSessionsLoading(false) }\r\n  }\r\n\r\n  const handleRevokeSession = async (sessionId: string) => {\r\n    if (!confirm('Thu hГҹв•—Гҙi phiв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp nв”ңГЎy?')) return\r\n    try {\r\n      await apiFetch(`/admin/sessions/${sessionId}`, { method: 'DELETE' })\r\n      toast.success('в”ҖГүв”ңГә thu hГҹв•—Гҙi phiв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp')\r\n      loadSessions()\r\n    } catch (err: any) { toast.error(err.message) }\r\n  }\r\n\r\n  const handleRevokeAllSessions = async (userId: string, userName: string) => {\r\n    if (!confirm(`Thu hГҹв•—Гҙi tГҹв•‘Г‘t cГҹв•‘Гә phiв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp cГҹв•—Вәa \"${userName}\"?`)) return\r\n    try {\r\n      await apiFetch(`/admin/sessions/user/${userId}`, { method: 'DELETE' })\r\n      toast.success('в”ҖГүв”ңГә thu hГҹв•—Гҙi tГҹв•‘Г‘t cГҹв•‘Гә phiв”ңВ¬n')\r\n      loadSessions()\r\n    } catch (err: any) { toast.error(err.message) }\r\n  }\r\n\r\n  const openCreateModal = () => {\r\n    setEditUser(null)\r\n    setForm({ username: '', full_name: '', password: '', role: 'dvkh', email: '', is_active: true })\r\n    setError('')\r\n    setShowModal(true)\r\n  }\r\n\r\n  const openEditModal = (u: UserItem) => {\r\n    setEditUser(u)\r\n    setForm({ username: u.username, full_name: u.full_name, password: '', role: u.role, email: u.email || '', is_active: u.is_active })\r\n    setError('')\r\n    setShowModal(true)\r\n  }\r\n\r\n  const handleSave = async () => {\r\n    setSaving(true)\r\n    setError('')\r\n    try {\r\n      if (editUser) {\r\n        await apiFetch(`/admin/users/${editUser.id}`, {\r\n          method: 'PUT',\r\n          body: { full_name: form.full_name, role: form.role, email: form.email || null, is_active: form.is_active },\r\n        })\r\n      } else {\r\n        if (!form.password || form.password.length < 6) {\r\n          setError('MГҹв•‘ВЎt khГҹв•‘вҢҗu phГҹв•‘Гәi cв”ңв”Ӯ в”ңВЎt nhГҹв•‘Г‘t 6 kв”ңв•ң tГҹв•—в–’')\r\n          setSaving(false)\r\n          return\r\n        }\r\n        await apiFetch('/admin/users', {\r\n          method: 'POST',\r\n          body: { username: form.username, full_name: form.full_name, password: form.password, role: form.role, email: form.email || null },\r\n        })\r\n      }\r\n      setShowModal(false)\r\n      await loadData()\r\n    } catch (err: any) {\r\n      setError(err.message || 'Cв”ңв”Ӯ lГҹв•—Г№i xГҹв•‘Гәy ra')\r\n    } finally {\r\n      setSaving(false)\r\n    }\r\n  }\r\n\r\n  const handleToggleActive = async (u: UserItem) => {\r\n    try {\r\n      await apiFetch(`/admin/users/${u.id}`, {\r\n        method: 'PUT',\r\n        body: { is_active: !u.is_active },\r\n      })\r\n      await loadData()\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i: ' + err.message)\r\n    }\r\n  }\r\n\r\n  const handleResetPassword = async () => {\r\n    if (!newPassword || newPassword.length < 6) {\r\n      toast.warning('MГҹв•‘ВЎt khГҹв•‘вҢҗu phГҹв•‘Гәi cв”ңв”Ӯ в”ңВЎt nhГҹв•‘Г‘t 6 kв”ңв•ң tГҹв•—в–’')\r\n      return\r\n    }\r\n    try {\r\n      await apiFetch(`/admin/users/${resetUserId}/reset-password`, {\r\n        method: 'PUT',\r\n        body: { new_password: newPassword },\r\n      })\r\n      setShowResetModal(false)\r\n      setNewPassword('')\r\n      toast.success('в”ҖГүГҹв•‘в•–t lГҹв•‘Гӯi mГҹв•‘ВЎt khГҹв•‘вҢҗu thв”ңГЎnh cв”ңв”Өng')\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i: ' + err.message)\r\n    }\r\n  }\r\n\r\n  const filteredUsers = users.filter(u => {\r\n    if (filterRole && u.role !== filterRole) return false\r\n    if (search) {\r\n      const q = search.toLowerCase()\r\n      return u.username.toLowerCase().includes(q) || u.full_name.toLowerCase().includes(q)\r\n    }\r\n    return true\r\n  })\r\n\r\n  const roleCounts = users.reduce((acc, u) => {\r\n    acc[u.role] = (acc[u.role] || 0) + 1\r\n    return acc\r\n  }, {} as Record<string, number>)\r\n\r\n  if (loading) return <div className=\"flex items-center justify-center h-64\"><div className=\"animate-spin w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full\" /></div>\r\n\r\n  return (\r\n    <div className=\"max-w-[1400px] mx-auto\">\r\n      <div className=\"flex items-center justify-between mb-6\">\r\n        <div>\r\n          <h1 className=\"text-2xl font-bold text-gray-800\">О“ГңГ–вҲ©в••Г… QuГҹв•‘Гәn trГҹв•—ГҜ hГҹв•—Г§ thГҹв•—ГҰng</h1>\r\n          <p className=\"text-sm text-gray-500\">QuГҹв•‘Гәn lв”ңв•ң ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng, phв”ңГіn quyГҹв•—Гјn</p>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Tabs */}\r\n      <div className=\"flex gap-2 mb-6 flex-wrap\">\r\n        <button onClick={() => setTab('users')}\r\n          className={`px-4 py-2 rounded-lg text-sm font-medium transition ${tab === 'users' ? 'bg-brand-500 text-white' : 'bg-white text-gray-600 hover:bg-gray-100'}`}>\r\n          вүЎЖ’ГҰГұ Ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng ({users.length})\r\n        </button>\r\n        <button onClick={() => setTab('roles')}\r\n          className={`px-4 py-2 rounded-lg text-sm font-medium transition ${tab === 'roles' ? 'bg-brand-500 text-white' : 'bg-white text-gray-600 hover:bg-gray-100'}`}>\r\n          вүЎЖ’Г¶ГҰ Vai trв”ңв–“ & Phв”ңГіn quyГҹв•—Гјn\r\n        </button>\r\n        <button onClick={() => { setTab('sessions'); loadSessions() }}\r\n          className={`px-4 py-2 rounded-lg text-sm font-medium transition ${tab === 'sessions' ? 'bg-brand-500 text-white' : 'bg-white text-gray-600 hover:bg-gray-100'}`}>\r\n          вүЎЖ’Г»Г‘вҲ©в••Г… Phiв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp\r\n        </button>\r\n        <button onClick={() => router.push('/dashboard/settings/permissions')}\r\n          className=\"px-4 py-2 rounded-lg text-sm font-medium bg-white text-gray-600 hover:bg-gray-100 transition border border-dashed border-gray-300\">\r\n          вүЎЖ’Г¶Гү Ma trГҹв•‘ВЎn phв”ңГіn quyГҹв•—Гјn О“ГҘГҶ\r\n        </button>\r\n        <button onClick={() => { setTab('seasonal'); loadSeasonalMode() }}\r\n          className={`px-4 py-2 rounded-lg text-sm font-medium transition ${tab === 'seasonal' ? 'bg-brand-500 text-white' : 'bg-white text-gray-600 hover:bg-gray-100'}`}>\r\n          вүЎЖ’Г„ГҜ ChГҹв•‘в”җ в”ҖГҰГҹв•—Г– mв”ңв•Јa vГҹв•—Г‘\r\n        </button>\r\n      </div>\r\n\r\n      {tab === 'users' && (\r\n        <div>\r\n          {/* Stats bar */}\r\n          <div className=\"flex items-center gap-4 mb-4 p-3 bg-white rounded-xl border shadow-sm\">\r\n            <div className=\"flex items-center gap-2\">\r\n              <span className=\"w-2 h-2 rounded-full bg-green-500 inline-block\" />\r\n              <span className=\"text-sm text-gray-700\"><strong className=\"text-green-700\">{users.filter(u => u.is_active).length}</strong> в”ҖГҰang hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng</span>\r\n            </div>\r\n            <div className=\"w-px h-4 bg-gray-200\" />\r\n            <div className=\"flex items-center gap-2\">\r\n              <span className=\"w-2 h-2 rounded-full bg-gray-400 inline-block\" />\r\n              <span className=\"text-sm text-gray-500\">{users.filter(u => !u.is_active).length} bГҹв•—ГҜ khoв”ңГӯ</span>\r\n            </div>\r\n            <div className=\"flex-1\" />\r\n            <span className=\"text-xs text-gray-400\">{users.length} tв”ңГЎi khoГҹв•‘Гәn tГҹв•—ГІng</span>\r\n          </div>\r\n\r\n          {/* Role summary */}\r\n          <div className=\"grid grid-cols-4 md:grid-cols-8 gap-2 mb-4\">\r\n            <button onClick={() => setFilterRole('')}\r\n              className={`text-center p-2 rounded-lg text-xs transition ${!filterRole ? 'bg-amber-100 ring-2 ring-amber-400' : 'bg-white hover:bg-gray-50'}`}>\r\n              <div className=\"font-bold text-lg\">{users.length}</div>\r\n              <div>TГҹв•‘Г‘t cГҹв•‘Гә</div>\r\n            </button>\r\n            {Object.entries(roleLabels).map(([code, name]) => (\r\n              <button key={code} onClick={() => setFilterRole(filterRole === code ? '' : code)}\r\n                className={`text-center p-2 rounded-lg text-xs transition ${filterRole === code ? 'bg-amber-100 ring-2 ring-amber-400' : 'bg-white hover:bg-gray-50'}`}>\r\n                <div className=\"font-bold text-lg\">{roleCounts[code] || 0}</div>\r\n                <div>{name}</div>\r\n              </button>\r\n            ))}\r\n          </div>\r\n\r\n          {/* Search + Add */}\r\n          <div className=\"flex gap-3 mb-4\">\r\n            <input type=\"text\" placeholder=\"Tв”ңВјm kiГҹв•‘в”җm theo tв”ңВ¬n hoГҹв•‘в•–c username...\"\r\n              value={search} onChange={e => setSearch(e.target.value)}\r\n              className=\"flex-1 px-4 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-amber-500 outline-none\" />\r\n            <button onClick={openCreateModal}\r\n              className=\"px-4 py-2 bg-green-600 text-white rounded-lg text-sm font-medium hover:bg-green-700 transition\">\r\n              О“вӮ§ГІ Thв”ңВ¬m ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng\r\n            </button>\r\n          </div>\r\n\r\n          {/* Users table */}\r\n          <div className=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n            <table className=\"w-full text-sm\">\r\n              <thead className=\"bg-gray-50\">\r\n                <tr>\r\n                  <th className=\"text-left py-3 px-4\">Tв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp</th>\r\n                  <th className=\"text-left py-3 px-4\">HГҹв•—Г¬ tв”ңВ¬n</th>\r\n                  <th className=\"text-center py-3 px-4\">Vai trв”ңв–“</th>\r\n                  <th className=\"text-center py-3 px-4\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n                  <th className=\"text-center py-3 px-4\">Thao tв”ңГӯc</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody>\r\n                {filteredUsers.map(u => {\r\n                  const nameParts = u.full_name.trim().split(' ')\r\n                  const initials = nameParts.length >= 2\r\n                    ? (nameParts[nameParts.length - 2][0] + nameParts[nameParts.length - 1][0]).toUpperCase()\r\n                    : u.full_name.slice(0, 2).toUpperCase()\r\n                  return (\r\n                  <tr key={u.id} className={`border-t hover:bg-gray-50 ${!u.is_active ? 'opacity-60' : ''}`}>\r\n                    <td className=\"py-3 px-4 font-mono text-sm\">{u.username}</td>\r\n                    <td className=\"py-3 px-4\">\r\n                      <div className=\"flex items-center gap-2\">\r\n                        <div className=\"w-8 h-8 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center text-xs font-bold flex-shrink-0\">{initials}</div>\r\n                        <div>\r\n                          <div className=\"font-medium\">{u.full_name}</div>\r\n                          {u.email && <div className=\"text-xs text-gray-400\">{u.email}</div>}\r\n                        </div>\r\n                      </div>\r\n                    </td>\r\n                    <td className=\"py-3 px-4 text-center\">\r\n                      <span className={`px-2 py-1 rounded-full text-xs font-medium ${roleColors[u.role] || 'bg-gray-100'}`}>\r\n                        {roleLabels[u.role] || u.role}\r\n                      </span>\r\n                    </td>\r\n                    <td className=\"py-3 px-4 text-center\">\r\n                      <button onClick={() => handleToggleActive(u)}\r\n                        className={`px-2 py-1 rounded-full text-xs font-medium ${u.is_active ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>\r\n                        {u.is_active ? 'О“ВЈГҙ HoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng' : 'О“ВЈГ№ в”ҖГүв”ңГә khв”ңв”Ӯa'}\r\n                      </button>\r\n                    </td>\r\n                    <td className=\"py-3 px-4 text-center\">\r\n                      <div className=\"flex justify-center gap-2\">\r\n                        <button onClick={() => openEditModal(u)}\r\n                          className=\"text-blue-600 hover:text-blue-800 text-xs\">О“ВЈГ…вҲ©в••Г… SГҹв•—ВЎa</button>\r\n                        <button onClick={() => { setResetUserId(u.id); setResetUserName(u.full_name); setNewPassword(''); setShowResetModal(true) }}\r\n                          className=\"text-orange-600 hover:text-orange-800 text-xs\">вүЎЖ’Г¶ГҰ в”ҖГүГҹв•‘в•–t lГҹв•‘Гӯi MK</button>\r\n                      </div>\r\n                    </td>\r\n                  </tr>\r\n                  )\r\n                })}\r\n              </tbody>\r\n            </table>\r\n            {filteredUsers.length === 0 && (\r\n              <div className=\"text-center py-8 text-gray-400\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng nв”ңГЎo</div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {tab === 'roles' && (\r\n        <div className=\"space-y-4\">\r\n          <div className=\"bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 text-sm text-amber-700\">\r\n            О“ГӨв•ЈвҲ©в••Г… HГҹв•—Г§ thГҹв•—ГҰng cв”ңв”Ӯ 8 vai trв”ңв–“ vГҹв•—Вўi phв”ңГіn quyГҹв•—Гјn cГҹв•—ГҰ в”ҖГҰГҹв•—ГҜnh. MГҹв•—Г№i ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng в”ҖГҰв•һв–‘Гҹв•—Гәc gв”ңГӯn в”ҖГҰв”ңв•‘ng 1 vai trв”ңв–“.\r\n          </div>\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n            {roles.map(role => (\r\n              <div key={role.code} className=\"bg-white rounded-xl shadow-sm p-5\">\r\n                <div className=\"flex items-center gap-3 mb-3\">\r\n                  <span className={`px-3 py-1 rounded-full text-sm font-medium ${roleColors[role.code] || 'bg-gray-100'}`}>\r\n                    {role.name}\r\n                  </span>\r\n                  <span className=\"text-xs text-gray-400 font-mono\">{role.code}</span>\r\n                  <span className=\"text-xs text-gray-400 ml-auto\">{roleCounts[role.code] || 0} ngв•һв–‘Гҹв•—ВҘi</span>\r\n                </div>\r\n                <p className=\"text-sm text-gray-600\">{role.description}</p>\r\n                <div className=\"mt-3 text-xs text-gray-400\">\r\n                  {role.code === 'admin' && 'Truy cГҹв•‘ВЎp: TГҹв•‘Г‘t cГҹв•‘Гә chГҹв•—вҢҗc nв”ҖГўng'}\r\n                  {role.code === 'dvkh' && 'Truy cГҹв•‘ВЎp: TГҹв•—ГІng quan, в”ҖГүв•һГӯn hв”ңГЎng, TГҹв•‘Гӯo в”ҖГҰв•һГӯn, SГҹв•‘Гәn phГҹв•‘вҢҗm, Khв”ңГӯch hв”ңГЎng'}\r\n                  {role.code === 'dispatcher' && 'Truy cГҹв•‘ВЎp: TГҹв•—ГІng quan, в”ҖГүв•һГӯn hв”ңГЎng, TГҹв•‘Гӯo в”ҖГҰв•һГӯn, LГҹв•‘ВЎp kГҹв•‘в”җ hoГҹв•‘Гӯch, ChuyГҹв•‘в”җn xe, BГҹв•‘Гәn в”ҖГҰГҹв•—Гҙ, SГҹв•‘Гәn phГҹв•‘вҢҗm, Khв”ңГӯch hв”ңГЎng, Phв•һв–‘в•һГӯng tiГҹв•—Г§n, Tв”ңГЎi xГҹв•‘в”җ'}\r\n                  {role.code === 'accountant' && 'Truy cГҹв•‘ВЎp: TГҹв•—ГІng quan, в”ҖГүв•һГӯn hв”ңГЎng, DuyГҹв•—Г§t в”ҖГҰв•һГӯn, в”ҖГүГҹв•—ГҰi soв”ңГӯt, ChГҹв•—ГҰt sГҹв•—ГІ ngв”ңГЎy'}\r\n                  {role.code === 'driver' && 'Truy cГҹв•‘ВЎp: ChuyГҹв•‘в”җn xe cГҹв•—Вәa tв”ңв”Өi'}\r\n                  {role.code === 'warehouse' && 'Truy cГҹв•‘ВЎp: QuГҹв•‘Гәn lв”ңв•ң kho, Quв”ңвҢҗt barcode, KiГҹв•—Гўm tra cГҹв•—ГІng'}\r\n                  {role.code === 'security' && 'Truy cГҹв•‘ВЎp: KiГҹв•—Гўm tra cГҹв•—ГІng'}\r\n                  {role.code === 'management' && 'Truy cГҹв•‘ВЎp: TГҹв•—ГІng quan, Bв”ңГӯo cв”ңГӯo KPI'}\r\n                </div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {tab === 'sessions' && (\r\n        <div>\r\n          {sessionsLoading ? (\r\n            <div className=\"flex items-center justify-center h-32\">\r\n              <div className=\"animate-spin w-6 h-6 border-4 border-[#F68634] border-t-transparent rounded-full\" />\r\n            </div>\r\n          ) : sessions.length === 0 ? (\r\n            <div className=\"text-center py-12 text-gray-400\">Khв”ңв”Өng cв”ңв”Ӯ phiв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp nв”ңГЎo</div>\r\n          ) : (\r\n            <div className=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n              <table className=\"w-full text-sm\">\r\n                <thead className=\"bg-gray-50\">\r\n                  <tr>\r\n                    <th className=\"text-left py-3 px-4\">Ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng</th>\r\n                    <th className=\"text-left py-3 px-4\">Vai trв”ңв–“</th>\r\n                    <th className=\"text-left py-3 px-4\">IP</th>\r\n                    <th className=\"text-left py-3 px-4\">ThiГҹв•‘в”җt bГҹв•—ГҜ</th>\r\n                    <th className=\"text-left py-3 px-4\">HoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng gГҹв•‘Вәn nhГҹв•‘Г‘t</th>\r\n                    <th className=\"text-center py-3 px-4\">Thao tв”ңГӯc</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody>\r\n                  {sessions.map(s => {\r\n                    const isRecent = Date.now() - new Date(s.last_active).getTime() < 300000\r\n                    return (\r\n                      <tr key={s.id} className=\"border-t hover:bg-gray-50\">\r\n                        <td className=\"py-3 px-4 font-medium\">{s.user_name}</td>\r\n                        <td className=\"py-3 px-4\">\r\n                          <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${roleColors[s.role] || 'bg-gray-100'}`}>\r\n                            {roleLabels[s.role] || s.role}\r\n                          </span>\r\n                        </td>\r\n                        <td className=\"py-3 px-4 font-mono text-xs text-gray-500\">{s.ip_address}</td>\r\n                        <td className=\"py-3 px-4 text-xs text-gray-500 max-w-[200px] truncate\" title={s.user_agent}>{s.user_agent}</td>\r\n                        <td className=\"py-3 px-4\">\r\n                          <div className=\"flex items-center gap-2\">\r\n                            <span className={`w-2 h-2 rounded-full ${isRecent ? 'bg-green-500' : 'bg-gray-300'}`} />\r\n                            <span className=\"text-xs text-gray-500\">{new Date(s.last_active).toLocaleString('vi-VN')}</span>\r\n                          </div>\r\n                        </td>\r\n                        <td className=\"py-3 px-4 text-center\">\r\n                          <div className=\"flex justify-center gap-2\">\r\n                            <button onClick={() => handleRevokeSession(s.id)}\r\n                              className=\"text-red-600 hover:text-red-800 text-xs\">вүЎЖ’Г¶ГҶ Thu hГҹв•—Гҙi</button>\r\n                            <button onClick={() => handleRevokeAllSessions(s.user_id, s.user_name)}\r\n                              className=\"text-orange-600 hover:text-orange-800 text-xs\">О“ГңГӯ TГҹв•‘Г‘t cГҹв•‘Гә</button>\r\n                          </div>\r\n                        </td>\r\n                      </tr>\r\n                    )\r\n                  })}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          )}\r\n        </div>\r\n      )}\r\n\r\n      {/* F5 О“ГҮГ¶ Seasonal Mode */}\r\n      {tab === 'seasonal' && (\r\n        <div className=\"max-w-lg\">\r\n          <div className=\"bg-white rounded-xl shadow-sm border p-6 space-y-5\">\r\n            <div>\r\n              <h2 className=\"text-lg font-bold text-gray-800\">вүЎЖ’Г„ГҜ ChГҹв•‘в”җ в”ҖГҰГҹв•—Г– mв”ңв•Јa vГҹв•—Г‘ (TГҹв•‘в”җt / Hв”ңВҝ / Cao в”ҖГҰiГҹв•—Гўm)</h2>\r\n              <p className=\"text-sm text-gray-500 mt-1\">Khi bГҹв•‘ВЎt, hГҹв•—Г§ thГҹв•—ГҰng sГҹв•‘в•ң tв”ҖГўng buffer tГҹв•‘Гәi trГҹв•—Г¬ng VRP vв”ңГЎ hiГҹв•—Гўn thГҹв•—ГҜ banner cГҹв•‘Гәnh bв”ңГӯo cho tГҹв•‘Г‘t cГҹв•‘Гә vai trв”ңв–“.</p>\r\n            </div>\r\n            {!seasonalMode ? (\r\n              <div className=\"flex items-center justify-center h-24\">\r\n                <div className=\"animate-spin w-6 h-6 border-4 border-brand-500 border-t-transparent rounded-full\" />\r\n              </div>\r\n            ) : (\r\n              <>\r\n                <div className=\"flex items-center justify-between p-4 bg-gray-50 rounded-xl border\">\r\n                  <div>\r\n                    <div className=\"font-semibold text-gray-800\">BГҹв•‘ВЎt chГҹв•‘в”җ в”ҖГҰГҹв•—Г– mв”ңв•Јa vГҹв•—Г‘</div>\r\n                    <div className=\"text-xs text-gray-500 mt-0.5\">TГҹв•—в–’ в”ҖГҰГҹв•—Г–ng в”ңГӯp dГҹв•—Г‘ng buffer VRP vв”ңГЎ cГҹв•‘Гәnh bв”ңГӯo toв”ңГЎn hГҹв•—Г§ thГҹв•—ГҰng</div>\r\n                  </div>\r\n                  <button\r\n                    onClick={() => setSeasonalMode({ ...seasonalMode, enabled: !seasonalMode.enabled })}\r\n                    className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${seasonalMode.enabled ? 'bg-brand-500' : 'bg-gray-200'}`}\r\n                  >\r\n                    <span className={`inline-block h-4 w-4 transform rounded-full bg-white shadow transition-transform ${seasonalMode.enabled ? 'translate-x-6' : 'translate-x-1'}`} />\r\n                  </button>\r\n                </div>\r\n                <div>\r\n                  <label className=\"block text-sm font-medium text-gray-700 mb-1\">Nhв”ңГәn hiГҹв•—Гўn thГҹв•—ГҜ</label>\r\n                  <input\r\n                    value={seasonalMode.label}\r\n                    onChange={e => setSeasonalMode({ ...seasonalMode, label: e.target.value })}\r\n                    className=\"w-full px-3 py-2 border rounded-lg text-sm\"\r\n                    placeholder=\"VD: TГҹв•‘в”җt Nguyв”ңВ¬n в”ҖГүв”ңГӯn 2026\"\r\n                  />\r\n                </div>\r\n                <div>\r\n                  <label className=\"block text-sm font-medium text-gray-700 mb-1\">Buffer tГҹв•‘Гәi trГҹв•—Г¬ng VRP (%)</label>\r\n                  <div className=\"flex items-center gap-3\">\r\n                    <input\r\n                      type=\"range\" min={0} max={50} step={5}\r\n                      value={seasonalMode.vrp_buffer_pct}\r\n                      onChange={e => setSeasonalMode({ ...seasonalMode, vrp_buffer_pct: parseInt(e.target.value) })}\r\n                      className=\"flex-1\"\r\n                    />\r\n                    <span className=\"text-sm font-bold text-brand-600 w-10 text-right\">{seasonalMode.vrp_buffer_pct}%</span>\r\n                  </div>\r\n                  <p className=\"text-xs text-gray-400 mt-1\">VRP sГҹв•‘в•ң giГҹв•‘Гәm tГҹв•‘Гәi trГҹв•—Г¬ng tГҹв•—ГҰi в”ҖГҰa xuГҹв•—ГҰng {100 - seasonalMode.vrp_buffer_pct}% в”ҖГҰГҹв•—Гў в”ҖГҰГҹв•‘Гәm bГҹв•‘Гәo tв”ңВЎnh linh hoГҹв•‘Гӯt trong mв”ңв•Јa cao в”ҖГҰiГҹв•—Гўm.</p>\r\n                </div>\r\n                {seasonalMode.enabled && (\r\n                  <div className=\"bg-amber-50 border border-amber-200 rounded-lg p-3 text-sm text-amber-800\">\r\n                    <strong>О“ГңГЎвҲ©в••Г… ChГҹв•‘в”җ в”ҖГҰГҹв•—Г– {seasonalMode.label} в”ҖГҰang bГҹв•‘ВЎt.</strong> TГҹв•‘Г‘t cГҹв•‘Гә ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng sГҹв•‘в•ң thГҹв•‘Г‘y banner cГҹв•‘Гәnh bв”ңГӯo. VRP buffer: -{seasonalMode.vrp_buffer_pct}% tГҹв•‘Гәi trГҹв•—Г¬ng.\r\n                  </div>\r\n                )}\r\n                <button\r\n                  onClick={handleSaveSeasonalMode}\r\n                  disabled={seasonalSaving}\r\n                  className=\"w-full py-2 bg-brand-500 text-white rounded-lg font-medium hover:bg-brand-600 disabled:opacity-50 transition\"\r\n                >\r\n                  {seasonalSaving ? 'в”ҖГүang lв•һв–‘u...' : 'Lв•һв–‘u cв”ңГЎi в”ҖГҰГҹв•‘в•–t mв”ңв•Јa vГҹв•—Г‘'}\r\n                </button>\r\n              </>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Create/Edit Modal */}\r\n      {showModal && (\r\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-center justify-center\">\r\n          <div className=\"bg-white rounded-xl shadow-xl w-full max-w-md p-6\">\r\n            <h2 className=\"text-lg font-bold mb-4\">{editUser ? 'О“ВЈГ…вҲ©в••Г… SГҹв•—ВЎa ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng' : 'О“вӮ§ГІ Thв”ңВ¬m ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng'}</h2>\r\n            <div className=\"space-y-3\">\r\n              {!editUser && (\r\n                <div>\r\n                  <label className=\"block text-sm font-medium text-gray-700 mb-1\">Tв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp *</label>\r\n                  <input type=\"text\" value={form.username} onChange={e => setForm({ ...form, username: e.target.value })}\r\n                    className=\"w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-amber-500 outline-none\"\r\n                    placeholder=\"VD: dvkh05\" />\r\n                </div>\r\n              )}\r\n              <div>\r\n                <label className=\"block text-sm font-medium text-gray-700 mb-1\">HГҹв•—Г¬ tв”ңВ¬n *</label>\r\n                <input type=\"text\" value={form.full_name} onChange={e => setForm({ ...form, full_name: e.target.value })}\r\n                  className=\"w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-amber-500 outline-none\"\r\n                  placeholder=\"VD: NguyГҹв•—Г n Vв”ҖГўn A\" />\r\n              </div>\r\n              {!editUser && (\r\n                <div>\r\n                  <label className=\"block text-sm font-medium text-gray-700 mb-1\">MГҹв•‘ВЎt khГҹв•‘вҢҗu * (в”ңВЎt nhГҹв•‘Г‘t 6 kв”ңв•ң tГҹв•—в–’)</label>\r\n                  <input type=\"password\" value={form.password} onChange={e => setForm({ ...form, password: e.target.value })}\r\n                    className=\"w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-amber-500 outline-none\" />\r\n                </div>\r\n              )}\r\n              <div>\r\n                <label className=\"block text-sm font-medium text-gray-700 mb-1\">Email</label>\r\n                <input type=\"email\" value={form.email} onChange={e => setForm({ ...form, email: e.target.value })}\r\n                  className=\"w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-amber-500 outline-none\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"block text-sm font-medium text-gray-700 mb-1\">Vai trв”ңв–“ *</label>\r\n                <select value={form.role} onChange={e => setForm({ ...form, role: e.target.value })}\r\n                  className=\"w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-amber-500 outline-none\">\r\n                  {Object.entries(roleLabels).map(([code, name]) => (\r\n                    <option key={code} value={code}>{name}</option>\r\n                  ))}\r\n                </select>\r\n              </div>\r\n              {editUser && (\r\n                <div className=\"flex items-center gap-2\">\r\n                  <input type=\"checkbox\" checked={form.is_active} onChange={e => setForm({ ...form, is_active: e.target.checked })} />\r\n                  <label className=\"text-sm text-gray-700\">Tв”ңГЎi khoГҹв•‘Гәn hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng</label>\r\n                </div>\r\n              )}\r\n              {error && <div className=\"bg-red-50 text-red-600 text-sm px-3 py-2 rounded-lg\">{error}</div>}\r\n            </div>\r\n            <div className=\"flex gap-3 mt-6\">\r\n              <button onClick={handleSave} disabled={saving}\r\n                className=\"flex-1 py-2 bg-brand-500 text-white rounded-lg hover:bg-brand-600 transition text-sm font-medium disabled:opacity-50\">\r\n                {saving ? 'в”ҖГүang lв•һв–‘u...' : 'Lв•һв–‘u'}\r\n              </button>\r\n              <button onClick={() => setShowModal(false)}\r\n                className=\"px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition text-sm\">\r\n                HГҹв•—Вәy\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Reset Password Modal */}\r\n      {showResetModal && (\r\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-center justify-center\">\r\n          <div className=\"bg-white rounded-xl shadow-xl w-full max-w-sm p-6\">\r\n            <h2 className=\"text-lg font-bold mb-2\">вүЎЖ’Г¶ГҰ в”ҖГүГҹв•‘в•–t lГҹв•‘Гӯi mГҹв•‘ВЎt khГҹв•‘вҢҗu</h2>\r\n            <p className=\"text-sm text-gray-500 mb-4\">Cho: <strong>{resetUserName}</strong></p>\r\n            <div>\r\n              <label className=\"block text-sm font-medium text-gray-700 mb-1\">MГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi (в”ңВЎt nhГҹв•‘Г‘t 6 kв”ңв•ң tГҹв•—в–’)</label>\r\n              <input type=\"password\" value={newPassword} onChange={e => setNewPassword(e.target.value)}\r\n                className=\"w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-amber-500 outline-none\" />\r\n            </div>\r\n            <div className=\"flex gap-3 mt-4\">\r\n              <button onClick={handleResetPassword}\r\n                className=\"flex-1 py-2 bg-brand-500 text-white rounded-lg hover:bg-brand-600 transition text-sm font-medium\">\r\n                Xв”ңГӯc nhГҹв•‘ВЎn\r\n              </button>\r\n              <button onClick={() => setShowResetModal(false)}\r\n                className=\"px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition text-sm\">\r\n                HГҹв•—Вәy\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\settings\\permissions\\page.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: 'loadPermissions', 'router', and 'user?.role'. Either include them or remove the dependency array.","line":51,"column":6,"nodeType":"ArrayExpression","endLine":51,"endColumn":8,"suggestions":[{"desc":"Update the dependencies array to be: [loadPermissions, router, user?.role]","fix":{"range":[1681,1683],"text":"[loadPermissions, router, user?.role]"}}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":56,"column":18,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":56,"endColumn":21,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1791,1794],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1791,1794],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":58,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":58,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1891,1894],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1891,1894],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":92,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":92,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3310,3313],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3310,3313],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState, useCallback } from 'react'\r\nimport { useRouter } from 'next/navigation'\r\nimport { apiFetch, getUser } from '@/lib/api'\r\nimport { toast } from '@/lib/useToast'\r\n\r\ninterface RolePermission {\r\n  id: string\r\n  role: string\r\n  resource: string\r\n  action: string\r\n  allowed: boolean\r\n}\r\n\r\nconst ROLES = ['admin', 'dispatcher', 'dvkh', 'accountant', 'driver', 'warehouse', 'security', 'management', 'workshop'] as const\r\n\r\nconst roleLabels: Record<string, string> = {\r\n  admin: 'Admin', dispatcher: 'в”ҖГүiГҹв•—Гјu phГҹв•—ГҰi', dvkh: 'DVKH',\r\n  accountant: 'KГҹв•‘в”җ toв”ңГӯn', driver: 'Tв”ңГЎi xГҹв•‘в”җ', warehouse: 'ThГҹв•—Вә kho',\r\n  security: 'BГҹв•‘Гәo vГҹв•—Г§', management: 'BGв”ҖГү', workshop: 'Phв”ңГіn xв•һв–‘Гҹв•—Ж’ng',\r\n}\r\n\r\nconst RESOURCES = [\r\n  'orders', 'trips', 'warehouse', 'customers', 'products', 'vehicles',\r\n  'drivers', 'reconciliation', 'kpi', 'admin', 'notifications', 'planning',\r\n] as const\r\n\r\nconst ACTIONS = ['view', 'create', 'edit', 'delete', 'approve', 'export'] as const\r\n\r\nconst actionLabels: Record<string, string> = {\r\n  view: 'Xem', create: 'TГҹв•‘Гӯo', edit: 'SГҹв•—ВЎa',\r\n  delete: 'Xв”ңв”Ӯa', approve: 'DuyГҹв•—Г§t', export: 'XuГҹв•‘Г‘t',\r\n}\r\n\r\nexport default function PermissionsPage() {\r\n  const router = useRouter()\r\n  const user = getUser()\r\n  const [permissions, setPermissions] = useState<RolePermission[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [saving, setSaving] = useState<string | null>(null)\r\n  const [selectedRole, setSelectedRole] = useState<string>('dispatcher')\r\n  const [filterResource, setFilterResource] = useState('')\r\n\r\n  useEffect(() => {\r\n    if (user?.role !== 'admin') {\r\n      router.replace('/dashboard')\r\n      return\r\n    }\r\n    loadPermissions()\r\n  }, [])\r\n\r\n  const loadPermissions = useCallback(async () => {\r\n    setLoading(true)\r\n    try {\r\n      const res: any = await apiFetch('/admin/permissions')\r\n      setPermissions(res.data || [])\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i tГҹв•‘Гәi danh sв”ңГӯch quyГҹв•—Гјn: ' + err.message)\r\n    } finally {\r\n      setLoading(false)\r\n    }\r\n  }, [])\r\n\r\n  const isAllowed = (role: string, resource: string, action: string): boolean => {\r\n    if (role === 'admin') return true\r\n    const p = permissions.find(p => p.role === role && p.resource === resource && p.action === action)\r\n    return p?.allowed ?? false\r\n  }\r\n\r\n  const handleToggle = async (role: string, resource: string, action: string) => {\r\n    if (role === 'admin') return // admin always has all permissions\r\n    const key = `${role}:${resource}:${action}`\r\n    setSaving(key)\r\n    const currentValue = isAllowed(role, resource, action)\r\n    try {\r\n      await apiFetch('/admin/permissions', {\r\n        method: 'PUT',\r\n        body: { role, resource, action, allowed: !currentValue },\r\n      })\r\n      // Optimistic update\r\n      setPermissions(prev => {\r\n        const idx = prev.findIndex(p => p.role === role && p.resource === resource && p.action === action)\r\n        if (idx >= 0) {\r\n          const updated = [...prev]\r\n          updated[idx] = { ...updated[idx], allowed: !currentValue }\r\n          return updated\r\n        }\r\n        return [...prev, { id: '', role, resource, action, allowed: !currentValue }]\r\n      })\r\n      toast.success(`в”ҖГүв”ңГә ${!currentValue ? 'cГҹв•‘Г‘p' : 'thu hГҹв•—Гҙi'} quyГҹв•—Гјn ${actionLabels[action]} ${resource} cho ${roleLabels[role]}`)\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i cГҹв•‘ВЎp nhГҹв•‘ВЎt quyГҹв•—Гјn: ' + err.message)\r\n    } finally {\r\n      setSaving(null)\r\n    }\r\n  }\r\n\r\n  const resourcesFiltered = filterResource\r\n    ? RESOURCES.filter(r => r.includes(filterResource.toLowerCase()))\r\n    : RESOURCES\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"flex items-center justify-center h-64\">\r\n        <div className=\"animate-spin w-8 h-8 border-4 border-[#F68634] border-t-transparent rounded-full\" />\r\n      </div>\r\n    )\r\n  }\r\n\r\n  return (\r\n    <div className=\"max-w-[1400px] mx-auto\">\r\n      {/* Header */}\r\n      <div className=\"flex items-center justify-between mb-6\">\r\n        <div>\r\n          <h1 className=\"text-2xl font-bold text-gray-800\">вүЎЖ’Г¶Гү Ma trГҹв•‘ВЎn phв”ңГіn quyГҹв•—Гјn</h1>\r\n          <p className=\"text-sm text-gray-500 mt-1\">QuГҹв•‘Гәn lв”ңв•ң quyГҹв•—Гјn truy cГҹв•‘ВЎp theo vai trв”ңв–“ О“ГҮГ¶ thay в”ҖГҰГҹв•—ГІi cв”ңв”Ӯ hiГҹв•—Г§u lГҹв•—в–’c ngay</p>\r\n        </div>\r\n        <button\r\n          onClick={() => router.push('/dashboard/settings')}\r\n          className=\"px-4 py-2 text-sm text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition\"\r\n        >\r\n          О“ГҘГү Quay lГҹв•‘Гӯi\r\n        </button>\r\n      </div>\r\n\r\n      {/* Role tabs */}\r\n      <div className=\"flex gap-1.5 mb-4 flex-wrap\">\r\n        {ROLES.map(role => (\r\n          <button\r\n            key={role}\r\n            onClick={() => setSelectedRole(role)}\r\n            className={`px-3 py-1.5 rounded-lg text-xs font-medium transition ${\r\n              selectedRole === role\r\n                ? 'bg-[#F68634] text-white shadow-sm'\r\n                : role === 'admin'\r\n                  ? 'bg-red-50 text-red-600 hover:bg-red-100'\r\n                  : 'bg-gray-100 text-gray-600 hover:bg-gray-200'\r\n            }`}\r\n          >\r\n            {roleLabels[role]}\r\n          </button>\r\n        ))}\r\n      </div>\r\n\r\n      {/* Search */}\r\n      <div className=\"mb-4\">\r\n        <input\r\n          type=\"text\"\r\n          placeholder=\"LГҹв•—Г¬c theo tв”ңГЎi nguyв”ңВ¬n...\"\r\n          value={filterResource}\r\n          onChange={e => setFilterResource(e.target.value)}\r\n          className=\"w-64 px-3 py-2 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#F68634]/30 focus:border-[#F68634] outline-none\"\r\n        />\r\n      </div>\r\n\r\n      {/* Permission Matrix */}\r\n      <div className=\"bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm\">\r\n        <div className=\"overflow-x-auto\">\r\n          <table className=\"w-full text-sm\">\r\n            <thead>\r\n              <tr className=\"bg-gray-50 border-b border-gray-200\">\r\n                <th className=\"text-left px-4 py-3 font-semibold text-gray-700 w-40\">Tв”ңГЎi nguyв”ңВ¬n</th>\r\n                {ACTIONS.map(action => (\r\n                  <th key={action} className=\"text-center px-3 py-3 font-semibold text-gray-700 w-24\">\r\n                    {actionLabels[action]}\r\n                  </th>\r\n                ))}\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              {resourcesFiltered.map((resource, ri) => (\r\n                <tr key={resource} className={`border-b border-gray-100 ${ri % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>\r\n                  <td className=\"px-4 py-3\">\r\n                    <span className=\"font-medium text-gray-800 capitalize\">{resource}</span>\r\n                  </td>\r\n                  {ACTIONS.map(action => {\r\n                    const allowed = isAllowed(selectedRole, resource, action)\r\n                    const isAdmin = selectedRole === 'admin'\r\n                    const key = `${selectedRole}:${resource}:${action}`\r\n                    const isSaving = saving === key\r\n                    return (\r\n                      <td key={action} className=\"text-center px-3 py-3\">\r\n                        <button\r\n                          onClick={() => handleToggle(selectedRole, resource, action)}\r\n                          disabled={isAdmin || isSaving}\r\n                          className={`w-8 h-8 rounded-lg inline-flex items-center justify-center transition ${\r\n                            isAdmin\r\n                              ? 'bg-green-100 text-green-600 cursor-not-allowed'\r\n                              : allowed\r\n                                ? 'bg-green-100 text-green-600 hover:bg-green-200'\r\n                                : 'bg-gray-100 text-gray-400 hover:bg-gray-200'\r\n                          } ${isSaving ? 'opacity-50' : ''}`}\r\n                          title={isAdmin ? 'Admin cв”ңв”Ӯ toв”ңГЎn quyГҹв•—Гјn' : allowed ? 'в”ҖГүang cho phв”ңвҢҗp О“ГҮГ¶ nhГҹв•‘Г‘n в”ҖГҰГҹв•—Гў thu hГҹв•—Гҙi' : 'в”ҖГүang tГҹв•—ВҪ chГҹв•—ГҰi О“ГҮГ¶ nhГҹв•‘Г‘n в”ҖГҰГҹв•—Гў cГҹв•‘Г‘p quyГҹв•—Гјn'}\r\n                        >\r\n                          {isSaving ? (\r\n                            <div className=\"w-4 h-4 border-2 border-gray-300 border-t-[#F68634] rounded-full animate-spin\" />\r\n                          ) : allowed ? (\r\n                            <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={2.5}>\r\n                              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M5 13l4 4L19 7\" />\r\n                            </svg>\r\n                          ) : (\r\n                            <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={2}>\r\n                              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M6 18L18 6M6 6l12 12\" />\r\n                            </svg>\r\n                          )}\r\n                        </button>\r\n                      </td>\r\n                    )\r\n                  })}\r\n                </tr>\r\n              ))}\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Legend */}\r\n      <div className=\"flex items-center gap-6 mt-4 text-xs text-gray-500\">\r\n        <div className=\"flex items-center gap-1.5\">\r\n          <div className=\"w-5 h-5 rounded bg-green-100 flex items-center justify-center\">\r\n            <svg className=\"w-3 h-3 text-green-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={2.5}>\r\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M5 13l4 4L19 7\" />\r\n            </svg>\r\n          </div>\r\n          Cho phв”ңвҢҗp\r\n        </div>\r\n        <div className=\"flex items-center gap-1.5\">\r\n          <div className=\"w-5 h-5 rounded bg-gray-100 flex items-center justify-center\">\r\n            <svg className=\"w-3 h-3 text-gray-400\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={2}>\r\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M6 18L18 6M6 6l12 12\" />\r\n            </svg>\r\n          </div>\r\n          TГҹв•—В