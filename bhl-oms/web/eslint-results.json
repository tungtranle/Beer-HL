hicles.filter(v => v.vehicle_type === type).length\r\n          return (\r\n            <div key={type} className=\"bg-white rounded-xl border p-4 text-center\">\r\n              <div className=\"text-2xl font-bold text-gray-900\">{count}</div>\r\n              <div className=\"text-xs text-gray-500 mt-1\">{label}</div>\r\n            </div>\r\n          )\r\n        })}\r\n      </div>\r\n\r\n      <div className=\"bg-white rounded-xl shadow-sm border overflow-hidden\">\r\n        <table className=\"w-full text-sm\">\r\n          <thead className=\"bg-gray-50 border-b\">\r\n            <tr>\r\n              <th className=\"text-left px-4 py-3 font-medium text-gray-600\">BiГҹв•—Гўn sГҹв•—ГҰ</th>\r\n              <th className=\"text-left px-4 py-3 font-medium text-gray-600\">LoГҹв•‘Гӯi xe</th>\r\n              <th className=\"text-right px-4 py-3 font-medium text-gray-600\">TГҹв•‘Гәi trГҹв•—Г¬ng (kg)</th>\r\n              <th className=\"text-right px-4 py-3 font-medium text-gray-600\">ThГҹв•—Гў tв”ңВЎch (mв”¬в”Ӯ)</th>\r\n              <th className=\"text-left px-4 py-3 font-medium text-gray-600\">Tв”ңГЎi xГҹв•‘в”җ mГҹв•‘в•–c в”ҖГҰГҹв•—ГҜnh</th>\r\n              <th className=\"text-center px-4 py-3 font-medium text-gray-600\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n              <th className=\"text-center px-4 py-3 font-medium text-gray-600\">Thao tв”ңГӯc</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody className=\"divide-y\">\r\n            {filteredByStatus.map(v => (\r\n              <tr key={v.id} className=\"hover:bg-gray-50\">\r\n                <td className=\"px-4 py-3 font-bold text-gray-900\">{v.plate_number}</td>\r\n                <td className=\"px-4 py-3 text-gray-600\">{vehicleTypeLabels[v.vehicle_type] || v.vehicle_type}</td>\r\n                <td className=\"px-4 py-3 text-right font-medium text-gray-900\">{v.capacity_kg.toLocaleString('vi-VN')}</td>\r\n                <td className=\"px-4 py-3 text-right text-gray-600\">{v.capacity_m3 ?