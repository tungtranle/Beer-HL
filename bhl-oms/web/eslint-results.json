ame=\"px-4 py-3 text-right\">{l.km_odometer.toLocaleString()}</td>\r\n                  <td className=\"px-4 py-3 text-right\">{fmt(l.liters_filled)}</td>\r\n                  <td className=\"px-4 py-3 text-right\">{fmt(l.expected_liters)}</td>\r\n                  <td className=\"px-4 py-3 text-right\">{fmt(l.amount_vnd)}</td>\r\n                  <td className=\"px-4 py-3\">{channelLabels[l.channel] || l.channel}</td>\r\n                  <td className=\"px-4 py-3 text-center\">{l.anomaly_flag ? 'вүЎЖ’Г¶в”Ө' : 'О“ВЈГ '}</td>\r\n                </tr>\r\n              ))}\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      ) : (\r\n        <div className=\"bg-white rounded-xl shadow-sm border overflow-hidden\">\r\n          <table className=\"w-full text-sm\">\r\n            <thead className=\"bg-gray-50\">\r\n              <tr>\r\n                <th className=\"px-4 py-3 text-left font-medium text-gray-500\">Xe</th>\r\n                <th className=\"px-4 py-3 text-left font-medium text-gray-500\">Tв”ңГЎi xГҹв•‘в”җ</th>\r\n                <th className=\"px-4 py-3 text-right font-medium text-gray-500\">KГҹв•—в”Ӯ vГҹв•—Г¬ng (L)</th>\r\n                <th className=\"px-4 py-3 text-right font-medium text-gray-500\">ThГҹв•—в–’c tГҹв•‘в”җ (L)</th>\r\n                <th className=\"px-4 py-3 text-right font-medium text-gray-500\">Chв”ңВ¬nh lГҹв•—Г§ch</th>\r\n                <th className=\"px-4 py-3 text-left font-medium text-gray-500\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody className=\"divide-y\">\r\n              {anomalies.length === 0 ? (\r\n                <tr><td colSpan={6} className=\"px-4 py-8 text-center text-gray-400\">Khв”ңв”Өng cв”ңв”Ӯ bГҹв•‘Г‘t thв•һв–‘Гҹв•—ВҘng</td></tr>\r\n              ) : anomalies.map(a => (\r\n                <tr key={a.id} className=\"hover:bg-gray-50\">\r\n                  <td className=\"px-4 py-3\">{a.vehicle_plate}</td>\r\n                  <td clas