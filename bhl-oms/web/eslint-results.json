ssName=\"py-2 px-3 text-center\">\r\n                        {!item.product_id ? (\r\n                          <span className=\"text-gray-400 text-xs\">О“ГҮГ¶</span>\r\n                        ) : atpLoading ? (\r\n                          <span className=\"text-gray-400 text-xs\">в”ҖГүang kiГҹв•—Гўm...</span>\r\n                        ) : atpChecked ? (\r\n                          <div className={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold ${\r\n                            atpOk ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'\r\n                          }`}>\r\n                            <span>{atpOk ? 'О“ВЈГ ' : 'О“ВҘГ®'}</span>\r\n                            <span>ATP: {formatNumber(atp!.atp)}</span>\r\n                            <span className=\"text-gray-400\">/ в”ҖГүГҹв•‘в•–t: {formatNumber(item.quantity)}</span>\r\n                          </div>\r\n                        ) : (\r\n                          <span className=\"text-gray-400 text-xs\">ChГҹв•—Г¬n kho в”ҖГҰГҹв•—Гў kiГҹв•—Гўm tra</span>\r\n                        )}\r\n                      </td>\r\n                      <td className=\"py-2 px-3\">\r\n                        <button type=\"button\" onClick={() => removeItem(idx)} className=\"text-red-500 hover:text-red-700\">О“ВЈГІ</button>\r\n                      </td>\r\n                    </tr>\r\n                  )\r\n                })}\r\n              </tbody>\r\n              <tfoot>\r\n                <tr className=\"border-t\">\r\n                  <td colSpan={3} className=\"py-2 px-3 text-right text-gray-600\">TiГҹв•—Гјn hв”ңГЎng:</td>\r\n                  <td className=\"py-2 px-3 text-right font-medium\">{formatVND(totalAmount)}</td>\r\n                  <td colSpan={2}></td>\r\n                </tr>\r\n                {totalDeposit > 0 && (\r\n                  <tr>\r\n                    <td colSpan={3} className=\"py-1 px-3 text-right text-gray-600\">Phв”ңВЎ vГҹв•—Г…/kв”ң