order rounded-lg px-3 py-2 mt-1\" placeholder=\"200000\" />\r\n                    </div>\r\n                  </div>\r\n                  <div className=\"flex gap-2 mt-4\">\r\n                    <button onClick={saveDriverRate} disabled={saving} className=\"px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm disabled:opacity-50\">\r\n                      {saving ? 'в”ҖГүang lв•һв–‘u...' : 'вүЎЖ’ГҶв•ӣ Lв•һв–‘u'}\r\n                    </button>\r\n                    <button onClick={() => setEditingRate(null)} className=\"px-4 py-2 bg-gray-200 rounded-lg hover:bg-gray-300 text-sm\">HГҹв•—Вәy</button>\r\n                  </div>\r\n                </div>\r\n              )}\r\n\r\n              <div className=\"bg-white rounded-xl border overflow-hidden\">\r\n                <table className=\"w-full text-sm\">\r\n                  <thead className=\"bg-gray-50\">\r\n                    <tr>\r\n                      <th className=\"text-left py-3 px-4\">Mв”ңв”Ө tГҹв•‘Гә</th>\r\n                      <th className=\"text-right py-3 px-4\">PhГҹв•—Г‘ cГҹв•‘Г‘p/km (О“Г©ВҪ)</th>\r\n                      <th className=\"text-right py-3 px-4\">TГҹв•—ГҰi thiГҹв•—Гўu/ngв”ңГЎy (О“Г©ВҪ)</th>\r\n                      <th className=\"text-center py-3 px-4\">Thao tв”ңГӯc</th>\r\n                    </tr>\r\n                  </thead>\r\n                  <tbody>\r\n                    {driverRates.map(r => (\r\n                      <tr key={r.id} className=\"border-t hover:bg-gray-50\">\r\n                        <td className=\"py-2.5 px-4\">{r.description}</td>\r\n                        <td className=\"py-2.5 px-4 text-right font-medium\">{formatVND(r.rate_per_km)}О“Г©ВҪ</td>\r\n                        <td className=\"py-2.5 px-4 text-right\">{formatVND(r.min_daily_rate)}О“Г©ВҪ</td>\r\n                        <td className=\"py-2.5 px-4 text-center\">\r\n                          <button onClick={() => setEditingRate(r)} className=\"text-blue-500 hover:text-blue-700 mr-2\">О“ВЈГ…вҲ©в••Г…</button>\r\n                          <button onClick={() => deleteDriverRate(r.id)} className=\"text-red-400 hover:text-red-600\">вүЎЖ’Г№ГҰвҲ©в••Г…</button>\r\n                        </td>\r\n                      </tr>\r\n                    ))}\r\n                    {driverRates.length === 0 && (\r\n                      <tr><td colSpan={4} className=\"text-center py-8 text-gray-400\">Chв•һв–‘a cв”ңв”Ӯ phГҹв•—Г‘ cГҹв•‘Г‘p tв”ңГЎi xГҹв•‘в”җ.</td></tr>\r\n                    )}\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n            </div>\r\n          )}\r\n        </>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮ Inline Editable Row for Vehicle Defaults О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction VehicleDefaultRow({ item, fuelPerKm, onSave, saving }: {\r\n  item: VehicleTypeCostDefault; fuelPerKm: number; onSave: (d: VehicleTypeCostDefault) => void; saving: boolean\r\n}) {\r\n  const [editing, setEditing] = useState(false)\r\n  const [local, setLocal] = useState(item)\r\n\r\n  useEffect(() => { setLocal(item) }, [item])\r\n\r\n  if (!editing) {\r\n    return (\r\n      <tr className=\"border-t hover:bg-gray-50\">\r\n        <td className=\"py-2.5 px-4 font-medium\">{item.vehicle_type}</td>\r\n        <td className=\"py-2.5 px-4 text-right\">{item.fuel_consumption_per_km}</td>\r\n        <td className=\"py-2.5 px-4 text-right\">{new Intl.NumberFormat('vi-VN').format(item.fuel_price_per_liter)}</td>\r\n        <td className=\"py-2.5 px-4 text-center\">\r\n          <span className=\"px-2 py-0.5 bg-blue-100 text-blue-700 rounded-full text-xs\">{item.toll_class}</span>\r\n        </td>\r\n        <td className=\"py-2.5 px-4 text-right font-medium text-green-700\">{new Intl.NumberFormat('vi-VN').format(Math.round(fuelPerKm))}О“Г©ВҪ</td>\r\n        <td className=\"py-2.5 px-4 text-center\">\r\n          <button onClick={() => setEditing(true)} className=\"text-blue-500 hover:text-blue-700\">О“ВЈГ…вҲ©в••Г…</button>\r\n        </td>\r\n      </tr>\r\n    )\r\n  }\r\n\r\n  return (\r\n    <tr className=\"border-t bg-yellow-50\">\r\n      <td className=\"py-2 px-4 font-medium\">{item.vehicle_type}</td>\r\n      <td className=\"py-2 px-2\">\r\n        <input type=\"number\" step=\"0.01\" value={local.fuel_consumption_per_km}\r\n          onChange={e => setLocal({ ...local, fuel_consumption_per_km: parseFloat(e.target.value) || 0 })}\r\n          className=\"w-full border rounded px-2 py-1.5 text-sm text-right\" />\r\n      </td>\r\n      <td className=\"py-2 px-2\">\r\n        <input type=\"number\" value={local.fuel_price_per_liter}\r\n          onChange={e => setLocal({ ...local, fuel_price_per_liter: parseFloat(e.target.value) || 0 })}\r\n          className=\"w-full border rounded px-2 py-1.5 text-sm text-right\" />\r\n      </td>\r\n      <td className=\"py-2 px-2\">\r\n        <select value={local.toll_class} onChange={e => setLocal({ ...local, toll_class: e.target.value })}\r\n          className=\"w-full border rounded px-2 py-1.5 text-sm text-center\">\r\n          {['L1', 'L2', 'L3', 'L4', 'L5'].map(c => <option key={c} value={c}>{c}</option>)}\r\n        </select>\r\n      </td>\r\n      <td className=\"py-2 px-4 text-right text-green-700 font-medium\">\r\n        {new Intl.NumberFormat('vi-VN').format(Math.round(local.fuel_consumption_per_km * local.fuel_price_per_liter))}О“Г©ВҪ\r\n      </td>\r\n      <td className=\"py-2 px-2 text-center\">\r\n        <button onClick={() => { onSave(local); setEditing(false) }} disabled={saving}\r\n          className=\"text-green-600 hover:text-green-800 mr-1\">вүЎЖ’ГҶв•ӣ</button>\r\n        <button onClick={() => { setLocal(item); setEditing(false) }} className=\"text-gray-400 hover:text-gray-600\">О“ВЈГ№</button>\r\n      </td>\r\n    </tr>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\trips\\[id]\\page.tsx",