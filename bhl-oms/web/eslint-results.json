nst lookup = async () => {\r\n    setBusy(true)\r\n    setSuggestions([])\r\n    setPallet(null)\r\n    try {\r\n      const r: any = await apiFetch(`/warehouse/pallets/${encodeURIComponent(lpn.trim())}`)\r\n      setPallet(r.data)\r\n      const s: any = await apiFetch('/warehouse/inbound/suggest-bin', {\r\n        method: 'POST',\r\n        body: {\r\n          warehouse_id: r.data.warehouse_id,\r\n          product_id: r.data.product_id,\r\n          lot_id: r.data.lot_id,\r\n          qty: r.data.qty,\r\n        },\r\n      })\r\n      setSuggestions(s.data || [])\r\n    } catch (e: any) { toast.error(e.message) }\r\n    finally { setBusy(false) }\r\n  }\r\n\r\n  const confirmPut = async (binCode: string) => {\r\n    setBusy(true)\r\n    try {\r\n      const isOverride = !!override && !suggestions.some(s => s.bin.bin_code === binCode)\r\n      if (isOverride && !reason.trim()) {\r\n        toast.error('Override yв”ңВ¬u cГҹв•‘Вәu lв”ңв•ң do')\r\n        setBusy(false)\r\n        return\r\n      }\r\n      await apiFetch('/warehouse/inbound/putaway', {\r\n        method: 'POST',\r\n        body: { lpn: pallet!.lpn_code, bin_code: binCode, override: isOverride, reason: isOverride ? reason : undefined },\r\n      })\r\n      toast.success(`в”ҖГүв”ңГә в”ҖГҰГҹв•‘в•–t ${pallet!.lpn_code} vв”ңГЎo ${binCode}`)\r\n      setLpn('')\r\n      setPallet(null)\r\n      setSuggestions([])\r\n    } catch (e: any) { toast.error(e.message) }\r\n    finally { setBusy(false) }\r\n  }\r\n\r\n  return (\r\n    <div className=\"p-4 max-w-3xl mx-auto\">\r\n      <h1 className=\"text-2xl font-bold mb-4\">вүЎЖ’Г…в•– Putaway О“ГҮГ¶ в”ҖГүГҹв•‘в•–t pallet vв”ңГЎo bin</h1>\r\n\r\n      <div className=\"bg-white rounded shadow p-4 mb-4 flex gap-2\">\r\n        <input className=\"flex-1 border rounded px-3 py-2 font-mono\" placeholder=\"Quв”ңвҢҗt/nhГҹв•‘ВЎp LPN\"\r\n          value={lpn} onChange={e => setLpn(e.target.value)}\r\n          onKeyDown={e => { if (e.key === 'Enter') lookup() }} />\r\n        <button onClick={lookup} disabled={busy || !lpn}\r\n          className=\"px-4 py-2 bg-blue-600 text-white rounded disabled:opacity-50\">\r\n          Tra cГҹв•—вҢҗu\r\n        </button>\r\n      </div>\r\n\r\n      {pallet && (\r\n        <div className=\"bg-yellow-50 border border-yellow-300 rounded p-3 mb-4\">\r\n          <div className=\"font-mono font-bold\">{pallet.lpn_code}</div>\r\n          <div className=\"text-sm\">{pallet.product_name} в”¬в•– Lв”ңв”Ө {pallet.batch_number} в”¬в•– HSD {pallet.expiry_date} в”¬в•– {pallet.qty} в”ҖГҰв•һГӯn vГҹв•—ГҜ</div>\r\n          {pallet.current_bin_code && (\r\n            <div className=\"text-xs text-gray-600\">в”ҖГүang Гҹв•—Ж’ bin {pallet.current_bin_code} (sГҹв•‘в•ң chuyГҹв•—Гўn)</div>\r\n          )}\r\n        </div>\r\n      )}\r\n\r\n      {suggestions.length > 0 && (\r\n        <div className=\"bg-white rounded shadow p-4 mb-4\">\r\n          <h2 className=\"font-semibold mb-2\">Bin gГҹв•—Гәi в”ңв•ң (xГҹв•‘в”җp hГҹв•‘Гӯng)</h2>\r\n          <div className=\"space-y-2\">\r\n            {suggestions.map((s, i) => (\r\n              <div key={s.bin.id} className=\"flex items-center justify-between border rounded p-3\">\r\n                <div>\r\n                  <span className=\"font-bold\">#{i + 1}</span> <span className=\"font-mono ml-2\">{s.bin.bin_code}</span>\r\n                  <span className=\"ml-2 text-xs bg-gray-200 px-2 rounded\">score {s.score}</span>\r\n                  <div className=\"text-xs text-gray-600\">{s.bin.velocity_class && `Vel ${s.bin.velocity_class} в”¬в•– `}{s.occupied_pallets}/{s.bin.capacity_pallets} chiГҹв•‘в”җm в”¬в•– {s.reason}</div>\r\n                </div>\r\n                <button onClick={() => confirmPut(s.bin.bin_code)} disabled={busy}\r\n                  className=\"px-3 py-1 bg-green-600 text-white rounded\">ChГҹв•—Г¬n</button>\r\n              </div>\r\n            ))}\r\n          </div>\r\n          <div className=\"mt-3 border-t pt-3\">\r\n            <label className=\"text-sm flex items-center gap-2\">\r\n              <input type=\"checkbox\" checked={override} onChange={e => setOverride(e.target.checked)} />\r\n              Override (chГҹв•—Г¬n bin khв”ңГӯc О“ГҮГ¶ ghi lв”ңв•ң do)\r\n            </label>\r\n            {override && (\r\n              <div className=\"mt-2 flex gap-2\">\r\n                <input className=\"flex-1 border rounded px-2 py-1\" placeholder=\"Bin code khв”ңГӯc\" value={chosenBin} onChange={e => setChosenBin(e.target.value)} />\r\n                <input className=\"flex-1 border rounded px-2 py-1\" placeholder=\"Lв”ңв•ң do\" value={reason} onChange={e => setReason(e.target.value)} />\r\n                <button onClick={() => confirmPut(chosenBin)} disabled={busy || !chosenBin}\r\n                  className=\"px-3 py-1 bg-orange-600 text-white rounded\">Override</button>\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\warehouse\\returns\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":22,"column":18,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":22,"endColumn":21,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[726,729],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[726,729],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":38,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":38,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fi