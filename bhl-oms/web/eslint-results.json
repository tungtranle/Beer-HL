and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[4647,4650],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":206,"column":67,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":206,"endColumn":70,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[7737,7740],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[7737,7740],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":11,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\n// WMS Phase 9 О“ГҮГ¶ Universal scan page (PDA HID + camera BarcodeDetector).\r\n// Routes:\r\n//   - Pallet QR (GS1: starts with \"(00)\") О“ГҘГҶ /warehouse/pallets/:lpn\r\n//   - Bin QR (\"(BIN)...\" or \"BHL-BIN-...\") О“ГҘГҶ /warehouse/bins/:code\r\n// Tools: any user can lookup; the LogScan record is auto-inserted by backend.\r\n\r\nimport { useEffect, useRef, useState } from 'react'\r\nimport { apiFetch } from '@/lib/api'\r\nimport { toast } from '@/lib/useToast'\r\n\r\ntype ScanResult = {\r\n  ok: boolean\r\n  type?: 'pallet' | 'bin'\r\n  data?: any\r\n  error?: string\r\n}\r\n\r\n// Parse a QR payload to detect type + extract code.\r\nfunction parseQR(raw: string): { type: 'pallet' | 'bin' | 'unknown'; code: string } {\r\n  const s = raw.trim()\r\n  if (s.startsWith('(00)')) {\r\n    // GS1 SSCC О“ГҮГ¶ extract LPN between (00) and next AI\r\n    const m = s.match(/^\\(00\\)([^()]+)/)\r\n    return { type: 'pallet', code: m ? m[1] : s }\r\n  }\r\n  if (s.startsWith('(BIN)')) {\r\n    return { type: 'bin', code: s.replace(/^\\(BIN\\)/, '') }\r\n  }\r\n  if (/^BHL-LP-/.test(s)) return { type: 'pallet', code: s }\r\n  if (/^[A-Z]\\d?-\\d+/.test(s)) return { type: 'bin', code: s }\r\n  return { type: 'unknown', code: s }\r\n}\r\n\r\nexport default function WarehouseScanPage() {\r\n  const [history, setHistory] = useState<ScanResult[]>([])\r\n  const [busy, setBusy] = useState(false)\r\n  const [cameraOn, setCameraOn] = useState(false)\r\n  const [manualInput, setManualInput] = useState('')\r\n  const videoRef = useRef<HTMLVideoElement | null>(null)\r\n  const streamRef = useRef<MediaStream | null>(null)\r\n  const detectorRef = useRef<any>(null)\r\n  const hidBufferRef = useRef('')\r\n  const hidTimerRef = useRef<any>(null)\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ PDA hardware-scanner KeyEvent listener О“Г¶ГҮО“Г¶ГҮ\r\n  useEffect(() => {\r\n    const onKey = (e: KeyboardEvent) => {\r\n      // ignore when typing in inputs\r\n      const t = e.target as HTMLElement\r\n      if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA')) return\r\n      if (e.key === 'Enter') {\r\n        if (hidBufferRef.current.length >= 3) {\r\n          handleScan(hidBufferRef.current)\r\n        }\r\n        hidBufferRef.current = ''\r\n        return\r\n      }\r\n      if (e.key.length === 1) {\r\n        hidBufferRef.current += e.key\r\n        clearTimeout(hidTimerRef.current)\r\n        hidTimerRef.current = setTimeout(() => { hidBufferRef.current = '' }, 200)\r\n      }\r\n    }\r\n    window.addEventListener('keydown', onKey)\r\n    return () => window.removeEventListener('keydown', onKey)\r\n  }, [])\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ Camera (BarcodeDetector API or fallback msg) О“Г¶ГҮО“Г¶ГҮ\r\n  const startCamera = async () => {\r\n    try {\r\n      const BD: any = (window as any).BarcodeDetector\r\n      if (!BD) {\r\n        toast.error('Trв”ңВјnh duyГҹв•—Г§t khв”ңв”Өng hГҹв•—Г№ trГҹв•—Гә BarcodeDetector. Vui lв”ңв–“ng dв”ңв•Јng PDA hoГҹв•‘в•–c nhГҹв•‘ВЎp tay.')\r\n        return\r\n      }\r\n      detectorRef.current = new BD({ formats: ['qr_code', 'data_matrix', 'code_128'] })\r\n      const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })\r\n      streamRef.current = stream\r\n      if (videoRef.current) {\r\n        videoRef.current.srcObject = stream\r\n        await videoRef.current.play()\r\n      }\r\n      setCameraOn(true)\r\n      tickDetect()\r\n    } catch (e: any) {\r\n      toast.error('Khв”ңв”Өng truy cГҹв•‘ВЎp в”ҖГҰв•һв–‘Гҹв•—Гәc camera: ' + e.message)\r\n    }\r\n  }\r\n\r\n  const stopCamera = () => {\r\n    if (streamRef.current) {\r\n      streamRef.current.getTracks().forEach(t => t.stop())\r\n      streamRef.current = null\r\n    }\r\n    setCameraOn(false)\r\n  }\r\n\r\n  const tickDetect = async () => {\r\n    if (!cameraOn && !streamRef.current) return\r\n    try {\r\n      if (videoRef.current && detectorRef.current) {\r\n        const codes = await detectorRef.current.detect(videoRef.current)\r\n        if (codes && codes.length) {\r\n          const raw = codes[0].rawValue\r\n          if (raw) {\r\n            handleScan(raw)\r\n          }\r\n        }\r\n      }\r\n    } catch {}\r\n    if (streamRef.current) requestAnimationFrame(tickDetect)\r\n  }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ Lookup О“Г¶ГҮО“Г¶ГҮ\r\n  const handleScan = async (raw: string) => {\r\n    if (busy) return\r\n    setBusy(true)\r\n    const parsed = parseQR(raw)\r\n    try {\r\n      if (parsed.type === 'pallet') {\r\n        const res: any = await apiFetch(`/warehouse/pallets/${encodeURIComponent(parsed.code)}`)\r\n        addHistory({ ok: true, type: 'pallet', data: res.data })\r\n      } else if (parsed.type === 'bin') {\r\n        const res: any = await apiFetch(`/warehouse/bins/${encodeURIComponent(parsed.code)}/contents`)\r\n        addHistory({ ok: true, type: 'bin', data: res.data })\r\n      } else {\r\n        addHistory({ ok: false, error: 'QR khв”ңв”Өng nhГҹв•‘ВЎn dГҹв•‘Гӯng: ' + raw })\r\n        toast.error('QR khв”ңв”Өng nhГҹв•‘ВЎn dГҹв•‘Гӯng')\r\n      }\r\n    } catch (e: any) {\r\n      addHistory({ ok: false, error: e.message })\r\n      toast.error(e.message)\r\n    } finally {\r\n      setBusy(false)\r\n    }\r\n  }\r\n\r\n  const addHistory = (r: ScanResult) => {\r\n    setHistory(prev => [r, ...prev].slice(0, 20))\r\n  }\r\n\r\n  return (\r\n    <div className=\"p-4 max-w-3xl mx-auto\">\r\n      <h1 className=\"text-2xl font-bold mb-4\">вүЎЖ’Гҙв•– Quв”ңвҢҗt QR Pallet / Bin</h1>\r\n\r\n      <div className=\"bg-white rounded-lg shadow p-4 mb-4\">\r\n        <div className=\"flex gap-2 mb-3\">\r\n          {!cameraOn ? (\r\n            <button onClick={startCamera} className=\"px-4 py-2 bg-blue-600 text-white rounded\">\r\n              BГҹв•‘ВЎt camera\r\n            </button>\r\n          ) : (\r\n            <button onClick={stopCamera} className=\"px-4 py-2 bg-gray-600 text-white rounded\">\r\n              TГҹв•‘В»t camera\r\n            </button>\r\n          )}\r\n          <span className=\"text-sm text-gray-500 self-center\">\r\n            HoГҹв•‘в•–c dв”ңв•Јng PDA (HID): quв”ңвҢҗt + Enter tГҹв•—в–’ в”ҖГҰГҹв•—Г–ng\r\n          </span>\r\n        </div>\r\n        {cameraOn && (\r\n          <video ref={videoRef} className=\"w-full max-h-80 bg-black rounded\" muted playsInline />\r\n        )}\r\n        <div className=\"mt-3 flex gap-2\">\r\n          <input\r\n            value={manualInput}\r\n            onChange={e => setManualInput(e.target.value)}\r\n            placeholder=\"NhГҹв•‘ВЎp tay LPN hoГҹв•‘в•–c bin_code (Enter)\"\r\n            className=\"flex-1 border rounded px-3 py-2\"\r\n            onKeyDown={e => {\r\n              if (e.key === 'Enter' && manualInput.trim()) {\r\n                handleScan(manualInput.trim())\r\n                setManualInput('')\r\n              }\r\n            }}\r\n          />\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"bg-white rounded-lg shadow p-4\">\r\n        <h2 className=\"font-semibold mb-2\">LГҹв•—ГҜch sГҹв•—ВЎ quв”ңвҢҗt (gГҹв•‘Вәn nhГҹв•‘Г‘t)</h2>\r\n        {history.length === 0 && <p className=\"text-gray-500\">Chв•һв–‘a cв”ңв”Ӯ lв•һв–‘Гҹв•—Гәt quв”ңвҢҗt.</p>}\r\n        <div className=\"space-y-2\">\r\n          {history.map((h, i) => (\r\n            <div key={i} className={'p-3 rounded border ' + (h.ok ? 'border-green-300 bg-green-50' : 'border-red-300 bg-red-50')}>\r\n              {h.ok ? (\r\n                h.type === 'pallet' ? (\r\n                  <div>\r\n                    <div className=\"font-mono font-semibold\">{h.data.lpn_code}</div>\r\n                    <div className=\"text-sm\">\r\n                      {h.data.product_name} в”¬в•– Lв”ңв”Ө {h.data.batch_number} в”¬в•– HSD {h.data.expiry_date}\r\n                    </div>\r\n                    <div className=\"text-xs text-gray-600\">\r\n                      Bin {h.data.current_bin_code || 'О“ГҮГ¶'} в”¬в•– SL {h.data.qty}/{h.data.initial_qty} в”¬в•– {h.data.status}\r\n                    </div>\r\n                  </div>\r\n                ) : (\r\n                  <div>\r\n                    <div className=\"font-mono font-semibold\">Bin {h.data.bin?.bin_code}</div>\r\n                    <div className=\"text-sm\">\r\n                      {h.data.occupied}/{h.data.capacity} pallet в”¬в•– {(h.data.bin?.bin_type)}\r\n                    </div>\r\n                    <div className=\"text-xs text-gray-600\">\r\n                      {(h.data.pallets || []).slice(0, 3).map((p: any) => p.lpn_code).join(', ')}\r\n                    </div>\r\n                  </div>\r\n                )\r\n              ) : (\r\n                <div className=\"text-red-700 text-sm\">{h.error}</div>\r\n              )}\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\workshop\\page.tsx","messages