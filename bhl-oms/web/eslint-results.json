    {items.map((item, idx) => (\r\n        <div key={item.asset_type} className=\"bg-gray-50 rounded-lg p-3\">\r\n          <div className=\"text-sm font-medium text-gray-700\">{assetLabels[item.asset_type] || item.asset_type}</div>\r\n          <div className=\"text-xs text-gray-500 mb-2\">ePOD ghi nhГҹв•‘ВЎn: {item.epod_qty}</div>\r\n          <div className=\"flex items-center gap-3\">\r\n            <span className=\"text-xs text-gray-500\">ThГҹв•—в–’c tГҹв•‘в”җ:</span>\r\n            <button\r\n              className=\"w-14 h-14 bg-gray-200 rounded-lg text-xl font-bold active:bg-gray-300\"\r\n              onClick={() => {\r\n                const next = [...items]\r\n                next[idx] = { ...item, actual_qty: Math.max(0, item.actual_qty - 1) }\r\n                setItems(next)\r\n              }}\r\n            >О“ГӘГҶ</button>\r\n            <span className=\"text-xl font-bold w-12 text-center\">{item.actual_qty}</span>\r\n            <button\r\n              className=\"w-14 h-14 bg-gray-200 rounded-lg text-xl font-bold active:bg-gray-300\"\r\n              onClick={() => {\r\n                const next = [...items]\r\n                next[idx] = { ...item, actual_qty: item.actual_qty + 1 }\r\n                setItems(next)\r\n              }}\r\n            >+</button>\r\n          </div>\r\n          {item.actual_qty !== item.epod_qty && (\r\n            <div className=\"mt-2 text-xs text-red-600 font-medium\">\r\n              О“ГңГЎвҲ©в••Г… Sai lГҹв•—Г§ch: {item.actual_qty - item.epod_qty > 0 ? '+' : ''}{item.actual_qty - item.epod_qty}\r\n            </div>\r\n          )}\r\n        </div>\r\n      ))}\r\n\r\n      {hasDiscrepancy && (\r\n        <div>\r\n          <label className=\"text-sm font-medium text-red-700\">Lв”ңв•ң do sai lГҹв•—Г§ch (*)</label>\r\n          <textarea\r\n            value={discrepancy}\r\n            onChange={e => setDiscrepancy(e.target.value)}\r\n            className=\"w-full mt-1 p-3 border border-red-300 rounde