ed-xl shadow-xl w-full max-w-md p-6\">\r\n            <h2 className=\"text-lg font-bold mb-4\">{modal === 'create' ? 'Thв”ңВ¬m phв•һв–‘в•һГӯng tiГҹв•—Г§n' : 'SГҹв•—ВЎa phв•һв–‘в•һГӯng tiГҹв•—Г§n'}</h2>\r\n            <div className=\"grid grid-cols-2 gap-4\">\r\n              <div className=\"col-span-2\">\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">BiГҹв•—Гўn sГҹв•—ГҰ</label>\r\n                <input value={form.plate_number} onChange={e => setForm({ ...form, plate_number: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">LoГҹв•‘Гӯi xe</label>\r\n                <select value={form.vehicle_type} onChange={e => setForm({ ...form, vehicle_type: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\">\r\n                  {Object.entries(vehicleTypeLabels).map(([val, lbl]) => (\r\n                    <option key={val} value={val}>{lbl}</option>\r\n                  ))}\r\n                </select>\r\n              </div>\r\n              <div>\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">TrГҹв•‘Гӯng thв”ңГӯi</label>\r\n                <select value={form.status} onChange={e => setForm({ ...form, status: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\">\r\n                  {Object.entries(statusLabels).map(([val, lbl]) => (\r\n                    <option key={val} value={val}>{lbl}</option>\r\n                  ))}\r\n                </select>\r\n              </div>\r\n              <div>\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">TГҹв•‘Гәi trГҹв•—Г¬ng (kg)</label>\r\n                <input type=\"number\" value={form.capacity_kg || ''} onChange={e => setForm({ ...form, capacity_kg: parseFloat(e.target.value) || 0 })} className=\"w-full border rounded-lg px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">ThГҹв•—Гў tв”ңВЎch (mв”¬в”Ӯ)</label>\r\n                <input type=\"number\" step=\"0.1\" value={form.capacity_m3 || ''} onChange={e => setForm({ ...form, capacity_m3: e.target.value ? parseFloat(e.target.value) : null })} className=\"w-full border rounded-lg px-3 py-2 text-sm\" />\r\n              </div>\r\n            </div>\r\n            <div className=\"flex justify-end gap-3 mt-6\">\r\n              <button onClick={() => setModal(null)} className=\"px-4 py-2 border rounded-lg text-sm\">HГҹв•—Вәy</button>\r\n              <button onClick={handleSave} disabled={saving} className=\"px-4 py-2 bg-brand-500 text-white rounded-lg text-sm font-medium hover:bg-brand-600 disabled:opacity-50\">\r\n                {saving ? 'в”ҖГүang lв•һв–‘u...' : 'Lв•һв–‘u'}\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\warehouse\\bin-map\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":27,"column":42,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":27,"endColumn":45,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[708,711],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[708,711],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":32,"column":16,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny",