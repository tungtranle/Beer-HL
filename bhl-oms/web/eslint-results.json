ort { apiFetch } from '@/lib/api'\r\nimport { toast } from '@/lib/useToast'\r\n\r\ninterface Driver {\r\n  id: string\r\n  full_name: string\r\n  phone: string\r\n  license_number: string | null\r\n  status: string\r\n  warehouse_id: string\r\n}\r\n\r\nconst statusColors: Record<string, string> = {\r\n  active: 'bg-green-100 text-green-700',\r\n  on_trip: 'bg-blue-100 text-blue-700',\r\n  off_duty: 'bg-gray-100 text-gray-600',\r\n  inactive: 'bg-red-100 text-red-700',\r\n}\r\n\r\nconst statusLabels: Record<string, string> = {\r\n  active: 'SГҹв•‘в•Ўn sв”ңГЎng',\r\n  on_trip: 'в”ҖГүang chГҹв•‘Гӯy',\r\n  off_duty: 'NghГҹв•—Г«',\r\n  inactive: 'Ngв•һв–‘ng',\r\n}\r\n\r\nconst emptyDriver = {\r\n  full_name: '', phone: '', license_number: null as string | null,\r\n  status: 'active', warehouse_id: 'a0000000-0000-0000-0000-000000000001',\r\n}\r\n\r\nexport default function DriversListPage() {\r\n  const [drivers, setDrivers] = useState<Driver[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [search, setSearch] = useState('')\r\n  const [modal, setModal] = useState<'create' | 'edit' | null>(null)\r\n  const [form, setForm] = useState(emptyDriver)\r\n  const [editId, setEditId] = useState<string | null>(null)\r\n  const [saving, setSaving] = useState(false)\r\n\r\n  const load = () => {\r\n    setLoading(true)\r\n    apiFetch<any>('/drivers').then(res => {\r\n      setDrivers(res.data || [])\r\n    }).finally(() => setLoading(false))\r\n  }\r\n\r\n  useEffect(() => { load() }, [])\r\n\r\n  const filtered = drivers.filter(d =>\r\n    d.full_name.toLowerCase().includes(search.toLowerCase()) ||\r\n    d.phone.includes(search)\r\n  )\r\n\r\n  const openCreate = () => {\r\n    setForm(emptyDriver)\r\n    setEditId(null)\r\n    setModal('create')\r\n  }\r\n\r\n  const openEdit = (d: Driver) => {\r\n    setForm({ full_name: d.full_name, phone: d.phone, license_number: d.license_number, status: d.status, warehouse_id: d.warehouse_id })\r\n    setEditId(d.id)\r\n    setModal('edit')\r\n  }\r\n\r\n  const handleSave = async () => {\r\n    setSaving(true)\r\n    try {\r\n      if (modal === 'create') {\r\n        await apiFetch('/drivers', { method: 'POST', body: form })\r\n      } else if (modal === 'edit' && editId) {\r\n        await apiFetch(`/drivers/${editId}`, { method: 'PUT', body: form })\r\n      }\r\n      setModal(null)\r\n      load()\r\n    } catch (e: any) {\r\n      toast.error(e.message)\r\n    } finally {\r\n      setSaving(false)\r\n    }\r\n  }\r\n\r\n  const handleDelete = async (id: string, name: string) => {\r\n    if (!confirm(`Vв”ңв”Ө hiГҹв•—Г§u hв”ңв”Ӯa tв”ңГЎi xГҹв•‘в”җ \"${name}\"?`)) return\r\n    try {\r\n      await apiFetch(`/drivers/${id}`, { method: 'DELETE' })\r\n      load()\r\n    } catch (e: any) {\r\n      toast.error(e.message)\r\n    }\r\n  }\r\n\r\n  if (loading) {\r\n    return <div className=\"flex items-center justify-center h-64 text-gray-400\">в”ҖГүang tГҹв•‘Гәi...</div>\r\n  }\r\n\r\n  const [statusFilter, setStatusFilter] = useState('')\r\n  const activeCount = drivers.filter(d => d.status === 'active').length\r\n  const onTripCount = drivers.filter(d => d.status === 'on_trip').length\r\n\r\n  const filteredDrivers = drivers\r\n    .filter(d => !statusFilter || d.status === statusFilter)\r\n    .filter(d => d.full_name.toLowerCase().includes(search.toLowerCase()) || d.phone.includes(search))\r\n\r\n  return (\r\n    <div>\r\n      <div className=\"flex items-center justify-between mb-4\">\r\n        <div>\r\n          <h1 className=\"text-2xl font-bold text-gray-900\">вүЎЖ’ГҰГұ Danh sв”ңГӯch tв”ңГЎi xГҹв•‘в”җ</h1>\r\n          <p className=\"text-sm text-gray-500 mt-1\">{drivers.length} tв”ңГЎi xГҹв•‘в”җ в”¬в•– {activeCount} sГҹв•‘в•Ўn sв”ңГЎng в”¬в•– {onTripCount} в”ҖГҰang chГҹв•‘Гӯy</p>\r\n        </div>\r\n        <div className=\"flex gap-3\">\r\n          <input\r\n            type=\"text\"\r\n            placeholder=\"Tв”ңВјm theo tв”ңВ¬n, Sв”ҖГүT...\"\r\n            value