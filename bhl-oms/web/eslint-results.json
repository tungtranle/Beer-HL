itle=\"Tв”ңГЎi khoГҹв•‘Гәn\" items={accountItems} />\r\n\r\n      {/* Monthly Performance */}\r\n      <section>\r\n        <h2 className=\"text-[11px] font-bold text-gray-500 uppercase tracking-wider px-3 mb-2\">HiГҹв•—Г§u suГҹв•‘Г‘t thв”ңГӯng nв”ңГЎy</h2>\r\n        {monthlyStats ? (\r\n          <div className=\"bg-white rounded-2xl border border-gray-100 p-4\">\r\n            <div className=\"grid grid-cols-3 gap-3 mb-3\">\r\n              <div className=\"text-center\">\r\n                <div className={`text-2xl font-black tabular-nums ${monthlyStats.score >= 80 ? 'text-green-600' : monthlyStats.score >= 60 ? 'text-amber-600' : 'text-red-600'}`}>{monthlyStats.score.toFixed(0)}</div>\r\n                <div className=\"text-[10px] text-gray-500 mt-0.5\">в”ҖГүiГҹв•—Гўm KPI</div>\r\n              </div>\r\n              <div className=\"text-center border-x border-gray-100\">\r\n                <div className=\"text-2xl font-black text-brand-600 tabular-nums\">{monthlyStats.trips}</div>\r\n                <div className=\"text-[10px] text-gray-500 mt-0.5\">ChuyГҹв•‘в”җn</div>\r\n              </div>\r\n              <div className=\"text-center\">\r\n                <div className=\"text-2xl font-black text-blue-600 tabular-nums\">#{monthlyStats.rank}</div>\r\n                <div className=\"text-[10px] text-gray-500 mt-0.5\">/{monthlyStats.rankTotal} xГҹв•‘в”җp hГҹв•‘Гӯng</div>\r\n              </div>\r\n            </div>\r\n            <div className=\"w-full bg-gray-100 rounded-full h-1.5\">\r\n              <div className={`h-1.5 rounded-full transition-all ${monthlyStats.score >= 80 ? 'bg-green-500' : monthlyStats.score >= 60 ? 'bg-amber-500' : 'bg-red-500'}`} style={{ width: `${monthlyStats.score}%` }} />\r\n            </div>\r\n          </div>\r\n        ) : (\r\n          <div className=\"bg-white rounded-2xl border border-gray-100 px-4 py-3 text-center text-xs text-gray-400\">в”ҖГүang tГҹв•‘Гәi dГҹв•—В» liГҹв•—Г§u hiГҹв•—Г§u suГҹв•‘Г‘t...</div>\r\n 