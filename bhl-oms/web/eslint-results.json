tps://nextjs.org/docs/messages/no-img-element","line":1694,"column":23,"nodeType":"JSXOpeningElement","endLine":1694,"endColumn":143},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":1750,"column":19,"nodeType":"JSXOpeningElement","endLine":1750,"endColumn":139}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":32,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState } from 'react'\r\nimport { useParams, useRouter } from 'next/navigation'\r\nimport Link from 'next/link'\r\nimport { apiFetch, getUser } from '@/lib/api'\r\nimport { toast } from '@/lib/useToast'\r\nimport { useGpsTracker } from '@/lib/useGpsTracker'\r\nimport { useOnlineStatus } from '@/lib/useOnlineStatus'\r\nimport { useDataRefresh } from '@/lib/notifications'\r\nimport { queueOfflineRequest } from '@/lib/useOfflineSync'\r\nimport { safeParseVNDSafe } from '@/lib/safeParseVND'\r\n\r\ninterface Stop {\r\n  id: string\r\n  customer_name: string\r\n  customer_address: string\r\n  customer_phone: string\r\n  customer_id: string\r\n  stop_order: number\r\n  status: string\r\n  order_number: string\r\n  order_amount: number\r\n  order_items: { product_id: string; product_name: string; quantity: number; unit_price: number }[]\r\n  actual_arrival: string | null\r\n  actual_departure: string | null\r\n  estimated_arrival: string | null\r\n  latitude: number | null\r\n  longitude: number | null\r\n}\r\n\r\ninterface EPODData {\r\n  id: string\r\n  delivery_status: string\r\n  delivered_items: { product_id: string; product_name: string; ordered_qty: number; delivered_qty: number; reason: string }[]\r\n  receiver_name: string\r\n  receiver_phone: string\r\n  total_amount: number\r\n  deposit_amount: number\r\n  notes: string | null\r\n  photo_urls: string[] | null\r\n  signature_url: string | null\r\n  reject_reason: string | null\r\n  reject_detail: string | null\r\n  reject_photos: string[] | null\r\n  created_at: string\r\n}\r\n\r\ninterface PaymentData {\r\n  id: string\r\n  payment_method: string\r\n  amount: number\r\n  status: string\r\n  reference_number: string | null\r\n  collected_at: string\r\n}\r\n\r\ninterface ReturnData {\r\n  id: string\r\n  asset_type: string\r\n  quantity: number\r\n  condition: string\r\n  photo_url: string | null\r\n  notes: string | null\r\n}\r\n\r\ntype ModalType = 'epod' | 'payment' | 'returns' | 'checklist' | 'incident' | 'trip_summary' | 'post_checklist' | 'reject' | 'reject_confirm' | null\r\n\r\ninterface Checklist {\r\n  id: string\r\n  tires_ok: boolean\r\n  brakes_ok: boolean\r\n  lights_ok: boolean\r\n  mirrors_ok: boolean\r\n  horn_ok: boolean\r\n  coolant_ok: boolean\r\n  oil_ok: boolean\r\n  fuel_level: number\r\n  fire_extinguisher_ok: boolean\r\n  first_aid_ok: boolean\r\n  documents_ok: boolean\r\n  cargo_secured: boolean\r\n  is_passed: boolean\r\n  notes: string | null\r\n}\r\n\r\ninterface TripDetail {\r\n  id: string\r\n  trip_number: string\r\n  status: string\r\n  planned_date: string\r\n  vehicle_plate: string\r\n  warehouse_name: string\r\n  total_stops: number\r\n  total_weight_kg: number\r\n  total_distance_km: number\r\n  total_duration_min: number\r\n  started_at: string | null\r\n  completed_at: string | null\r\n  stops: Stop[]\r\n  checklist: Checklist | null\r\n}\r\n\r\nconst statusColors: Record<string, string> = {\r\n  planned: 'bg-blue-100 text-blue-700',\r\n  assigned: 'bg-blue-100 text-blue-700',\r\n  pre_check: 'bg-purple-100 text-purple-700',\r\n  ready: 'bg-indigo-100 text-indigo-700',\r\n  in_transit: 'bg-amber-100 text-amber-700',\r\n  completed: 'bg-green-100 text-green-700',\r\n  cancelled: 'bg-red-100 text-red-700',\r\n}\r\n\r\nconst statusLabels: Record<string, string> = {\r\n  planned: 'в”ҖГүв”ңГә lГҹв•‘ВЎp kГҹв•‘в”җ hoГҹв•‘Гӯch', assigned: 'в”ҖГүв”ңГә phв”ңГіn cв”ңв”Өng', pre_check: 'KiГҹв•—Гўm tra xe',\r\n  ready: 'SГҹв•‘в•Ўn sв”ңГЎng', in_transit: 'в”ҖГүang giao hв”ңГЎng', completed: 'Hoв”ңГЎn thв”ңГЎnh',\r\n  cancelled: 'в”ҖГүв”ңГә hГҹв•—Вәy', checked: 'в”ҖГүв”ңГә kiГҹв•—Гўm tra xe', loading: 'в”ҖГүang xГҹв•‘в”җp hв”ңГЎng',\r\n  gate_checked: 'в”ҖГүв”ңГә kiГҹв•—Гўm tra cГҹв•—ГІng', returning: 'в”ҖГүang vГҹв•—Гј kho',\r\n  settling: 'в”ҖГүang в”ҖГҰГҹв•—ГҰi soв”ңГӯt', reconciled: 'в”ҖГүв”ңГә в”ҖГҰГҹв•—ГҰi soв”ңГӯt',\r\n}\r\n\r\nconst stopStatusLabels: Record<string, string> = {\r\n  pending: 'ChГҹв•—ВҘ giao', arrived: 'в”ҖГүв”ңГә в”ҖГҰГҹв•‘в”җn', delivering: 'в”ҖГүang giao',\r\n  delivered: 'в”ҖГүв”ңГә giao', partial: 'Giao mГҹв•—Г–t phГҹв•‘Вәn', partially_delivered: 'Giao mГҹв•—Г–t phГҹв•‘Вәn',\r\n  failed: 'ThГҹв•‘Г‘t bГҹв•‘Гӯi', rejected: 'NPP tГҹв•—ВҪ chГҹв•—ГҰi', skipped: 'BГҹв•—Г… qua', re_delivery: 'Giao lГҹв•‘Гӯi',\r\n}\r\n\r\nconst stopStatusColors: Record<string, string> = {\r\n  pending: 'bg-gray-100 text-gray-700', arrived: 'bg-blue-100 text-blue-700',\r\n  delivering: 'bg-amber-100 text-amber-700', delivered: 'bg-green-100 text-green-700',\r\n  partial: 'bg-yellow-100 text-yellow-700', partially_delivered: 'bg-yellow-100 text-yellow-700',\r\n  failed: 'bg-red-100 text-red-700', rejected: 'bg-red-100 text-red-700',\r\n  skipped: 'bg-gray-100 text-gray-500', re_delivery: 'bg-orange-100 text-orange-700',\r\n}\r\n\r\nconst assetTypeLabels: Record<string, string> = {\r\n  bottle: 'Chai', crate: 'Kв”ңвҢҗt', keg: 'Keg', pallet: 'Pallet',\r\n}\r\n\r\nconst conditionLabels: Record<string, string> = {\r\n  good: 'TГҹв•—ГҰt', damaged: 'Hв•һв–‘ hГҹв•—Г…ng', lost: 'MГҹв•‘Г‘t',\r\n}\r\n\r\nexport default function DriverTripDetailPage() {\r\n  const params = useParams()\r\n  const router = useRouter()\r\n  const tripId = params.id as string\r\n  const [trip, setTrip] = useState<TripDetail | null>(null)\r\n  const [loading, setLoading] = useState(true)\r\n  const [actionLoading, setActionLoading] = useState(false)\r\n  const user = getUser()\r\n\r\n  // Start GPS tracking for driver\r\n  useGpsTracker()\r\n  const isOnline = useOnlineStatus()\r\n\r\n  // Modal state\r\n  const [activeModal, setActiveModal] = useState<ModalType>(null)\r\n  const [selectedStop, setSelectedStop] = useState<Stop | null>(null)\r\n\r\n  // ePOD form state\r\n  const [epodItems, setEpodItems] = useState<{ product_id: string; product_name: string; ordered_qty: number; delivered_qty: number; reason: string }[]>([])\r\n  const [epodReceiverName, setEpodReceiverName] = useState('')\r\n  const [epodReceiverPhone, setEpodReceiverPhone] = useState('')\r\n  const [epodDeliveryStatus, setEpodDeliveryStatus] = useState<'delivered' | 'partial' | 'rejected'>('delivered')\r\n  const [epodNotes, setEpodNotes] = useState('')\r\n  const [existingEpod, setExistingEpod] = useState<EPODData | null>(null)\r\n\r\n  // Payment form state\r\n  const [paymentMethod, setPaymentMethod] = useState<'cash' | 'transfer' | 'credit' | 'partial'>('cash')\r\n  const [paymentAmount, setPaymentAmount] = useState(0)\r\n  const [paymentRef, setPaymentRef] = useState('')\r\n\r\n  // Returns form state\r\n  const [returnItems, setReturnItems] = useState<{ asset_type: string; quantity: number; condition: string; notes: string; photo: string }[]>([])\r\n  const [existingReturns, setExistingReturns] = useState<ReturnData[]>([])\r\n\r\n  // Checklist form state\r\n  const [checklistForm, setChecklistForm] = useState({\r\n    tires_ok: true, brakes_ok: true, lights_ok: true, mirrors_ok: true,\r\n    horn_ok: true, coolant_ok: true, oil_ok: true, fuel_level: 100,\r\n    fire_extinguisher_ok: true, first_aid_ok: true, documents_ok: true, cargo_secured: true,\r\n    notes: '',\r\n  })\r\n\r\n  // Incident form state\r\n  const [incidentType, setIncidentType] = useState<string>('address_wrong')\r\n  const [incidentDesc, setIncidentDesc] = useState('')\r\n  const [incidentPhotos, setIncidentPhotos] = useState<string[]>([])\r\n\r\n  // ePOD photo state (base64 previews)\r\n  const [epodPhotos, setEpodPhotos] = useState<string[]>([])\r\n\r\n  // NPP Rejection form state\r\n  const [rejectReason, setRejectReason] = useState<string>('wrong_product')\r\n  const [rejectDetail, setRejectDetail] = useState('')\r\n  const [rejectPhotos, setRejectPhotos] = useState<string[]>([])\r\n  // Payment/Returns display state for ePOD view\r\n  const [existingPayments, setExistingPayments] = useState<PaymentData[]>([])\r\n\r\n  // Post-trip checklist state (US-TMS-18)\r\n  const [postChecklist, setPostChecklist] = useState({\r\n    vehicle_clean: false, vehicle_no_damage: false, fuel_noted: false,\r\n    cash_ready: false, returns_collected: false, keys_ready: false,\r\n  })\r\n\r\n  // Handover A state\r\n  const [handoverA, setHandoverA] = useState<any>(null)\r\n  const [handoverAction, setHandoverAction] = useState<'confirm' | 'reject' | null>(null)\r\n  const [handoverRejectReason, setHandoverRejectReason] = useState('')\r\n  const [handoverLoading, setHandoverLoading] = useState(false)\r\n\r\n  const loadTrip = async () => {\r\n    try {\r\n      const res: any = await apiFetch(`/trips/${tripId}`)\r\n      setTrip(res.data)\r\n    } catch { /* empty */ } finally {\r\n      setLoading(false)\r\n    }\r\n  }\r\n\r\n  const loadHandoverA = async () => {\r\n    try {\r\n      const res: any = await apiFetch(`/warehouse/handovers/trip/${tripId}`)\r\n      const handovers = (res.data || []).filter((h: any) => h.handover_type === 'A')\r\n      if (handovers.length > 0) setHandoverA(handovers[handovers.length - 1])\r\n    } catch { /* empty */ }\r\n  }\r\n\r\n  const handleHandoverConfirm = async () => {\r\n    if (!handoverA) return\r\n    setHandoverLoading(true)\r\n    try {\r\n      await apiFetch(`/warehouse/handovers/${handoverA.id}/sign`, {\r\n        method: 'POST',\r\n        body: { role: 'driver', action: 'confirm' },\r\n      })\r\n      toast.success('в”ҖГүв”ңГә xв”ңГӯc nhГҹв•‘ВЎn bв”ңГЎn giao')\r\n      await loadHandoverA()\r\n    } catch (err: any) { toast.error('LГҹв•—Г№i: ' + err.message) }\r\n    finally { setHandoverLoading(false) }\r\n  }\r\n\r\n  const handleHandoverReject = async () => {\r\n    if (!handoverA || !handoverRejectReason.trim()) {\r\n      toast.warning('Vui lв”ңв–“ng nhГҹв•‘ВЎp lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi')\r\n      return\r\n    }\r\n    setHandoverLoading(true)\r\n    try {\r\n      await apiFetch(`/warehouse/handovers/${handoverA.id}/sign`, {\r\n        method: 'POST',\r\n        body: { role: 'driver', action: 'reject', reject_reason: handoverRejectReason },\r\n      })\r\n      toast.success('в”ҖГүв”ңГә tГҹв•—ВҪ chГҹв•—ГҰi bв”ңГЎn giao')\r\n      setHandoverAction(null)\r\n      await loadHandoverA()\r\n    } catch (err: any) { toast.error('LГҹв•—Г№i: ' + err.message) }\r\n    finally { setHandoverLoading(false) }\r\n  }\r\n\r\n  useEffect(() => { loadTrip() }, [tripId])\r\n  useEffect(() => { loadHandoverA() }, [tripId])\r\n  useDataRefresh('handover', loadHandoverA)\r\n\r\n  const handleStartTrip = async () => {\r\n    setActionLoading(true)\r\n    try {\r\n      await apiFetch(`/driver/trips/${tripId}/start`, { method: 'PUT' })\r\n      await loadTrip()\r\n    } catch (err: any) { toast.error(err?.message || 'Khв”ңв”Өng bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu в”ҖГҰв•һв–‘Гҹв•—Гәc chuyГҹв•‘в”җn xe') }\r\n    finally { setActionLoading(false) }\r\n  }\r\n\r\n  const handleCompleteTrip = async () => {\r\n    setActionLoading(true)\r\n    try {\r\n      await apiFetch(`/driver/trips/${tripId}/complete`, { method: 'PUT' })\r\n      await loadTrip()\r\n    } catch (err: any) {\r\n      toast.error(err?.message || 'Khв”ңв”Өng thГҹв•—Гў hoв”ңГЎn thв”ңГЎnh chuyГҹв•‘в”җn xe. Vui lв”ңв–“ng thГҹв•—ВЎ lГҹв•‘Гӯi.')\r\n    }\r\n    finally { setActionLoading(false) }\r\n  }\r\n\r\n  const handleUpdateStop = async (stopId: string, action: string) => {\r\n    setActionLoading(true)\r\n    const url = `/driver/trips/${tripId}/stops/${stopId}/update`\r\n    const body = { action }\r\n    if (!isOnline) {\r\n      await queueOfflineRequest(url, 'PUT', JSON.stringify(body))\r\n      toast.warning('в”ҖГүang offline О“ГҮГ¶ в”ҖГҰв”ңГә lв•һв–‘u, sГҹв•‘в•ң tГҹв•—в–’ в”ҖГҰГҹв•—Гҙng bГҹв•—Г– khi cв”ңв”Ӯ mГҹв•‘Гӯng')\r\n      setActionLoading(false)\r\n      return\r\n    }\r\n    try {\r\n      await apiFetch(url, { method: 'PUT', body })\r\n      await loadTrip()\r\n    } catch (err: any) { toast.error(err?.message || 'Khв”ңв”Өng cГҹв•‘ВЎp nhГҹв•‘ВЎt в”ҖГҰв•һв–‘Гҹв•—Гәc в”ҖГҰiГҹв•—Гўm dГҹв•—ВҪng') }\r\n    finally { setActionLoading(false) }\r\n  }\r\n\r\n  // --- Checklist ---\r\n  const openChecklistModal = () => {\r\n    setChecklistForm({\r\n      tires_ok: true, brakes_ok: true, lights_ok: true, mirrors_ok: true,\r\n      horn_ok: true, coolant_ok: true, oil_ok: true, fuel_level: 100,\r\n      fire_extinguisher_ok: true, first_aid_ok: true, documents_ok: true, cargo_secured: true,\r\n      notes: '',\r\n    })\r\n    setActiveModal('checklist')\r\n  }\r\n\r\n  const handleSubmitChecklist = async () => {\r\n    setActionLoading(true)\r\n    try {\r\n      await apiFetch(`/driver/trips/${tripId}/checklist`, {\r\n        method: 'POST',\r\n        body: { ...checklistForm, notes: checklistForm.notes || undefined },\r\n      })\r\n      setActiveModal(null)\r\n      await loadTrip()\r\n    } catch (err: any) { toast.error(err?.message || 'Khв”ңв”Өng gГҹв•—ВЎi в”ҖГҰв•һв–‘Гҹв•—Гәc checklist') }\r\n    finally { setActionLoading(false) }\r\n  }\r\n\r\n  // --- Multi-stop navigation ---\r\n  const buildNavUrl = (currentStop: Stop): string => {\r\n    if (!trip) return '#'\r\n    const sorted = [...trip.stops].sort((a, b) => a.stop_order - b.stop_order)\r\n    const remaining = sorted.filter(\r\n      s => s.stop_order >= currentStop.stop_order && (s.status === 'pending' || s.status === 'arrived')\r\n    ).filter(s => s.latitude && s.longitude)\r\n    if (remaining.length === 0) {\r\n      return currentStop.latitude && currentStop.longitude\r\n        ? `https://www.google.com/maps/dir/?api=1&destination=${currentStop.latitude},${currentStop.longitude}`\r\n        : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(currentStop.customer_address)}`\r\n    }\r\n    const dest = remaining[remaining.length - 1]\r\n    const waypoints = remaining.slice(0, -1)\r\n    let url = `https://www.google.com/maps/dir/?api=1&destination=${dest.latitude},${dest.longitude}`\r\n    if (waypoints.length > 0) {\r\n      url += `&waypoints=${waypoints.map(s => `${s.latitude},${s.longitude}`).join('|')}`\r\n    }\r\n    return url\r\n  }\r\n\r\n  // --- Incident ---\r\n  const openIncidentModal = (stop: Stop) => {\r\n    setSelectedStop(stop)\r\n    setIncidentType('address_wrong')\r\n    setIncidentDesc('')\r\n    setActiveModal('incident')\r\n  }\r\n\r\n  const handleSubmitIncident = async () => {\r\n    if (!selectedStop) return\r\n    setActionLoading(true)\r\n    try {\r\n      await apiFetch(`/driver/trips/${tripId}/stops/${selectedStop.id}/update`, {\r\n        method: 'PUT',\r\n        body: { action: 'fail', notes: `[${incidentType}] ${incidentDesc}` },\r\n      })\r\n      setActiveModal(null)\r\n      await loadTrip()\r\n    } catch (err: any) { toast.error(err?.message || 'Khв”ңв”Өng bв”ңГӯo cв”ңГӯo в”ҖГҰв•һв–‘Гҹв•—Гәc sГҹв•—в–’ cГҹв•—ГҰ') }\r\n    finally { setActionLoading(false) }\r\n  }\r\n\r\n  // --- Trip Summary ---\r\n  const openTripSummary = () => {\r\n    setActiveModal('trip_summary')\r\n  }\r\n\r\n  // --- ePOD ---\r\n  const openEpodModal = async (stop: Stop) => {\r\n    setSelectedStop(stop)\r\n    // Pre-fill items from order\r\n    if (stop.order_items?.length) {\r\n      setEpodItems(stop.order_items.map(item => ({\r\n        product_id: item.product_id || '',\r\n        product_name: item.product_name,\r\n        ordered_qty: item.quantity,\r\n        delivered_qty: item.quantity,\r\n        reason: '',\r\n      })))\r\n    }\r\n    setEpodReceiverName('')\r\n    setEpodReceiverPhone('')\r\n    setEpodDeliveryStatus('delivered')\r\n    setEpodNotes('')\r\n    setExistingEpod(null)\r\n    setEpodPhotos([])\r\n\r\n    // Check for existing ePOD\r\n    try {\r\n      const res: any = await apiFetch(`/driver/trips/${tripId}/stops/${stop.id}/epod`)\r\n      if (res.data) setExistingEpod(res.data)\r\n    } catch { /* no existing epod */ }\r\n\r\n    // Fetch existing payments for this stop\r\n    try {\r\n      const res: any = await apiFetch(`/driver/trips/${tripId}/stops/${stop.id}/payments`)\r\n      if (res.data?.length) setExistingPayments(res.data)\r\n      else setExistingPayments([])\r\n    } catch { setExistingPayments([]) }\r\n\r\n    // Fetch returns for ePOD view\r\n    try {\r\n      const res: any = await apiFetch(`/driver/trips/${tripId}/stops/${stop.id}/returns`)\r\n      if (res.data?.length) setExistingReturns(res.data)\r\n      else setExistingReturns([])\r\n    } catch { setExistingReturns([]) }\r\n\r\n    setActiveModal('epod')\r\n  }\r\n\r\n  const handleSubmitEpod = async () => {\r\n    if (!selectedStop) return\r\n    setActionLoading(true)\r\n    const url = `/driver/trips/${tripId}/stops/${selectedStop.id}/epod`\r\n    const body = {\r\n      delivery_status: epodDeliveryStatus,\r\n      delivered_items: epodItems,\r\n      receiver_name: epodReceiverName,\r\n      receiver_phone: epodReceiverPhone,\r\n      photo_urls: epodPhotos,\r\n      notes: epodNotes || undefined,\r\n    }\r\n    if (!isOnline) {\r\n      await queueOfflineRequest(url, 'POST', JSON.stringify(body))\r\n      toast.warning('в”ҖГүang offline О“ГҮГ¶ в”ҖГҰв”ңГә lв•һв–‘u ePOD, sГҹв•‘в•ң в”ҖГҰГҹв•—Гҙng bГҹв•—Г– khi cв”ңв”Ӯ mГҹв•‘Гӯng')\r\n      setActiveModal(null)\r\n      setActionLoading(false)\r\n      return\r\n    }\r\n    try {\r\n      await apiFetch(url, { method: 'POST', body })\r\n      setActiveModal(null)\r\n      await loadTrip()\r\n    } catch (err: any) { toast.error(err?.message || 'Khв”ңв”Өng lв•һв–‘u в”ҖГҰв•һв–‘Гҹв•—Гәc ePOD') }\r\n    finally { setActionLoading(false) }\r\n  }\r\n\r\n  // --- Payment ---\r\n  const openPaymentModal = async (stop: Stop) => {\r\n    setSelectedStop(stop)\r\n    setPaymentMethod('cash')\r\n    setPaymentAmount(stop.order_amount || 0)\r\n    setPaymentRef('')\r\n    setActiveModal('payment')\r\n  }\r\n\r\n  const handleSubmitPayment = async () => {\r\n    if (!selectedStop) return\r\n    setActionLoading(true)\r\n    const url = `/driver/trips/${tripId}/stops/${selectedStop.id}/payment`\r\n    const body = {\r\n      payment_method: paymentMethod,\r\n      amount: paymentAmount,\r\n      reference_number: paymentRef || undefined,\r\n    }\r\n    if (!isOnline) {\r\n      await queueOfflineRequest(url, 'POST', JSON.stringify(body))\r\n      toast.warning('в”ҖГүang offline О“ГҮГ¶ в”ҖГҰв”ңГә lв•һв–‘u thanh toв”ңГӯn, sГҹв•‘в•ң в”ҖГҰГҹв•—Гҙng bГҹв•—Г– khi cв”ңв”Ӯ mГҹв•‘Гӯng')\r\n      setActiveModal(null)\r\n      setActionLoading(false)\r\n      return\r\n    }\r\n    try {\r\n      await apiFetch(url, { method: 'POST', body })\r\n      setActiveModal(null)\r\n      await loadTrip()\r\n    } catch (err: any) { toast.error(err?.message || 'Khв”ңв”Өng ghi nhГҹв•‘ВЎn в”ҖГҰв•һв–‘Гҹв•—Гәc thanh toв”ңГӯn') }\r\n    finally { setActionLoading(false) }\r\n  }\r\n\r\n  // --- Returns ---\r\n  const openReturnsModal = async (stop: Stop) => {\r\n    setSelectedStop(stop)\r\n    setReturnItems([{ asset_type: 'crate', quantity: 0, condition: 'good', notes: '', photo: '' }])\r\n    setExistingReturns([])\r\n\r\n    try {\r\n      const res: any = await apiFetch(`/driver/trips/${tripId}/stops/${stop.id}/returns`)\r\n      if (res.data?.length) setExistingReturns(res.data)\r\n    } catch { /* no existing returns */ }\r\n\r\n    setActiveModal('returns')\r\n  }\r\n\r\n  const handleSubmitReturns = async () => {\r\n    if (!selectedStop) return\r\n    const validItems = returnItems.filter(i => i.quantity > 0)\r\n    if (!validItems.length) return\r\n    // Block if damaged/lost items have no photo\r\n    const missingPhoto = validItems.some(i => (i.condition === 'damaged' || i.condition === 'lost') && !i.photo)\r\n    if (missingPhoto) { toast.warning('Vui lв”ңв–“ng chГҹв•—Г‘p Гҹв•‘Гәnh cho cв”ңГӯc mГҹв•—Г‘c hв•һв–‘ hГҹв•—Г…ng/mГҹв•‘Г‘t'); return }\r\n    setActionLoading(true)\r\n    try {\r\n      await apiFetch(`/driver/trips/${tripId}/stops/${selectedStop.id}/returns`, {\r\n        method: 'POST',\r\n        body: { items: validItems.map(i => ({ ...i, photo_url: i.photo || undefined })) },\r\n      })\r\n      setActiveModal(null)\r\n      await loadTrip()\r\n    } catch (err: any) { toast.error(err?.message || 'Khв”ңв”Өng lв•һв–‘u в”ҖГҰв•һв–‘Гҹв•—Гәc vГҹв•—Г… chai/kв”ңвҢҗt trГҹв•‘Гә vГҹв•—Гј') }\r\n    finally { setActionLoading(false) }\r\n  }\r\n\r\n  const addReturnItem = () => {\r\n    setReturnItems([...returnItems, { asset_type: 'crate', quantity: 0, condition: 'good', notes: '', photo: '' }])\r\n  }\r\n\r\n  const removeReturnItem = (idx: number) => {\r\n    setReturnItems(returnItems.filter((_, i) => i !== idx))\r\n  }\r\n\r\n  // --- NPP Rejection ---\r\n  const rejectReasonLabels: Record<string, string> = {\r\n    wrong_product: 'Sai sГҹв•‘Гәn phГҹв•‘вҢҗm',\r\n    quality_issue: 'Hв”ңГЎng lГҹв•—Г№i/hГҹв•‘в”җt hГҹв•‘Гӯn',\r\n    wrong_quantity: 'Sai sГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng',\r\n    not_ordered: 'Khв”ңв”Өng в”ҖГҰГҹв•‘в•–t hв”ңГЎng',\r\n    closed: 'NPP в”ҖГҰв”ңв”Ӯng cГҹв•—ВЎa/khв”ңв”Өng cв”ңв”Ӯ ngв•һв–‘Гҹв•—ВҘi nhГҹв•‘ВЎn',\r\n    other: 'Khв”ңГӯc',\r\n  }\r\n\r\n  const openRejectModal = (stop: Stop) => {\r\n    setSelectedStop(stop)\r\n    setRejectReason('wrong_product')\r\n    setRejectDetail('')\r\n    setRejectPhotos([])\r\n    setActiveModal('reject')\r\n  }\r\n\r\n  const handleConfirmReject = async () => {\r\n    if (!selectedStop) return\r\n    if (rejectReason === 'other' && !rejectDetail.trim()) return\r\n    if (rejectPhotos.length === 0) return\r\n    setActionLoading(true)\r\n    try {\r\n      await apiFetch(`/driver/trips/${tripId}/stops/${selectedStop.id}/epod`, {\r\n        method: 'POST',\r\n        body: {\r\n          delivery_status: 'rejected',\r\n          delivered_items: selectedStop.order_items?.map(item => ({\r\n            product_id: item.product_id,\r\n            product_name: item.product_name,\r\n            ordered_qty: item.quantity,\r\n            delivered_qty: 0,\r\n            reason: rejectReasonLabels[rejectReason] || rejectReason,\r\n          })) || [],\r\n          reject_reason: rejectReason,\r\n          reject_detail: rejectDetail || undefined,\r\n          reject_photos: rejectPhotos,\r\n          photo_urls: rejectPhotos,\r\n          notes: `NPP tГҹв•—ВҪ chГҹв•—ГҰi: ${rejectReasonLabels[rejectReason]}${rejectDetail ? ' О“ГҮГ¶ ' + rejectDetail : ''}`,\r\n        },\r\n      })\r\n      setActiveModal(null)\r\n      await loadTrip()\r\n    } catch (err: any) { toast.error(err?.message || 'Khв”ңв”Өng ghi nhГҹв•‘ВЎn в”ҖГҰв•һв–‘Гҹв•—Гәc tГҹв•—ВҪ chГҹв•—ГҰi') }\r\n    finally { setActionLoading(false) }\r\n  }\r\n\r\n  if (loading) {\r\n    return <div className=\"flex justify-center items-center min-h-screen\"><div className=\"animate-spin rounded-full h-12 w-12 border-b-2 border-brand-500\"></div></div>\r\n  }\r\n\r\n  if (!trip) {\r\n    return <div className=\"p-6 text-center text-red-500\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y chuyГҹв•‘в”җn xe</div>\r\n  }\r\n\r\n  return (\r\n    <div className=\"max-w-2xl mx-auto p-4 space-y-4\">\r\n      {/* Offline Banner */}\r\n      {!isOnline && (\r\n        <div className=\"bg-red-500 text-white text-center text-sm py-2 rounded-lg sticky top-0 z-50\">\r\n          вүЎЖ’ГҙГӯ BГҹв•‘Гӯn в”ҖГҰang offline О“ГҮГ¶ dГҹв•—В» liГҹв•—Г§u sГҹв•‘в•ң tГҹв•—в–’ в”ҖГҰГҹв•—Гҙng bГҹв•—Г– khi cв”ңв”Ӯ mГҹв•‘Гӯng\r\n        </div>\r\n      )}\r\n\r\n      {/* Header */}\r\n      <div className=\"flex items-center gap-3\">\r\n        <Link href=\"/dashboard/driver\" className=\"text-2xl\">О“ГҘГү</Link>\r\n        <div className=\"flex-1\">\r\n          <h1 className=\"text-xl font-bold\">{trip.trip_number}</h1>\r\n          <p className=\"text-sm text-gray-500\">{trip.vehicle_plate} в”¬в•– {trip.planned_date}</p>\r\n        </div>\r\n        <span className={`px-3 py-1 rounded-full text-sm font-medium ${statusColors[trip.status] || 'bg-gray-100'}`}>\r\n          {statusLabels[trip.status] || trip.status}\r\n        </span>\r\n      </div>\r\n\r\n      {/* О“Г¶ГҮО“Г¶ГҮ Wizard Step Indicator О“Г¶ГҮО“Г¶ГҮ */}\r\n      {(() => {\r\n        const tripStep =\r\n          ['planned','assigned','pre_check'].includes(trip.status) ? 1 :\r\n          ['ready','gate_checked','loading'].includes(trip.status) ? 2 :\r\n          trip.status === 'in_transit' ? 3 :\r\n          ['returning','settling','reconciled','completed'].includes(trip.status) ? 4 : 1\r\n\r\n        const steps = [\r\n          { n: 1, label: 'KiГҹв•—Гўm tra xe', icon: 'вүЎЖ’Г¶Вә' },\r\n          { n: 2, label: 'XuГҹв•‘Г‘t kho', icon: 'вүЎЖ’ГҙВӘ' },\r\n          { n: 3, label: 'Giao hв”ңГЎng', icon: 'вүЎЖ’ГңВў' },\r\n          { n: 4, label: 'KГҹв•‘в”җt ca', icon: 'О“ВЈГ ' },\r\n        ]\r\n        return (\r\n          <div className=\"bg-white rounded-xl shadow-sm px-4 py-3\">\r\n            <div className=\"flex items-center\">\r\n              {steps.map(({ n, label, icon }, idx) => (\r\n                <div key={n} className=\"flex items-center flex-1 last:flex-none\">\r\n                  <div className=\"flex flex-col items-center\">\r\n                    <div className={`w-9 h-9 rounded-full flex items-center justify-center text-base border-2 transition ${n < tripStep ? 'bg-brand-500 border-brand-500 text-white' : n === tripStep ? 'border-brand-500 bg-brand-50 text-brand-600' : 'border-gray-200 bg-gray-50 text-gray-400'}`}>\r\n                      {n < tripStep ? 'О“ВЈГҙ' : icon}\r\n                    </div>\r\n                    <div className={`text-[10px] mt-1 font-medium ${n === tripStep ? 'text-brand-600' : n < tripStep ? 'text-brand-400' : 'text-gray-400'}`}>\r\n                      {label}\r\n                    </div>\r\n                  </div>\r\n                  {idx < 3 && (\r\n                    <div className={`flex-1 h-0.5 mx-1 mb-4 ${n < tripStep ? 'bg-brand-500' : 'bg-gray-200'}`} />\r\n                  )}\r\n                </div>\r\n              ))}\r\n            </div>\r\n          </div>\r\n        )\r\n      })()}\r\n\r\n      {/* Trip Summary */}\r\n      <div className=\"grid grid-cols-4 gap-2 text-center\">\r\n        <div className=\"bg-white rounded-lg p-3 shadow-sm\">\r\n          <div className=\"text-lg font-bold text-brand-500\">{trip.total_stops}</div>\r\n          <div className=\"text-xs text-gray-500\">в”ҖГүiГҹв•—Гўm giao</div>\r\n        </div>\r\n        <div className=\"bg-white rounded-lg p-3 shadow-sm\">\r\n          <div className=\"text-lg font-bold text-orange-600\">{trip.total_distance_km?.toFixed(1)}</div>\r\n          <div className=\"text-xs text-gray-500\">km</div>\r\n        </div>\r\n        <div className=\"bg-white rounded-lg p-3 shadow-sm\">\r\n          <div className=\"text-lg font-bold text-purple-600\">{trip.total_weight_kg?.toFixed(0)}</div>\r\n          <div className=\"text-xs text-gray-500\">kg</div>\r\n        </div>\r\n        <div className=\"bg-white rounded-lg p-3 shadow-sm\">\r\n          <div className=\"text-lg font-bold text-green-600\">{trip.total_duration_min}</div>\r\n          <div className=\"text-xs text-gray-500\">phв”ңв•‘t</div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Action Buttons */}\r\n      {/* Pre-trip checklist - required before starting */}\r\n      {(trip.status === 'planned' || trip.status === 'assigned' || trip.status === 'ready') && !trip.checklist && (\r\n        <div className=\"space-y-2\">\r\n          <button onClick={openChecklistModal} disabled={actionLoading}\r\n            className=\"w-full bg-purple-600 text-white py-3 rounded-lg font-medium hover:bg-purple-700 disabled:opacity-50\">\r\n            вүЎЖ’ГҙГҜ KiГҹв•—Гўm tra xe trв•һв–‘Гҹв•—Вўc khi xuГҹв•‘Г‘t phв”ңГӯt\r\n          </button>\r\n          <p className=\"text-xs text-center text-gray-500\">BГҹв•‘В»t buГҹв•—Г–c kiГҹв•—Гўm tra xe trв•һв–‘Гҹв•—Вўc khi bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu chuyГҹв•‘в”җn</p>\r\n        </div>\r\n      )}\r\n\r\n      {/* Handover A section for driver */}\r\n      {(trip.status === 'planned' || trip.status === 'assigned' || trip.status === 'ready') && trip.checklist?.is_passed && handoverA && (() => {\r\n        const driverSig = (handoverA.signatories || []).find((s: any) => s.role === 'driver')\r\n        const driverDone = driverSig?.action === 'confirm' || driverSig?.action === 'reject'\r\n        if (driverDone) return null\r\n        return (\r\n          <div className=\"bg-blue-50 border-2 border-blue-200 rounded-xl p-4 space-y-3\">\r\n            <div className=\"flex items-center gap-2\">\r\n              <span className=\"text-xl\">вүЎЖ’ГҙГҜ</span>\r\n              <h3 className=\"font-bold text-blue-800\">Bв”ңГЎn giao A О“ГҮГ¶ Xв”ңГӯc nhГҹв•‘ВЎn xuГҹв•‘Г‘t kho</h3>\r\n            </div>\r\n            <p className=\"text-sm text-blue-600\">ThГҹв•—Вә kho в”ҖГҰв”ңГә tГҹв•‘Гӯo biв”ңВ¬n bГҹв•‘Гәn bв”ңГЎn giao. Vui lв”ңв–“ng kiГҹв•—Гўm tra hв”ңГЎng hв”ңв”Ӯa vв”ңГЎ xв”ңГӯc nhГҹв•‘ВЎn.</p>\r\n            {handoverA.photo_urls?.length > 0 && (\r\n              <div className=\"flex gap-2 flex-wrap\">\r\n                {handoverA.photo_urls.map((url: string, i: number) => (\r\n                  <img key={i} src={url} alt={`PhiГҹв•‘в”җu ${i+1}`}\r\n                    className=\"w-16 h-16 object-cover rounded-lg border cursor-pointer\"\r\n                    onClick={() => window.open(url, '_blank')} />\r\n                ))}\r\n              </div>\r\n            )}\r\n            {handoverA.notes && <p className=\"text-sm text-gray-600\">Ghi chв”ңв•‘: {handoverA.notes}</p>}\r\n            {handoverAction !== 'reject' ? (\r\n              <div className=\"flex gap-2\">\r\n                <button onClick={handleHandoverConfirm} disabled={handoverLoading}\r\n                  className=\"flex-1 h-12 bg-green-600 text-white rounded-lg font-bold hover:bg-green-700 disabled:opacity-50\">\r\n                  {handoverLoading ? 'в”ҖГүang xГҹв•—ВЎ lв”ңв•ң...' : 'О“ВЈГ  Xв”ңГӯc nhГҹв•‘ВЎn bв”ңГЎn giao'}\r\n                </button>\r\n                <button onClick={() => setHandoverAction('reject')}\r\n                  className=\"px-4 h-12 bg-red-100 text-red-700 rounded-lg font-medium hover:bg-red-200\">\r\n                  О“ВҘГ® TГҹв•—ВҪ chГҹв•—ГҰi\r\n                </button>\r\n              </div>\r\n            ) : (\r\n              <div className=\"space-y-2\">\r\n                <textarea value={handoverRejectReason} onChange={e => setHandoverRejectReason(e.target.value)}\r\n                  placeholder=\"NhГҹв•‘ВЎp lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi...\" className=\"w-full border border-red-300 rounded-lg px-3 py-2 text-sm bg-red-50\" rows={2} />\r\n                <div className=\"flex gap-2\">\r\n                  <button onClick={handleHandoverReject} disabled={handoverLoading || !handoverRejectReason.trim()}\r\n                    className=\"flex-1 h-12 bg-red-600 text-white rounded-lg font-bold hover:bg-red-700 disabled:opacity-50\">\r\n                    {handoverLoading ? 'в”ҖГүang xГҹв•—ВЎ lв”ңв•ң...' : 'О“ВҘГ® Xв”ңГӯc nhГҹв•‘ВЎn tГҹв•—ВҪ chГҹв•—ГҰi'}\r\n                  </button>\r\n                  <button onClick={() => setHandoverAction(null)}\r\n                    className=\"px-4 h-12 border rounded-lg text-gray-600 hover:bg-gray-50\">HГҹв•—Вәy</button>\r\n                </div>\r\n              </div>\r\n            )}\r\n          </div>\r\n        )\r\n      })()}\r\n\r\n      {(trip.status === 'planned' || trip.status === 'assigned' || trip.status === 'ready') && trip.checklist?.is_passed && (\r\n        <button onClick={handleStartTrip} disabled={actionLoading}\r\n          className=\"w-full bg-green-600 text-white py-3 rounded-lg font-medium hover:bg-green-700 disabled:opacity-50\">\r\n          {actionLoading ? 'в”ҖГүang xГҹв•—ВЎ lв”ңв•ң...' : 'вүЎЖ’ГңГҮ BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu chuyГҹв•‘в”җn xe'}\r\n        </button>\r\n      )}\r\n\r\n      {(trip.status === 'planned' || trip.status === 'assigned' || trip.status === 'ready') && trip.checklist && !trip.checklist.is_passed && (\r\n        <div className=\"bg-red-50 border border-red-200 rounded-lg p-3 text-center\">\r\n          <p className=\"text-red-700 font-medium\">О“ГңГЎвҲ©в••Г… Xe khв”ңв”Өng в”ҖГҰГҹв•‘Гӯt kiГҹв•—Гўm tra</p>\r\n          <p className=\"text-red-600 text-sm\">Vui lв”ңв–“ng bв”ңГӯo trв•һв–‘Гҹв•—Ж’ng nhв”ңв”Ӯm в”ҖГҰГҹв•—Гў в”ҖГҰГҹв•—ГІi xe</p>\r\n        </div>\r\n      )}\r\n\r\n      {trip.status === 'in_transit' && trip.stops?.every(s => s.status === 'delivered' || s.status === 'failed' || s.status === 'skipped' || s.status === 'partially_delivered') && (\r\n        <div className=\"space-y-2\">\r\n          <Link href={`/dashboard/driver/${tripId}/eod`}\r\n            className=\"w-full block text-center bg-brand-500 text-white py-3 rounded-lg font-medium hover:bg-brand-600\">\r\n            О“ВЈГ  KГҹв•‘в”җt ca (3 trГҹв•‘Гӯm xв”ңГӯc nhГҹв•‘ВЎn)\r\n          </Link>\r\n        </div>\r\n      )}\r\n\r\n      {/* Stops List */}\r\n      <div>\r\n        <h2 className=\"text-lg font-semibold mb-2\">Danh sв”ңГӯch в”ҖГҰiГҹв•—Гўm giao ({trip.stops?.length || 0})</h2>\r\n        <div className=\"space-y-3\">\r\n          {trip.stops?.sort((a, b) => a.stop_order - b.stop_order).map((stop) => (\r\n            <div key={stop.id} className=\"bg-white rounded-lg shadow-sm p-4\">\r\n              <div className=\"flex items-start justify-between\">\r\n                <div className=\"flex-1\">\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <span className=\"w-7 h-7 rounded-full bg-brand-500 text-white text-xs flex items-center justify-center font-bold\">\r\n                      {stop.stop_order}\r\n                    </span>\r\n                    <span className=\"font-medium\">{stop.customer_name}</span>\r\n                  </div>\r\n                  <p className=\"text-sm text-gray-500 mt-1 ml-8\">вүЎЖ’ГҙГ¬ {stop.customer_address}</p>\r\n                  {stop.customer_phone && (\r\n                    <p className=\"text-sm text-gray-500 mt-0.5 ml-8\">\r\n                      <a href={`tel:${stop.customer_phone}`} className=\"text-blue-600 hover:underline\">вүЎЖ’ГҙвӮ§ {stop.customer_phone}</a>\r\n                    </p>\r\n                  )}\r\n                  {stop.estimated_arrival && (\r\n                    <p className=\"text-sm text-gray-400 mt-0.5 ml-8\">\r\n                      вүЎЖ’ГІГү DГҹв•—в–’ kiГҹв•‘в”җn: {new Date(stop.estimated_arrival).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' })}\r\n                    </p>\r\n                  )}\r\n                  {stop.order_number && (\r\n                    <p className=\"text-sm text-gray-400 mt-0.5 ml-8\">\r\n                      в”ҖГүв•һГӯn: {stop.order_number} в”¬в•– {stop.order_amount?.toLocaleString('vi-VN')}в”ҖГҰ\r\n                    </p>\r\n                  )}\r\n                </div>\r\n                <span className={`px-2 py-0.5 rounded text-xs font-medium ${stopStatusColors[stop.status] || 'bg-gray-100'}`}>\r\n                  {stopStatusLabels[stop.status] || stop.status}\r\n                </span>\r\n              </div>\r\n\r\n              {/* Order Items */}\r\n              {stop.order_items && stop.order_items.length > 0 && (\r\n                <div className=\"mt-2 ml-8 text-sm text-gray-600\">\r\n                  {stop.order_items.map((item, idx) => (\r\n                    <div key={idx} className=\"flex justify-between\">\r\n                      <span>{item.product_name}</span>\r\n                      <span>в”ңГ№{item.quantity}</span>\r\n                    </div>\r\n                  ))}\r\n                </div>\r\n              )}\r\n\r\n              {/* Stop Actions */}\r\n              {/* Navigation button О“ГҮГ¶ multi-stop chain with remaining waypoints */}\r\n              {trip.status === 'in_transit' && (stop.status === 'pending' || stop.status === 'arrived') && (\r\n                <div className=\"mt-2 ml-8\">\r\n                  <a href={buildNavUrl(stop)}\r\n                    target=\"_blank\" rel=\"noopener noreferrer\"\r\n                    className=\"inline-flex items-center gap-1 px-4 h-12 bg-emerald-50 text-emerald-700 text-sm rounded-lg hover:bg-emerald-100 transition font-medium\">\r\n                    вүЎЖ’Г№в•‘вҲ©в••Г… ChГҹв•—Г« в”ҖГҰв•һв–‘Гҹв•—ВҘng ({(() => {\r\n                      const sorted = [...trip.stops].sort((a, b) => a.stop_order - b.stop_order)\r\n                      const rem = sorted.filter(s => s.stop_order >= stop.stop_order && (s.status === 'pending' || s.status === 'arrived')).length\r\n                      return `${rem} в”ҖГҰiГҹв•—Гўm cв”ңв–“n lГҹв•‘Гӯi`\r\n                    })()})\r\n                  </a>\r\n                </div>\r\n              )}\r\n\r\n              {trip.status === 'in_transit' && stop.status === 'pending' && (\r\n                <div className=\"mt-2 ml-8 flex gap-2\">\r\n                  <button onClick={() => handleUpdateStop(stop.id, 'arrive')} disabled={actionLoading}\r\n                    className=\"px-4 h-12 bg-brand-500 text-white text-sm rounded-lg hover:bg-brand-600 disabled:opacity-50 font-medium\">\r\n                    вүЎЖ’ГҙГ¬ в”ҖГүв”ңГә в”ҖГҰГҹв•‘в”җn nв•һГӯi\r\n                  </button>\r\n                </div>\r\n              )}\r\n              {trip.status === 'in_transit' && stop.status === 'arrived' && (\r\n                <div className=\"mt-2 ml-8 flex flex-wrap gap-2\">\r\n                  <button onClick={() => handleUpdateStop(stop.id, 'delivering')} disabled={actionLoading}\r\n                    className=\"px-4 h-12 bg-brand-500 text-white text-sm rounded-lg hover:bg-brand-600 disabled:opacity-50 font-medium\">\r\n                    вүЎЖ’ГҙВӘ BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu hГҹв•‘Гӯ hв”ңГЎng\r\n                  </button>\r\n                  <button onClick={() => openIncidentModal(stop)} disabled={actionLoading}\r\n                    className=\"px-4 h-12 bg-orange-100 text-orange-700 text-sm rounded-lg hover:bg-orange-200 disabled:opacity-50 font-medium\">\r\n                    О“ГңГЎвҲ©в••Г… Bв”ңГӯo sГҹв•—в–’ cГҹв•—ГҰ\r\n                  </button>\r\n                </div>\r\n              )}\r\n              {trip.status === 'in_transit' && stop.status === 'delivering' && (\r\n                <div className=\"mt-2 ml-8 flex flex-wrap gap-2\">\r\n                  <button onClick={() => openEpodModal(stop)} disabled={actionLoading}\r\n                    className=\"px-4 h-14 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700 disabled:opacity-50 font-medium\">\r\n                    вүЎЖ’ГҙВҘ Xв”ңГӯc nhГҹв•‘ВЎn giao hв”ңГЎng (ePOD)\r\n                  </button>\r\n                  <button onClick={() => openRejectModal(stop)} disabled={actionLoading}\r\n                    className=\"px-4 h-12 bg-red-600 text-white text-sm rounded-lg hover:bg-red-700 disabled:opacity-50 font-medium\">\r\n                    О“ВҘГ® NPP tГҹв•—ВҪ chГҹв•—ГҰi nhГҹв•‘ВЎn\r\n                  </button>\r\n                  <button onClick={() => openIncidentModal(stop)} disabled={actionLoading}\r\n                    className=\"px-4 h-12 bg-orange-100 text-orange-700 text-sm rounded-lg hover:bg-orange-200 disabled:opacity-50 font-medium\">\r\n                    О“ГңГЎвҲ©в••Г… SГҹв•—в–’ cГҹв•—ГҰ\r\n                  </button>\r\n                </div>\r\n              )}\r\n              {trip.status === 'in_transit' && (stop.status === 'delivered' || stop.status === 'partially_delivered') && (\r\n                <div className=\"mt-2 ml-8 flex flex-wrap gap-2\">\r\n                  <button onClick={() => openPaymentModal(stop)} disabled={actionLoading}\r\n                    className=\"px-4 h-12 bg-yellow-600 text-white text-sm rounded-lg hover:bg-yellow-700 disabled:opacity-50 font-medium\">\r\n                    вүЎЖ’ГҶв–‘ Thu tiГҹв•—Гјn\r\n                  </button>\r\n                  <button onClick={() => openReturnsModal(stop)} disabled={actionLoading}\r\n                    className=\"px-4 h-12 bg-purple-600 text-white text-sm rounded-lg hover:bg-purple-700 disabled:opacity-50 font-medium\">\r\n                    вүЎЖ’ГҙВӘ Thu hГҹв•—Гҙi vГҹв•—Г…\r\n                  </button>\r\n                  <button onClick={() => openEpodModal(stop)} disabled={actionLoading}\r\n                    className=\"px-4 h-12 bg-gray-200 text-gray-700 text-sm rounded-lg hover:bg-gray-300 disabled:opacity-50 font-medium\">\r\n                    вүЎЖ’ГҰГј Xem biв”ңВ¬n bГҹв•‘Гәn\r\n                  </button>\r\n                </div>\r\n              )}\r\n              {trip.status === 'in_transit' && stop.status === 'failed' && (\r\n                <div className=\"mt-2 ml-8\">\r\n                  <span className=\"text-xs text-red-500\">Giao thГҹв•‘Г‘t bГҹв•‘Гӯi О“ГҮГ¶ в”ҖГүiГҹв•—Гјu phГҹв•—ГҰi sГҹв•‘в•ң lв”ңВ¬n lГҹв•—ГҜch giao lГҹв•‘Гӯi</span>\r\n                </div>\r\n              )}\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </div>\r\n\r\n      {/* Checklist Summary (if exists) */}\r\n      {trip.checklist && (\r\n        <div className=\"bg-white rounded-lg shadow-sm p-4\">\r\n          <h2 className=\"text-lg font-semibold mb-2\">BГҹв•‘Гәng kiГҹв•—Гўm tra xe</h2>\r\n          <div className={`text-sm font-medium ${trip.checklist.is_passed ? 'text-green-600' : 'text-red-600'}`}>\r\n            {trip.checklist.is_passed ? 'О“ВЈГ  в”ҖГүв”ңГә kiГҹв•—Гўm tra - в”ҖГүГҹв•‘ГЎT' : 'О“ВҘГ® KiГҹв•—Гўm tra - KHв”ңГ¶NG в”ҖГүГҹв•‘ГЎT'}\r\n          </div>\r\n          <div className=\"grid grid-cols-2 gap-1 mt-2 text-sm text-gray-600\">\r\n            <div>{trip.checklist.tires_ok ? 'О“ВЈГҙ' : 'О“ВЈГ№'} LГҹв•—ГҰp xe</div>\r\n            <div>{trip.checklist.brakes_ok ? 'О“ВЈГҙ' : 'О“ВЈГ№'} Phanh</div>\r\n            <div>{trip.checklist.lights_ok ? 'О“ВЈГҙ' : 'О“ВЈГ№'} в”ҖГүв”ңВҝn</div>\r\n            <div>{trip.checklist.mirrors_ok ? 'О“ВЈГҙ' : 'О“ВЈГ№'} Gв•һв–‘в•һГӯng</div>\r\n            <div>{trip.checklist.horn_ok ? 'О“ВЈГҙ' : 'О“ВЈГ№'} Cв”ңв–“i</div>\r\n            <div>{trip.checklist.documents_ok ? 'О“ВЈГҙ' : 'О“ВЈГ№'} GiГҹв•‘Г‘y tГҹв•—ВҘ</div>\r\n            <div>{trip.checklist.cargo_secured ? 'О“ВЈГҙ' : 'О“ВЈГ№'} Hв”ңГЎng hв”ңв”Ӯa</div>\r\n            <div>О“Вўв•ң {trip.checklist.fuel_level}%</div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* ==================== ePOD MODAL ==================== */}\r\n      {activeModal === 'epod' && selectedStop && (\r\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-end justify-center\">\r\n          <div className=\"bg-white w-full max-w-lg rounded-t-2xl max-h-[90vh] overflow-y-auto p-4 space-y-4\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <h2 className=\"text-lg font-bold\">\r\n                {existingEpod ? 'вүЎЖ’ГҙГҜ Biв”ңВ¬n bГҹв•‘Гәn giao hв”ңГЎng' : 'вүЎЖ’ГҙВҘ Xв”ңГӯc nhГҹв•‘ВЎn giao hв”ңГЎng'}\r\n              </h2>\r\n              <button onClick={() => setActiveModal(null)} className=\"text-2xl text-gray-400 hover:text-gray-600\">в”ңГ№</button>\r\n            </div>\r\n            <p className=\"text-sm text-gray-500\">\r\n              {selectedStop.customer_name} в”¬в•– {selectedStop.order_number}\r\n            </p>\r\n\r\n            {existingEpod ? (\r\n              /* ===== BIв”ңГЁN BГҹв•‘ГіN GIAO Hв”ңГҮNG (Delivery Receipt) ===== */\r\n              <div className=\"space-y-3\">\r\n                {/* Header biв”ңВ¬n bГҹв•‘Гәn */}\r\n                <div className=\"bg-gray-50 border rounded-lg p-3 space-y-1\">\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <span className=\"text-xs font-medium text-gray-500\">BIв”ңГЁN BГҹв•‘ГіN GIAO Hв”ңГҮNG</span>\r\n                    <span className=\"text-xs text-gray-400\">#{selectedStop.order_number}</span>\r\n                  </div>\r\n                  <div className=\"grid grid-cols-2 gap-x-4 gap-y-1 text-xs text-gray-600\">\r\n                    <div>NPP: <strong className=\"text-gray-900\">{selectedStop.customer_name}</strong></div>\r\n                    <div>Ngв”ңГЎy giao: <strong className=\"text-gray-900\">{new Date().toLocaleDateString('vi-VN')}</strong></div>\r\n                    <div>Tв”ңГЎi xГҹв•‘в”җ: <strong className=\"text-gray-900\">О“ГҮГ¶</strong></div>\r\n                    <div>BiГҹв•—Гўn sГҹв•—ГҰ: <strong className=\"text-gray-900\">{trip?.vehicle_plate || '-'}</strong></div>\r\n                  </div>\r\n                </div>\r\n\r\n                {/* TrГҹв•‘Гӯng thв”ңГӯi giao */}\r\n                <div className={`px-3 py-2 rounded text-sm font-medium ${\r\n                  existingEpod.delivery_status === 'delivered' ? 'bg-green-100 text-green-700' :\r\n                  existingEpod.delivery_status === 'partial' ? 'bg-yellow-100 text-yellow-700' :\r\n                  'bg-red-100 text-red-700'\r\n                }`}>\r\n                  {existingEpod.delivery_status === 'delivered' ? 'О“ВЈГ  Giao в”ҖГҰГҹв•—Вә' :\r\n                   existingEpod.delivery_status === 'partial' ? 'О“ГңГЎвҲ©в••Г… Giao mГҹв•—Г–t phГҹв•‘Вәn' : 'О“ВҘГ® TГҹв•—ВҪ chГҹв•—ГҰi'}\r\n                </div>\r\n\r\n                {/* Rejection details */}\r\n                {existingEpod.delivery_status === 'rejected' && (\r\n                  <div className=\"bg-red-50 border border-red-200 rounded-lg p-3 space-y-2\">\r\n                    <p className=\"text-sm font-medium text-red-700\">Lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi:</p>\r\n                    <p className=\"text-sm text-red-600\">{existingEpod.reject_reason && ({\r\n                      wrong_product: 'Sai sГҹв•‘Гәn phГҹв•‘вҢҗm', quality_issue: 'Hв”ңГЎng lГҹв•—Г№i/hГҹв•‘в”җt hГҹв•‘Гӯn',\r\n                      wrong_quantity: 'Sai sГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng', not_ordered: 'Khв”ңв”Өng в”ҖГҰГҹв•‘в•–t hв”ңГЎng',\r\n                      closed: 'NPP в”ҖГҰв”ңв”Ӯng cГҹв•—ВЎa/khв”ңв”Өng cв”ңв”Ӯ ngв•һв–‘Гҹв•—ВҘi nhГҹв•‘ВЎn', other: 'Khв”ңГӯc',\r\n                    } as Record<string, string>)[existingEpod.reject_reason] || existingEpod.reject_reason}</p>\r\n                    {existingEpod.reject_detail && <p className=\"text-sm text-gray-600\">Chi tiГҹв•‘в”җt: {existingEpod.reject_detail}</p>}\r\n                    {existingEpod.reject_photos && existingEpod.reject_photos.length > 0 && (\r\n                      <div className=\"flex gap-2 flex-wrap\">\r\n                        {existingEpod.reject_photos.map((photo, idx) => (\r\n                          <img key={idx} src={photo} alt={`TГҹв•—ВҪ chГҹв•—ГҰi ${idx + 1}`} className=\"w-20 h-20 object-cover rounded border border-red-300\" />\r\n                        ))}\r\n                      </div>\r\n                    )}\r\n                  </div>\r\n                )}\r\n\r\n                {/* Chi tiГҹв•‘в”җt sГҹв•‘Гәn phГҹв•‘вҢҗm - dГҹв•‘Гӯng bГҹв•‘Гәng */}\r\n                <div className=\"border rounded-lg overflow-hidden\">\r\n                  <table className=\"w-full text-xs\">\r\n                    <thead className=\"bg-gray-50\">\r\n                      <tr>\r\n                        <th className=\"text-left py-2 px-2\">SГҹв•‘Гәn phГҹв•‘вҢҗm</th>\r\n                        <th className=\"text-right py-2 px-2 w-16\">в”ҖГүГҹв•‘в•–t</th>\r\n                        <th className=\"text-right py-2 px-2 w-16\">Giao</th>\r\n                        <th className=\"text-right py-2 px-2 w-16\">LГҹв•—Г§ch</th>\r\n                      </tr>\r\n                    </thead>\r\n                    <tbody className=\"divide-y\">\r\n                      {existingEpod.delivered_items?.map((item, idx) => {\r\n                        const diff = item.delivered_qty - item.ordered_qty\r\n                        return (\r\n                          <tr key={idx}>\r\n                            <td className=\"py-1.5 px-2\">{item.product_name}</td>\r\n                            <td className=\"py-1.5 px-2 text-right\">{item.ordered_qty}</td>\r\n                            <td className=\"py-1.5 px-2 text-right font-medium\">{item.delivered_qty}</td>\r\n                            <td className={`py-1.5 px-2 text-right font-medium ${diff < 0 ? 'text-red-600' : diff > 0 ? 'text-blue-600' : 'text-green-600'}`}>\r\n                              {diff === 0 ? 'О“ВЈГҙ' : diff > 0 ? `+${diff}` : diff}\r\n                            </td>\r\n                          </tr>\r\n                        )\r\n                      })}\r\n                    </tbody>\r\n                    <tfoot className=\"bg-gray-50 font-medium\">\r\n                      <tr>\r\n                        <td className=\"py-1.5 px-2\">TГҹв•—ГІng</td>\r\n                        <td className=\"py-1.5 px-2 text-right\">{existingEpod.delivered_items?.reduce((s, i) => s + i.ordered_qty, 0)}</td>\r\n                        <td className=\"py-1.5 px-2 text-right\">{existingEpod.delivered_items?.reduce((s, i) => s + i.delivered_qty, 0)}</td>\r\n                        <td className=\"py-1.5 px-2 text-right\">\r\n                          {(() => {\r\n                            const d = (existingEpod.delivered_items?.reduce((s, i) => s + i.delivered_qty, 0) || 0)\r\n                              - (existingEpod.delivered_items?.reduce((s, i) => s + i.ordered_qty, 0) || 0)\r\n                            return d === 0 ? 'О“ВЈГҙ' : d\r\n                          })()}\r\n                        </td>\r\n                      </tr>\r\n                    </tfoot>\r\n                  </table>\r\n                </div>\r\n\r\n                {/* Thв”ңв”Өng tin ngв•һв–‘Гҹв•—ВҘi nhГҹв•‘ВЎn + thanh toв”ңГӯn */}\r\n                <div className=\"bg-gray-50 rounded-lg p-3 space-y-1.5\">\r\n                  <div className=\"text-sm\"><span className=\"text-gray-500\">Ngв•һв–‘Гҹв•—ВҘi nhГҹв•‘ВЎn:</span> <strong>{existingEpod.receiver_name}</strong></div>\r\n                  <div className=\"text-sm\"><span className=\"text-gray-500\">Sв”ҖГүT:</span> {existingEpod.receiver_phone}</div>\r\n                  <div className=\"text-sm\"><span className=\"text-gray-500\">TГҹв•—ГІng tiГҹв•—Гјn:</span> <strong className=\"text-[#F68634]\">{existingEpod.total_amount?.toLocaleString('vi-VN')} О“Г©ВҪ</strong></div>\r\n                  {existingEpod.notes && <div className=\"text-sm\"><span className=\"text-gray-500\">Ghi chв”ңв•‘:</span> {existingEpod.notes}</div>}\r\n                </div>\r\n\r\n                {/* Гҹв•‘Гіnh xв”ңГӯc nhГҹв•‘ВЎn giao hв”ңГЎng */}\r\n                {existingEpod.photo_urls && existingEpod.photo_urls.length > 0 && (\r\n                  <div>\r\n                    <p className=\"text-xs font-medium text-gray-500 mb-1\">вүЎЖ’Гҙв•– Гҹв•‘Гіnh giao hв”ңГЎng ({existingEpod.photo_urls.length})</p>\r\n                    <div className=\"flex gap-2 flex-wrap\">\r\n                      {existingEpod.photo_urls.map((photo: string, idx: number) => (\r\n                        <img key={idx} src={photo} alt={`ePOD ${idx + 1}`} className=\"w-20 h-20 object-cover rounded border\" />\r\n                      ))}\r\n                    </div>\r\n                  </div>\r\n                )}\r\n\r\n                {/* ChГҹв•—В» kв”ңв•ң */}\r\n                {existingEpod.signature_url && (\r\n                  <div>\r\n                    <p className=\"text-xs font-medium text-gray-500 mb-1\">О“ВЈГ¬вҲ©в••Г… ChГҹв•—В» kв”ңв•ң ngв•һв–‘Гҹв•—ВҘi nhГҹв•‘ВЎn</p>\r\n                    <img src={existingEpod.signature_url} alt=\"ChГҹв•—В» kв”ңв•ң\" className=\"h-16 border rounded\" />\r\n                  </div>\r\n                )}\r\n\r\n                {/* Payment info */}\r\n                {existingPayments.length > 0 && (\r\n                  <div className=\"bg-green-50 border border-green-200 rounded-lg p-3\">\r\n                    <h3 className=\"text-sm font-medium text-green-700 mb-2\">вүЎЖ’ГҶв–‘ Thв”ңв”Өng tin thu tiГҹв•—Гјn</h3>\r\n                    {existingPayments.map((p, idx) => (\r\n                      <div key={idx} className=\"flex justify-between text-sm\">\r\n                        <span>{{cash: 'TiГҹв•—Гјn mГҹв•‘в•–t', transfer: 'ChuyГҹв•—Гўn khoГҹв•‘Гәn', credit: 'Cв”ңв”Өng nГҹв•—Гә', cod: 'COD', partial: 'Thu mГҹв•—Г–t phГҹв•‘Вәn'}[p.payment_method] || p.payment_method}</span>\r\n                        <span className=\"font-medium\">{p.amount?.toLocaleString('vi-VN')}в”ҖГҰ</span>\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                )}\r\n\r\n                {/* Return collection info */}\r\n                {existingReturns.length > 0 && (\r\n                  <div className=\"bg-purple-50 border border-purple-200 rounded-lg p-3\">\r\n                    <h3 className=\"text-sm font-medium text-purple-700 mb-2\">вүЎЖ’ГҙВӘ Thu hГҹв•—Гҙi vГҹв•—Г…</h3>\r\n                    {existingReturns.map((r, idx) => (\r\n                      <div key={idx} className=\"flex justify-between text-sm\">\r\n                        <span>{assetTypeLabels[r.asset_type] || r.asset_type} ({conditionLabels[r.condition] || r.condition})</span>\r\n                        <span className=\"font-medium\">в”ңГ№{r.quantity}</span>\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                )}\r\n              </div>\r\n            ) : (\r\n              /* ePOD submission form */\r\n              <div className=\"space-y-4\">\r\n                {/* Delivery Status */}\r\n                <div>\r\n                  <label className=\"text-sm font-medium text-gray-700\">TrГҹв•‘Гӯng thв”ңГӯi giao</label>\r\n                  <div className=\"flex gap-2 mt-1\">\r\n                    {(['delivered', 'partial', 'rejected'] as const).map(s => (\r\n                      <button key={s} onClick={() => setEpodDeliveryStatus(s)}\r\n                        className={`px-3 py-1.5 text-sm rounded ${\r\n                          epodDeliveryStatus === s ? 'bg-brand-500 text-white' : 'bg-gray-100 text-gray-700'\r\n                        }`}>\r\n                        {s === 'delivered' ? 'Giao в”ҖГҰГҹв•—Вә' : s === 'partial' ? 'Giao mГҹв•—Г–t phГҹв•‘Вәn' : 'TГҹв•—ВҪ chГҹв•—ГҰi'}\r\n                      </button>\r\n                    ))}\r\n                  </div>\r\n                </div>\r\n\r\n                {/* Delivered Items */}\r\n                <div>\r\n                  <label className=\"text-sm font-medium text-gray-700\">Chi tiГҹв•‘в”җt sГҹв•‘Гәn phГҹв•‘вҢҗm</label>\r\n                  <div className=\"space-y-2 mt-1\">\r\n                    {epodItems.map((item, idx) => (\r\n                      <div key={idx} className=\"bg-gray-50 rounded p-2\">\r\n                        <div className=\"flex justify-between items-center text-sm\">\r\n                          <span className=\"font-medium\">{item.product_name}</span>\r\n                          <span className=\"text-gray-500\">в”ҖГүГҹв•‘в•–t: {item.ordered_qty}</span>\r\n                        </div>\r\n                        <div className=\"flex items-center gap-2 mt-1\">\r\n                          <label className=\"text-xs text-gray-500\">Giao:</label>\r\n                          <input type=\"number\" min={0} max={item.ordered_qty}\r\n                            value={item.delivered_qty || ''}\r\n                            onChange={e => {\r\n                              const updated = [...epodItems]\r\n                              updated[idx].delivered_qty = parseInt(e.target.value) || 0\r\n                              setEpodItems(updated)\r\n                            }}\r\n                            className=\"w-20 px-2 py-1 border rounded text-sm\"\r\n                          />\r\n                          {item.delivered_qty < item.ordered_qty && (\r\n                            <input type=\"text\" placeholder=\"Lв”ңв•ң do thiГҹв•‘в”җu\"\r\n                              value={item.reason}\r\n                              onChange={e => {\r\n                                const updated = [...epodItems]\r\n                                updated[idx].reason = e.target.value\r\n                                setEpodItems(updated)\r\n                              }}\r\n                              className=\"flex-1 px-2 py-1 border rounded text-sm\"\r\n                            />\r\n                          )}\r\n                        </div>\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                </div>\r\n\r\n                {/* Receiver Info */}\r\n                <div className=\"grid grid-cols-2 gap-2\">\r\n                  <div>\r\n                    <label className=\"text-xs font-medium text-gray-700\">Ngв•һв–‘Гҹв•—ВҘi nhГҹв•‘ВЎn</label>\r\n                    <input type=\"text\" value={epodReceiverName}\r\n                      onChange={e => setEpodReceiverName(e.target.value)}\r\n                      className=\"w-full mt-1 px-2 py-1.5 border rounded text-sm\" placeholder=\"HГҹв•—Г¬ tв”ңВ¬n\" />\r\n                  </div>\r\n                  <div>\r\n                    <label className=\"text-xs font-medium text-gray-700\">Sв”ҖГүT nhГҹв•‘ВЎn</label>\r\n                    <input type=\"tel\" value={epodReceiverPhone}\r\n                      onChange={e => setEpodReceiverPhone(e.target.value)}\r\n                      className=\"w-full mt-1 px-2 py-1.5 border rounded text-sm\" placeholder=\"SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi\" />\r\n                  </div>\r\n                </div>\r\n\r\n                {/* Notes */}\r\n                <div>\r\n                  <label className=\"text-xs font-medium text-gray-700\">Ghi chв”ңв•‘</label>\r\n                  <textarea value={epodNotes} onChange={e => setEpodNotes(e.target.value)}\r\n                    rows={2} className=\"w-full mt-1 px-2 py-1.5 border rounded text-sm\" />\r\n                </div>\r\n\r\n                {/* Photo Evidence */}\r\n                <div>\r\n                  <label className=\"text-sm font-medium text-gray-700\">вүЎЖ’Гҙв•– Гҹв•‘Гіnh giao hв”ңГЎng <span className=\"text-red-500\">*</span></label>\r\n                  <p className=\"text-xs text-gray-400 mb-1\">ChГҹв•—Г‘p в”ңВЎt nhГҹв•‘Г‘t 1 Гҹв•‘Гәnh xв”ңГӯc nhГҹв•‘ВЎn giao hв”ңГЎng</p>\r\n                  <div className=\"flex gap-2 flex-wrap mt-1\">\r\n                    {epodPhotos.map((photo, idx) => (\r\n                      <div key={idx} className=\"relative w-20 h-20\">\r\n                        <img src={photo} alt={`ePOD ${idx + 1}`} className=\"w-full h-full object-cover rounded border\" />\r\n                        <button onClick={() => setEpodPhotos(epodPhotos.filter((_, i) => i !== idx))}\r\n                          className=\"absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white rounded-full text-xs flex items-center justify-center\">в”ңГ№</button>\r\n                      </div>\r\n                    ))}\r\n                    <label className=\"w-20 h-20 border-2 border-dashed border-gray-300 rounded flex flex-col items-center justify-center cursor-pointer hover:border-blue-400\">\r\n                      <span className=\"text-2xl text-gray-400\">вүЎЖ’Гҙв•–</span>\r\n                      <span className=\"text-xs text-gray-400\">Thв”ңВ¬m Гҹв•‘Гәnh</span>\r\n                      <input type=\"file\" accept=\"image/*\" capture=\"environment\" className=\"hidden\" onChange={e => {\r\n                        const file = e.target.files?.[0]\r\n                        if (!file) return\r\n                        const reader = new FileReader()\r\n                        reader.onload = () => { if (reader.result) setEpodPhotos(prev => [...prev, reader.result as string]) }\r\n                        reader.readAsDataURL(file)\r\n                        e.target.value = ''\r\n                      }} />\r\n                    </label>\r\n                  </div>\r\n                </div>\r\n\r\n                <button onClick={handleSubmitEpod} disabled={actionLoading || !epodReceiverName || epodPhotos.length === 0}\r\n                  className=\"w-full h-14 bg-green-600 text-white rounded-lg font-medium hover:bg-green-700 disabled:opacity-50\">\r\n                  {actionLoading ? 'в”ҖГүang gГҹв•—ВЎi...' : 'О“ВЈГ  Xв”ңГӯc nhГҹв•‘ВЎn giao hв”ңГЎng'}\r\n                </button>\r\n                {epodPhotos.length === 0 && (\r\n                  <p className=\"text-xs text-red-500 text-center\">Vui lв”ңв–“ng chГҹв•—Г‘p в”ңВЎt nhГҹв•‘Г‘t 1 Гҹв•‘Гәnh в”ҖГҰГҹв•—Гў xв”ңГӯc nhГҹв•‘ВЎn</p>\r\n                )}\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* ==================== PAYMENT MODAL ==================== */}\r\n      {activeModal === 'payment' && selectedStop && (\r\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-end justify-center\">\r\n          <div className=\"bg-white w-full max-w-lg rounded-t-2xl max-h-[90vh] overflow-y-auto p-4 space-y-4\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <h2 className=\"text-lg font-bold\">вүЎЖ’ГҶв–‘ Thu tiГҹв•—Гјn</h2>\r\n              <button onClick={() => setActiveModal(null)} className=\"text-2xl text-gray-400 hover:text-gray-600\">в”ңГ№</button>\r\n            </div>\r\n            <p className=\"text-sm text-gray-500\">\r\n              {selectedStop.customer_name} в”¬в•– {selectedStop.order_number}\r\n            </p>\r\n\r\n            <div className=\"space-y-4\">\r\n              {/* Payment Method */}\r\n              <div>\r\n                <label className=\"text-sm font-medium text-gray-700\">Hв”ңВјnh thГҹв•—вҢҗc thanh toв”ңГӯn</label>\r\n                <div className=\"grid grid-cols-2 gap-2 mt-1\">\r\n                  {([\r\n                    { v: 'cash', l: 'вүЎЖ’ГҶв•Ў TiГҹв•—Гјn mГҹв•‘в•–t' },\r\n                    { v: 'transfer', l: 'вүЎЖ’Г…ВӘ ChuyГҹв•—Гўn khoГҹв•‘Гәn' },\r\n                    { v: 'credit', l: 'вүЎЖ’ГҙВҘ Cв”ңв”Өng nГҹв•—Гә' },\r\n                    { v: 'partial', l: 'вүЎЖ’ГҶв–‘ Thu mГҹв•—Г–t phГҹв•‘Вәn' },\r\n                  ] as const).map(m => (\r\n                    <button key={m.v} onClick={() => setPaymentMethod(m.v as typeof paymentMethod)}\r\n                      className={`px-3 py-2 text-sm rounded-lg border transition ${\r\n                        paymentMethod === m.v ? 'bg-brand-500 text-white border-brand-500' : 'bg-white text-gray-700 border-gray-200 hover:border-brand-300'\r\n                      }`}>\r\n                      {m.l}\r\n                    </button>\r\n                  ))}\r\n                </div>\r\n              </div>\r\n\r\n              {/* Amount - not shown for credit */}\r\n              {paymentMethod !== 'credit' && (\r\n                <div>\r\n                  <label className=\"text-sm font-medium text-gray-700\">SГҹв•—ГҰ tiГҹв•—Гјn thu</label>\r\n                  <input type=\"number\" value={paymentAmount || ''}\r\n                    onChange={e => setPaymentAmount(safeParseVNDSafe(e.target.value))}\r\n                    className=\"w-full mt-1 px-3 py-2 border rounded-lg text-lg font-bold\" />\r\n                  <p className=\"text-xs text-gray-400 mt-1\">\r\n                    TГҹв•—ГІng в”ҖГҰв•һГӯn: {selectedStop.order_amount?.toLocaleString('vi-VN')}в”ҖГҰ\r\n                  </p>\r\n                </div>\r\n              )}\r\n\r\n              {/* Credit / Debt notice */}\r\n              {paymentMethod === 'credit' && (\r\n                <div className=\"bg-amber-50 border border-amber-200 rounded-lg p-3\">\r\n                  <p className=\"text-amber-800 text-sm font-medium\">вүЎЖ’ГҙВҘ Ghi cв”ңв”Өng nГҹв•—Гә</p>\r\n                  <p className=\"text-amber-600 text-xs mt-1\">SГҹв•—ГҰ tiГҹв•—Гјn {selectedStop.order_amount?.toLocaleString('vi-VN')}в”ҖГҰ sГҹв•‘в•ң в”ҖГҰв•һв–‘Гҹв•—Гәc ghi vв”ңГЎo cв”ңв”Өng nГҹв•—Гә NPP</p>\r\n                </div>\r\n              )}\r\n\r\n              {/* Reference Number (for transfer) */}\r\n              {paymentMethod === 'transfer' && (\r\n                <div>\r\n                  <label className=\"text-sm font-medium text-gray-700\">Mв”ңГә giao dГҹв•—ГҜch</label>\r\n                  <input type=\"text\" value={paymentRef}\r\n                    onChange={e => setPaymentRef(e.target.value)}\r\n                    className=\"w-full mt-1 px-3 py-2 border rounded-lg text-sm\" placeholder=\"Mв”ңГә chuyГҹв•—Гўn khoГҹв•‘Гәn\" />\r\n                </div>\r\n              )}\r\n\r\n              <button onClick={handleSubmitPayment}\r\n                disabled={actionLoading || (paymentMethod !== 'credit' && paymentAmount <= 0)}\r\n                className=\"w-full h-12 bg-yellow-600 text-white rounded-lg font-medium hover:bg-yellow-700 disabled:opacity-50\">\r\n                {actionLoading ? 'в”ҖГүang gГҹв•—ВЎi...' : paymentMethod === 'credit' ? 'вүЎЖ’ГҙВҘ Xв”ңГӯc nhГҹв•‘ВЎn ghi nГҹв•—Гә' : 'вүЎЖ’ГҶв–‘ Xв”ңГӯc nhГҹв•‘ВЎn thu tiГҹв•—Гјn'}\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* ==================== RETURNS MODAL ==================== */}\r\n      {activeModal === 'returns' && selectedStop && (\r\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-end justify-center\">\r\n          <div className=\"bg-white w-full max-w-lg rounded-t-2xl max-h-[90vh] overflow-y-auto p-4 space-y-4\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <h2 className=\"text-lg font-bold\">вүЎЖ’ГҙВӘ Thu hГҹв•—Гҙi vГҹв•—Г…</h2>\r\n              <button onClick={() => setActiveModal(null)} className=\"text-2xl text-gray-400 hover:text-gray-600\">в”ңГ№</button>\r\n            </div>\r\n            <p className=\"text-sm text-gray-500\">\r\n              {selectedStop.customer_name}\r\n            </p>\r\n\r\n            {/* Existing returns */}\r\n            {existingReturns.length > 0 && (\r\n              <div className=\"bg-green-50 rounded-lg p-3\">\r\n                <h3 className=\"text-sm font-medium text-green-700 mb-2\">в”ҖГүв”ңГә thu hГҹв•—Гҙi trв•һв–‘Гҹв•—Вўc в”ҖГҰв”ңв”Ӯ:</h3>\r\n                {existingReturns.map((r, idx) => (\r\n                  <div key={idx} className=\"flex justify-between text-sm\">\r\n                    <span>{assetTypeLabels[r.asset_type] || r.asset_type} ({conditionLabels[r.condition] || r.condition})</span>\r\n                    <span>в”ңГ№{r.quantity}</span>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            )}\r\n\r\n            {/* Return Items Form */}\r\n            <div className=\"space-y-3\">\r\n              {returnItems.map((item, idx) => (\r\n                <div key={idx} className=\"bg-gray-50 rounded-lg p-3 space-y-2\">\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <span className=\"text-sm font-medium\">MГҹв•—Г‘c #{idx + 1}</span>\r\n                    {returnItems.length > 1 && (\r\n                      <button onClick={() => removeReturnItem(idx)} className=\"text-red-500 text-sm\">Xв”ңв”Ӯa</button>\r\n                    )}\r\n                  </div>\r\n                  <div className=\"grid grid-cols-2 gap-2\">\r\n                    <div>\r\n                      <label className=\"text-xs text-gray-500\">LoГҹв•‘Гӯi vГҹв•—Г…</label>\r\n                      <select value={item.asset_type}\r\n                        onChange={e => {\r\n                          const updated = [...returnItems]\r\n                          updated[idx].asset_type = e.target.value\r\n                          setReturnItems(updated)\r\n                        }}\r\n                        className=\"w-full mt-0.5 px-2 py-1.5 border rounded text-sm\">\r\n                        <option value=\"bottle\">Chai</option>\r\n                        <option value=\"crate\">Kв”ңвҢҗt</option>\r\n                        <option value=\"keg\">Keg</option>\r\n                        <option value=\"pallet\">Pallet</option>\r\n                      </select>\r\n                    </div>\r\n                    <div>\r\n                      <label className=\"text-xs text-gray-500\">SГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng</label>\r\n                      <input type=\"number\" min={0} value={item.quantity || ''}\r\n                        onChange={e => {\r\n                          const updated = [...returnItems]\r\n                          updated[idx].quantity = parseInt(e.target.value) || 0\r\n                          setReturnItems(updated)\r\n                        }}\r\n                        className=\"w-full mt-0.5 px-2 py-1.5 border rounded text-sm\" />\r\n                    </div>\r\n                  </div>\r\n                  <div>\r\n                    <label className=\"text-xs text-gray-500\">Tв”ңВјnh trГҹв•‘Гӯng</label>\r\n                    <div className=\"flex gap-2 mt-0.5\">\r\n                      {(['good', 'damaged', 'lost'] as const).map(c => (\r\n                        <button key={c} onClick={() => {\r\n                          const updated = [...returnItems]\r\n                          updated[idx].condition = c\r\n                          setReturnItems(updated)\r\n                        }}\r\n                          className={`px-2 py-1 text-xs rounded ${\r\n                            item.condition === c ? 'bg-brand-500 text-white' : 'bg-gray-200 text-gray-700'\r\n                          }`}>\r\n                          {conditionLabels[c]}\r\n                        </button>\r\n                      ))}\r\n                    </div>\r\n                  </div>\r\n                  {/* Photo required for damaged/lost */}\r\n                  {(item.condition === 'damaged' || item.condition === 'lost') && (\r\n                    <div className=\"mt-1\">\r\n                      <label className=\"text-xs text-red-500 font-medium\">вүЎЖ’Гҙв•– Гҹв•‘Гіnh bГҹв•‘В»t buГҹв•—Г–c (hв•һв–‘ hГҹв•—Г…ng/mГҹв•‘Г‘t)</label>\r\n                      {item.photo ? (\r\n                        <div className=\"relative w-20 h-20 mt-1\">\r\n                          <img src={item.photo} alt=\"Minh chГҹв•—вҢҗng\" className=\"w-full h-full object-cover rounded border border-red-300\" />\r\n                          <button onClick={() => { const next = [...returnItems]; next[idx] = { ...next[idx], photo: '' }; setReturnItems(next) }}\r\n                            className=\"absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white rounded-full text-xs flex items-center justify-center\">в”ңГ№</button>\r\n                        </div>\r\n                      ) : (\r\n                        <label className=\"mt-1 block w-full py-2 border-2 border-dashed border-red-300 rounded text-center text-sm text-red-500 cursor-pointer hover:border-red-400\">\r\n                          вүЎЖ’Гҙв•– ChГҹв•—Г‘p Гҹв•‘Гәnh minh chГҹв•—вҢҗng\r\n                          <input type=\"file\" accept=\"image/*\" capture=\"environment\" className=\"hidden\" onChange={e => {\r\n                            const file = e.target.files?.[0]\r\n                            if (!file) return\r\n                            const reader = new FileReader()\r\n                            reader.onload = () => {\r\n                              if (reader.result) {\r\n                                const next = [...returnItems]\r\n                                next[idx] = { ...next[idx], photo: reader.result as string }\r\n                                setReturnItems(next)\r\n                              }\r\n                            }\r\n                            reader.readAsDataURL(file)\r\n                            e.target.value = ''\r\n                          }} />\r\n                        </label>\r\n                      )}\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              ))}\r\n              <button onClick={addReturnItem}\r\n                className=\"w-full py-2 border-2 border-dashed border-gray-300 rounded-lg text-sm text-gray-500 hover:border-blue-400 hover:text-blue-500\">\r\n                + Thв”ңВ¬m loГҹв•‘Гӯi vГҹв•—Г…\r\n              </button>\r\n            </div>\r\n\r\n            <button onClick={handleSubmitReturns} disabled={actionLoading || !returnItems.some(i => i.quantity > 0) || returnItems.some(i => i.quantity > 0 && (i.condition === 'damaged' || i.condition === 'lost') && !i.photo)}\r\n              className=\"w-full h-12 bg-purple-600 text-white rounded-lg font-medium hover:bg-purple-700 disabled:opacity-50\">\r\n              {actionLoading ? 'в”ҖГүang gГҹв•—ВЎi...' : 'вүЎЖ’ГҙВӘ Xв”ңГӯc nhГҹв•‘ВЎn thu hГҹв•—Гҙi'}\r\n            </button>\r\n            {returnItems.some(i => i.quantity > 0 && (i.condition === 'damaged' || i.condition === 'lost') && !i.photo) && (\r\n              <p className=\"text-xs text-red-500 text-center\">Vui lв”ңв–“ng chГҹв•—Г‘p Гҹв•‘Гәnh cho cв”ңГӯc mГҹв•—Г‘c hв•һв–‘ hГҹв•—Г…ng/mГҹв•‘Г‘t</p>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* ==================== CHECKLIST MODAL ==================== */}\r\n      {activeModal === 'checklist' && (\r\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-end justify-center\">\r\n          <div className=\"bg-white w-full max-w-lg rounded-t-2xl max-h-[90vh] overflow-y-auto p-4 space-y-4\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <h2 className=\"text-lg font-bold\">вүЎЖ’ГҙГҜ KiГҹв•—Гўm tra xe trв•һв–‘Гҹв•—Вўc khi xuГҹв•‘Г‘t phв”ңГӯt</h2>\r\n              <button onClick={() => setActiveModal(null)} className=\"text-2xl text-gray-400 hover:text-gray-600\">в”ңГ№</button>\r\n            </div>\r\n            <p className=\"text-sm text-gray-500\">{trip.vehicle_plate} в”¬в•– {trip.trip_number}</p>\r\n\r\n            <div className=\"space-y-3\">\r\n              {([\r\n                { key: 'tires_ok', label: 'вүЎЖ’ВўвӮ§ LГҹв•—ГҰp xe' },\r\n                { key: 'brakes_ok', label: 'вүЎЖ’ВўГҰ Phanh' },\r\n                { key: 'lights_ok', label: 'вүЎЖ’ГҶГӯ в”ҖГүв”ңВҝn' },\r\n                { key: 'mirrors_ok', label: 'вүЎЖ’В¬вӮ§ Gв•һв–‘в•һГӯng' },\r\n                { key: 'horn_ok', label: 'вүЎЖ’ГҙВ» Cв”ңв–“i' },\r\n                { key: 'coolant_ok', label: 'вүЎЖ’ГҶВә Nв•һв–‘Гҹв•—Вўc lв”ңГЎm mв”ңГӯt' },\r\n                { key: 'oil_ok', label: 'вүЎЖ’ВўГівҲ©в••Г… DГҹв•‘Вәu' },\r\n                { key: 'fire_extinguisher_ok', label: 'вүЎЖ’ВәВ» Bв”ңВјnh chГҹв•—В»a chв”ңГӯy' },\r\n                { key: 'first_aid_ok', label: 'вүЎЖ’вҢҗв•‘ Sв•һГӯ cГҹв•—вҢҗu' },\r\n                { key: 'documents_ok', label: 'вүЎЖ’ГҙГӨ GiГҹв•‘Г‘y tГҹв•—ВҘ xe' },\r\n                { key: 'cargo_secured', label: 'вүЎЖ’ГҙВӘ Hв”ңГЎng hв”ңв”Ӯa cГҹв•—ГҰ в”ҖГҰГҹв•—ГҜnh' },\r\n              ] as const).map(item => (\r\n                <div key={item.key} className=\"flex items-center justify-between bg-gray-50 rounded-lg px-3 py-2.5\">\r\n                  <span className=\"text-sm\">{item.label}</span>\r\n                  <div className=\"flex gap-2\">\r\n                    <button onClick={() => setChecklistForm(prev => ({ ...prev, [item.key]: true }))}\r\n                      className={`px-3 py-1 text-xs rounded-lg font-medium ${\r\n                        checklistForm[item.key] ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-500'\r\n                      }`}>О“ВЈГҙ в”ҖГүГҹв•‘Гӯt</button>\r\n                    <button onClick={() => setChecklistForm(prev => ({ ...prev, [item.key]: false }))}\r\n                      className={`px-3 py-1 text-xs rounded-lg font-medium ${\r\n                        !checklistForm[item.key] ? 'bg-red-500 text-white' : 'bg-gray-200 text-gray-500'\r\n                      }`}>О“ВЈГ№ LГҹв•—Г№i</button>\r\n                  </div>\r\n                </div>\r\n              ))}\r\n\r\n              {/* Fuel Level */}\r\n              <div className=\"bg-gray-50 rounded-lg px-3 py-2.5\">\r\n                <div className=\"flex items-center justify-between\">\r\n                  <span className=\"text-sm\">О“Вўв•ң MГҹв•—вҢҗc nhiв”ңВ¬n liГҹв•—Г§u</span>\r\n                  <span className=\"text-sm font-bold text-brand-500\">{checklistForm.fuel_level}%</span>\r\n                </div>\r\n                <input type=\"range\" min={0} max={100} step={5} value={checklistForm.fuel_level}\r\n                  onChange={e => setChecklistForm(prev => ({ ...prev, fuel_level: parseInt(e.target.value) }))}\r\n                  className=\"w-full mt-2\" />\r\n              </div>\r\n\r\n              {/* Notes */}\r\n              <div>\r\n                <label className=\"text-xs font-medium text-gray-700\">Ghi chв”ңв•‘ (nГҹв•‘в”җu cв”ңв”Ӯ)</label>\r\n                <textarea value={checklistForm.notes}\r\n                  onChange={e => setChecklistForm(prev => ({ ...prev, notes: e.target.value }))}\r\n                  rows={2} className=\"w-full mt-1 px-2 py-1.5 border rounded text-sm\"\r\n                  placeholder=\"Ghi chв”ңв•‘ thв”ңВ¬m vГҹв•—Гј tв”ңВјnh trГҹв•‘Гӯng xe...\" />\r\n              </div>\r\n\r\n              {/* Summary */}\r\n              {Object.entries(checklistForm).some(([k, v]) => k !== 'fuel_level' && k !== 'notes' && v === false) && (\r\n                <div className=\"bg-red-50 border border-red-200 rounded-lg p-3\">\r\n                  <p className=\"text-red-700 text-sm font-medium\">О“ГңГЎвҲ©в••Г… Cв”ңв”Ӯ hГҹв•‘Гӯng mГҹв•—Г‘c khв”ңв”Өng в”ҖГҰГҹв•‘Гӯt:</p>\r\n                  <ul className=\"text-red-600 text-xs mt-1 list-disc list-inside\">\r\n                    {!checklistForm.tires_ok && <li>LГҹв•—ГҰp xe</li>}\r\n                    {!checklistForm.brakes_ok && <li>Phanh</li>}\r\n                    {!checklistForm.lights_ok && <li>в”ҖГүв”ңВҝn</li>}\r\n                    {!checklistForm.mirrors_ok && <li>Gв•һв–‘в•һГӯng</li>}\r\n                    {!checklistForm.horn_ok && <li>Cв”ңв–“i</li>}\r\n                    {!checklistForm.coolant_ok && <li>Nв•һв–‘Гҹв•—Вўc lв”ңГЎm mв”ңГӯt</li>}\r\n                    {!checklistForm.oil_ok && <li>DГҹв•‘Вәu</li>}\r\n                    {!checklistForm.fire_extinguisher_ok && <li>Bв”ңВјnh chГҹв•—В»a chв”ңГӯy</li>}\r\n                    {!checklistForm.first_aid_ok && <li>Sв•һГӯ cГҹв•—вҢҗu</li>}\r\n                    {!checklistForm.documents_ok && <li>GiГҹв•‘Г‘y tГҹв•—ВҘ xe</li>}\r\n                    {!checklistForm.cargo_secured && <li>Hв”ңГЎng hв”ңв”Ӯa</li>}\r\n                  </ul>\r\n                </div>\r\n              )}\r\n\r\n              <button onClick={handleSubmitChecklist} disabled={actionLoading}\r\n                className=\"w-full h-12 bg-purple-600 text-white rounded-lg font-medium hover:bg-purple-700 disabled:opacity-50\">\r\n                {actionLoading ? 'в”ҖГүang gГҹв•—ВЎi...' : 'вүЎЖ’ГҙГҜ GГҹв•—ВЎi kiГҹв•—Гўm tra xe'}\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* ==================== INCIDENT MODAL ==================== */}\r\n      {activeModal === 'incident' && selectedStop && (\r\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-end justify-center\">\r\n          <div className=\"bg-white w-full max-w-lg rounded-t-2xl max-h-[90vh] overflow-y-auto p-4 space-y-4\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <h2 className=\"text-lg font-bold\">О“ГңГЎвҲ©в••Г… Bв”ңГӯo sГҹв•—в–’ cГҹв•—ГҰ</h2>\r\n              <button onClick={() => setActiveModal(null)} className=\"text-2xl text-gray-400 hover:text-gray-600\">в”ңГ№</button>\r\n            </div>\r\n            <p className=\"text-sm text-gray-500\">\r\n              {selectedStop.customer_name} в”¬в•– {selectedStop.order_number}\r\n            </p>\r\n\r\n            <div className=\"space-y-4\">\r\n              <div>\r\n                <label className=\"text-sm font-medium text-gray-700\">LoГҹв•‘Гӯi sГҹв•—в–’ cГҹв•—ГҰ</label>\r\n                <div className=\"grid grid-cols-1 gap-2 mt-1\">\r\n                  {[\r\n                    { v: 'address_wrong', l: 'вүЎЖ’ГҙГ¬ Sai в”ҖГҰГҹв•—ГҜa chГҹв•—Г« giao hв”ңГЎng' },\r\n                    { v: 'customer_absent', l: 'вүЎЖ’ГңВҪ Khв”ңГӯch hв”ңГЎng khв”ңв”Өng cв”ңв”Ӯ mГҹв•‘в•–t' },\r\n                    { v: 'vehicle_breakdown', l: 'вүЎЖ’Г¶Вә Hв•һв–‘ hГҹв•—Г…ng xe' },\r\n                    { v: 'traffic_police', l: 'вүЎЖ’ГҰВ« BГҹв•—ГҜ CSGT giГҹв•—В»' },\r\n                    { v: 'road_blocked', l: 'вүЎЖ’ГңВә в”ҖГүв•һв–‘Гҹв•—ВҘng bГҹв•—ГҜ chГҹв•‘в•–n / ngГҹв•‘ВЎp' },\r\n                    { v: 'accident', l: 'вүЎЖ’ГҶГ‘ Tai nГҹв•‘Гӯn giao thв”ңв”Өng' },\r\n                    { v: 'other', l: 'вүЎЖ’ГҙГҜ Khв”ңГӯc' },\r\n                  ].map(t => (\r\n                    <button key={t.v} onClick={() => setIncidentType(t.v)}\r\n                      className={`px-3 py-2 text-sm text-left rounded-lg border transition ${\r\n                        incidentType === t.v ? 'bg-orange-50 border-orange-400 text-orange-700' : 'bg-white border-gray-200 hover:border-orange-300'\r\n                      }`}>\r\n                      {t.l}\r\n                    </button>\r\n                  ))}\r\n                </div>\r\n              </div>\r\n\r\n              <div>\r\n                <label className=\"text-sm font-medium text-gray-700\">Mв”ңв”Ө tГҹв•‘Гә chi tiГҹв•‘в”җt</label>\r\n                <textarea value={incidentDesc} onChange={e => setIncidentDesc(e.target.value)}\r\n                  rows={3} className=\"w-full mt-1 px-3 py-2 border rounded-lg text-sm\"\r\n                  placeholder=\"Mв”ңв”Ө tГҹв•‘Гә tв”ңВјnh huГҹв•—ГҰng cГҹв•—Г‘ thГҹв•—Гў...\" />\r\n              </div>\r\n\r\n              {/* Photo evidence */}\r\n              <div>\r\n                <label className=\"text-sm font-medium text-gray-700\">вүЎЖ’Гҙв•– Гҹв•‘Гіnh minh chГҹв•—вҢҗng</label>\r\n                <div className=\"flex gap-2 flex-wrap mt-1\">\r\n                  {incidentPhotos.map((photo, idx) => (\r\n                    <div key={idx} className=\"relative w-20 h-20\">\r\n                      <img src={photo} alt={`SГҹв•—в–’ cГҹв•—ГҰ ${idx + 1}`} className=\"w-full h-full object-cover rounded border\" />\r\n                      <button onClick={() => setIncidentPhotos(incidentPhotos.filter((_, i) => i !== idx))}\r\n                        className=\"absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white rounded-full text-xs flex items-center justify-center\">в”ңГ№</button>\r\n                    </div>\r\n                  ))}\r\n                  <label className=\"w-20 h-20 border-2 border-dashed border-orange-300 rounded-lg flex flex-col items-center justify-center cursor-pointer hover:border-orange-400\">\r\n                    <span className=\"text-2xl text-orange-400\">вүЎЖ’Гҙв•–</span>\r\n                    <span className=\"text-xs text-orange-400\">Thв”ңВ¬m Гҹв•‘Гәnh</span>\r\n                    <input type=\"file\" accept=\"image/*\" capture=\"environment\" className=\"hidden\" onChange={e => {\r\n                      const file = e.target.files?.[0]\r\n                      if (!file) return\r\n                      const reader = new FileReader()\r\n                      reader.onload = () => { if (reader.result) setIncidentPhotos(prev => [...prev, reader.result as string]) }\r\n                      reader.readAsDataURL(file)\r\n                      e.target.value = ''\r\n                    }} />\r\n                  </label>\r\n                </div>\r\n              </div>\r\n\r\n              <button onClick={handleSubmitIncident} disabled={actionLoading || !incidentDesc.trim()}\r\n                className=\"w-full h-14 bg-orange-600 text-white rounded-lg font-medium hover:bg-orange-700 disabled:opacity-50\">\r\n                {actionLoading ? 'в”ҖГүang gГҹв•—ВЎi...' : 'О“ГңГЎвҲ©в••Г… GГҹв•—ВЎi bв”ңГӯo sГҹв•—в–’ cГҹв•—ГҰ'}\r\n              </button>\r\n              <p className=\"text-xs text-gray-400 text-center\">в”ҖГүiГҹв•—Гјu phГҹв•—ГҰi viв”ңВ¬n sГҹв•‘в•ң nhГҹв•‘ВЎn thв”ңв”Өng bв”ңГӯo vв”ңГЎ hв•һв–‘Гҹв•—Вўng dГҹв•‘ВҪn bГҹв•‘Гӯn</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* ==================== TRIP SUMMARY MODAL ==================== */}\r\n      {/* ==================== POST-TRIP CHECKLIST MODAL (US-TMS-18) ==================== */}\r\n      {activeModal === 'post_checklist' && trip && (\r\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-end justify-center\">\r\n          <div className=\"bg-white w-full max-w-lg rounded-t-2xl max-h-[90vh] overflow-y-auto p-4 space-y-4\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <h2 className=\"text-lg font-bold\">вүЎЖ’ГҙГҜ Checklist cuГҹв•—ГҰi chuyГҹв•‘в”җn</h2>\r\n              <button onClick={() => setActiveModal(null)} className=\"text-2xl text-gray-400 hover:text-gray-600\">в”ңГ№</button>\r\n            </div>\r\n            <p className=\"text-sm text-gray-500\">KiГҹв•—Гўm tra vв”ңГЎ xв”ңГӯc nhГҹв•‘ВЎn trв•һв–‘Гҹв•—Вўc khi hoв”ңГЎn thв”ңГЎnh chuyГҹв•‘в”җn xe</p>\r\n\r\n            <div className=\"space-y-3\">\r\n              {[\r\n                { key: 'vehicle_clean', label: 'Xe sГҹв•‘Гӯch sГҹв•‘в•ң, cabin gГҹв•—Г¬n gв”ңГЎng' },\r\n                { key: 'vehicle_no_damage', label: 'Xe khв”ңв”Өng hв•һв–‘ hГҹв•—Г…ng mГҹв•—Вўi phв”ңГӯt sinh' },\r\n                { key: 'fuel_noted', label: 'в”ҖГүв”ңГә ghi nhГҹв•‘ВЎn mГҹв•—вҢҗc nhiв”ңВ¬n liГҹв•—Г§u cв”ңв–“n lГҹв•‘Гӯi' },\r\n                { key: 'cash_ready', label: 'TiГҹв•—Гјn mГҹв•‘в•–t в”ҖГҰв”ңГә thu sГҹв•‘в•Ўn sв”ңГЎng nГҹв•—Г–p kГҹв•‘в”җ toв”ңГӯn' },\r\n                { key: 'returns_collected', label: 'VГҹв•—Г… thu hГҹв•—Гҙi в”ҖГҰв”ңГә kiГҹв•—Гўm в”ҖГҰГҹв•‘в”җm в”ҖГҰГҹв•‘Вәy в”ҖГҰГҹв•—Вә' },\r\n                { key: 'keys_ready', label: 'SГҹв•‘в•Ўn sв”ңГЎng bв”ңГЎn giao chв”ңВјa khв”ңв”Ӯa xe' },\r\n              ].map(item => (\r\n                <label key={item.key} className=\"flex items-center gap-3 p-3 bg-gray-50 rounded-lg cursor-pointer hover:bg-gray-100\">\r\n                  <input type=\"checkbox\"\r\n                    checked={(postChecklist as any)[item.key]}\r\n                    onChange={(e) => setPostChecklist(prev => ({ ...prev, [item.key]: e.target.checked }))}\r\n                    className=\"w-5 h-5 text-brand-500 rounded\" />\r\n                  <span className=\"text-sm\">{item.label}</span>\r\n                </label>\r\n              ))}\r\n            </div>\r\n\r\n            <button\r\n              onClick={() => { setActiveModal(null); openTripSummary() }}\r\n              disabled={!Object.values(postChecklist).every(Boolean)}\r\n              className=\"w-full py-3 bg-brand-500 text-white rounded-lg font-bold hover:bg-brand-600 disabled:opacity-50 disabled:cursor-not-allowed text-lg\">\r\n              {Object.values(postChecklist).every(Boolean) ? 'О“ГҘГҶ Xem tГҹв•—ГІng kГҹв•‘в”җt chuyГҹв•‘в”җn xe' : 'О“ВјВЈ Vui lв”ңв–“ng check hГҹв•‘в”җt cв”ңГӯc mГҹв•—Г‘c'}\r\n            </button>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* ==================== TRIP SUMMARY MODAL ==================== */}\r\n      {activeModal === 'trip_summary' && trip && (\r\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-end justify-center\">\r\n          <div className=\"bg-white w-full max-w-lg rounded-t-2xl max-h-[90vh] overflow-y-auto p-4 space-y-4\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <h2 className=\"text-lg font-bold\">вүЎЖ’ГҙГЁ TГҹв•—ГІng kГҹв•‘в”җt chuyГҹв•‘в”җn xe</h2>\r\n              <button onClick={() => setActiveModal(null)} className=\"text-2xl text-gray-400 hover:text-gray-600\">в”ңГ№</button>\r\n            </div>\r\n\r\n            <div className=\"space-y-3\">\r\n              {/* Delivery stats */}\r\n              <div className=\"bg-blue-50 rounded-lg p-3\">\r\n                <h3 className=\"text-sm font-semibold text-blue-800 mb-2\">вүЎЖ’ГңГң Giao hв”ңГЎng</h3>\r\n                <div className=\"grid grid-cols-3 gap-2 text-center\">\r\n                  <div>\r\n                    <div className=\"text-lg font-bold text-green-600\">\r\n                      {trip.stops?.filter(s => s.status === 'delivered').length || 0}\r\n                    </div>\r\n                    <div className=\"text-xs text-gray-500\">Thв”ңГЎnh cв”ңв”Өng</div>\r\n                  </div>\r\n                  <div>\r\n                    <div className=\"text-lg font-bold text-yellow-600\">\r\n                      {trip.stops?.filter(s => s.status === 'partially_delivered').length || 0}\r\n                    </div>\r\n                    <div className=\"text-xs text-gray-500\">MГҹв•—Г–t phГҹв•‘Вәn</div>\r\n                  </div>\r\n                  <div>\r\n                    <div className=\"text-lg font-bold text-red-600\">\r\n                      {trip.stops?.filter(s => s.status === 'failed' || s.status === 'skipped').length || 0}\r\n                    </div>\r\n                    <div className=\"text-xs text-gray-500\">ThГҹв•‘Г‘t bГҹв•‘Гӯi</div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Route stats */}\r\n              <div className=\"bg-gray-50 rounded-lg p-3\">\r\n                <h3 className=\"text-sm font-semibold text-gray-700 mb-2\">вүЎЖ’ГҙГ… LГҹв•—Г– trв”ңВјnh</h3>\r\n                <div className=\"grid grid-cols-2 gap-2 text-sm\">\r\n                  <div>TГҹв•—ГІng quв”ңГәng в”ҖГҰв•һв–‘Гҹв•—ВҘng: <strong>{trip.total_distance_km?.toFixed(1)} km</strong></div>\r\n                  <div>TГҹв•—ГІng thГҹв•—ВҘi gian: <strong>~{trip.total_duration_min} phв”ңв•‘t</strong></div>\r\n                  <div>TГҹв•—ГІng trГҹв•—Г¬ng lв•һв–‘Гҹв•—Гәng: <strong>{trip.total_weight_kg?.toFixed(0)} kg</strong></div>\r\n                  <div>TГҹв•—ГІng в”ҖГҰiГҹв•—Гўm giao: <strong>{trip.total_stops}</strong></div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Financial summary */}\r\n              <div className=\"bg-green-50 rounded-lg p-3\">\r\n                <h3 className=\"text-sm font-semibold text-green-800 mb-2\">вүЎЖ’ГҶв–‘ Thu tiГҹв•—Гјn</h3>\r\n                <div className=\"text-sm text-gray-700\">\r\n                  <p>TГҹв•—ГІng tiГҹв•—Гјn в”ҖГҰв•һГӯn hв”ңГЎng: <strong>{(trip.stops?.reduce((sum, s) => sum + (s.order_amount || 0), 0) || 0).toLocaleString('vi-VN')}в”ҖГҰ</strong></p>\r\n                  <p className=\"text-xs text-gray-500 mt-1\">Chi tiГҹв•‘в”җt thu/nГҹв•—Гә sГҹв•‘в•ң в”ҖГҰв•һв–‘Гҹв•—Гәc в”ҖГҰГҹв•—ГҰi soв”ңГӯt bГҹв•—Ж’i kГҹв•‘в”җ toв”ңГӯn</p>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Confirmation */}\r\n              <div className=\"bg-amber-50 border border-amber-200 rounded-lg p-3\">\r\n                <p className=\"text-amber-800 text-sm\"><strong>Lв•һв–‘u в”ңв•ң:</strong> Sau khi hoв”ңГЎn thв”ңГЎnh, bГҹв•‘Гӯn cГҹв•‘Вәn:</p>\r\n                <ul className=\"text-amber-700 text-xs mt-1 list-disc list-inside space-y-1\">\r\n                  <li>Mang tiГҹв•—Гјn mГҹв•‘в•–t в”ҖГҰв”ңГә thu nГҹв•—Г–p cho kГҹв•‘в”җ toв”ңГӯn</li>\r\n                  <li>Giao vГҹв•—Г… thu hГҹв•—Гҙi cho thГҹв•—Вә kho kiГҹв•—Гўm в”ҖГҰГҹв•‘в”җm</li>\r\n                  <li>Bв”ңГ