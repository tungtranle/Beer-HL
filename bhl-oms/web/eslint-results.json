ips: d.history?.[0]?.trips_count || 0, delivered: d.history?.[0]?.otd_score || 0, score: d.current_score || 0, rank: d.rank || 0, rankTotal: d.rank_total || 0 })\r\n      }).catch(() => {})\r\n  // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  }, [])\r\n\r\n  if (!user) {\r\n    if (typeof window !== 'undefined') router.push('/login')\r\n    return null\r\n  }\r\n\r\n  const initials = (user.full_name || '?').split(' ').slice(-2).map((w: string) => w[0]).join('').toUpperCase()\r\n\r\n  const handleLogout = () => {\r\n    clearAuth()\r\n    router.push('/login')\r\n  }\r\n\r\n  const handleGpsConsentToggle = async () => {\r\n    const newValue = !gpsConsent\r\n    setConsentSaving(true)\r\n    try {\r\n      await apiFetch('/driver/gps-consent', {\r\n        method: 'POST',\r\n        body: { consent_given: newValue },\r\n      })\r\n      setGpsConsent(newValue)\r\n      toast.success(newValue\r\n        ? 'в”ҖГүв”ңГә bГҹв•‘ВЎt chia sГҹв•‘в•— GPS О“ГҮГ¶ xГҹв•‘в”җp hГҹв•‘Гӯng & в”ҖГҰiГҹв•—Гўm thв•һв–‘Гҹв•—Ж’ng sГҹв•‘в•ң в”ҖГҰв•һв–‘Гҹв•—Гәc tв”ңВЎnh'\r\n        : 'в”ҖГүв”ңГә tГҹв•‘В»t chia sГҹв•‘в•— GPS О“ГҮГ¶ dГҹв•—В» liГҹв•—Г§u vГҹв•—ГҜ trв”ңВЎ khв”ңв”Өng cв”ңв–“n в”ҖГҰв•һв–‘Гҹв•—Гәc dв”ңв•Јng cho KPI'\r\n      )\r\n    } catch {\r\n      toast.error('Khв”ңв”Өng thГҹв•—Гў lв•һв–‘u cв”ңГЎi в”ҖГҰГҹв•‘в•–t О“ГҮГ¶ thГҹв•—ВЎ lГҹв•‘Гӯi sau')\r\n    } finally {\r\n      setConsentSaving(false)\r\n    }\r\n  }\r\n\r\n  const accountItems: SettingItem[] = [\r\n    { icon: Bell, label: 'Thв”ңв”Өng bв”ңГӯo', hint: 'BГҹв•‘ВЎt / tГҹв•‘В»t push', onClick: () => router.push('/dashboard/notifications') },\r\n    { icon: Shield, label: 'BГҹв•‘Гәo mГҹв•‘ВЎt', hint: 'в”ҖГүГҹв•—ГІi mГҹв•‘ВЎt khГҹв•‘вҢҗu' },\r\n    { icon: Smartphone, label: 'ThiГҹв•‘в”җt bГҹв•—ГҜ & GPS', hint: 'QuyГҹв•—Гјn vГҹв•—ГҜ trв”ңВЎ' },\r\n  ]\r\n\r\n  const supportItems: SettingItem[] = [\r\n    { icon: HelpCircle, label: 'Trung tв”ңГіm trГҹв•—Гә giв”ңв•‘p', hint: 'Hв•һв–‘Гҹв•—Вўng dГҹв•‘ВҪn sГҹв•—В