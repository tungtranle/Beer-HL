oast.error(e.message) }\r\n    finally { setBusy(false) }\r\n  }\r\n\r\n  const submit = async () => {\r\n    if (!active) return\r\n    setBusy(true)\r\n    try {\r\n      await apiFetch('/warehouse/cycle-count/submit', {\r\n        method: 'POST',\r\n        body: { task_id: active.id, scanned_lpns: scanned },\r\n      })\r\n      toast.success('в”ҖГүв”ңГә submit')\r\n      setActive(null)\r\n      setScanned([])\r\n      load()\r\n    } catch (e: any) { toast.error(e.message) }\r\n    finally { setBusy(false) }\r\n  }\r\n\r\n  const pendingCount = tasks.filter(t => t.status === 'pending').length\r\n  const progressCount = tasks.filter(t => t.status === 'in_progress').length\r\n  const doneCount = tasks.filter(t => t.status === 'completed').length\r\n  const varianceCount = tasks.filter(t => t.variance).length\r\n  const totalCount = tasks.length\r\n\r\n  const velColors: Record<string, string> = { A: 'bg-red-100 text-red-700 border-red-200', B: 'bg-amber-100 text-amber-700 border-amber-200', C: 'bg-green-100 text-green-700 border-green-200' }\r\n  const statusColors: Record<string, string> = { pending: 'bg-gray-100 text-gray-600', in_progress: 'bg-blue-100 text-blue-700', completed: 'bg-green-100 text-green-700' }\r\n\r\n  return (\r\n    <div className=\"p-4 max-w-5xl mx-auto\">\r\n      <h1 className=\"text-2xl font-bold mb-4\">вүЎЖ’Г¶Гі KiГҹв•—Гўm kв”ңВ¬ chu kГҹв•—в”Ӯ (Cycle Count)</h1>\r\n\r\n      {/* Summary bar */}\r\n      {tasks.length > 0 && (\r\n        <div className=\"grid grid-cols-4 gap-3 mb-4\">\r\n          <div className=\"bg-white rounded-xl border p-3 text-center shadow-sm\">\r\n            <div className=\"text-2xl font-bold text-gray-500\">{pendingCount}</div>\r\n            <div className=\"text-xs text-gray-500 mt-0.5\">ChГҹв•—ВҘ kiГҹв•—Гўm</div>\r\n          </div>\r\n          <div className=\"bg-white rounded-xl border p-3 text-center shadow-sm\">\r\n            <div className=\"text-2xl font-bold text-blue-600\">{progressCount}</div>\r\n            <div className=\"text-xs text-gray-500 mt-0.5\">в”ҖГүang kiГҹв•—Гўm</div>\r\n          </div>\r\n          <div className=\"bg-white rounded-xl border p-3 text-center shadow-sm\">\r\n            <div className=\"text-2xl font-bold text-green-600\">{doneCount}</div>\r\n            <div className=\"text-xs text-gray-500 mt-0.5\">Hoв”ңГЎn thв”ңГЎnh</div>\r\n          </div>\r\n          <div className={`rounded-xl border p-3 text-center shadow-sm ${varianceCount > 0 ? 'bg-red-50 border-red-200' : 'bg-white'}`}>\r\n            <div className={`text-2xl font-bold ${varianceCount > 0 ? 'text-red-600' : 'text-gray-400'}`}>{varianceCount}</div>\r\n            <div className=\"text-xs text-gray-500 mt-0.5\">Sai lГҹв•—Г§ch</div>\r\n          </div>\r\n        </div>\r\n      )}\r\n      {/* Progress bar */}\r\n      {totalCount > 0 && (\r\n        <div className=\"mb-4\">\r\n          <div className=\"flex justify-between text-xs text-gray-500 mb-1\">\r\n            <span>TiГҹв•‘в”җn в”ҖГҰГҹв•—Г– kiГҹв•—Гўm kв”ңВ¬</span>\r\n            <span>{doneCount}/{totalCount}</span>\r\n          </div>\r\n          <div className=\"w-full bg-gray-100 rounded-full h-2\">\r\n            <div className=\"bg-green-500 h-2 rounded-full transition-all\" style={{ width: `${totalCount > 0 ? (doneCount / totalCount) * 100 : 0}%` }} />\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      <div className=\"bg-white rounded shadow p-4 mb-4\">\r\n        <h2 className=\"font-semibold mb-2\">TГҹв•‘Гӯo task mГҹв•—Вўi (theo velocity class)</h2>\r\n        <div className=\"flex gap-2 items-end flex-wrap\">\r\n          <div>\r\n            <label className=\"block text-xs\">Ngв”ңГЎy kiГҹв•—Гўm</label>\r\n            <input type=\"date\" className=\"border rounded px-2 py-1\" value={date} onChange={e => setDate(e.target.value)} />\r\n          </div>\r\n          <div className=\"flex gap-2\">\r\n            {['A', 'B', 'C'].map(cls => (\r\n              <label key={cls} className=\"text-sm\">\r\n                <input type=\"checkbox\" checked={classes.includes(cls)}\r\n                  onChange={e => setClasses(e.target.checked ? [...classes, cls] : classes.filter(x => x !== cls))} /> {cls}\r\n              </label>\r\n            ))}\r\n          </div>\r\n          <button onClick={generate} disabled={busy} className=\"px-3 py-1 bg-blue-600 text-white rounded\">TГҹв•‘Гӯo task</button>\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"bg-white rounded shadow p-4\">\r\n        <h2 className=\"font-semibold mb-2\">Danh sв”ңГӯch task ({tasks.length})</h2>\r\n        <table className=\"w-full text-sm\">\r\n          <thead><tr className=\"text-left border-b text-xs text-gray-500 uppercase tracking-wide\"><th className=\"py-2\">Bin</th><th className=\"py-2\">Velocity</th><th className=\"py-2\">Ngв”ңГЎy</th><th className=\"py-2\">TrГҹв•‘Гӯng thв”ңГӯi</th><th className=\"py-2\">Sai lГҹв•—Г§ch</th><th className=\"py-2\"></th></tr></thead>\r\n          <tbody>\r\n            {tasks.map(t => {\r\n              const velClass = t.bin_code?.match(/^([ABC])/)?.[1] || ''\r\n              return (\r\n              <tr key={t.id} className=\"border-b hover:bg-gray-50\">\r\n                <td className=\"font-mono py-2 pr-4\">{t.bin_code}</td>\r\n                <td className=\"py-2 pr-4\">\r\n                  {velClass ? (\r\n                    <span className={`inline-block px-2 py-0.5 rounded text-xs font-bold border ${velColors[velClass] || 'bg-gray-100 text-gray-500'}`}>{velClass}</span>\r\n                  ) : 'О“ГҮГ¶'}\r\n                </td>\r\n                <td className=\"py-2 pr-4 text-gray-600\">{t.scheduled_date}</td>\r\n                <td className=\"py-2 pr-4\">\r\n                  <span className={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[t.status] || 'bg-gray-100 text-gray-600'}`}>\r\n                    {t.status === 'pending' ? 'ChГҹв•—ВҘ kiГҹв•—Гўm' : t.status === 'in_progress' ? 'в”ҖГүang kiГҹв•—Гўm' : t.status === 'completed' ? 'Xong' : t.status}\r\n                  </span>\r\n                </td>\r\n                <td className=\"py-2 pr-4\">{t.variance ? <span className=\"text-red-600 font-medium text-xs\">О“ГңГЎвҲ©в••Г… Sai lГҹв•—Г§ch</span> : <span className=\"text-gray-300\">О“ГҮГ¶</span>}</td>\r\n                <td className=\"py-2\">\r\n                  {t.status === 'pending' && (\r\n                    <button onClick={() => { setActive(t); setScanned([]) }}\r\n                      className=\"px-3 py-1 bg-brand-500 text-white rounded-lg text-xs font-medium hover:bg-brand-600\">BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu</button>\r\n                  )}\r\n                </td>\r\n              </tr>\r\n              )\r\n            })}\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n\r\n      {active && (\r\n        <div className=\"fixed inset-0 bg-black/40 flex items-center justify-center p-4\">\r\n          <div className=\"bg-white rounded-lg p-4 max-w-lg w-full\">\r\n            <h3 className=\"font-bold mb-2\">KiГҹв•—Гўm kв”ңВ¬ bin <code>{active.bin_code}</code></h3>\r\n            <div className=\"text-xs text-gray-500 mb-2\">\r\n              Expected: <code>{active.expected_snapshot || '[]'}</code>\r\n            </div>\r\n            <div className=\"flex gap-2 mb-3\">\r\n              <input autoFocus className=\"flex-1 border rounded px-2 py-1 font-mono\" placeholder=\"Quв”ңвҢҗt LPN\"\r\n                value={scan} onChange={e => setScan(e.target.value)}\r\n                onKeyDown={e => {\r\n                  if (e.key === 'Enter' && scan.trim()) {\r\n                    setScanned(Array.from(new Set([...scanned, scan.trim()])))\r\n                    setScan('')\r\n                  }\r\n                }} />\r\n            </div>\r\n            <div className=\"border rounded p-2 max-h-40 overflow-auto text-xs font-mono mb-3\">\r\n              {scanned.map(l => <div key={l}>О“ВЈГ  {l}</div>)}\r\n            </div>\r\n            <div className=\"flex justify-end gap-2\">\r\n              <button onClick={() => setActive(null)} className=\"px-3 py-1 border rounded\">HГҹв•—Вәy</button>\r\n              <button onClick={submit} disabled={busy} className=\"px-3 py-1 bg-blue-600 text-white rounded\">Submit ({scanned.length})</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\warehouse\\dashboard\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":9,"column":22,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":9,"endColumn":25,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[199,202],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[199,202],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":10,"column":26,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":10,"endColumn":29,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[231,234],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[231,234],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":11,"column":18,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":11,"endColumn":2