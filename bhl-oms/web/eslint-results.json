er\r\n  rate_per_km_l5: number\r\n  is_active: boolean\r\n  gates: TollGate[]\r\n}\r\n\r\ninterface TollGate {\r\n  id: string\r\n  expressway_id: string\r\n  gate_name: string\r\n  latitude: number\r\n  longitude: number\r\n  km_marker: number\r\n  detection_radius_m: number\r\n  is_active: boolean\r\n}\r\n\r\ninterface VehicleTypeCostDefault {\r\n  id: string\r\n  vehicle_type: string\r\n  fuel_consumption_per_km: number\r\n  fuel_price_per_liter: number\r\n  toll_class: string\r\n  fuel_cost_per_km?: number\r\n  is_active?: boolean\r\n  effective_date?: string\r\n  notes?: string\r\n}\r\n\r\ninterface DriverCostRate {\r\n  id: string\r\n  driver_name?: string\r\n  rate_per_km: number\r\n  min_daily_rate: number\r\n  description: string\r\n}\r\n\r\ntype Tab = 'toll-stations' | 'expressways' | 'vehicle-defaults' | 'driver-rates'\r\n\r\nconst TABS: { key: Tab; label: string; icon: string }[] = [\r\n  { key: 'toll-stations', label: 'TrГҹв•‘Гӯm thu phв”ңВЎ', icon: 'вүЎЖ’Г…Г№вҲ©в••Г…' },\r\n  { key: 'expressways', label: 'Cao tГҹв•—ГҰc', icon: 'вүЎЖ’ВўГәвҲ©в••Г…' },\r\n  { key: 'vehicle-defaults', label: 'в”ҖГүГҹв•—ГҜnh mГҹв•—вҢҗc xe', icon: 'О“Вўв•ң' },\r\n  { key: 'driver-rates', label: 'PhГҹв•—Г‘ cГҹв•‘Г‘p tв”ңГЎi xГҹв•‘в”җ', icon: 'вүЎЖ’ГҰГұ' },\r\n]\r\n\r\nconst TOLL_CLASSES = ['L1', 'L2', 'L3', 'L4', 'L5']\r\n\r\n// О“Г¶ГҮО“Г¶ГҮ Helpers О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction formatVND(n: number): string {\r\n  return new Intl.NumberFormat('vi-VN').format(n)\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮ Component О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nexport default function TransportCostsPage() {\r\n  const [tab, setTab] = useState<Tab>('toll-stations')\r\n  const [loading, setLoading] = useState(false)\r\n  const [saving, setSaving] = useState(false)\r\n  const [msg, setMsg] = useState('')\r\n\r\n  // Data\r\n  const [tollStations, setTollStations] = useState<TollStation[]>([])\r\n  const [expressways, setExpressways] = useState<TollExpressway[]>([])\r\n  const [vehicleDefaults, setVehicleDefaults] = useState<VehicleTypeCostDefault[]>([])\r\n  const [driverRates, setDriverRates] = useState<DriverCostRate[]>([])\r\n\r\n  // Edit state\r\n  const [editingStation, setEditingStation] = useState<Partial<TollStation> | null>(null)\r\n  const [editingExpressway, setEditingExpressway] = useState<Partial<TollExpressway> | null>(null)\r\n  const [editingRate, setEditingRate] = useState<Partial<DriverCostRate> | null>(null)\r\n  const [addingGateForId, setAddingGateForId] = useState<string | null>(null)\r\n  const [newGate, setNewGate] = useState({ gate_name: '', km_marker: 0, latitude: 0, longitude: 0 })\r\n\r\n  const loadData = useCallback(async () => {\r\n    setLoading(true)\r\n    try {\r\n      const [s, e, v, d] = await Promise.all([\r\n        apiFetch<any>('/cost/toll-stations'),\r\n        apiFetch<any>('/cost/toll-expressways'),\r\n        apiFetch<any>('/cost/vehicle-type-defaults'),\r\n        apiFetch<any>('/cost/driver-rates'),\r\n      ])\r\n      setTollStations(s.data || [])\r\n      setExpressways(e.data || [])\r\n      setVehicleDefaults(v.data || [])\r\n      setDriverRates(d.data || [])\r\n    } catch (err) {\r\n      handleError(err, { userMessage: 'Khв”ңв”Өng tГҹв•‘Гәi в”ҖГҰв•һв–‘Гҹв•—Гәc cГҹв•‘Г‘u hв”ңВјnh chi phв”ңВЎ vГҹв•‘ВЎn tГҹв•‘Гәi' })\r\n    }\r\n    setLoading(false)\r\n  }, [])\r\n\r\n  useEffect(() => { loadData() }, [loadData])\r\n\r\n  const showMsg = (text: string) => { setMsg(text); setTimeout(() => setMsg(''), 3000) }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ CRUD: Toll Stations О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\n  const saveTollStation = async () => {\r\n    if (!editingStation) return\r\n    setSaving(true)\r\n    try {\r\n      if (editingStation.id) {\r\n        await apiFetch(`/cost/toll-stations/${editingStation.id}`, { method: 'PUT', body: editingStation })\r\n      } else {\r\n        await apiFetch('/cost/toll-stations', { method: 'POST', body: editingStation })\r\n      }\r\n      setEditingStation(null)\r\n      showMsg('в”ҖГүв”ңГә lв•һв–‘u trГҹв•‘Гӯm thu phв”ңВЎ')\r\n      loadData()\r\n    } catch (err: any) {\r\n      showMsg('LГҹв•—Г№i: ' + err.message)\r\n    }\r\n    setSaving(false)\r\n  }\r\n\r\n  const deleteTollStation = async (id: string) => {\r\n    if (!confirm('Xв”ңв”Ӯa trГҹв•‘Гӯm thu phв”ңВЎ nв”ңГЎy?')) return\r\n    try {\r\n      await apiFetch(`/cost/toll-stations/${id}`, { method: 'DELETE' })\r\n      showMsg('в”ҖГүв”ңГә xв”ңв”Ӯa')\r\n      loadData()\r\n    } catch (err: any) { showMsg('LГҹв•—Г№i: ' + err.message) }\r\n  }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ CRUD: Expressways О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\n  const saveExpressway = async () => {\r\n    if (!editingExpressway) return\r\n    setSaving(true)\r\n    try {\r\n      if (editingExpressway.id) {\r\n        await apiFetch(`/cost/toll-expressways/${editingExpressway.id}`, { method: 'PUT', body: editingExpressway })\r\n      } else {\r\n        await apiFetch('/cost/toll-expressways', { method: 'POST', body: editingExpressway })\r\n      }\r\n      setEditingExpressway(null)\r\n      showMsg('в”ҖГүв”ңГә lв•һв–‘u tuyГҹв•‘в”җn cao tГҹв•—ГҰc')\r\n      loadData()\r\n    } catch (err: any) { showMsg('LГҹв•—Г№i: ' + err.message) }\r\n    setSaving(false)\r\n  }\r\n\r\n  const deleteExpressway = async (id: string) => {\r\n    if (!confirm('Xв”ңв”Ӯa tuyГҹв•‘в”җn cao tГҹв•—ГҰc nв”ңГЎy?')) return\r\n    try {\r\n      await apiFetch(`/cost/toll-expressways/${id}`, { method: 'DELETE' })\r\n      showMsg('в”ҖГүв”ңГә xв”ңв”Ӯa')\r\n      loadData()\r\n    } catch (err: any) { showMsg('LГҹв•—Г№i: ' + err.message) }\r\n  }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ CRUD: Expressway Gates О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n  const saveGate = async (expresswayId: string) => {\r\n    if (!newGate.gate_name) return\r\n    setSaving(true)\r\n    try {\r\n      await apiFetch(`/cost/toll-expressways/${expresswayId}/gates`, {\r\n        method: 'POST',\r\n        body: { ...newGate, detection_radius_m: 800 }\r\n      })\r\n      setAddingGateForId(null)\r\n      setNewGate({ gate_name: '', km_marker: 0, latitude: 0, longitude: 0 })\r\n      showMsg('в”ҖГүв”ңГә thв”ңВ¬m cГҹв•—ГІng')\r\n      loadData()\r\n    } catch (err: any) { showMsg('LГҹв•—Г№i: ' + err.message) }\r\n    setSaving(false)\r\n  }\r\n\r\n  const deleteGate = async (expresswayId: string, gateId: string) => {\r\n    if (!confirm('Xв”ңв”Ӯa cГҹв•—ГІng nв”ңГЎy?')) return\r\n    try {\r\n      await apiFetch(`/cost/toll-expressways/${expresswayId}/gates/${gateId}`, { method: 'DELETE' })\r\n      showMsg('в”ҖГүв”ңГә xв”ңв”Ӯa cГҹв•—ГІng')\r\n      loadData()\r\n    } catch (err: any) { showMsg('LГҹв•—Г№i: ' + err.message) }\r\n  }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ CRUD: Vehicle Defaults О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\n  const saveVehicleDefault = async (d: VehicleTypeCostDefault) => {\r\n    setSaving(true)\r\n    try {\r\n      await apiFetch(`/cost/vehicle-type-defaults/${d.id}`, { method: 'PUT', body: d })\r\n      showMsg('в”ҖГүв”ңГә lв•һв–‘u в”ҖГҰГҹв•—ГҜnh mГҹв•—вҢҗc xe')\r\n      loadData()\r\n    } catch (err: any) { showMsg('LГҹв•—Г№i: ' + err.message) }\r\n    setSaving(false)\r\n  }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ CRUD: Driver Rates О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\n  const saveDriverRate = async () => {\r\n    if (!editingRate) return\r\n    setSaving(true)\r\n    try {\r\n      if (editingRate.id) {\r\n        await apiFetch(`/cost/driver-rates/${editingRate.id}`, { method: 'PUT', body: editingRate })\r\n      } else {\r\n        await apiFetch('/cost/driver-rates', { method: 'POST', body: editingRate })\r\n      }\r\n      setEditingRate(null)\r\n      showMsg('в”ҖГүв”ңГә lв•һв–‘u phГҹв•—Г‘ cГҹв•‘Г‘p tв”ңГЎi xГҹв•‘в”җ')\r\n      loadData()\r\n    } catch (err: any) { showMsg('LГҹв•—Г№i: ' + err.message) }\r\n    setSaving(false)\r\n  }\r\n\r\n  const deleteDriverRate = async (id: string) => {\r\n    if (!confirm('Xв”ңв”Ӯa phГҹв•—Г‘ cГҹв•‘Г‘p tв”ңГЎi xГҹв•‘в”җ nв”ңГЎy?')) return\r\n    try {\r\n      await apiFetch(`/cost/driver-rates/${id}`, { method: 'DELETE' })\r\n      showMsg('в”ҖГүв”ңГә xв”ңв”Ӯa')\r\n      loadData()\r\n    } catch (err: any) { showMsg('LГҹв•—Г№i: ' + err.message) }\r\n  }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ Render О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\n  return (\r\n    <div className=\"max-w-6xl mx-auto\">\r\n      <div className=\"flex items-center justify-between mb-6\">\r\n        <div>\r\n          <h1 className=\"text-2xl font-bold text-gray-800\">вүЎЖ’ГҶв–‘ Chi phв”ңВЎ vГҹв•‘ВЎn chuyГҹв•—Гўn</h1>\r\n          <p className=\"text-sm text-gray-500 mt-1\">\r\n            QuГҹв•‘Гәn lв”ңв•ң trГҹв•‘Гӯm thu phв”ңВЎ, cao tГҹв•—ГҰc, в”ҖГҰГҹв•—ГҜnh mГҹв•—вҢҗc nhiв”ңВ¬n liГҹв•—Г§u vв”ңГЎ phГҹв•—Г‘ cГҹв•‘Г‘p tв”ңГЎi xГҹв•‘в”җ.\r\n            DГҹв•—В» liГҹв•—Г§u nв”ңГЎy в”ҖГҰв•һв–‘Гҹв•—Гәc dв”ңв•Јng в”ҖГҰГҹв•—Гў tв”ңВЎnh chi phв”ңВЎ trong lГҹв•‘ВЎp kГҹв•‘в”җ hoГҹв•‘Гӯch giao hв”ңГЎng.\r\n          </p>\r\n        </div>\r\n        <button onClick={loadData} className=\"px-3 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg text-sm\">\r\n          вүЎЖ’Г¶ГӨ TГҹв•‘Гәi lГҹв•‘Гӯi\r\n        </button>\r\n      </div>\r\n\r\n      {msg && (\r\n        <div className=\"mb-4 p-3 rounded-lg bg-green-50 text-green-700 text-sm border border-green-200\">\r\n          О“ВЈГ  {msg}\r\n        </div>\r\n      )}\r\n\r\n      {/* Summary Cards */}\r\n      <div className=\"grid grid-cols-4 gap-4 mb-6\">\r\n        <div className=\"bg-white rounded-lg p-4 border shadow-sm\">\r\n          <div className=\"text-3xl font-bold text-amber-600\">{tollStations.length}</div>\r\n          <div className=\"text-xs text-gray-500\">TrГҹв•‘Гӯm thu phв”ңВЎ</div>\r\n        </div>\r\n        <div className=\"bg-white rounded-lg p-4 border shadow-sm\">\r\n          <div className=\"text-3xl font-bold text-blue-600\">{expressways.length}</div>\r\n          <div className=\"text-xs text-gray-500\">TuyГҹв•‘в”җn cao tГҹв•—ГҰc</div>\r\n        </div>\r\n        <div className=\"bg-white rounded-lg p-4 border shadow-sm\">\r\n          <div className=\"text-3xl font-bold text-green-600\">{vehicleDefaults.filter(v => v.fuel_consumption_per_km > 0).length}</div>\r\n          <div className=\"text-xs text-gray-500\">LoГҹв•‘Гӯi xe cв”ңв”Ӯ в”ҖГҰГҹв•—ГҜnh mГҹв•—вҢҗc</div>\r\n        </div>\r\n        <div className=\"bg-white rounded-lg p-4 border shadow-sm\">\r\n          <div className=\"text-3xl font-bold text-purple-600\">{driverRates.length}</div>\r\n          <div className=\"text-xs text-gray-500\">PhГҹв•—Г‘ cГҹв•‘Г‘p tв”ңГЎi xГҹв•‘в”җ</div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Tabs */}\r\n      <div className=\"flex gap-1 bg-gray-100 rounded-xl p-1 mb-6\">\r\n        {TABS.map(t => (\r\n          <button key={t.key}\r\n            onClick={() => setTab(t.key)}\r\n            className={`flex-1 py-2.5 px-4 rounded-lg text-sm font-medium transition ${\r\n              tab === t.key ? 'bg-white text-gray-800 shadow-sm' : 'text-gray-500 hover:text-gray-700'\r\n            }`}>\r\n            {t.icon} {t.label}\r\n          </button>\r\n        ))}\r\n      </div>\r\n\r\n      {loading ? (\r\n        <div className=\"text-center py-20 text-gray-400\">в”ҖГүang tГҹв•‘Гәi...</div>\r\n      ) : (\r\n        <>\r\n          {/* TAB: Toll Stations */}\r\n          {tab === 'toll-stations' && (\r\n            <div>\r\n              <div className=\"flex justify-between items-center mb-4\">\r\n                <h2 className=\"text-lg font-semibold\">вүЎЖ’Г…Г№вҲ©в••Г… Danh sв”ңГӯch trГҹв•‘Гӯm thu phв”ңВЎ</h2>\r\n                <button onClick={() => setEditingStation({ station_name: '', latitude: 0, longitude: 0, detection_radius_m: 500, fee_l1: 0, fee_l2: 0, fee_l3: 0, fee_l4: 0, fee_l5: 0, is_active: true })}\r\n                  className=\"px-4 py-2 bg-amber-500 text-white rounded-lg hover:bg-amber-600 text-sm\">\r\n                  + Thв”ңВ¬m trГҹв•‘Гӯm\r\n                </button>\r\n              </div>\r\n\r\n              {editingStation && (\r\n                <div className=\"bg-amber-50 border border-amber-200 rounded-xl p-4 mb-4\">\r\n                  <h3 className=\"font-semibold mb-3\">{editingStation.id ? 'SГҹв•—ВЎa' : 'Thв”ңВ¬m'} trГҹв•‘Гӯm thu phв”ңВЎ</h3>\r\n                  <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3 text-sm\">\r\n                    <div className=\"col-span-2\">\r\n                      <label className=\"text-xs text-gray-500\">Tв”ңВ¬n trГҹв•‘Гӯm</label>\r\n                      <input value={editingStation.station_name || ''} onChange={e => setEditingStation({ ...editingStation, station_name: e.target.value })}\r\n                        className=\"w-full border rounded-lg px-3 py-2 mt-1\" placeholder=\"TrГҹв•‘Гӯm BOT QuГҹв•—ГҰc lГҹв•—Г– 1\" />\r\n                    </div>\r\n                    <div>\r\n                      <label className=\"text-xs text-gray-500\">Vв”ҖвҢҗ в”ҖГҰГҹв•—Г– (Lat)</label>\r\n                      <input type=\"number\" step=\"0.0001\" value={editingStation.latitude || ''} onChange={e => setEditingStation({ ...editingStation, latitude: parseFloat(e.target.value) || 0 })}\r\n                        className=\"w-full border rounded-lg px-3 py-2 mt-1\" />\r\n                    </div>\r\n                    <div>\r\n                      <label className=\"text-xs text-gray-500\">Kinh в”ҖГҰГҹв•—Г– (Lng)</label>\r\n                      <input type=\"number\" step=\"0.0001\" value={editingStation.longitude || ''} onChange={e => setEditingStation({ ...editingStation, longitude: parseFloat(e.target.value) || 0 })}\r\n                        className=\"w-full border rounded-lg px-3 py-2 mt-1\" />\r\n                    </div>\r\n                    {TOLL_CLASSES.map(cls => (\r\n                      <div key={cls}>\r\n                        <label className=\"text-xs text-gray-500\">Phв”ңВЎ {cls} (О“Г©ВҪ)</label>\r\n                        <input type=\"number\" value={(editingStation as any)[`fee_${cls.toLowerCase()}`] || ''} onChange={e => setEditingStation({ ...editingStation, [`fee_${cls.toLowerCase()}`]: parseFloat(e.target.value) || 0 })}\r\n                          className=\"w-full border rounded-lg px-3 py-2 mt-1\" placeholder=\"35000\" />\r\n                      </div>\r\n                    ))}\r\n                    <div>\r\n                      <label className=\"text-xs text-gray-500\">Bв”ңГӯn kв”ңВЎnh (m)</label>\r\n                      <input type=\"number\" value={editingStation.detection_radius_m || 500} onChange={e => setEditingStation({ ...editingStation, detection_radius_m: parseInt(e.target.value) || 500 })}\r\n                        className=\"w-full border rounded-lg px-3 py-2 mt-1\" />\r\n                    </div>\r\n                  </div>\r\n                  <div className=\"flex gap-2 mt-4\">\r\n                    <button onClick={saveTollStation} disabled={saving} className=\"px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm disabled:opacity-50\">\r\n                      {saving ? 'в”ҖГүang lв•һв–‘u...' : 'вүЎЖ’ГҶв•ӣ Lв•һв–‘u'}\r\n                    </button>\r\n                    <button onClick={() => setEditingStation(null)} className=\"px-4 py-2 bg-gray-200 rounded-lg hover:bg-gray-300 text-sm\">HГҹв•—Вәy</button>\r\n                  </div>\r\n                </div>\r\n              )}\r\n\r\n              <div className=\"bg-white rounded-xl border overflow-hidden\">\r\n                <table className=\"w-full text-sm\">\r\n                  <thead className=\"bg-gray-50\">\r\n                    <tr>\r\n                      <th className=\"text-left py-3 px-4\">Tв”ңВ¬n trГҹв•‘Гӯm</th>\r\n                      <th className=\"text-center py-3 px-2\">TГҹв•—Г¬a в”ҖГҰГҹв•—Г–</th>\r\n                      {TOLL_CLASSES.map(c => <th key={c} className=\"text-right py-3 px-2\">{c}</th>)}\r\n                      <th className=\"text-center py-3 px-2\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n                      <th className=\"text-center py-3 px-2\">Thao tв”ңГӯc</th>\r\n                    </tr>\r\n                  </thead>\r\n                  <tbody>\r\n                    {tollStations.map(st => (\r\n                      <tr key={st.id} className=\"border-t hover:bg-gray-50\">\r\n                        <td className=\"py-2.5 px-4 font-medium\">{st.station_name}</td>\r\n                        <td className=\"py-2.5 px-2 text-center text-xs text-gray-400\">{st.latitude.toFixed(4)}, {st.longitude.toFixed(4)}</td>\r\n                        <td className=\"py-2.5 px-2 text-right\">{formatVND(st.fee_l1)}</td>\r\n                        <td className=\"py-2.5 px-2 text-right\">{formatVND(st.fee_l2)}</td>\r\n                        <td className=\"py-2.5 px-2 text-right\">{formatVND(st.fee_l3)}</td>\r\n                        <td className=\"py-2.5 px-2 text-right\">{formatVND(st.fee_l4)}</td>\r\n                        <td className=\"py-2.5 px-2 text-right\">{formatVND(st.fee_l5)}</td>\r\n                        <td className=\"py-2.5 px-2 text-center\">\r\n                          <span className={`px-2 py-0.5 rounded-full text-xs ${st.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>\r\n                            {st.is_active ? 'HoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng' : 'TГҹв•‘В»t'}\r\n                          </span>\r\n                        </td>\r\n                        <td className=\"py-2.5 px-2 text-center\">\r\n                          <button onClick={() => setEditingStation(st)} className=\"text-blue-500 hover:text-blue-700 mr-2\">О“ВЈГ…вҲ©в••Г…</button>\r\n                          <button onClick={() => deleteTollStation(st.id)} className=\"text-red-400 hover:text-red-600\">вүЎЖ’Г№ГҰвҲ©в••Г…</button>\r\n                        </td>\r\n                      </tr>\r\n                    ))}\r\n                    {tollStations.length === 0 && (\r\n                      <tr><td colSpan={9} className=\"text-center py-8 text-gray-400\">Chв•һв–‘a cв”ңв”Ӯ trГҹв•‘Гӯm thu phв”ңВЎ. BГҹв•‘Г‘m \"+ Thв”ңВ¬m trГҹв•‘Гӯm\" в”ҖГҰГҹв•—Гў thв”ңВ¬m.</td></tr>\r\n                    )}\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {/* TAB: Expressways */}\r\n          {tab === 'expressways' && (\r\n            <div>\r\n              <div className=\"flex justify-between items-center mb-4\">\r\n                <h2 className=\"text-lg font-semibold\">вүЎЖ’ВўГәвҲ©в••Г… TuyГҹв•‘в”җn cao tГҹв•—ГҰc</h2>\r\n                <button onClick={() => setEditingExpressway({ expressway_name: '', rate_per_km_l1: 0, rate_per_km_l2: 0, rate_per_km_l3: 0, rate_per_km_l4: 0, rate_per_km_l5: 0, is_active: true })}\r\n                  className=\"px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 text-sm\">\r\n                  + Thв”ңВ¬m tuyГҹв•‘в”җn\r\n                </button>\r\n              </div>\r\n\r\n              {editingExpressway && (\r\n                <div className=\"bg-blue-50 border border-blue-200 rounded-xl p-4 mb-4\">\r\n                  <h3 className=\"font-semibold mb-3\">{editingExpressway.id ? 'SГҹв•—ВЎa' : 'Thв”ңВ¬m'} tuyГҹв•‘в”җn cao tГҹв•—ГҰc</h3>\r\n                  <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3 text-sm\">\r\n                    <div className=\"col-span-2\">\r\n                      <label className=\"text-xs text-gray-500\">Tв”ңВ¬n tuyГҹв•‘в”җn</label>\r\n                      <input value={editingExpressway.expressway_name || ''} onChange={e => setEditingExpressway({ ...editingExpressway, expressway_name: e.target.value })}\r\n                        className=\"w-full border rounded-lg px-3 py-2 mt-1\" placeholder=\"Cao tГҹв•—ГҰc Hв”ңГЎ NГҹв•—Г–i - HГҹв•‘Гәi Phв”ңв–“ng\" />\r\n                    </div>\r\n                    {TOLL_CLASSES.map(cls => (\r\n                      <div key={cls}>\r\n                        <label className=\"text-xs text-gray-500\">О“Г©ВҪ/km {cls}</label>\r\n                        <input type=\"number\" value={(editingExpressway as any)[`rate_per_km_${cls.toLowerCase()}`] || ''} onChange={e => setEditingExpressway({ ...editingExpressway, [`rate_per_km_${cls.toLowerCase()}`]: parseFloat(e.target.value) || 0 })}\r\n                          className=\"w-full border rounded-lg px-3 py-2 mt-1\" placeholder=\"1500\" />\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                  <div className=\"flex gap-2 mt-4\">\r\n                    <button onClick={saveExpressway} disabled={saving} className=\"px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm disabled:opacity-50\">\r\n                      {saving ? 'в”ҖГүang lв•һв–‘u...' : 'вүЎЖ’ГҶв•ӣ Lв•һв–‘u'}\r\n                    </button>\r\n                    <button onClick={() => setEditingExpressway(null)} className=\"px-4 py-2 bg-gray-200 rounded-lg hover:bg-gray-300 text-sm\">HГҹв•—Вәy</button>\r\n                  </div>\r\n                </div>\r\n              )}\r\n\r\n              <div className=\"space-y-4\">\r\n                {expressways.map(ew => (\r\n                  <div key={ew.id} className=\"bg-white rounded-xl border p-4\">\r\n                    <div className=\"flex justify-between items-center mb-2\">\r\n                      <h3 className=\"font-semibold\">{ew.expressway_name}</h3>\r\n                      <div className=\"flex items-center gap-2\">\r\n                        <span className={`px-2 py-0.5 rounded-full text-xs ${ew.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>\r\n                          {ew.is_active ? 'HoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng' : 'TГҹв•‘В»t'}\r\n                        </span>\r\n                        <button onClick={() => setEditingExpressway(ew)} className=\"text-blue-500 hover:text-blue-700\">О“ВЈГ…вҲ©в••Г…</button>\r\n                        <button onClick={() => deleteExpressway(ew.id)} className=\"text-red-400 hover:text-red-600\">вүЎЖ’Г№ГҰвҲ©в••Г…</button>\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"flex gap-4 text-xs text-gray-500 mb-3\">\r\n                      {TOLL_CLASSES.map(c => (\r\n                        <span key={c}>{c}: {formatVND((ew as any)[`rate_per_km_${c.toLowerCase()}`])}О“Г©ВҪ/km</span>\r\n                      ))}\r\n                    </div>\r\n                    {/* Gate list with management */}\r\n                    <div className=\"bg-gray-50 rounded-lg p-3\">\r\n                      <div className=\"flex justify-between items-center mb-2\">\r\n                        <p className=\"text-xs font-medium text-gray-600\">вүЎЖ’ВўГәвҲ©в••Г… CГҹв•—ВЎa ra/vв”ңГЎo ({ew.gates?.length || 0})</p>\r\n                        <button onClick={() => { setAddingGateForId(addingGateForId === ew.id ? null : ew.id); setNewGate({ gate_name: '', km_marker: 0, latitude: 0, longitude: 0 }) }}\r\n                          className=\"text-xs px-2 py-1 bg-blue-500 text-white rounded hover:bg-blue-600\">\r\n                          + Thв”ңВ¬m cГҹв•—ГІng\r\n                        </button>\r\n                      </div>\r\n\r\n                      {/* Form thв”ңВ¬m cГҹв•—ГІng mГҹв•—Вўi */}\r\n                      {addingGateForId === ew.id && (\r\n                        <div className=\"bg-blue-50 border border-blue-200 rounded-lg p-3 mb-2\">\r\n                          <div className=\"grid grid-cols-2 md:grid-cols-4 gap-2 text-xs\">\r\n                            <div>\r\n                              <label className=\"text-gray-500\">Tв”ңВ¬n cГҹв•—ГІng</label>\r\n                              <input value={newGate.gate_name} onChange={e => setNewGate({ ...newGate, gate_name: e.target.value })}\r\n                                className=\"w-full border rounded px-2 py-1.5 mt-0.5\" placeholder=\"Nв”ңв•‘t giao ABC\" />\r\n                            </div>\r\n                            <div>\r\n                              <label className=\"text-gray-500\">Km marker</label>\r\n                              <input type=\"number\" value={newGate.km_marker || ''} onChange={e => setNewGate({ ...newGate, km_marker: parseFloat(e.target.value) || 0 })}\r\n                                className=\"w-full border rounded px-2 py-1.5 mt-0.5\" placeholder=\"52\" />\r\n                            </div>\r\n                            <div>\r\n                              <label className=\"text-gray-500\">Vв”ҖвҢҗ в”ҖГҰГҹв•—Г– (Lat)</label>\r\n                              <input type=\"number\" step=\"0.001\" value={newGate.latitude || ''} onChange={e => setNewGate({ ...newGate, latitude: parseFloat(e.target.value) || 0 })}\r\n                                className=\"w-full border rounded px-2 py-1.5 mt-0.5\" placeholder=\"20.977\" />\r\n                            </div>\r\n                            <div>\r\n                              <label className=\"text-gray-500\">Kinh в”ҖГҰГҹв•—Г– (Lng)</label>\r\n                              <input type=\"number\" step=\"0.001\" value={newGate.longitude || ''} onChange={e => setNewGate({ ...newGate, longitude: parseFloat(e.target.value) || 0 })}\r\n                                className=\"w-full border rounded px-2 py-1.5 mt-0.5\" placeholder=\"105.952\" />\r\n                            </div>\r\n                          </div>\r\n                          <div className=\"flex gap-2 mt-2\">\r\n                            <button onClick={() => saveGate(ew.id)} disabled={saving || !newGate.gate_name}\r\n                              className=\"px-3 py-1 bg-green-600 text-white rounded text-xs hover:bg-green-700 disabled:opacity-50\">\r\n                              {saving ? 'в”ҖГүang lв•һв–‘u...' : 'вүЎЖ’ГҶв•ӣ Lв•һв–‘u'}\r\n                            </button>\r\n                            <button onClick={() => setAddingGateForId(null)} className=\"px-3 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300\">HГҹв•—Вәy</button>\r\n                          </div>\r\n                        </div>\r\n                      )}\r\n\r\n                      {ew.gates && ew.gates.length > 0 && (\r\n                        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2 text-xs\">\r\n                          {ew.gates.map(g => (\r\n                            <div key={g.id} className=\"bg-white rounded px-2 py-1.5 border flex justify-between items-center group\">\r\n                              <div>\r\n                                <span className=\"font-medium\">{g.gate_name}</span>\r\n                                <span className=\"text-gray-400 ml-1\">Km {g.km_marker}</span>\r\n                                <span