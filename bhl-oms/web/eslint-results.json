stNever","fix":{"range":[3474,3477],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":253,"column":54,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":253,"endColumn":57,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[9349,9352],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[9349,9352],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":329,"column":101,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":329,"endColumn":104,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[13431,13434],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[13431,13434],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":7,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState, useCallback } from 'react'\r\nimport { apiFetch, getUser } from '@/lib/api'\r\nimport { formatVND } from '@/lib/status-config'\r\nimport { toast } from '@/lib/useToast'\r\n\r\ninterface EODCheckpoint {\r\n  id: string\r\n  session_id: string\r\n  trip_id: string\r\n  checkpoint_type: string\r\n  checkpoint_order: number\r\n  status: string\r\n  driver_data: any\r\n  submitted_at: string | null\r\n  receiver_name: string\r\n  confirmed_at: string | null\r\n}\r\n\r\nconst cpTypeLabels: Record<string, string> = {\r\n  container_return: 'NhГҹв•‘ВЎn vГҹв•—Г… & hв”ңГЎng trГҹв•‘Гә tГҹв•—ВҪ tв”ңГЎi xГҹв•‘в”җ',\r\n  cash_handover: 'NhГҹв•‘ВЎn tiГҹв•—Гјn tГҹв•—ВҪ tв”ңГЎi xГҹв•‘в”җ',\r\n  vehicle_return: 'NhГҹв•‘ВЎn xe tГҹв•—ВҪ tв”ңГЎi xГҹв•‘в”җ',\r\n}\r\n\r\nconst cpTypeIcons: Record<string, string> = {\r\n  container_return: 'вүЎЖ’ГҙВӘ',\r\n  cash_handover: 'вүЎЖ’ГҶв–‘',\r\n  vehicle_return: 'вүЎЖ’ГңВў',\r\n}\r\n\r\n// Subpage selection\r\ntype ViewMode = 'list' | 'detail'\r\n\r\nexport default function EODReceiverPage() {\r\n  const user = getUser()\r\n  const [checkpoints, setCheckpoints] = useState<EODCheckpoint[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [selectedCp, setSelectedCp] = useState<EODCheckpoint | null>(null)\r\n  const [viewMode, setViewMode] = useState<ViewMode>('list')\r\n  const [processing, setProcessing] = useState(false)\r\n\r\n  // Determine checkpoint type based on user role\r\n  const getCpType = () => {\r\n    if (!user) return 'container_return'\r\n    const role = user.role\r\n    if (role === 'warehouse_handler') return 'container_return'\r\n    if (role === 'accountant') return 'cash_handover'\r\n    if (role === 'dispatcher' || role === 'admin') return 'vehicle_return'\r\n    return 'container_return' // fallback\r\n  }\r\n  const cpType = getCpType()\r\n\r\n  // Receiver form state\r\n  const [receiverData, setReceiverData] = useState<any>({})\r\n  const [discrepancyReason, setDiscrepancyReason] = useState('')\r\n  const [rejectReason, setRejectReason] = useState('')\r\n\r\n  const loadPending = useCallback(async () => {\r\n    try {\r\n      const res: any = await apiFetch(`/eod/pending/${cpType}`)\r\n      setCheckpoints(res.data || [])\r\n    } catch {\r\n      setCheckpoints([])\r\n    } finally {\r\n      setLoading(false)\r\n    }\r\n  }, [cpType])\r\n\r\n  useEffect(() => { loadPending() }, [loadPending])\r\n\r\n  // Auto-refresh\r\n  useEffect(() => {\r\n    const interval = setInterval(loadPending, 15000)\r\n    return () => clearInterval(interval)\r\n  }, [loadPending])\r\n\r\n  const handleConfirm = async (checkpointId: string) => {\r\n    setProcessing(true)\r\n    try {\r\n      await apiFetch(`/eod/checkpoint/${checkpointId}/confirm`, {\r\n        method: 'POST',\r\n        body: {\r\n          receiver_data: receiverData,\r\n          discrepancy_reason: discrepancyReason || undefined,\r\n        },\r\n      })\r\n      toast.success('в”ҖГүв”ңГә xв”ңГӯc nhГҹв•‘ВЎn thв”ңГЎnh cв”ңв”Өng')\r\n      setViewMode('list')\r\n      setSelectedCp(null)\r\n      await loadPending()\r\n    } catch (err: any) {\r\n      toast.error(err?.message || 'LГҹв•—Г№i xв”ңГӯc nhГҹв•‘ВЎn')\r\n    } finally {\r\n      setProcessing(false)\r\n    }\r\n  }\r\n\r\n  const handleReject = async (checkpointId: string) => {\r\n    if (!rejectReason.trim()) {\r\n      toast.error('Vui lв”ңв–“ng nhГҹв•‘ВЎp lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi')\r\n      return\r\n    }\r\n    setProcessing(true)\r\n    try {\r\n      await apiFetch(`/eod/checkpoint/${checkpointId}/reject`, {\r\n        method: 'POST',\r\n        body: { reason: rejectReason },\r\n      })\r\n      toast.success('в”ҖГүв”ңГә tГҹв•—ВҪ chГҹв•—ГҰi О“ГҮГ¶ tв”ңГЎi xГҹв•‘в”җ sГҹв•‘в•ң gГҹв•—ВЎi lГҹв•‘Гӯi')\r\n      setViewMode('list')\r\n      setSelectedCp(null)\r\n      setRejectReason('')\r\n      await loadPending()\r\n    } catch (err: any) {\r\n      toast.error(err?.message || 'LГҹв•—Г№i tГҹв•—ВҪ chГҹв•—ГҰi')\r\n    } finally {\r\n      setProcessing(false)\r\n    }\r\n  }\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"p-6\">\r\n        <div className=\"animate-pulse space-y-4\">\r\n          <div className=\"h-8 bg-gray-200 rounded w-1/3\" />\r\n          <div className=\"h-32 bg-gray-200 rounded\" />\r\n        </div>\r\n      </div>\r\n    )\r\n  }\r\n\r\n  // List view\r\n  if (viewMode === 'list') {\r\n    const eodSteps = [\r\n      { key: 'container_return', label: 'NhГҹв•‘ВЎn vГҹв•—Г… & hв”ңГЎng trГҹв•‘Гә', icon: 'вүЎЖ’ГҙВӘ', role: 'warehouse_handler' },\r\n      { key: 'cash_handover', label: 'NhГҹв•‘ВЎn tiГҹв•—Гјn mГҹв•‘в•–t', icon: 'вүЎЖ’ГҶв–‘', role: 'accountant' },\r\n      { key: 'vehicle_return', label: 'NhГҹв•‘ВЎn xe vГҹв•—Гј kho', icon: 'вүЎЖ’ГңВў', role: 'dispatcher/admin' },\r\n    ]\r\n    const activeStep = eodSteps.findIndex(s => s.key === cpType)\r\n\r\n    return (\r\n      <div className=\"p-6 max-w-4xl mx-auto\">\r\n        {/* EOD 3-step progress */}\r\n        <div className=\"bg-white rounded-xl shadow-sm px-4 py-3 mb-6\">\r\n          <div className=\"flex items-center\">\r\n            {eodSteps.map((step, i) => (\r\n              <div key={step.key} className=\"flex items-center flex-1\">\r\n                <div className={`flex flex-col items-center gap-1 ${i === activeStep ? 'opacity-100' : 'opacity-40'}`}>\r\n                  <div className={`w-10 h-10 rounded-full flex items-center justify-center text-lg font-bold border-2 transition ${\r\n                    i < activeStep ? 'bg-brand-500 border-brand-500 text-white' :\r\n                    i === activeStep ? 'border-brand-500 bg-brand-50 text-brand-600' :\r\n                    'border-gray-200 bg-gray-50 text-gray-400'\r\n                  }`}>\r\n                    {i < activeStep ? 'О“ВЈГҙ' : step.icon}\r\n                  </div>\r\n                  <div className={`text-xs font-medium ${i === activeStep ? 'text-brand-600' : 'text-gray-400'}`}>{step.label}</div>\r\n                  <div className=\"text-[10px] text-gray-400\">{step.role}</div>\r\n                </div>\r\n                {i < eodSteps.length - 1 && (\r\n                  <div className={`flex-1 h-0.5 mx-2 mb-7 ${i < activeStep ? 'bg-brand-500' : 'bg-gray-200'}`} />\r\n                )}\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"flex items-center gap-3 mb-6\">\r\n          <span className=\"text-3xl\">{cpTypeIcons[cpType]}</span>\r\n          <div>\r\n            <h1 className=\"text-2xl font-bold text-gray-900\">{cpTypeLabels[cpType]}</h1>\r\n            <p className=\"text-sm text-gray-500\">\r\n              {checkpoints.length > 0\r\n                ? `${checkpoints.length} yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰang chГҹв•—ВҘ xв”ңГӯc nhГҹв•‘ВЎn`\r\n                : 'Khв”ңв”Өng cв”ңв”Ӯ yв”ңВ¬u cГҹв•‘Вәu nв”ңГЎo в”ҖГҰang chГҹв•—ВҘ'\r\n              }\r\n            </p>\r\n          </div>\r\n        </div>\r\n\r\n        {checkpoints.length === 0 ? (\r\n          <div className=\"text-center py-16 bg-gray-50 rounded-xl\">\r\n            <div className=\"text-6xl mb-4\">вүЎЖ’ГҙГҜ</div>\r\n            <p className=\"text-gray-500\">Chв•һв–‘a cв”ңв”Ӯ tв”ңГЎi xГҹв•‘в”җ nв”ңГЎo gГҹв•—ВЎi yв”ңВ¬u cГҹв•‘Вәu {cpTypeLabels[cpType]?.toLowerCase()}</p>\r\n            <p className=\"text-xs text-gray-400 mt-2\">Trang sГҹв•‘в•ң tГҹв•—в–’ cГҹв•‘ВЎp nhГҹв•‘ВЎt mГҹв•—Г№i 15 giв”ңГіy</p>\r\n          </div>\r\n        ) : (\r\n          <div className=\"space-y-3\">\r\n            {checkpoints.map(cp => (\r\n              <div\r\n                key={cp.id}\r\n                onClick={() => { setSelectedCp(cp); setViewMode('detail'); setReceiverData({}); setDiscrepancyReason(''); }}\r\n                className=\"bg-white rounded-xl shadow-sm border border-gray-100 p-4 cursor-pointer hover:border-[#F68634] hover:shadow-md transition-all\"\r\n              >\r\n                <div className=\"flex items-center justify-between\">\r\n                  <div>\r\n                    <div className=\"font-semibold text-gray-800\">\r\n                      ChuyГҹв•‘в”җn xe (Trip)\r\n                    </div>\r\n                    <div className=\"text-sm text-gray-500\">\r\n                      GГҹв•—ВЎi lв”ңв•‘c: {cp.submitted_at ? new Date(cp.submitted_at).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) : 'О“ГҮГ¶'}\r\n                    </div>\r\n                  </div>\r\n                  <span className=\"text-sm text-[#F68634] font-medium\">Xem chi tiГҹв•‘в”җt О“ГҘГҶ</span>\r\n                </div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        )}\r\n      </div>\r\n    )\r\n  }\r\n\r\n  // Detail view\r\n  if (!selectedCp) return null\r\n  const driverData = selectedCp.driver_data\r\n\r\n  return (\r\n    <div className=\"p-6 max-w-4xl mx-auto\">\r\n      <button\r\n        onClick={() => { setViewMode('list'); setSelectedCp(null) }}\r\n        className=\"mb-4 text-sm text-gray-500 hover:text-gray-700\"\r\n      >\r\n        О“ГҘГү Quay lГҹв•‘Гӯi danh sв”ңГӯch\r\n      </button>\r\n\r\n      <div className=\"flex items-center gap-3 mb-6\">\r\n        <span className=\"text-3xl\">{cpTypeIcons[cpType]}</span>\r\n        <div>\r\n          <h1 className=\"text-xl font-bold text-gray-900\">{cpTypeLabels[cpType]}</h1>\r\n          <p className=\"text-sm text-gray-500\">\r\n            GГҹв•—ВЎi lв”ңв•‘c: {selectedCp.submitted_at ? new Date(selectedCp.submitted_at).toLocaleString('vi-VN') : 'О“ГҮГ¶'}\r\n          </p>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Container Return О“ГҮГ¶ W-WH-06 */}\r\n      {cpType === 'container_return' && driverData && (\r\n        <div className=\"space-y-4\">\r\n          <div className=\"bg-white rounded-xl shadow-sm p-4\">\r\n            <h3 className=\"font-semibold text-gray-800 mb-3\">VГҹв•—Г… trГҹв•‘Гә vГҹв•—Гј</h3>\r\n            <table className=\"w-full text-sm\">\r\n              <thead>\r\n                <tr className=\"text-gray-500 border-b\">\r\n                  <th className=\"text-left py-2\">LoГҹв•‘Гӯi vГҹв•—Г…</th>\r\n                  <th className=\"text-center py-2\">TX khai</th>\r\n                  <th className=\"text-center py-2\">TK в”ҖГҰГҹв•‘в”җm</th>\r\n                  <th className=\"text-center py-2\">KГҹв•‘в”җt quГҹв•‘Гә</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody>\r\n                {(driverData.items || []).map((item: any, idx: number) => {\r\n                  const tkCount = receiverData[`count_${idx}`] ?? item.actual_qty\r\n                  const match = tkCount === item.actual_qty\r\n                  return (\r\n                    <tr key={idx} className=\"border-b\">\r\n                      <td className=\"py-2\">{item.asset_type === 'crate' ? 'Kв”ңвҢҗt 24 lon' : item.asset_type === 'bottle' ? 'Thв”ңв•Јng chai' : item.asset_type}</td>\r\n                      <td className=\"text-center\">{item.actual_qty}</td>\r\n                      <td className=\"text-center\">\r\n                        <input\r\n                          type=\"number\"\r\n                          value={tkCount}\r\n                          onChange={e => setReceiverData({ ...receiverData, [`count_${idx}`]: parseInt(e.target.value) || 0 })}\r\n                          className=\"w-20 text-center border rounded px-2 py-1\"\r\n                        />\r\n                      </td>\r\n                      <td className={`text-center font-medium ${match ? 'text-green-600' : 'text-red-600'}`}>\r\n                        {match ? 'О“ВЈГ  KhГҹв•—Вўp' : 'О“ВҘГ® LГҹв•—Г§ch'}\r\n                      </td>\r\n                    </tr>\r\n                  )\r\n                })}\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Cash Handover О“ГҮГ¶ W-KT-07 */}\r\n      {cpType === 'cash_handover' && driverData && (\r\n        <div className=\"space-y-4\">\r\n          <div className=\"bg-white rounded-xl shadow-sm p-4\">\r\n            <h3 className=\"font-semibold text-gray-800 mb-3\">TiГҹв•—Гјn TX khai nГҹв•—Г–p</h3>\r\n            <div className=\"flex items-center justify-between bg-yellow-50 rounded-lg p-4 mb-4\">\r\n              <span className=\"text-gray-700\">TiГҹв•—Гјn mГҹв•‘в•–t:</span>\r\n              <span className=\"text-2xl font-bold font-mono\">{formatVND(driverData.total_cash || 0)}</span>\r\n            </div>\r\n            {driverData.total_transfer > 0 && (\r\n              <div className=\"flex items-center justify-between bg-blue-50 rounded-lg p-4 mb-4\">\r\n                <span className=\"text-gray-700\">ChuyГҹв•—Гўn khoГҹв•‘Гәn:</span>\r\n                <span className=\"text-lg font-bold font-mono\">{formatVND(driverData.total_transfer)}</span>\r\n              </div>\r\n            )}\r\n            <div className=\"mt-4\">\r\n              <label className=\"text-sm font-medium text-gray-700\">KT в”ҖГҰГҹв•‘в”җm thГҹв•—в–’c tГҹв•‘в”җ (tiГҹв•—Гјn mГҹв•‘в•–t):</label>\r\n              <input\r\n                type=\"number\"\r\n                value={receiverData.actual_cash ?? driverData.total_cash ?? 0}\r\n                onChange={e => setReceiverData({ ...receiverData, actual_cash: parseInt(e.target.value) || 0 })}\r\n                className=\"w-full mt-1 h-12 px-3 border rounded-lg text-lg font-mono\"\r\n              />\r\n            </div>\r\n            {receiverData.actual_cash !== undefined && receiverData.actual_cash !== driverData.total_cash && (\r\n              <div className=\"mt-2 text-sm text-red-600 font-medium\">\r\n                Chв”ңВ¬nh lГҹв•—Г§ch: {formatVND(receiverData.actual_cash - driverData.total_cash)}\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Vehicle Return О“ГҮГ¶ W-DT-01 */}\r\n      {cpType === 'vehicle_return' && driverData && (\r\n        <div className=\"space-y-4\">\r\n          <div className=\"bg-white rounded-xl shadow-sm p-4\">\r\n            <h3 className=\"font-semibold text-gray-800 mb-3\">Thв”ңв”Өng tin xe</h3>\r\n            <div className=\"space-y-2 text-sm\">\r\n              <div className=\"flex justify-between\">\r\n                <span className=\"text-gray-600\">Km cuГҹв•—ГҰi ca:</span>\r\n                <span className=\"font-mono font-medium\">{driverData.km_end?.toLocaleString()} km</span>\r\n              </div>\r\n              <div className=\"flex justify-between\">\r\n                <span className=\"text-gray-600\">Nhiв”ңВ¬n liГҹв•—Г§u:</span>\r\n                <span className=\"font-medium\">{driverData.fuel_level}%</span>\r\n              </div>\r\n            </div>\r\n            <h4 className=\"font-medium text-gray-700 mt-4 mb-2\">Checklist TX khai:</h4>\r\n            {driverData.checklist && Object.entries(driverData.checklist).map(([key, val]: [string, any]) => (\r\n              <div key={key} className=\"flex items-center gap-2 text-sm py-1\">\r\n                <span>{val ? 'О“ВЈГ ' : 'О“ВўГ¶'}</span>\r\n                <span>{key.replace(/_/g, ' ')}</span>\r\n              </div>\r\n            ))}\r\n            {driverData.damage_description && (\r\n              <div className=\"mt-3 bg-red-50 border border-red-200 rounded-lg p-3\">\r\n                <div className=\"text-sm font-medium text-red-700\">Hв•һв–‘ hГҹв•—Г…ng:</div>\r\n                <div className=\"text-sm text-red-600\">{driverData.damage_description}</div>\r\n              </div>\r\n            )}\r\n            <div className=\"mt-4\">\r\n              <label className=\"text-sm font-medium text-gray-700\">Tв”ңВјnh trГҹв•‘Гӯng xe:</label>\r\n              <div className=\"flex gap-3 mt-2\">\r\n                {['good', 'needs_repair', 'severe'].map(v => (\r\n                  <label key={v} className={`flex items-center gap-2 px-3 py-2 rounded-lg border cursor-pointer ${\r\n                    receiverData.vehicle_condition === v ? 'border-[#F68634] bg-orange-50' : 'border-gray-200'\r\n                  }`}>\r\n                    <input\r\n                      type=\"radio\"\r\n                      name=\"condition\"\r\n                      checked={receiverData.vehicle_condition === v}\r\n                      onChange={() => setReceiverData({ ...receiverData, vehicle_condition: v })}\r\n                      className=\"accent-[#F68634]\"\r\n                    />\r\n                    <span className=\"text-sm\">{v === 'good' ? 'TГҹв•—ГҰt' : v === 'needs_repair' ? 'CГҹв•‘Вәn sГҹв•—ВЎa' : 'NГҹв•‘в•–ng'}</span>\r\n                  </label>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Discrepancy Reason (all types) */}\r\n      <div className=\"mt-4 bg-white rounded-xl shadow-sm p-4\">\r\n        <label className=\"text-sm font-medium text-gray-700\">Ghi chв”ңв•‘ / Lв”ңв•ң do sai lГҹв•—Г§ch (nГҹв•‘в”җu cв”ңв”Ӯ):</label>\r\n        <textarea\r\n          value={discrepancyReason}\r\n          onChange={e => setDiscrepancyReason(e.target.value)}\r\n          className=\"w-full mt-1 p-3 border rounded-lg text-sm\"\r\n          placeholder=\"NhГҹв•‘ВЎp ghi chв”ңв•‘ nГҹв•‘в”җu cв”ңв”Ӯ chв”ңВ¬nh lГҹв•—Г§ch...\"\r\n          rows={2}\r\n        />\r\n      </div>\r\n\r\n      {/* Action Buttons */}\r\n      <div className=\"flex gap-3 mt-6\">\r\n        <button\r\n          onClick={() => handleConfirm(selectedCp.id)}\r\n          disabled={processing}\r\n          className=\"flex-1 h-12 bg-green-600 text-white rounded-xl font-semibold hover:bg-green-700 disabled:opacity-50 transition-colors\"\r\n        >\r\n          {processing ? 'в”ҖГүang xГҹв•—ВЎ lв”ңв•ң...' : 'О“ВЈГ  Xв”ңГӯc nhГҹв•‘ВЎn'}\r\n        </button>\r\n        <button\r\n          onClick={() => {\r\n            const reason = prompt('NhГҹв•‘ВЎp lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi:')\r\n            if (reason) {\r\n              setRejectReason(reason)\r\n              handleReject(selectedCp.id)\r\n            }\r\n          }}\r\n          disabled={processing}\r\n          className=\"h-12 px-6 bg-red-600 text-white rounded-xl font-semibold hover:bg-red-700 disabled:opacity-50 transition-colors\"\r\n        >\r\n          О“ВҘГ® TГҹв•—ВҪ chГҹв•—ГҰi\r\n        </button>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\