n instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState } from 'react'\r\nimport { useParams, useRouter } from 'next/navigation'\r\nimport { apiFetch } from '@/lib/api'\r\nimport { toast } from '@/lib/useToast'\r\nimport { handleError } from '@/lib/handleError'\r\n\r\ninterface DriverDoc {\r\n  id: string\r\n  driver_id: string\r\n  doc_type: string\r\n  doc_number: string\r\n  issued_date?: string\r\n  expiry_date: string\r\n  license_class?: string\r\n  notes?: string\r\n  driver_name: string\r\n  days_to_expiry: number\r\n}\r\n\r\nconst docTypeLabels: Record<string, string> = {\r\n  license: 'BГҹв•‘в–’ng lв”ңГӯi xe',\r\n  health_check: 'Khв”ңГӯm sГҹв•—вҢҗc khГҹв•—Г…e',\r\n}\r\n\r\nconst emptyDoc = {\r\n  doc_type: 'license',\r\n  doc_number: '',\r\n  issued_date: '',\r\n  expiry_date: '',\r\n  license_class: '',\r\n  notes: '',\r\n}\r\n\r\nexport default function DriverDocumentsPage() {\r\n  const params = useParams()\r\n  const router = useRouter()\r\n  const driverId = params.id as string\r\n  const [docs, setDocs] = useState<DriverDoc[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [driverName, setDriverName] = useState('')\r\n  const [modal, setModal] = useState<'create' | 'edit' | null>(null)\r\n  const [form, setForm] = useState(emptyDoc)\r\n  const [editId, setEditId] = useState<string | null>(null)\r\n  const [saving, setSaving] = useState(false)\r\n\r\n  const load = () => {\r\n    setLoading(true)\r\n    apiFetch<any>(`/drivers/${driverId}/documents`)\r\n      .then((r) => {\r\n        const data = r.data || []\r\n        setDocs(data)\r\n        if (data.length > 0) setDriverName(data[0].driver_name)\r\n      })\r\n      .catch(err => handleError(err))\r\n      .finally(() => setLoading(false))\r\n\r\n    if (!driverName) {\r\n      apiFetch<any>(`/drivers/${driverId}`)\r\n        .then((r) => setDriverName(r.data?.full_name || r.data?.name || ''))\r\n        .catch(() => {})\r\n    }\r\n  }\r\n\r\n  useEffect(() => { load() }, [driverId])\r\n\r\n  const openCreate = () => {\r\n    setForm(emptyDoc)\r\n    setEditId(null)\r\n    setModal('create')\r\n  }\r\n\r\n  const openEdit = (d: DriverDoc) => {\r\n    setForm({\r\n      doc_type: d.doc_type,\r\n      doc_number: d.doc_number || '',\r\n      issued_date: d.issued_date || '',\r\n      expiry_date: d.expiry_date,\r\n      license_class: d.license_class || '',\r\n      notes: d.notes || '',\r\n    })\r\n    setEditId(d.id)\r\n    setModal('edit')\r\n  }\r\n\r\n  const handleSave = async () => {\r\n    if (!form.doc_type || !form.expiry_date) {\r\n      toast.warning('LoГҹв•‘Гӯi giГҹв•‘Г‘y tГҹв•—ВҘ vв”ңГЎ ngв”ңГЎy hГҹв•‘в”җt hГҹв•‘Гӯn lв”ңГЎ bГҹв•‘В»t buГҹв•—Г–c')\r\n      return\r\n    }\r\n    setSaving(true)\r\n    try {\r\n      if (modal === 'create') {\r\n        await apiFetch(`/drivers/${driverId}/documents`, { method: 'POST', body: form })\r\n      } else if (modal === 'edit' && editId) {\r\n        await apiFetch(`/drivers/${driverId}/documents/${editId}`, { method: 'PUT', body: form })\r\n      }\r\n      setModal(null)\r\n      load()\r\n    } catch (e: any) {\r\n      toast.error(e.message)\r\n    } finally {\r\n      setSaving(false)\r\n    }\r\n  }\r\n\r\n  const handleDelete = async (id: string, docType: string) => {\r\n    if (!confirm(`Xв”ңв”Ӯa giГҹв•‘Г‘y tГҹв•—ВҘ \"${docTypeLabels[docType] || docType}\"?`)) return\r\n    try {\r\n      await apiFetch(`/drivers/${driverId}/documents/${id}`, { method: 'DELETE' })\r\n      load()\r\n    } catch (e: any) {\r\n      toast.error(e.message)\r\n    }\r\n  }\r\n\r\n  const expiryBadge = (days: number) => {\r\n    if (days <= 0) return 'bg-red-100 text-red-700'\r\n    if (days <= 7) return 'bg-orange-100 text-orange-700'\r\n    if (days <= 30) return 'bg-yellow-100 text-yellow-700'\r\n    return 'bg-green-100 text-green-700'\r\n  }\r\n\r\n  const expiryText = (days: number) => {\r\n    if (days <= 0) return 'в”ҖГүв”ңГә hГҹв•‘в”җt hГҹв•‘Гӯn'\r\n    if (days === 1) return 'Cв”ңв–“n 1 ngв”ңГЎy'\r\n    return `Cв”ңв–“n ${days} ngв”ңГЎy`\r\n  }\r\n\r\n  if (loading) return <div className=\"flex justify-center py-20\"><div className=\"animate-spin rounded-full h-10 w-10 border-b-2 border-brand-500\"></div></div>\r\n\r\n  return (\r\n    <div className=\"max-w-3xl\">\r\n      <div className=\"flex items-center justify-between mb-6\">\r\n        <div>\r\n          <button onClick={() => router.back()} className=\"text-sm text-gray-500 hover:text-gray-700 mb-1\">\r\n            О“ГҘГү Quay lГҹв•‘Гӯi\r\n          </button>\r\n          <h1 className=\"text-2xl font-bold text-gray-800\">вүЎЖ’ГҙГӨ GiГҹв•‘Г‘y tГҹв•—ВҘ tв”ңГЎi xГҹв•‘в”җ {driverName}</h1>\r\n        </div>\r\n        <button onClick={openCreate} className=\"px-4 py-2 bg-brand-500 text-white rounded-lg text-sm font-medium hover:bg-brand-600\">\r\n          + Thв”ңВ¬m giГҹв•‘Г‘y tГҹв•—ВҘ\r\n        </button>\r\n      </div>\r\n\r\n      {docs.length === 0 ? (\r\n        <div className=\"bg-white rounded-xl shadow-sm p-12 text-center text-gray-400\">\r\n          <p className=\"text-4xl mb-2\">вүЎЖ’ГҙГӨ</p>\r\n          <p>Chв•һв–‘a cв”ңв”Ӯ giГҹв•‘Г‘y tГҹв•—ВҘ nв”ңГЎo. NhГҹв•‘Г‘n &quot;+ Thв”ңВ¬m giГҹв•‘Г‘y tГҹв•—ВҘ&quot; в”ҖГҰГҹв•—Гў bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu.</p>\r\n        </div>\r\n      ) : (\r\n        <div className=\"space-y-3\">\r\n          {docs.map((d) => (\r\n            <div key={d.id} className=\"bg-white rounded-xl shadow-sm border p-5\">\r\n              <div className=\"flex items-center justify-between mb-3\">\r\n                <span className=\"font-semibold text-gray-800\">\r\n                  {docTypeLabels[d.doc_type] || d.doc_type}\r\n                  {d.license_class && <span className=\"ml-2 text-sm text-gray-500\">({d.license_class})</span>}\r\n                </span>\r\n                <span className={`px-2.5 py-0.5 rounded-full text-xs font-medium ${expiryBadge(d.days_to_expiry)}`}>\r\n                  {expiryText(d.days_to_expiry)}\r\n                </span>\r\n              </div>\r\n              <div className=\"grid grid-cols-2 gap-3 text-sm text-gray-600\">\r\n                {d.doc_number && (\r\n                  <div><span className=\"text-gray-400\">SГҹв•—ГҰ giГҹв•‘Г‘y tГҹв•—ВҘ:</span> {d.doc_number}</div>\r\n                )}\r\n                {d.issued_date && (\r\n                  <div><span className=\"text-gray-400\">Ngв”ңГЎy cГҹв•‘Г‘p:</span> {new Date(d.issued_date).toLocaleDateString('vi-VN')}</div>\r\n                )}\r\n                <div><span className=\"text-gray-400\">HГҹв•‘в”җt hГҹв•‘Гӯn:</span> <strong>{new Date(d.expiry_date).toLocaleDateString('vi-VN')}</strong></div>\r\n                {d.notes && (\r\n                  <div className=\"col-span-2\"><span className=\"text-gray-400\">Ghi chв”ңв•‘:</span> {d.notes}</div>\r\n                )}\r\n              </div>\r\n              <div className=\"flex justify-end gap-2 mt-3 pt-3 border-t\">\r\n                <button onClick={() => openEdit(d)} className=\"text-brand-500 hover:underline text-xs\">SГҹв•—ВЎa</button>\r\n                <button onClick={() => handleDelete(d.id, d.doc_type)} className=\"text-red-600 hover:underline text-xs\">Xв”ңв”Ӯa</button>\r\n              </div>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      )}\r\n\r\n      {/* Modal */}\r\n      {modal && (\r\n        <div className=\"fixed inset-0 bg-black/40 flex items-center justify-center z-50\">\r\n          <div className=\"bg-white rounded-xl shadow-xl w-full max-w-md p-6\">\r\n            <h2 className=\"text-lg font-bold mb-4\">{modal === 'create' ? 'Thв”ңВ¬m giГҹв•‘Г‘y tГҹв•—ВҘ' : 'SГҹв•—ВЎa giГҹв•‘Г‘y tГҹв•—ВҘ'}</h2>\r\n            <div className=\"grid gap-4\">\r\n              <div>\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">LoГҹв•‘Гӯi giГҹв•‘Г‘y tГҹв•—ВҘ *</label>\r\n                <select value={form.doc_type} onChange={e => setForm({ ...form, doc_type: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\">\r\n                  {Object.entries(docTypeLabels).map(([val, lbl]) => (\r\n                    <option key={val} value={val}>{lbl}</option>\r\n                  ))}\r\n                </select>\r\n              </div>\r\n              <div>\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">SГҹв•—ГҰ giГҹв•‘Г‘y tГҹв•—ВҘ</label>\r\n                <input value={form.doc_number} onChange={e => setForm({ ...form, doc_number: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\" />\r\n              </div>\r\n              {form.doc_type === 'license' && (\r\n                <div>\r\n                  <label className=\"block text-xs font-medium text-gray-600 mb-1\">HГҹв•‘Гӯng bГҹв•‘в–’ng lв”ңГӯi</label>\r\n                  <select value={form.license_class} onChange={e => setForm({ ...form, license_class: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\">\r\n                    <option value=\"\">О“ГҮГ¶ ChГҹв•—Г¬n О“ГҮГ¶</option>\r\n                    <option value=\"B2\">B2</option>\r\n                    <option value=\"C\">C</option>\r\n                    <option value=\"D\">D</option>\r\n                    <option value=\"E\">E</option>\r\n                  </select>\r\n                </div>\r\n              )}\r\n              <div className=\"grid grid-cols-2 gap-4\">\r\n                <div>\r\n                  <label className=\"block text-xs font-medium text-gray-600 mb-1\">Ngв”ңГЎy cГҹв•‘Г‘p</label>\r\n                  <input type=\"date\" value={form.issued_date} onChange={e => setForm({ ...form, issued_date: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\" />\r\n                </div>\r\n                <div>\r\n                  <label className=\"block text-xs font-medium text-gray-600 mb-1\">Ngв”ңГЎy hГҹв•‘в”җt hГҹв•‘Гӯn *</label>\r\n                  <input type=\"date\" value={form.expiry_date} onChange={e => setForm({ ...form, expiry_date: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm\" />\r\n                </div>\r\n              </div>\r\n              <div>\r\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">Ghi chв”ңв•‘</label>\r\n                <textarea value={form.notes} onChange={e => setForm({ ...form, notes: e.target.value })} className=\"w-full border rounded-lg px-3 py-2 text-sm resize-none\" rows={2} />\r\n              </div>\r\n            </div>\r\n            <div className=\"flex justify-end gap-3 mt-5\">\r\n              <button onClick={() => setModal(null)} className=\"px-4 py-2 text-sm text-gray-600 hover:text-gray-800\">HГҹв•—Вәy</button>\r\n              <button onClick={handleSave} disabled={saving} className=\"px-5 py-2 bg-brand-500 text-white text-sm rounded-lg hover:bg-brand-600 disabled:opacity-50\">\r\n                {saving ? 'в”ҖГүang lв•һв–‘u...' : 'Lв•һв–‘u'}\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\drivers-list\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":47,"column":14,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":47,"endColumn":17,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1337,1340],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1337,1340],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type par