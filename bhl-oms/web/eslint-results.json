"suggestUnknown","fix":{"range":[25871,25874],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[25871,25874],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'confirmed' is assigned a value but never used.","line":604,"column":19,"nodeType":null,"messageId":"unusedVar","endLine":604,"endColumn":28},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'total' is assigned a value but never used.","line":605,"column":19,"nodeType":null,"messageId":"unusedVar","endLine":605,"endColumn":24}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":12,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState, useCallback } from 'react'\r\nimport { useSearchParams } from 'next/navigation'\r\nimport { apiFetch } from '@/lib/api'\r\nimport { toast } from '@/lib/useToast'\r\nimport { useDataRefresh } from '@/lib/notifications'\r\n\r\n// О“Г¶ГҮО“Г¶ГҮ Types О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\ninterface Signatory {\r\n  role: string; role_label: string\r\n  user_id?: string; name?: string; signed_at?: string; action?: string\r\n}\r\n\r\ninterface HandoverItem {\r\n  product_name: string; product_sku: string; expected_qty: number; actual_qty: number\r\n}\r\n\r\ninterface HandoverRecord {\r\n  id: string; handover_type: string; trip_id: string; status: string\r\n  signatories: Signatory[]; photo_urls: string[]\r\n  items: HandoverItem[]; reject_reason?: string\r\n  notes?: string; created_at: string; updated_at: string\r\n}\r\n\r\ninterface TripForHandover {\r\n  id: string; trip_number: string; vehicle_plate: string\r\n  driver_name: string; status: string; total_stops: number\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮ Helper О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nconst statusConfig: Record<string, { label: string; color: string; icon: string }> = {\r\n  pending: { label: 'ChГҹв•—ВҘ xв”ңГӯc nhГҹв•‘ВЎn', color: 'bg-yellow-100 text-yellow-800', icon: 'О“Г…в”Ӯ' },\r\n  partially_signed: { label: 'в”ҖГүang xв”ңГӯc nhГҹв•‘ВЎn', color: 'bg-blue-100 text-blue-800', icon: 'вүЎЖ’Г¶ГӨ' },\r\n  completed: { label: 'Hoв”ңГЎn tГҹв•‘Г‘t', color: 'bg-green-100 text-green-800', icon: 'О“ВЈГ ' },\r\n  rejected: { label: 'BГҹв•—ГҜ tГҹв•—ВҪ chГҹв•—ГҰi', color: 'bg-red-100 text-red-800', icon: 'О“ВҘГ®' },\r\n}\r\n\r\nfunction timeAgo(dateStr: string): string {\r\n  const diff = Date.now() - new Date(dateStr).getTime()\r\n  const mins = Math.floor(diff / 60000)\r\n  if (mins < 1) return 'vГҹв•—ВҪa xong'\r\n  if (mins < 60) return `${mins} phв”ңв•‘t trв•һв–‘Гҹв•—Вўc`\r\n  const hours = Math.floor(mins / 60)\r\n  if (hours < 24) return `${hours} giГҹв•—ВҘ trв•һв–‘Гҹв•—Вўc`\r\n  return `${Math.floor(hours / 24)} ngв”ңГЎy trв•һв–‘Гҹв•—Вўc`\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮ Main Page О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nexport default function HandoverAPage() {\r\n  const searchParams = useSearchParams()\r\n  const tripIdFromUrl = searchParams.get('trip_id')\r\n\r\n  const [mode, setMode] = useState<'list' | 'create'>('list')\r\n  const [handovers, setHandovers] = useState<HandoverRecord[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n\r\n  // Create form state\r\n  const [trips, setTrips] = useState<TripForHandover[]>([])\r\n  const [selectedTrip, setSelectedTrip] = useState<TripForHandover | null>(null)\r\n  const [tripSearch, setTripSearch] = useState('')\r\n  const [photos, setPhotos] = useState<string[]>([])\r\n  const [note, setNote] = useState('')\r\n  const [items, setItems] = useState<HandoverItem[]>([])\r\n  const [submitting, setSubmitting] = useState(false)\r\n\r\n  // Detail view\r\n  const [detail, setDetail] = useState<HandoverRecord | null>(null)\r\n\r\n  const loadHandovers = useCallback(async () => {\r\n    try {\r\n      const tripsRes: any = await apiFetch('/trips?limit=50')\r\n      const allTrips = tripsRes.data || []\r\n      const records: HandoverRecord[] = []\r\n      for (const t of allTrips.slice(0, 20)) {\r\n        try {\r\n          const res: any = await apiFetch(`/warehouse/handovers/trip/${t.id}`)\r\n          const recs = (res.data || []).filter((r: HandoverRecord) => r.handover_type === 'A')\r\n          recs.forEach((r: HandoverRecord) => {\r\n            (r as any)._trip = t\r\n          })\r\n          records.push(...recs)\r\n        } catch { /* ignore */ }\r\n      }\r\n      setHandovers(records.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime()))\r\n    } catch { /* ignore */ }\r\n    finally { setLoading(false) }\r\n  }, [])\r\n\r\n  const loadTrips = useCallback(async () => {\r\n    try {\r\n      const res: any = await apiFetch('/trips?limit=50')\r\n      setTrips((res.data || []).filter((t: TripForHandover) =>\r\n        ['ready', 'assigned', 'pre_check'].includes(t.status)))\r\n    } catch { /* ignore */ }\r\n  }, [])\r\n\r\n  // Auto-detect trip from URL param (coming from picking page)\r\n  useEffect(() => {\r\n    if (tripIdFromUrl) {\r\n      // Read trip data from sessionStorage (set by picking page)\r\n      const stored = sessionStorage.getItem('handover_trip')\r\n      if (stored) {\r\n        try {\r\n          const data = JSON.parse(stored)\r\n          if (data.trip_id === tripIdFromUrl) {\r\n            setSelectedTrip({\r\n              id: data.trip_id,\r\n              trip_number: data.trip_number,\r\n              vehicle_plate: data.vehicle_plate,\r\n              driver_name: data.driver_name,\r\n              status: 'ready',\r\n              total_stops: data.total_stops || 0,\r\n            })\r\n            setTripSearch(data.trip_number)\r\n            setItems(data.items || [])\r\n            setMode('create')\r\n            return\r\n          }\r\n        } catch { /* ignore parse error */ }\r\n      }\r\n      // Fallback: just switch to create mode with trip_id\r\n      setMode('create')\r\n      loadTrips()\r\n    }\r\n  }, [tripIdFromUrl, loadTrips])\r\n\r\n  useEffect(() => {\r\n    if (!tripIdFromUrl) loadHandovers()\r\n  }, [loadHandovers, tripIdFromUrl])\r\n\r\n  useDataRefresh('handover', loadHandovers)\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ Photo upload via FileReader (base64) О“Г¶ГҮО“Г¶ГҮ\r\n\r\n  const handlePhotoUpload = (e: React.ChangeEvent<HTMLInputElement>) => {\r\n    const files = Array.from(e.target.files || [])\r\n    files.forEach(file => {\r\n      const reader = new FileReader()\r\n      reader.onload = () => {\r\n        setPhotos(prev => [...prev, reader.result as string])\r\n      }\r\n      reader.readAsDataURL(file)\r\n    })\r\n    e.target.value = ''\r\n  }\r\n\r\n  const removePhoto = (idx: number) => {\r\n    setPhotos(prev => prev.filter((_, i) => i !== idx))\r\n  }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ Create handover О“Г¶ГҮО“Г¶ГҮ\r\n\r\n  const createHandover = async () => {\r\n    if (!selectedTrip) {\r\n      toast.warning('Vui lв”ңв–“ng chГҹв•—Г¬n chuyГҹв•‘в”җn xe')\r\n      return\r\n    }\r\n    if (photos.length === 0) {\r\n      toast.warning('Vui lв”ңв–“ng chГҹв•—Г‘p/в”ҖГҰв”ңВЎnh kв”ңВҝm Гҹв•‘Гәnh phiГҹв•‘в”җu xuГҹв•‘Г‘t kho Bravo')\r\n      return\r\n    }\r\n\r\n    setSubmitting(true)\r\n    try {\r\n      const signatories = [\r\n        { role: 'warehouse_handler', role_label: 'ThГҹв•—Вә kho' },\r\n        { role: 'driver', role_label: 'Tв”ңГЎi xГҹв•‘в”җ' },\r\n        { role: 'security', role_label: 'BГҹв•‘Гәo vГҹв•—Г§' },\r\n      ]\r\n\r\n      const res: any = await apiFetch('/warehouse/handovers', {\r\n        method: 'POST',\r\n        body: {\r\n          handover_type: 'A',\r\n          trip_id: selectedTrip.id,\r\n          signatories,\r\n          photo_urls: photos,\r\n          items: items.length > 0 ? items : undefined,\r\n          notes: note || undefined,\r\n        },\r\n      })\r\n\r\n      toast.success('в”ҖГүв”ңГә tГҹв•‘Гӯo biв”ңВ¬n bГҹв•‘Гәn bв”ңГЎn giao A')\r\n      sessionStorage.removeItem('handover_trip')\r\n\r\n      // Auto-sign warehouse_handler\r\n      if (res.data?.id) {\r\n        try {\r\n          await apiFetch(`/warehouse/handovers/${res.data.id}/sign`, {\r\n            method: 'POST',\r\n            body: { role: 'warehouse_handler', action: 'confirm' },\r\n          })\r\n        } catch { /* ignore auto-sign error */ }\r\n\r\n        // Show the created handover detail\r\n        try {\r\n          const detailRes: any = await apiFetch(`/warehouse/handovers/${res.data.id}`)\r\n          setDetail(detailRes.data)\r\n          setMode('list')\r\n        } catch {\r\n          setMode('list')\r\n          await loadHandovers()\r\n        }\r\n      } else {\r\n        setMode('list')\r\n        await loadHandovers()\r\n      }\r\n      setSelectedTrip(null)\r\n      setPhotos([])\r\n      setNote('')\r\n      setItems([])\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i: ' + err.message)\r\n    } finally {\r\n      setSubmitting(false)\r\n    }\r\n  }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ Confirm / Reject О“Г¶ГҮО“Г¶ГҮ\r\n\r\n  const confirmHandover = async (handoverId: string, role: string) => {\r\n    try {\r\n      await apiFetch(`/warehouse/handovers/${handoverId}/sign`, {\r\n        method: 'POST',\r\n        body: { role, action: 'confirm' },\r\n      })\r\n      toast.success('в”ҖГүв”ңГә xв”ңГӯc nhГҹв•‘ВЎn bв”ңГЎn giao')\r\n      // Refresh detail if viewing\r\n      if (detail && detail.id === handoverId) {\r\n        const res: any = await apiFetch(`/warehouse/handovers/${handoverId}`)\r\n        setDetail(res.data)\r\n      }\r\n      await loadHandovers()\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i: ' + err.message)\r\n    }\r\n  }\r\n\r\n  // О“Г¶ГҮО“Г¶ГҮ RENDER О“Г¶ГҮО“Г¶ГҮ\r\n\r\n  // Create mode\r\n  if (mode === 'create') {\r\n    return (\r\n      <div className=\"max-w-[800px] mx-auto\">\r\n        <div className=\"flex items-center gap-3 mb-6\">\r\n          <button onClick={() => { setMode('list'); loadHandovers() }} className=\"text-gray-400 hover:text-gray-600 text-xl\">О“ГҘГү</button>\r\n          <h1 className=\"text-2xl font-bold text-gray-800\">вүЎЖ’ГҙГҜ TГҹв•‘Гӯo biв”ңВ¬n bГҹв•‘Гәn bв”ңГЎn giao A</h1>\r\n        </div>\r\n\r\n        {/* Step 1: Select trip */}\r\n        <div className=\"bg-white rounded-xl shadow-sm p-5 mb-4\">\r\n          <h2 className=\"font-semibold text-gray-700 mb-3\">1. ChГҹв•—Г¬n chuyГҹв•‘в”җn xe</h2>\r\n          {selectedTrip ? (\r\n            <div className=\"bg-blue-50 rounded-lg p-3 flex items-center justify-between\">\r\n              <div>\r\n                <span className=\"font-bold text-blue-800\">{selectedTrip.trip_number}</span>\r\n                <span className=\"text-blue-600 text-sm ml-2\">{selectedTrip.vehicle_plate} в”¬в•– {selectedTrip.driver_name}</span>\r\n              </div>\r\n              {!tripIdFromUrl && (\r\n                <button onClick={() => { setSelectedTrip(null); setTripSearch(''); setItems([]) }} className=\"text-blue-400 hover:text-blue-600\">О“ВЈГІ</button>\r\n              )}\r\n            </div>\r\n          ) : (\r\n            <>\r\n              <input\r\n                type=\"text\"\r\n                value={tripSearch}\r\n                onChange={e => {\r\n                  setTripSearch(e.target.value)\r\n                  if (!trips.length) loadTrips()\r\n                }}\r\n                onFocus={() => { if (!trips.length) loadTrips() }}\r\n                placeholder=\"Tв”ңВјm sГҹв•—ГҰ chuyГҹв•‘в”җn hoГҹв•‘в•–c biГҹв•—Гўn sГҹв•—ГҰ xe...\"\r\n                className=\"w-full border rounded-lg px-4 py-3 text-sm mb-3\"\r\n              />\r\n              {trips.length > 0 && (\r\n                <div className=\"space-y-2 max-h-48 overflow-y-auto\">\r\n                  {trips\r\n                    .filter(t => !tripSearch ||\r\n                      t.trip_number.toLowerCase().includes(tripSearch.toLowerCase()) ||\r\n                      t.vehicle_plate.toLowerCase().includes(tripSearch.toLowerCase()))\r\n                    .map(t => (\r\n                      <button\r\n                        key={t.id}\r\n                        onClick={() => { setSelectedTrip(t); setTripSearch(t.trip_number) }}\r\n                        className=\"w-full text-left p-3 rounded-lg border hover:bg-gray-50 transition flex items-center justify-between\"\r\n                      >\r\n                        <div>\r\n                          <span className=\"font-medium\">{t.trip_number}</span>\r\n                          <span className=\"text-gray-400 mx-2\">в”¬в•–</span>\r\n                          <span className=\"text-sm text-gray-500\">{t.vehicle_plate}</span>\r\n                          <span className=\"text-gray-400 mx-2\">в”¬в•–</span>\r\n                          <span className=\"text-sm text-gray-500\">{t.driver_name}</span>\r\n                        </div>\r\n                        <span className=\"text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full\">{t.total_stops} в”ҖГҰiГҹв•—Гўm</span>\r\n                      </button>\r\n                    ))}\r\n                </div>\r\n              )}\r\n            </>\r\n          )}\r\n        </div>\r\n\r\n        {/* Items table (auto-populated from picking) */}\r\n        {items.length > 0 && (\r\n          <div className=\"bg-white rounded-xl shadow-sm p-5 mb-4\">\r\n            <h2 className=\"font-semibold text-gray-700 mb-3\">вүЎЖ’ГҙВӘ Danh sв”ңГӯch hв”ңГЎng hв”ңв”Ӯa bв”ңГЎn giao</h2>\r\n            <div className=\"overflow-x-auto\">\r\n              <table className=\"w-full text-sm\">\r\n                <thead className=\"bg-gray-50 text-gray-600\">\r\n                  <tr>\r\n                    <th className=\"text-left py-2 px-3\">STT</th>\r\n                    <th className=\"text-left py-2 px-3\">SГҹв•‘Гәn phГҹв•‘вҢҗm</th>\r\n                    <th className=\"text-left py-2 px-3\">Mв”ңГә SP</th>\r\n                    <th className=\"text-right py-2 px-3\">SL yв”ңВ¬u cГҹв•‘Вәu</th>\r\n                    <th className=\"text-right py-2 px-3\">SL thГҹв•—в–’c tГҹв•‘в”җ</th>\r\n                    <th className=\"text-center py-2 px-3\">KhГҹв•—Вўp</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody className=\"divide-y divide-gray-100\">\r\n                  {items.map((item, idx) => (\r\n                    <tr key={idx} className=\"hover:bg-gray-50\">\r\n                      <td className=\"py-2 px-3 text-gray-500\">{idx + 1}</td>\r\n                      <td className=\"py-2 px-3 font-medium\">{item.product_name}</td>\r\n                      <td className=\"py-2 px-3 text-gray-500 font-mono text-xs\">{item.product_sku}</td>\r\n                      <td className=\"py-2 px-3 text-right\">{item.expected_qty}</td>\r\n                      <td className=\"py-2 px-3 text-right\">\r\n                        <input\r\n                          type=\"number\"\r\n                          value={item.actual_qty}\r\n                          onChange={e => {\r\n                            const val = parseInt(e.target.value) || 0\r\n                            setItems(prev => prev.map((it, i) => i === idx ? { ...it, actual_qty: val } : it))\r\n                          }}\r\n                          className=\"w-20 text-right border rounded px-2 py-1 text-sm\"\r\n                          min={0}\r\n                        />\r\n                      </td>\r\n                      <td className=\"py-2 px-3 text-center\">\r\n                        {item.actual_qty === item.expected_qty ? (\r\n                          <span className=\"text-green-600\">О“ВЈГ </span>\r\n                        ) : (\r\n                          <span className=\"text-red-600\">О“ГңГЎвҲ©в••Г…</span>\r\n                        )}\r\n                      </td>\r\n                    </tr>\r\n                  ))}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n            <div className=\"mt-2 text-xs text-gray-400\">\r\n              SГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng thГҹв•—в–’c tГҹв•‘в”җ в”ҖГҰв•һв–‘Гҹв•—Гәc tГҹв•—в–’ в”ҖГҰГҹв•—Г–ng в”ҖГҰiГҹв•—Гјn tГҹв•—ВҪ dГҹв•—В» liГҹв•—Г§u soГҹв•‘Гӯn hв”ңГЎng. BГҹв•‘Гӯn cв”ңв”Ӯ thГҹв•—Гў sГҹв•—ВЎa nГҹв•‘в”җu cГҹв•‘Вәn.\r\n            </div>\r\n          </div>\r\n        )}\r\n\r\n        {/* Step 2: Attach photos */}\r\n        <div className=\"bg-white rounded-xl shadow-sm p-5 mb-4\">\r\n          <h2 className=\"font-semibold text-gray-700 mb-3\">{items.length > 0 ? '2' : '2'}. ChГҹв•—Г‘p/в”ҖГҰв”ңВЎnh kв”ңВҝm phiГҹв•‘в”җu xuГҹв•‘Г‘t kho Bravo</h2>\r\n          <p className=\"text-sm text-gray-500 mb-3\">In phiГҹв•‘в”җu xuГҹв•‘Г‘t kho tГҹв•—ВҪ Bravo О“ГҘГҶ kв”ңв•ң tay 3 bв”ңВ¬n О“ГҘГҶ chГҹв•—Г‘p Гҹв•‘Гәnh О“ГҘГҶ в”ҖГҰв”ңВЎnh kв”ңВҝm tГҹв•‘Гӯi в”ҖГҰв”ңГіy</p>\r\n\r\n          <label className=\"flex items-center justify-center gap-2 w-full h-14 border-2 border-dashed border-gray-300 rounded-xl cursor-pointer hover:border-[#F68634] hover:bg-orange-50 transition text-gray-500\">\r\n            <span className=\"text-lg\">вүЎЖ’Гҙв•–</span>\r\n            <span className=\"font-medium\">ChГҹв•—Г‘p Гҹв•‘Гәnh hoГҹв•‘в•–c chГҹв•—Г¬n file</span>\r\n            <input\r\n              type=\"file\"\r\n              accept=\"image/*\"\r\n              multiple\r\n              capture=\"environment\"\r\n              onChange={handlePhotoUpload}\r\n              className=\"hidden\"\r\n            />\r\n          </label>\r\n\r\n          {photos.length > 0 && (\r\n            <div className=\"flex gap-3 mt-3 flex-wrap\">\r\n              {photos.map((photo, idx) => (\r\n                <div key={idx} className=\"relative group\">\r\n                  <img src={photo} alt={`PhiГҹв•‘в”җu ${idx + 1}`} className=\"w-24 h-24 object-cover rounded-lg border\" />\r\n                  <button\r\n                    onClick={() => removePhoto(idx)}\r\n                    className=\"absolute -top-2 -right-2 w-6 h-6 bg-red-500 text-white rounded-full text-xs opacity-0 group-hover:opacity-100 transition\"\r\n                  >О“ВЈГІ</button>\r\n                </div>\r\n              ))}\r\n            </div>\r\n          )}\r\n        </div>\r\n\r\n        {/* Step 3: Notes */}\r\n        <div className=\"bg-white rounded-xl shadow-sm p-5 mb-4\">\r\n          <h2 className=\"font-semibold text-gray-700 mb-3\">3. Ghi chв”ңв•‘ (tв”ңв•Јy chГҹв•—Г¬n)</h2>\r\n          <textarea\r\n            value={note}\r\n            onChange={e => setNote(e.target.value)}\r\n            placeholder=\"Ghi chв”ңв•‘ thв”ңВ¬m nГҹв•‘в”җu cГҹв•‘Вәn...\"\r\n            className=\"w-full border rounded-lg px-4 py-3 text-sm h-20 resize-none\"\r\n          />\r\n        </div>\r\n\r\n        {/* Submit */}\r\n        <button\r\n          onClick={createHandover}\r\n          disabled={submitting || !selectedTrip || photos.length === 0}\r\n          className=\"w-full h-14 bg-[#F68634] text-white rounded-xl font-medium text-base hover:bg-orange-600 transition disabled:opacity-50 flex items-center justify-center gap-2\"\r\n        >\r\n          {submitting ? (\r\n            <><span className=\"animate-spin w-5 h-5 border-2 border-white border-t-transparent rounded-full\" /> в”ҖГүang tГҹв•‘Гӯo...</>\r\n          ) : (\r\n            <>вүЎЖ’ГҙГҜ TГҹв•‘Гӯo biв”ңВ¬n bГҹв•‘Гәn &amp; gГҹв•—ВЎi cho Tв”ңГЎi xГҹв•‘в”җ, BГҹв•‘Гәo vГҹв•—Г§ xв”ңГӯc nhГҹв•‘ВЎn</>\r\n          )}\r\n        </button>\r\n\r\n        <p className=\"text-xs text-gray-400 text-center mt-3\">\r\n          Sau khi tГҹв•‘Гӯo, ThГҹв•—Вә kho tГҹв•—в–’ в”ҖГҰГҹв•—Г–ng xв”ңГӯc nhГҹв•‘ВЎn О“ГҮГ¶ Tв”ңГЎi xГҹв•‘в”җ vв”ңГЎ BГҹв•‘Гәo vГҹв•—Г§ sГҹв•‘в•ң nhГҹв•‘ВЎn thв”ңв”Өng bв”ңГӯo в”ҖГҰГҹв•—Гў xв”ңГӯc nhГҹв•‘ВЎn trв”ңВ¬n thiГҹв•‘в”җt bГҹв•—ГҜ cГҹв•—Вәa hГҹв•—Г¬\r\n        </p>\r\n      </div>\r\n    )\r\n  }\r\n\r\n  // Detail view\r\n  if (detail) {\r\n    const sc = statusConfig[detail.status] || statusConfig.pending\r\n    return (\r\n      <div className=\"max-w-[800px] mx-auto\">\r\n        <div className=\"flex items-center gap-3 mb-6\">\r\n          <button onClick={() => setDetail(null)} className=\"text-gray-400 hover:text-gray-600 text-xl\">О“ГҘГү</button>\r\n          <h1 className=\"text-2xl font-bold text-gray-800\">Chi tiГҹв•‘в”җt Bв”ңГЎn giao A</h1>\r\n          <span className={`px-3 py-1 rounded-full text-xs font-medium ${sc.color}`}>{sc.icon} {sc.label}</span>\r\n        </div>\r\n\r\n        {/* Reject reason */}\r\n        {detail.reject_reason && (\r\n          <div className=\"bg-red-50 border border-red-200 rounded-xl p-4 mb-4\">\r\n            <div className=\"font-semibold text-red-700 mb-1\">О“ВҘГ® Lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi</div>\r\n            <div className=\"text-red-600\">{detail.reject_reason}</div>\r\n          </div>\r\n        )}\r\n\r\n        {/* Items table */}\r\n        {detail.items && detail.items.length > 0 && (\r\n          <div className=\"bg-white rounded-xl shadow-sm p-5 mb-4\">\r\n            <h2 className=\"font-semibold text-gray-700 mb-3\">вүЎЖ’ГҙВӘ Danh sв”ңГӯch hв”ңГЎng hв”ңв”Ӯa bв”ңГЎn giao</h2>\r\n            <div className=\"overflow-x-auto\">\r\n              <table className=\"w-full text-sm\">\r\n                <thead className=\"bg-gray-50 text-gray-600\">\r\n                  <tr>\r\n                    <th className=\"text-left py-2 px-3\">STT</th>\r\n                    <th className=\"text-left py-2 px-3\">SГҹв•‘Гәn phГҹв•‘вҢҗm</th>\r\n                    <th className=\"text-left py-2 px-3\">Mв”ңГә SP</th>\r\n                    <th className=\"text-right py-2 px-3\">SL yв”ңВ¬u cГҹв•‘Вәu</th>\r\n                    <th className=\"text-right py-2 px-3\">SL thГҹв•—в–’c tГҹв•‘в”җ</th>\r\n                    <th className=\"text-center py-2 px-3\">KhГҹв•—Вўp</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody className=\"divide-y divide-gray-100\">\r\n                  {detail.items.map((item, idx) => (\r\n                    <tr key={idx}>\r\n                      <td className=\"py-2 px-3 text-gray-500\">{idx + 1}</td>\r\n                      <td className=\"py-2 px-3 font-medium\">{item.product_name}</td>\r\n                      <td className=\"py-2 px-3 text-gray-500 font-mono text-xs\">{item.product_sku}</td>\r\n                      <td className=\"py-2 px-3 text-right\">{item.expected_qty}</td>\r\n                      <td className=\"py-2 px-3 text-right\">{item.actual_qty}</td>\r\n                      <td className=\"py-2 px-3 text-center\">\r\n                        {item.actual_qty === item.expected_qty ? (\r\n                          <span className=\"text-green-600\">О“ВЈГ </span>\r\n                        ) : (\r\n                          <span className=\"text-red-600 font-medium\">О“ГңГЎвҲ©в••Г… {item.actual_qty - item.expected_qty > 0 ? '+' : ''}{item.actual_qty - item.expected_qty}</span>\r\n                        )}\r\n                      </td>\r\n                    </tr>\r\n                  ))}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          </div>\r\n        )}\r\n\r\n        {/* Signatories status */}\r\n        <div className=\"bg-white r