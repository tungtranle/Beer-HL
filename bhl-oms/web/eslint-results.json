ad, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":123,"column":17,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":123,"endColumn":20,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[4172,4175],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[4172,4175],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":127,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":127,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[4399,4402],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[4399,4402],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":9,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState } from 'react'\r\nimport { apiFetch, getUser } from '@/lib/api'\r\nimport { toast } from '@/lib/useToast'\r\nimport { handleError } from '@/lib/handleError'\r\nimport { useRouter } from 'next/navigation'\r\n\r\ninterface BottleClassification {\r\n  id: string; trip_id: string; trip_number: string\r\n  product_id: string; product_name: string\r\n  bottles_sent: number; bottles_returned_good: number\r\n  bottles_returned_damaged: number; bottles_missing: number\r\n  notes: string; classified_at: string\r\n}\r\n\r\ninterface BottleSummary {\r\n  total_sent: number; total_returned_good: number\r\n  total_returned_damaged: number; total_missing: number\r\n  trips_processed: number\r\n}\r\n\r\ninterface Trip {\r\n  id: string; trip_number: string; vehicle_plate: string\r\n  driver_name: string; status: string\r\n}\r\n\r\n// F9: Production Planning Feed (BHL WorldClass Strategy)\r\ninterface SkuForecast {\r\n  sku_id: string\r\n  sku_name: string\r\n  predicted_qty: number\r\n  unit: string\r\n  vs_last_week_pct: number | null\r\n  safety_stock_alert: boolean\r\n  priority_score: number\r\n}\r\n\r\ninterface ProductionPlan {\r\n  forecast_as_of: string\r\n  forecast_week: string\r\n  warehouse_name: string\r\n  sku_forecast: SkuForecast[]\r\n  max_qty: number\r\n  alert_count: number\r\n}\r\n\r\nexport default function WorkshopPage() {\r\n  const router = useRouter()\r\n  const user = getUser()\r\n  const [activeTab, setActiveTab] = useState<'classify' | 'planning'>('classify')\r\n  const [summary, setSummary] = useState<BottleSummary | null>(null)\r\n  const [tripSearch, setTripSearch] = useState('')\r\n  const [selectedTrip, setSelectedTrip] = useState<Trip | null>(null)\r\n  const [classifications, setClassifications] = useState<BottleClassification[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [submitting, setSubmitting] = useState(false)\r\n  const [planningData, setPlanningData] = useState<ProductionPlan | null>(null)\r\n  const [planningLoading, setPlanningLoading] = useState(false)\r\n\r\n  // Form\r\n  const [productId, setProductId] = useState('')\r\n  const [productName, setProductName] = useState('')\r\n  const [sent, setSent] = useState(0)\r\n  const [returnedGood, setReturnedGood] = useState(0)\r\n  const [returnedDmg, setReturnedDmg] = useState(0)\r\n  const [notes, setNotes] = useState('')\r\n\r\n  useEffect(() => {\r\n    if (!user || !['admin', 'warehouse', 'workshop'].includes(user.role)) {\r\n      router.replace('/dashboard')\r\n      return\r\n    }\r\n    apiFetch<any>('/warehouse/bottles/summary')\r\n      .then(r => setSummary(r.data))\r\n      .catch(err => handleError(err))\r\n      .finally(() => setLoading(false))\r\n    // F9: Load production planning feed (graceful fail О“ГҮГ¶ available after AI Demand module)\r\n    setPlanningLoading(true)\r\n    apiFetch<any>('/workshop/production-plan')\r\n      .then(r => setPlanningData(r.data))\r\n      .catch(() => {})\r\n      .finally(() => setPlanningLoading(false))\r\n  }, [])\r\n\r\n  const searchTrip = async () => {\r\n    if (!tripSearch.trim()) return\r\n    try {\r\n      const res: any = await apiFetch(`/trips?search=${encodeURIComponent(tripSearch.trim())}`)\r\n      const trips = res.data || []\r\n      if (trips.length > 0) {\r\n        setSelectedTrip(trips[0])\r\n        const bc: any = await apiFetch(`/warehouse/bottles/trip/${trips[0].id}`)\r\n        setClassifications(bc.data || [])\r\n      } else {\r\n        toast.warning('Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y chuyГҹв•‘в”җn xe')\r\n      }\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i: ' + err.message)\r\n    }\r\n  }\r\n\r\n  const handleClassify = async () => {\r\n    if (!selectedTrip || !productId) return\r\n    setSubmitting(true)\r\n    try {\r\n      await apiFetch('/warehouse/bottles/classify', {\r\n        method: 'POST',\r\n        body: {\r\n          trip_id: selectedTrip.id,\r\n          trip_number: selectedTrip.trip_number,\r\n          product_id: productId,\r\n          product_name: productName,\r\n          bottles_sent: sent,\r\n          bottles_returned_good: returnedGood,\r\n          bottles_returned_damaged: returnedDmg,\r\n          notes,\r\n        },\r\n      })\r\n      // Reload\r\n      const bc: any = await apiFetch(`/warehouse/bottles/trip/${selectedTrip.id}`)\r\n      setClassifications(bc.data || [])\r\n      const sm: any = await apiFetch('/warehouse/bottles/summary')\r\n      setSummary(sm.data)\r\n      // Reset form\r\n      setProductId(''); setProductName(''); setSent(0); setReturnedGood(0); setReturnedDmg(0); setNotes('')\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i: ' + err.message)\r\n    } finally {\r\n      setSubmitting(false)\r\n    }\r\n  }\r\n\r\n  if (loading) return <div className=\"flex items-center justify-center h-64\"><div className=\"animate-spin w-8 h-8 border-4 border-amber-500 border-t-transparent rounded-full\" /></div>\r\n\r\n  return (\r\n    <div className=\"max-w-[1200px] mx-auto\">\r\n      {/* Tab navigation */}\r\n      <div className=\"flex items-center justify-between mb-6\">\r\n        <div>\r\n          <h1 className=\"text-2xl font-bold text-gray-800\">вүЎЖ’Г…ВЎ Phв”ңГіn xв•һв–‘Гҹв•—Ж’ng</h1>\r\n          <p className=\"text-sm text-gray-500 mt-0.5\">Phв”ңГіn loГҹв•‘Гӯi vГҹв•—Г… chai & KГҹв•‘в”җ hoГҹв•‘Гӯch sГҹв•‘Гәn xuГҹв•‘Г‘t</p>\r\n        </div>\r\n        <div className=\"flex gap-1 bg-gray-100 rounded-xl p-1\">\r\n          <button\r\n            onClick={() => setActiveTab('classify')}\r\n            className={`px-4 py-2 rounded-lg text-sm font-medium transition ${\r\n              activeTab === 'classify' ? 'bg-white shadow-sm text-gray-800' : 'text-gray-500 hover:text-gray-700'\r\n            }`}\r\n          >\r\n            вүЎЖ’ГҙВӘ Phв”ңГіn loГҹв•‘Гӯi vГҹв•—Г…\r\n          </button>\r\n          <button\r\n            onClick={() => setActiveTab('planning')}\r\n            className={`px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-1.5 ${\r\n              activeTab === 'planning' ? 'bg-white shadow-sm text-gray-800' : 'text-gray-500 hover:text-gray-700'\r\n            }`}\r\n          >\r\n            вүЎЖ’Г¶В« KГҹв•‘в”җ hoГҹв•‘Гӯch SX\r\n            {planningData?.alert_count ? (\r\n              <span className=\"w-4 h-4 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center\">{planningData.alert_count}</span>\r\n            ) : (\r\n              <span className=\"text-[9px] bg-blue-100 text-blue-600 px-1 rounded\">AI</span>\r\n            )}\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Tab: Classify (existing) */}\r\n      {activeTab === 'classify' && (\r\n        <div className=\"space-y-6\">\r\n        {summary && (\r\n        <>\r\n        <div className=\"grid grid-cols-2 md:grid-cols-5 gap-4\">\r\n          <div className=\"bg-white rounded-xl shadow-sm p-4 border-l-4 border-blue-500\">\r\n            <div className=\"text-xs text-gray-500 mb-1\">VГҹв•—Г… xuГҹв•‘Г‘t</div>\r\n            <div className=\"text-2xl font-bold text-blue-700\">{summary.total_sent.toLocaleString()}</div>\r\n          </div>\r\n          <div className=\"bg-white rounded-xl shadow-sm p-4 border-l-4 border-green-500\">\r\n            <div className=\"text-xs text-gray-500 mb-1\">Thu hГҹв•—Гҙi tГҹв•—ГҰt</div>\r\n            <div className=\"text-2xl font-bold text-green-700\">{summary.total_returned_good.toLocaleString()}</div>\r\n          </div>\r\n          <div className=\"bg-white rounded-xl shadow-sm p-4 border-l-4 border-amber-500\">\r\n            <div className=\"text-xs text-gray-500 mb-1\">Hв•һв–‘ hГҹв•—Г…ng</div>\r\n            <div className=\"text-2xl font-bold text-amber-700\">{summary.total_returned_damaged.toLocaleString()}</div>\r\n          </div>\r\n          <div className={`bg-white rounded-xl shadow-sm p-4 border-l-4 border-red-500 ${summary.total_missing > 0 ? 'animate-pulse' : ''}`}>\r\n            <div className=\"text-xs text-gray-500 mb-1\">ThiГҹв•‘в”җu/mГҹв•‘Г‘t</div>\r\n            <div className=\"text-2xl font-bold text-red-700\">{summary.total_missing.toLocaleString()}</div>\r\n          </div>\r\n          <div className=\"bg-white rounded-xl shadow-sm p-4 border-l-4 border-gray-400\">\r\n            <div className=\"text-xs text-gray-500 mb-1\">ChuyГҹв•‘в”җn в”ҖГҰв”ңГә xГҹв•—ВЎ lв”ңв•ң</div>\r\n            <div className=\"text-2xl font-bold text-gray-700\">{summary.trips_processed}</div>\r\n          </div>\r\n        </div>\r\n        {/* Recovery rate bar */}\r\n        {summary.total_sent > 0 && (() => {\r\n          const recoveryRate = Math.round(((summary.total_returned_good + summary.total_returned_damaged) / summary.total_sent) * 100)\r\n          const goodPct = Math.round((summary.total_returned_good / summary.total_sent) * 100)\r\n          const dmgPct = Math.round((summary.total_returned_damaged / summary.total_sent) * 100)\r\n          return (\r\n            <div className=\"bg-white rounded-xl shadow-sm p-4 border\">\r\n              <div className=\"flex justify-between items-center mb-2\">\r\n                <span className=\"text-sm font-medium text-gray-700\">TГҹв•—в•– lГҹв•—Г§ thu hГҹв•—Гҙi vГҹв•—Г…</span>\r\n                <span className={`text-sm font-bold ${recoveryRate >= 90 ? 'text-green-600' : recoveryRate >= 70 ? 'text-amber-600' : 'text-red-600'}`}>{recoveryRate}%</span>\r\n              </div>\r\n              <div className=\"w-full h-3 bg-gray-100 rounded-full overflow-hidden flex\">\r\n                <div className=\"bg-green-500 h-full transition-all\" style={{ width: `${goodPct}%` }} />\r\n                <div className=\"bg-amber-400 h-full transition-all\" style={{ width: `${dmgPct}%` }} />\r\n              </div>\r\n              <div className=\"flex gap-4 mt-1.5 text-xs text-gray-500\">\r\n                <span className=\"flex items-center gap-1\"><span className=\"w-2 h-2 rounded-full bg-green-500 inline-block\" />TГҹв•—ГҰt {goodPct}%</span>\r\n                <span className=\"flex items-center gap-1\"><span className=\"w-2 h-2 rounded-full bg-amber-400 inline-block\" />HГҹв•—Г…ng {dmgPct}%</span>\r\n                <span className=\"flex items-center gap-1\"><span className=\"w-2 h-2 rounded-full bg-gray-300 inline-block\" />ThiГҹв•‘в”җu {100 - goodPct - dmgPct}%</span>\r\n              </div>\r\n            </div>\r\n          )\r\n        })()}\r\n        </>\r\n        )}\r\n\r\n      {/* Search trip */}\r\n      <div className=\"bg-white rounded-xl shadow-sm p-6 mb-6\">\r\n        <h2 className=\"font-semibold text-gray-700 mb-3\">Tв”ңВјm chuyГҹв•‘в”җn xe</h2>\r\n        <div className=\"flex gap-3\">\r\n          <input\r\n            type=\"text\"\r\n            value={tripSearch}\r\n            onChange={e => setTripSearch(e.target.value)}\r\n            onKeyDown={e => e.key === 'Enter' && searchTrip()}\r\n            placeholder=\"NhГҹв•‘ВЎp mв”ңГә chuyГҹв•‘в”җn (VD: TR-20260316-001)\"\r\n            className=\"flex-1 px-4 py-2 border rounded-lg text-sm\"\r\n          />\r\n          <button onClick={searchTrip} className=\"px-6 py-2 bg-[#F68634] text-white rounded-lg hover:bg-[#e5752a] transition text-sm\">\r\n            вүЎЖ’Г¶Г¬ Tв”ңВјm\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Trip detail + classify form */}\r\n      {selectedTrip && (\r\n        <div className=\"bg-white rounded-xl shadow-sm p-6 mb-6\">\r\n          <div className=\"flex items-center justify-between mb-4\">\r\n            <div>\r\n              <h2 className=\"font-semibold text-gray-700\">ChuyГҹв•‘в”җn: {selectedTrip.trip_number}</h2>\r\n              <p className=\"text-sm text-gray-500\">{selectedTrip.vehicle_plate} О“ГҮГ¶ {selectedTrip.driver_name}</p>\r\n            </div>\r\n            <span className=\"px-3 py-1 rounded-full text-xs bg-blue-100 text-blue-700\">{selectedTrip.status}</span>\r\n          </div>\r\n\r\n          {/* Existing classifications */}\r\n          {classifications.length > 0 && (\r\n            <div className=\"mb-6\">\r\n              <h3 className=\"text-sm font-medium text-gray-600 mb-2\">в”ҖГүв”ңГә phв”ңГіn loГҹв•‘Гӯi:</h3>\r\n              <table className=\"w-full text-sm\">\r\n                <thead className=\"bg-gray-50\">\r\n                  <tr>\r\n                    <th className=\"text-left py-2 px-3\">SГҹв•‘Гәn phГҹв•‘вҢҗm</th>\r\n                    <th className=\"text-right py-2 px-3\">XuГҹв•‘Г‘t</th>\r\n                    <th className=\"text-right py-2 px-3\">TГҹв•—ГҰt</th>\r\n                    <th className=\"text-right py-2 px-3\">HГҹв•—Г…ng</th>\r\n                    <th className=\"text-right py-2 px-3\">ThiГҹв•‘в”җu</th>\r\n                    <th className=\"text-left py-2 px-3\">Ghi chв”ңв•‘</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody>\r\n                  {classifications.map(bc => (\r\n                    <tr key={bc.id} className=\"border-t\">\r\n                      <td className=\"py-2 px-3\">{bc.product_name}</td>\r\n                      <td className=\"py-2 px-3 text-right\">{bc.bottles_sent}</td>\r\n                      <td className=\"py-2 px-3 text-right text-green-600\">{bc.bottles_returned_good}</td>\r\n                      <td className=\"py-2 px-3 text-right text-amber-600\">{bc.bottles_returned_damaged}</td>\r\n                      <td className={`py-2 px-3 text-right font-medium ${bc.bottles_missing > 0 ? 'text-red-600' : 'text-gray-400'}`}>\r\n                        {bc.bottles_missing}\r\n                      </td>\r\n                      <td className=\"py-2 px-3 text-gray-500 text-xs\">{bc.notes || 'О“ГҮГ¶'}</td>\r\n                    </tr>\r\n                  ))}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          )}\r\n\r\n          {/* Add new classification */}\r\n          <div className=\"border-t pt-4\">\r\n            <h3 className=\"text-sm font-medium text-gray-600 mb-3\">Thв”ңВ¬m phв”ңГіn loГҹв•‘Гӯi:</h3>\r\n            <div className=\"grid grid-cols-2 md:grid-cols-3 gap-3 mb-3\">\r\n              <div>\r\n                <label className=\"text-xs text-gray-500\">Mв”ңГә SP</label>\r\n                <input type=\"text\" value={productId} onChange={e => setProductId(e.target.value)}\r\n                  placeholder=\"UUID sГҹв•‘Гәn phГҹв•‘вҢҗm\" className=\"w-full border rounded px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"text-xs text-gray-500\">Tв”ңВ¬n SP</label>\r\n                <input type=\"text\" value={productName} onChange={e => setProductName(e.target.value)}\r\n                  placeholder=\"Bia Heineken 330ml\" className=\"w-full border rounded px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"text-xs text-gray-500\">VГҹв•—Г… xuГҹв•‘Г‘t</label>\r\n                <input type=\"number\" value={sent} onChange={e => setSent(+e.target.value)}\r\n                  className=\"w-full border rounded px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"text-xs text-gray-500\">VГҹв•—Г… thu tГҹв•—ГҰt</label>\r\n                <input type=\"number\" value={returnedGood} onChange={e => setReturnedGood(+e.target.value)}\r\n                  className=\"w-full border rounded px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"text-xs text-gray-500\">VГҹв•—Г… hв•һв–‘ hГҹв•—Г…ng</label>\r\n                <input type=\"number\" value={returnedDmg} onChange={e => setReturnedDmg(+e.target.value)}\r\n                  className=\"w-full border rounded px-3 py-2 text-sm\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"text-xs text-gray-500\">Ghi chв”ңв•‘</label>\r\n                <input type=\"text\" value={notes} onChange={e => setNotes(e.target.value)}\r\n                  placeholder=\"Ghi chв”ңв•‘...\" className=\"w-full border rounded px-3 py-2 text-sm\" />\r\n              </div>\r\n            </div>\r\n            <div className=\"flex items-center gap-3\">\r\n              <div className=\"text-sm text-gray-500\">\r\n                ThiГҹв•‘в”җu: <strong className={sent - returnedGood - returnedDmg > 0 ? 'text-red-600' : 'text-green-600'}>\r\n                  {Math.max(0, sent - returnedGood - returnedDmg)}\r\n                </strong>\r\n              </div>\r\n              <button\r\n                onClick={handleClassify}\r\n                disabled={!productId || submitting}\r\n                className=\"ml-auto px-6 py-2 bg-[#F68634] text-white rounded-lg hover:bg-[#e5752a] transition text-sm disabled:opacity-50\"\r\n              >\r\n                {submitting ? 'в”ҖГүang lв•һв–‘u...' : 'О“ВЈГ  Phв”ңГіn loГҹв•‘Гӯi'}\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n      </div>\r\n      )}\r\n\r\n      {/* Tab: F9 Production Planning Feed */}\r\n      {activeTab === 'planning' && (\r\n        <div className=\"space-y-5\">\r\n          {planningLoading ? (\r\n            <div className=\"flex items-center justify-center h-48\">\r\n              <div className=\"animate-spin w-8 h-8 border-4 border-blue-400 border-t-transparent rounded-full\" />\r\n            </div>\r\n          ) : planningData ? (\r\n            <>\r\n              {/* Header info */}\r\n              <div className=\"bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-xl px-4 py-3 flex items-center justify-between\">\r\n                <div>\r\n                  <p className=\"text-sm font-bold text-blue-800\">KГҹв•‘в”җ hoГҹв•‘Гӯch sГҹв•‘Гәn xuГҹв•‘Г‘t О“ГҮГ¶ {planningData.forecast_week}</p>\r\n                  <p className=\"text-xs text-blue-600 mt-0.5\">Kho: {planningData.warehouse_name} в”¬в•– CГҹв•‘ВЎp nhГҹв•‘ВЎt: {planningData.forecast_as_of}</p>\r\n                </div>\r\n                {planningData.alert_count > 0 && (\r\n                  <div className=\"flex items-center gap-1.5 bg-red-100 text-red-700 text-xs font-semibold px-3 py-1.5 rounded-lg\">\r\n                    <span>О“ГңГЎвҲ©в••Г…</span> {planningData.alert_count} cГҹв•‘Гәnh bв”ңГӯo tГҹв•—Гҙn kho\r\n                  </div>\r\n                )}\r\n              </div>\r\n\r\n              {/* SKU forecast list */}\r\n              <div className=\"bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden\">\r\n                <div className=\"px-4 py-3 border-b border-gray-100 flex items-center justify-between\">\r\n                  <h3 className=\"text-sm font-bold text-gray-700\">DГҹв•—в–’ bв”ңГӯo nhu cГҹв•‘Вәu theo SKU (7 ngв”ңГЎy tГҹв•—Вўi)</h3>\r\n                  <span className=\"text-xs text-gray-400\">{planningData.sku_forecast.length} SKUs</span>\r\n                </div>\r\n                <div className=\"divide-y divide-gray-50\">\r\n                  {planningData.sku_forecast\r\n                    .sort((a, b) => b.priority_score - a.priority_score)\r\n                    .map((sku) => (\r\n                      <div key={sku.sku_id} className=\"px-4 py-3 flex items-center gap-4\">\r\n                        {/* Priority badge */}\r\n                        {sku.safety_stock_alert && (\r\n                          <span className=\"shrink-0 text-[10px] font-bold uppercase bg-red-100 text-red-700 px-1.5 py-0.5 rounded\">О“ГңГЎвҲ©в••Г… в•һВ»u tiв”ңВ¬n</span>\r\n                        )}\r\n                        {/* SKU name + bar */}\r\n                        <div className=\"flex-1 min-w-0\">\r\n                          <div className=\"flex items-center justify-between mb-1\">\r\n                            <p className=\"text-sm font-medium text-gray-800 truncate pr-2\">{sku.sku_name}</p>\r\n                            <div className=\"flex items-center gap-1.5 shrink-0\">\r\n                              <span className=\"text-sm font-bold text-blue-700\">{sku.predicted_qty.toLocaleString()}</span>\r\n                              <span className=\"text-xs text-gray-400\">{sku.unit}</span>\r\n                              {sku.vs_last_week_pct !== null && (\r\n                                <span className={`text-[10px] font-semibold px-1 rounded ${\r\n                                  sku.vs_last_week_pct > 0 ? 'text-emerald-700 bg-emerald-50' : 'text-red-600 bg-red-50'\r\n                                }`}>\r\n                                  {sku.vs_last_week_pct > 0 ? 'О“ГҘГҰ' : 'О“ГҘГҙ'}{Math.abs(sku.vs_last_week_pct)}%\r\n                                </span>\r\n                              )}\r\n                            </div>\r\n                          </div>\r\n                          <div className=\"h-1.5 bg-gray-100 rounded-full overflow-hidden\">\r\n                            <div\r\n                              className={`h-full rounded-full ${\r\n                                sku.safety_stock_alert ? 'bg-red-400' : 'bg-blue-400'\r\n                              }`}\r\n                              style={{ width: `${Math.min(100, planningData.max_qty > 0 ? (sku.predicted_qty / planningData.max_qty) * 100 : 0)}%` }}\r\n                            />\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    ))\r\n                  }\r\n                </div>\r\n              </div>\r\n\r\n              <p className=\"text-xs text-gray-400 text-center\">DГҹв•—в–’ bв”ңГӯo tГҹв•—ВҪ AI Demand Model в”¬в•– HiГҹв•—Гўu chГҹв•—Г«nh theo mв”ңв•Јa vГҹв•—Г‘ (Prophet + Croston)</p>\r\n            </>\r\n          ) : (\r\n            <div className=\"text-center py-16\">\r\n              <div className=\"text-5xl mb-4\">вүЎЖ’Г¶В«</div>\r\n              <p className=\"text-base font-semibold text-gray-700\">Tв”ңВЎnh nв”ҖГўng в”ҖГҰang phв”ңГӯt triГҹв•—Гўn</p>\r\n              <p className=\"text-sm text-gray-400 mt-2\">KГҹв•‘в”җ hoГҹв•‘Гӯch sГҹв•‘Гәn xuГҹв•‘Г‘t tГҹв•—ВҪ AI Demand Forecast sГҹв•‘в•ң hiГҹв•—Гўn thГҹв•—ГҜ Гҹв•—Ж’ в”ҖГҰв”ңГіy sau khi module khГҹв•—Ж’i в”ҖГҰГҹв•—Г–ng</p>\r\n              <div className=\"mt-6 bg-blue-50 border border-blue-200 rounded-xl p-5 max-w-sm mx-auto text-left\">\r\n                <p className=\"text-xs font-bold text-blue-700 mb-3\">Khi hoв”ңГЎn thiГҹв•—Г§n sГҹв•‘в•