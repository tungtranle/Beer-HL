: 'border-red-200 bg-red-50/30',\r\n    rows: [\r\n      { event: 'Gate check fail', channels: ['Web popup', 'App push', 'SMS', 'Escalate 5\\''] },\r\n      { event: 'Xe tai nГҹв•‘Гӯn / sГҹв•—в–’ cГҹв•—ГҰ nghiв”ңВ¬m trГҹв•—Г¬ng', channels: ['Web popup', 'App push', 'SMS'] },\r\n      { event: 'DLQ hГҹв•‘в”җt 3 lГҹв•‘Вәn retry', channels: ['Web popup', 'SMS Admin'] },\r\n    ]},\r\n  { priority: 'P1 Urgent', label: 'Routing theo sГҹв•—в–’ kiГҹв•—Г§n О“ГҮГ¶ P1 Urgent', color: 'border-amber-200 bg-amber-50/30',\r\n    rows: [\r\n      { event: 'в”ҖГүв•һГӯn chГҹв•—ВҘ duyГҹв•—Г§t hГҹв•‘Гӯn mГҹв•—вҢҗc (R15)', channels: ['Web toast', 'App push', 'Escalate 30\\''] },\r\n      { event: 'CK timeout chв•һв–‘a xв”ңГӯc nhГҹв•‘ВЎn', channels: ['Web toast', 'App push', 'Escalate config'] },\r\n      { event: 'Sai lГҹв•—Г§ch T+1 cв”ңв–“n < 2 giГҹв•—ВҘ', channels: ['Web toast', 'App push'] },\r\n      { event: 'Xe dГҹв•—ВҪng > ngв•һв–‘Гҹв•—Гӯng cГҹв•‘Гәnh bв”ңГӯo', channels: ['Web toast', 'App push'] },\r\n      { event: 'NPP tГҹв•—ВҪ chГҹв•—ГҰi в”ҖГҰв•һГӯn hв”ңГЎng (R16)', channels: ['Web toast'] },\r\n    ]},\r\n  { priority: 'P2 & Zalo OA', label: 'Routing theo sГҹв•—в–’ kiГҹв•—Г§n О“ГҮГ¶ P2 & Zalo OA', color: 'border-blue-200 bg-blue-50/30',\r\n    rows: [\r\n      { event: 'Trip hoв”ңГЎn thв”ңГЎnh', channels: ['Web bell', 'App badge'] },\r\n      { event: 'Xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰв•һГӯn hв”ңГЎng (R16) О“ГҮГ¶ cho NPP', channels: ['Zalo OA'] },\r\n      { event: 'Xв”ңГӯc nhГҹв•‘ВЎn nhГҹв•‘ВЎn hв”ңГЎng (R13) О“ГҮГ¶ cho NPP', channels: ['Zalo OA'] },\r\n      { event: 'HГҹв•‘Гӯn mГҹв•—вҢҗc NPP sГҹв•‘В»p hГҹв•‘в”җt thГҹв•—ВҘi kГҹв•—в”Ӯ', channels: ['Web bell'] },\r\n      { event: 'Xe cГҹв•‘Вәn kiГҹв•—Гўm в”ҖГҰГҹв•—ГҜnh / bГҹв•‘Гәo dв•һв–‘Гҹв•—Гӯng', channels: ['Web bell', 'App push'] },\r\n    ]},\r\n]\r\n\r\n// О“Г¶ГҮО“Г¶ГҮ Settings rows (Гҹв•‘Гәnh 4) О“Г¶ГҮО“Г¶ГҮ\r\nconst SETTINGS_EVENTS = [\r\n  'в”ҖГүв•һГӯn chГҹв•—ВҘ duyГҹв•—Г§t hГҹв•‘Гӯn mГҹв•—вҢҗc', 'Xв”ңГӯc nhГҹв•‘ВЎn chuyГҹв•—Гўn khoГҹв•‘Гәn', 'Trip hoв”ңГЎn thв”ңГЎnh',\r\n  'Sai lГҹв•—Г§ch в”ҖГҰГҹв•—ГҰi soв”ңГӯt', 'DLQ lГҹв•—Г№i tв”ңВЎch hГҹв•—Гәp', 'Hв”ңГЎng cГҹв•‘ВЎn date',\r\n]\r\n\r\n// О“Г¶ГҮО“Г¶ГҮ Escalation example (Гҹв•‘Гәnh 5) О“Г¶ГҮО“Г¶ГҮ\r\nconst ESCALATION_STEPS = [\r\n  { time: 'T+0: ngay lГҹв•‘ВЎp tГҹв•—вҢҗc', title: 'KГҹв•‘в”җ toв”ңГӯn phГҹв•—Г‘ trв”ңГӯch nhГҹв•‘ВЎn notification', desc: 'Web toast + App push О“ГҮГ¶ VГҹв•—Вўi nв”ңв•‘t DuyГҹв•—Г§t / TГҹв•—ВҪ chГҹв•—ГҰi inline', color: 'bg-blue-600' },\r\n  { time: 'T+20 phв”ңв•‘t', title: 'NГҹв•‘в”җu chв•һв–‘a xГҹв•—ВЎ lв”ңв•ң О“ГҮГ¶ nhГҹв•‘В»c lГҹв•‘Гӯi + badge в”ҖГҰГҹв•—ГІi mв”ңГЎu', desc: 'Notification chuyГҹв•—Гўn mв”ңГЎu amber, snooze bГҹв•—ГҜ tГҹв•‘В»t', color: 'bg-amber-500' },\r\n  { time: 'T+30 phв”ңв•‘t', title: 'KГҹв•‘в”җ toв”ңГӯn trв•һв–‘Гҹв•—Ж’ng nhГҹв•‘ВЎn notification', desc: 'Web toast + App push О“ГҮГ¶ note \"KГҹв•‘в”җ toв”ңГӯn X chв•һв–‘a xГҹв•—ВЎ lв”ңв•ң\"', color: 'bg-orange-500' },\r\n  { time: 'T+45 phв”ңв•‘t', title: 'QuГҹв•‘Гәn lв”ңв•ң vГҹв•‘ВЎn hв”ңГЎnh nhГҹв•‘ВЎn Web popup + SMS', desc: 'в”ҖГүв•һГӯn sГҹв•‘В»p quв”ңГӯ mГҹв•—ГҰc chГҹв•—ГҰt 16h О“ГҮГ¶ cГҹв•‘Вәn quyГҹв•‘в”җt в”ҖГҰГҹв•—ГҜnh ngay', color: 'bg-red-500' },\r\n  { time: 'T+60 phв”ңв•‘t (hoГҹв•‘в•–c quв”ңГӯ 16h cutoff)', title: 'TГҹв•—в–’ в”ҖГҰГҹв•—Г–ng tГҹв•—ВҪ chГҹв•—ГҰi nГҹв•‘в”җu khв”ңв”Өng ai xГҹв•—ВЎ lв”ңв•ң', desc: 'Log в”ҖГҰГҹв•‘Вәy в”ҖГҰГҹв•—Вә ai nhГҹв•‘ВЎn notification, ai khв”ңв”Өng phГҹв•‘Гәn hГҹв•—Гҙi', color: 'bg-gray-800' },\r\n]\r\n\r\n// О“Г¶ГҮО“Г¶ГҮ Channel badge component О“Г¶ГҮО“Г¶ГҮ\r\nfunction ChannelBadge({ ch }: { ch: string }) {\r\n  const colors: Record<string, string> = {\r\n    'Web popup': 'bg-red-100 text-red-700 border-red-200',\r\n    'App push': 'bg-green-100 text-green-700 border-green-200',\r\n    'SMS': 'bg-amber-100 text-amber-700 border-amber-200',\r\n    'SMS fallback': 'bg-amber-100 text-amber-700 border-amber-200',\r\n    'SMS Admin': 'bg-amber-100 text-amber-700 border-amber-200',\r\n    'Web toast': 'bg-orange-100 text-orange-700 border-orange-200',\r\n    'Web bell': 'bg-blue-100 text-blue-700 border-blue-200',\r\n    'App badge': 'bg-purple-100 text-purple-700 border-purple-200',\r\n    'Hourly digest': 'bg-gray-100 text-gray-700 border-gray-200',\r\n    'Zalo OA': 'bg-blue-100 text-blue-700 border-blue-200',\r\n  }\r\n  const c = colors[ch] || 'bg-gray-100 text-gray-600 border-gray-200'\r\n  const isEscalate = ch.startsWith('Escalate')\r\n  return (\r\n    <span className={`inline-block px-2 py-0.5 text-[11px] font-medium rounded border ${isEscalate ? 'bg-gray-800 text-white border-gray-800' : c}`}>\r\n      {ch}\r\n    </span>\r\n  )\r\n}\r\n\r\nfunction timeAgo(dateStr: string) {\r\n  const diff = Date.now() - new Date(dateStr).getTime()\r\n  const mins = Math.floor(diff / 60000)\r\n  if (mins < 1) return 'vГҹв•—ВҪa xong'\r\n  if (mins < 60) return `${mins} phв”ңв•‘t`\r\n  const hours = Math.floor(mins / 60)\r\n  if (hours < 24) return `${hours} giГҹв•—ВҘ`\r\n  return `${Math.floor(hours / 24)}d`\r\n}\r\n\r\nfunction formatDateTime(dateStr: string) {\r\n  const d = new Date(dateStr)\r\n  return d.toLocaleString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' })\r\n}\r\n\r\n// GГҹв•—Г–p notifications cв”ңв•Јng group_key thв”ңГЎnh 1 thread, giГҹв•—В» nguyв”ңВ¬n thГҹв•—вҢҗ tГҹв•—в–’ thГҹв•—ВҘi gian\r\nfunction mergeGroups(notifs: Notification[]): { grouped: boolean; items: Notification[]; key: string | null }[] {\r\n  const groupKeyMap = new Map<string, Notification[]>()\r\n  const processedGroupKeys = new Set<string>()\r\n  const result: { grouped: boolean; items: Notification[]; key: string | null }[] = []\r\n\r\n  for (const n of notifs) {\r\n    if (n.group_key) {\r\n      const arr = groupKeyMap.get(n.group_key) || []\r\n      arr.push(n)\r\n      groupKeyMap.set(n.group_key, arr)\r\n    }\r\n  }\r\n\r\n  for (const n of notifs) {\r\n    if (n.group_key) {\r\n      if (processedGroupKeys.has(n.group_key)) continue\r\n      processedGroupKeys.add(n.group_key)\r\n      const groupItems = groupKeyMap.get(n.group_key)!\r\n      result.push({ grouped: groupItems.length > 1, items: groupItems, key: n.group_key })\r\n    } else {\r\n      result.push({ grouped: false, items: [n], key: null })\r\n    }\r\n  }\r\n  return result\r\n}\r\n\r\nfunction groupByTime(notifs: Notification[]) {\r\n  const now = new Date()\r\n  const oneHourAgo = new Date(now.getTime() - 3600000)\r\n  const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate())\r\n\r\n  const groups: { label: string; items: Notification[] }[] = [\r\n    { label: 'Ngay bв”ңГіy giГҹв•—ВҘ', items: [] },\r\n    { label: 'Hв”ңв”Өm nay', items: [] },\r\n    { label: 'Trв•һв–‘Гҹв•—Вўc в”ҖГҰв”ңв”Ӯ', items: [] },\r\n  ]\r\n\r\n  for (const n of notifs) {\r\n    const d = new Date(n.created_at)\r\n    if (d >= oneHourAgo) groups[0].items.push(n)\r\n    else if (d >= todayStart) groups[1].items.push(n)\r\n    else groups[2].items.push(n)\r\n  }\r\n  return groups.filter(g => g.items.length > 0)\r\n}\r\n\r\nexport default function NotificationsPage() {\r\n  const router = useRouter()\r\n  const [tab, setTab] = useState<Tab>('center')\r\n  const [notifications, setNotifications] = useState<Notification[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [filter, setFilter] = useState<CategoryFilter>('all')\r\n  const [unreadCount, setUnreadCount] = useState(0)\r\n  const [settingsToggles, setSettingsToggles] = useState<Record<string, Record<string, boolean>>>({})\r\n  const [page, setPage] = useState(1)\r\n  const [limit, setLimit] = useState(50)\r\n  const [totalRows, setTotalRows] = useState(0)\r\n  const [searchQuery, setSearchQuery] = useState('')\r\n  const [expandedGroups, setExpandedGroups] = useState<Set<string>>(new Set())\r\n\r\n  const load = useCallback(async () => {\r\n    try {\r\n      const res = await apiFetch<any>(`/notifications?page=${page}&limit=${limit}`)\r\n      setNotifications(res.data || [])\r\n      setTotalRows(res.meta?.total ?? 0)\r\n    } catch { /* ignore */ }\r\n    try {\r\n      const res = await apiFetch<any>('/notifications/unread-count')\r\n      setUnreadCount(res.data?.unread_count || 0)\r\n    } catch { /* ignore */ }\r\n    setLoading(false)\r\n  }, [page, limit])\r\n\r\n  useEffect(() => { load() }, [load])\r\n\r\n  const markRead = async (id: string) => {\r\n    try {\r\n      await apiFetch(`/notifications/${id}/read`, { method: 'POST' })\r\n      setNotifications(prev => prev.map(n => n.id === id ? { ...n, is_read: true } : n))\r\n      setUnreadCount(prev => Math.max(0, prev - 1))\r\n    } catch { /* ignore */ }\r\n  }\r\n\r\n  const markAllRead = async () => {\r\n    try {\r\n      await apiFetch('/notifications/read-all', { method: 'POST' })\r\n      setNotifications(prev => prev.map(n => ({ ...n, is_read: true })))\r\n      setUnreadCount(0)\r\n    } catch { /* ignore */ }\r\n  }\r\n\r\n  const handleClick = (n: Notification) => {\r\n    if (!n.is_read) markRead(n.id)\r\n    if (n.link) router.push(`/dashboard${n.link}`)\r\n  }\r\n\r\n  const toggleSetting = (event: string, channel: string) => {\r\n    setSettingsToggles(prev => ({\r\n      ...prev,\r\n      [event]: { ...(prev[event] || {}), [channel]: !(prev[event]?.[channel]) }\r\n    }))\r\n  }\r\n\r\n  const filteredNotifications = notifications.filter(n => {\r\n    const matchesCategory = filter === 'all' || n.category === filter\r\n    const matchesSearch = !searchQuery ||\r\n      n.title.toLowerCase().includes(searchQuery.toLowerCase()) ||\r\n      n.body.toLowerCase().includes(searchQuery.toLowerCase())\r\n    return matchesCategory && matchesSearch\r\n  })\r\n\r\n  const TABS: { key: Tab; label: string }[] = [\r\n    { key: 'architecture', label: 'KiГҹв•‘в”җn trв”ңв•‘c' },\r\n    { key: 'center', label: 'Notification center' },\r\n    { key: 'routing', label: 'Routing thв”ңв”Өng minh' },\r\n    { key: 'settings', label: 'Cв”ңГЎi в”ҖГҰГҹв•‘в•–t cв”ңГӯ nhв”ңГіn' },\r\n    { key: 'escalation', label: 'Escalation chain' },\r\n  ]\r\n\r\n  return (\r\n    <div className=\"max-w-4xl mx-auto\">\r\n      {/* Tab bar */}\r\n      <div className=\"flex gap-2 mb-6 flex-wrap\">\r\n        {TABS.map(t => (\r\n          <button\r\n            key={t.key}\r\n            onClick={() => setTab(t.key)}\r\n            className={`px-4 py-2.5 text-sm font-medium rounded-lg border transition ${\r\n              tab === t.key\r\n                ? 'bg-white border-gray-300 shadow-sm text-gray-900'\r\n                : 'bg-white border-gray-200 text-gray-500 hover:border-gray-300 hover:text-gray-700'\r\n            }`}\r\n          >\r\n            {t.label}\r\n          </button>\r\n        ))}\r\n      </div>\r\n\r\n      {/* О“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГү Tab 1: KiГҹв•‘в”җn trв”ңв•‘c (Гҹв•‘Гәnh 1) О“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГү */}\r\n      {tab === 'architecture' && (\r\n        <div className=\"space-y-6\">\r\n          {/* 4 Priority cards */}\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n            {Object.entries(PRIORITY).map(([key, p]) => (\r\n              <div key={key} className={`rounded-xl border-2 p-5 ${p.color}`}>\r\n                <p className=\"text-xs font-bold uppercase tracking-wider mb-1\">{p.label}</p>\r\n                <p className=\"font-semibold text-base mb-2\">{p.title}</p>\r\n                <p className=\"text-sm opacity-80 mb-3\">{p.examples}</p>\r\n                <div className=\"flex flex-wrap gap-1.5\">\r\n                  {p.channels.map(ch => <ChannelBadge key={ch} ch={ch} />)}\r\n                </div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n\r\n          {/* 5 Design principles */}\r\n          <div>\r\n            <h3 className=\"text-base font-semibold text-gray-800 mb-3\">5 nguyв”ңВ¬n tГҹв•‘В»c thiГҹв•‘в”җt kГҹв•‘в”җ</h3>\r\n            <div className=\"grid grid-cols-2 md:grid-cols-3 gap-3\">\r\n              {[\r\n                { name: 'Actionable', desc: 'MГҹв•—Г¬i thв”ңв”Өng bв”ңГӯo cв”ңв”Ӯ CTA inline, khв”ңв”Өng phГҹв•‘Гәi chГҹв•—Г« \"xem thв”ңВ¬m\"' },\r\n                { name: 'Grouped', desc: 'NhiГҹв•—Гјu sГҹв•—в–’ kiГҹв•—Г§n cв”ңв•Јng Trip/Order gГҹв•—Г–p thв”ңГЎnh 1 thread' },\r\n                { name: 'Context-rich', desc: 'Link thГҹв•‘в”Ӯng в”ҖГҰГҹв•‘в”җn record, khв”ңв”Өng cГҹв•‘Вәn tв”ңВјm lГҹв•‘Гӯi' },\r\n                { name: 'Role-aware', desc: 'KГҹв•‘в”җ toв”ңГӯn khв”ңв”Өng nhГҹв•‘ВЎn alert GPS, Tв”ңГЎi xГҹв•‘в”җ khв”ңв”Өng nhГҹв•‘ВЎn alert kho' },\r\n                { name: 'Audit trail', desc: 'Ai в”ҖГҰв”ңГә в”ҖГҰГҹв•—Г¬c, ai в”ҖГҰв”ңГә xГҹв•—ВЎ lв”ңв•ң, lв”ңв•‘c mГҹв•‘Г‘y giГҹв•—ВҘ О“ГҮГ¶ cв”ңв”Ӯ log в”ҖГҰГҹв•‘Вәy в”ҖГҰГҹв•—Вә' },\r\n              ].map(p => (\r\n                <div key={p.name} className=\"bg-white rounded-lg border border-gray-200 p-4\">\r\n                  <p className=\"font-semibold text-sm text-gray-800 mb-1\">{p.name}</p>\r\n                  <p className=\"text-xs text-gray-500 leading-relaxed\">{p.desc}</p>\r\n                </div>\r\n              ))}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* О“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГү Tab 2: Notification Center (Гҹв•‘Гәnh 2) О“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГүО“ГІГү */}\r\n      {tab === 'center' && (\r\n        <div>\r\n          {/* Header */}\r\n          <div className=\"flex items-center justify-between mb-4\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <h2 className=\"text-lg font-semibold text-gray-900\">Thв”ңв”Өng bв”ңГӯo</h2>\r\n              {unreadCount > 0 && (\r\n                <span className=\"px-2 py-0.5 bg-red-500 text-white text-xs font-bold rounded-full\">{unreadCount}</span>\r\n              )}\r\n            </div>\r\n            <div className=\"flex items-center gap-2\">\r\n              {unreadCount > 0 && (\r\n                <button onClick={markAllRead}\r\n                  className=\"text-sm text-gray-600 hover:text-gray-800 px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition\">\r\n                  в”ҖГүв”ңГӯnh dГҹв•‘Г‘u tГҹв•‘Г‘t cГҹв•‘Гә в”ҖГҰв”ңГә в”ҖГҰГҹв•—Г¬c\r\n                </button>\r\n              )}\r\n              <button className=\"text-sm text-gray-600 hover:text-gray-800 px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition\">\r\n                Cв”ңГЎi в”ҖГҰГҹв•‘в•–t\r\n              </button>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Search + Category filters */}\r\n          <div className=\"flex flex-col gap-3 mb-5\">\r\n            <div className=\"relative\">\r\n              <svg className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={2}>\r\n                <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" />\r\n              </svg>\r\n              <input\r\n                type=\"text\"\r\n                placeholder=\"Tв”ңВјm theo tiв”ңВ¬u в”ҖГҰГҹв•—Гј, nГҹв•—Г–i dung, mв”ңГә в”ҖГҰв•һГӯn...\"\r\n                value={searchQuery}\r\n                onChange={e => { setSearchQuery(e.target.value); setPage(1) }}\r\n                className=\"w-full pl-9 pr-4 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#F68634]/40 focus:border-[#F68634] transition\"\r\n              />\r\n              {searchQuery && (\r\n                <button onClick={() => setSearchQuery('')} className=\"absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600\">\r\n                  <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={2}>\r\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M6 18L18 6M6 6l12 12\" />\r\n                  </svg>\r\n                </button>\r\n              )}\r\n            </div>\r\n            <div className=\"flex gap-2 flex-wrap\">\r\n              {([\r\n                { key: 'all' as CategoryFilter, label: 'TГҹв•‘Г‘t cГҹв•‘Гә' },\r\n                { key: 'order' as CategoryFilter, label: 'в”ҖГүв•һГӯn hв”ңГЎng' },\r\n                { key: 'delivery' as CategoryFilter, label: 'VГҹв•‘ВЎn chuyГҹв•—Гўn' },\r\n                { key: 'recon' as CategoryFilter, label: 'в”ҖГүГҹв•—ГҰi soв”ңГӯt' },\r\n                { key: 'system' as CategoryFilter, label: 'HГҹв•—Г§ thГҹв•—ГҰng' },\r\n              ]).map(f => (\r\n                <button key={f.key} onClick={() => setFilter(f.key)}\r\n                  className={`px-3.5 py-1.5 text-sm rounded-lg border transition ${\r\n                    filter === f.key\r\n                      ? 'bg-gray-800 text-white border-gray-800'\r\n                      : 'bg-white text-gray-600 border-gray-200 hover:border-gray-300'\r\n                  }`}>\r\n                  {f.label}\r\n                </button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Notification list grouped by time */}\r\n          {loading ? (\r\n            <div className=\"flex justify-center py-20\">\r\n              <div className=\"animate-spin rounded-full h-8 w-8 border-b-2 border-[#F68634]\"></div>\r\n            </div>\r\n          ) : filteredNotifications.length === 0 ? (\r\n            <div className=\"bg-white rounded-xl border border-gray-200 p-12 text-center\">\r\n              <p className=\"text-4xl mb-3\">вүЎЖ’Г¶Г¶</p>\r\n              {searchQuery ? (\r\n                <>\r\n                  <p className=\"text-gray-700 font-medium\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y kГҹв•‘в”җt quГҹв•‘Гә</p>\r\n                  <p className=\"text-gray-400 text-sm mt-1\">cho &ldquo;{searchQuery}&rdquo;</p>\r\n                  <button onClick={() => setSearchQuery('')} className=\"mt-3 text-sm text-[#F68634] hover:underline\">Xв”ңв”Ӯa tв”ңВјm kiГҹв•‘в”җm</button>\r\n                </>\r\n              ) : filter !== 'all' ? (\r\n                <p className=\"text-gray-500\">Khв”ңв”Өng cв”ңв”Ӯ thв”ңв”Өng bв”ңГӯo nв”ңГЎo trong mГҹв•—Г‘c nв”ңГЎy</p>\r\n              ) : (\r\n                <p className=\"text-gray-500\">Chв•һв–‘a cв”ңв”Ӯ thв”ңв”Өng bв”ңГӯo nв”ңГЎo</p>\r\n              )}\r\n            </div>\r\n          ) : (\r\n            <div className=\"space-y-6\">\r\n              {groupByTime(filteredNotifications).map(group => (\r\n                <div key={group.label}>\r\n                  <p className=\"text-xs font-medium text-gray-400 uppercase tracking-wider mb-2\">{group.label}</p>\r\n                  <div className=\"space-y-2\">\r\n                    {mergeGroups(group.items).map(({ grouped, items, key }) => {\r\n                      const n = items[0]\r\n                      const isExpanded = key ? expandedGroups.has(key) : false\r\n                      const cat = CATEGORY_BADGE[n.category] || CATEGORY_BADGE.system\r\n                      const borderClass = PRIORITY_BORDER[n.priority] || PRIORITY_BORDER.normal\r\n                      return (\r\n                        <div key={n.id} className={`bg-white rounded-lg border border-gray-200 overflow-hidden ${borderClass}`}>\r\n                          {/* Main notification row */}\r\n                          <div\r\n                            onClick={() => {\r\n                              if (!n.is_read) markRead(n.id)\r\n                              if (n.link) router.push(`/dashboard${n.link}`)\r\n                            }}\r\n                            className={`p-4 cursor-pointer hover:shadow-md transition ${!n.is_read ? 'bg-amber-50/30' : ''}`}>\r\n                            <div className=\"flex items-start gap-3\">\r\n                              <div className={`flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold ${cat.color}`}>\r\n                   