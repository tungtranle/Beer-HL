                                >XГҹв•—ВЎ lв”ңв•ң</button>\r\n                              )\r\n                            )}\r\n                            {d.status === 'resolved' && (\r\n                              <span className=\"text-xs text-gray-400\" title={d.resolution || ''}>О“ВЈГ </span>\r\n                            )}\r\n                            {/* Task 6.3: Action history button */}\r\n                            <button\r\n                              onClick={() => loadHistory(d.id)}\r\n                              className=\"text-blue-500 text-xs hover:underline ml-1\"\r\n                              title=\"Xem lГҹв•—ГҜch sГҹв•—ВЎ\"\r\n                            >вүЎЖ’ГҙВЈ</button>\r\n                          </div>\r\n                        </td>\r\n                      </tr>\r\n                    )\r\n                  })\r\n                )}\r\n              </tbody>\r\n            </table>\r\n            {discTotal > 0 && (\r\n              <Pagination page={discPage} limit={discLimit} total={discTotal}\r\n                onPageChange={setDiscPage}\r\n                onLimitChange={(n) => { setDiscLimit(n); setDiscPage(1) }}\r\n                className=\"border-t bg-gray-50\" />\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* в”ңГіО“ГҮВҘО“Г©Вјв”ңГіО“ГҮВҘО“Г©Вј TAB: Daily Close в”ңГіО“ГҮВҘО“Г©Вјв”ңГіО“ГҮВҘО“Г©Вј */}\r\n      {activeTab === 'close' && (\r\n        <div>\r\n          <div className=\"flex justify-end mb-4\">\r\n            <button\r\n              onClick={handleGenerateDailyClose}\r\n              className=\"px-4 py-2 bg-brand-500 text-white rounded-lg hover:bg-brand-600 transition text-sm\"\r\n            >\r\n              вүЎЖ’ГҙГ  ChГҹв•—ГҰt sГҹв•—ГІ hв”ңв”Өm nay\r\n            </button>\r\n          </div>\r\n\r\n          <div className=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n            <table className=\"w-full text-sm\">\r\n              <thead clas