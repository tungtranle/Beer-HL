ssert the type is correct."},{"messageId":"suggestNever","fix":{"range":[5733,5736],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":9,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState, useRef, useCallback } from 'react'\r\nimport { useParams, useRouter } from 'next/navigation'\r\nimport { apiFetch } from '@/lib/api'\r\nimport { toast } from '@/lib/useToast'\r\nimport { handleError } from '@/lib/handleError'\r\n\r\ninterface TripStop {\r\n  id: string; stop_order: number; shipment_id: string\r\n  customer_name: string; customer_address: string\r\n  latitude: number; longitude: number; status: string\r\n  estimated_arrival: string; estimated_departure: string\r\n  cumulative_load_kg: number\r\n}\r\n\r\ninterface TripDetail {\r\n  id: string; trip_number: string; vehicle_plate: string; driver_name: string\r\n  driver_phone: string; warehouse_name: string; warehouse_lat: number; warehouse_lng: number\r\n  status: string; total_distance_km: number; total_weight_kg: number\r\n  planned_date: string; created_at: string; total_stops: number\r\n  stops: TripStop[]\r\n}\r\n\r\nconst statusLabels: Record<string, string> = {\r\n  planned: 'в”ҖГүв”ңГә lв”ңВ¬n kГҹв•‘в”җ hoГҹв•‘Гӯch', assigned: 'в”ҖГүв”ңГә phв”ңГіn cв”ңв”Өng', ready: 'SГҹв•‘в•Ўn sв”ңГЎng',\r\n  in_transit: 'в”ҖГүang giao', completed: 'Hoв”ңГЎn thв”ңГЎnh', cancelled: 'в”ҖГүв”ңГә hГҹв•—Вәy',\r\n}\r\n\r\nconst stopStatusLabels: Record<string, string> = {\r\n  pending: 'ChГҹв•—ВҘ', arrived: 'в”ҖГүв”ңГә в”ҖГҰГҹв•‘в”җn', delivering: 'в”ҖГүang giao',\r\n  delivered: 'в”ҖГүв”ңГә giao', failed: 'ThГҹв•‘Г‘t bГҹв•‘Гӯi', skipped: 'BГҹв•—Г… qua',\r\n}\r\n\r\nconst tripActions: Record<string, { label: string; next: string; color: string }[]> = {\r\n  planned:   [{ label: 'BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu giao', next: 'in_transit', color: 'bg-yellow-500 hover:bg-yellow-600' },\r\n              { label: 'HГҹв•—Вәy chuyГҹв•‘в”җn', next: 'cancelled', color: 'bg-red-500 hover:bg-red-600' }],\r\n  assigned:  [{ label: 'BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu giao', next: 'in_transit', color: 'bg-yellow-500 hover:bg-yellow-600' },\r\n              { label: 'HГҹв•—Вәy chuyГҹв•‘в”җn', next: 'cancelled', color: 'bg-red-500 hover:bg-red-600' }],\r\n  ready:     [{ label: 'BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu giao', next: 'in_transit', color: 'bg-yellow-500 hover:bg-yellow-600' },\r\n              { label: 'HГҹв•—Вәy chuyГҹв•‘в”җn', next: 'cancelled', color: 'bg-red-500 hover:bg-red-600' }],\r\n  in_transit:[{ label: 'Hoв”ңГЎn thв”ңГЎnh chuyГҹв•‘в”җn', next: 'completed', color: 'bg-green-500 hover:bg-green-600' },\r\n              { label: 'HГҹв•—Вәy chuyГҹв•‘в”җn', next: 'cancelled', color: 'bg-red-500 hover:bg-red-600' }],\r\n}\r\n\r\nconst stopActions: Record<string, { label: string; action: string; color: string }[]> = {\r\n  pending:  [{ label: 'в”ҖГүв”ңГә в”ҖГҰГҹв•‘в”җn', action: 'arrive', color: 'text-blue-600 hover:text-blue-800' },\r\n             { label: 'BГҹв•—Г… qua', action: 'skip', color: 'text-gray-500 hover:text-gray-700' }],\r\n  arrived:  [{ label: 'в”ҖГүв”ңГә giao', action: 'deliver', color: 'text-green-600 hover:text-green-800' },\r\n             { label: 'ThГҹв•‘Г‘t bГҹв•‘Гӯi', action: 'fail', color: 'text-red-600 hover:text-red-800' }],\r\n}\r\n\r\nexport default function TripDetailPage() {\r\n  const params = useParams()\r\n  const router = useRouter()\r\n  const [trip, setTrip] = useState<TripDetail | null>(null)\r\n  const [loading, setLoading] = useState(true)\r\n  const [updating, setUpdating] = useState(false)\r\n  const mapRef = useRef<HTMLDivElement>(null)\r\n  const mapInstanceRef = useRef<any>(null)\r\n\r\n  // Cancel trip modal state\r\n  const [showCancelModal, setShowCancelModal] = useState(false)\r\n  const [cancelReason, setCancelReason] = useState('')\r\n  const [cancelNote, setCancelNote] = useState('')\r\n\r\n  const cancelReasons = [\r\n    'Khв”ңГӯch hв”ңГЎng yв”ңВ¬u cГҹв•‘Вәu hГҹв•—Вәy',\r\n    'Xe gГҹв•‘в•–p sГҹв•—в–’ cГҹв•—ГҰ kГҹв•—в•Ј thuГҹв•‘ВЎt',\r\n    'Tв”ңГЎi xГҹв•‘в”җ khв”ңв”Өng khГҹв•‘Гә dГҹв•—Г‘ng',\r\n    'ThГҹв•—ВҘi tiГҹв•‘в”җt xГҹв•‘Г‘u, khв”ңв”Өng thГҹв•—Гў giao',\r\n    'в”ҖГүв•һв–‘Гҹв•—ВҘng bГҹв•—ГҜ tГҹв•‘В»c / khв”ңв”Өng thГҹв•—Гў в”ҖГҰi',\r\n    'Lв”ңв•ң do khв”ңГӯc',\r\n  ]\r\n\r\n  const loadTrip = useCallback(() => {\r\n    apiFetch<any>(`/trips/${params.id}`)\r\n      .then((r) => setTrip(r.data))\r\n      .catch(err => handleError(err))\r\n      .finally(() => setLoading(false))\r\n  }, [params.id])\r\n\r\n  useEffect(() => { loadTrip() }, [loadTrip])\r\n\r\n  const updateTripStatus = async (newStatus: string) => {\r\n    if (!trip) return\r\n    if (newStatus === 'cancelled') {\r\n      setShowCancelModal(true)\r\n      return\r\n    }\r\n    setUpdating(true)\r\n    try {\r\n      const r = await apiFetch<any>(`/trips/${trip.id}/status`, { method: 'PUT', body: { status: newStatus } })\r\n      setTrip(r.data)\r\n    } catch (e: any) {\r\n      toast.error(e.message || 'CГҹв•‘ВЎp nhГҹв•‘ВЎt thГҹв•‘Г‘t bГҹв•‘Гӯi')\r\n    } finally {\r\n      setUpdating(false)\r\n    }\r\n  }\r\n\r\n  const confirmCancelTrip = async () => {\r\n    if (!trip || !cancelReason) return\r\n    setUpdating(true)\r\n    setShowCancelModal(false)\r\n    try {\r\n      const reason = cancelReason === 'Lв”ңв•ң do khв”ңГӯc' && cancelNote ? cancelNote : cancelReason\r\n      const r = await apiFetch<any>(`/trips/${trip.id}/status`, {\r\n        method: 'PUT',\r\n        body: { status: 'cancelled', reason }\r\n      })\r\n      setTrip(r.data)\r\n    } catch (e: any) {\r\n      toast.error(e.message || 'HГҹв•—Вәy chuyГҹв•‘в”җn thГҹв•‘Г‘t bГҹв•‘Гӯi')\r\n    } finally {\r\n      setUpdating(false)\r\n      setCancelReason('')\r\n      setCancelNote('')\r\n    }\r\n  }\r\n\r\n  const updateStopStatus = async (stopId: string, action: string) => {\r\n    if (!trip) return\r\n    setUpdating(true)\r\n    try {\r\n      const r = await apiFetch<any>(`/trips/${trip.id}/stops/${stopId}/status`, { method: 'PUT', body: { action } })\r\n      setTrip(r.data)\r\n    } catch (e: any) {\r\n      toast.error(e.message || 'CГҹв•‘ВЎp nhГҹв•‘ВЎt thГҹв•‘Г‘t bГҹв•‘Гӯi')\r\n    } finally {\r\n      setUpdating(false)\r\n    }\r\n  }\r\n\r\n  // Initialize Leaflet map\r\n  useEffect(() => {\r\n    if (!trip || !mapRef.current) return\r\n    let cancelled = false\r\n\r\n    // Dynamic import Leaflet (client-side only)\r\n    import('leaflet').then((L) => {\r\n      if (cancelled || !mapRef.current) return\r\n\r\n      // Cleanup any existing map on this container\r\n      if (mapInstanceRef.current) {\r\n        mapInstanceRef.current.remove()\r\n        mapInstanceRef.current = null\r\n      }\r\n\r\n      // Fix default marker icons\r\n      delete (L.Icon.Default.prototype as any)._getIconUrl\r\n      L.Icon.Default.mergeOptions({\r\n        iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',\r\n        iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',\r\n        shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',\r\n      })\r\n\r\n      const map = L.map(mapRef.current!, { zoomControl: true })\r\n      mapInstanceRef.current = map\r\n\r\n      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {\r\n        attribution: '&copy; OpenStreetMap contributors',\r\n        maxZoom: 18,\r\n      }).addTo(map)\r\n\r\n      const bounds: [number, number][] = []\r\n\r\n      // Depot marker (warehouse)\r\n      if (trip.warehouse_lat && trip.warehouse_lng) {\r\n        const depotIcon = L.divIcon({\r\n          html: '<div style=\"background:#d97706;color:white;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:14px;border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3)\">вүЎЖ’Г…ВЎ</div>',\r\n          className: '',\r\n          iconSize: [32, 32],\r\n          iconAnchor: [16, 16],\r\n        })\r\n        L.marker([trip.warehouse_lat, trip.warehouse_lng], { icon: depotIcon })\r\n          .addTo(map)\r\n          .bindPopup(`<b>Kho: ${trip.warehouse_name}</b><br/>в”ҖГүiГҹв•—Гўm xuГҹв•‘Г‘t phв”ңГӯt`)\r\n        bounds.push([trip.warehouse_lat, trip.warehouse_lng])\r\n      }\r\n\r\n      // Stop markers\r\n      const routeCoords: [number, number][] = []\r\n      if (trip.warehouse_lat && trip.warehouse_lng) {\r\n        routeCoords.push([trip.warehouse_lat, trip.warehouse_lng])\r\n      }\r\n\r\n      trip.stops?.forEach((stop) => {\r\n        if (!stop.latitude || !stop.longitude) return\r\n\r\n        const stopIcon = L.divIcon({\r\n          html: `<div style=\"background:#2563eb;color:white;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:12px;border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3)\">${stop.stop_order}</div>`,\r\n          className: '',\r\n          iconSize: [28, 28],\r\n          iconAnchor: [14, 14],\r\n        })\r\n\r\n        L.marker([stop.latitude, stop.longitude], { icon: stopIcon })\r\n          .addTo(map)\r\n          .bindPopup(\r\n            `<b>#${stop.stop_order} ${stop.customer_name}</b><br/>${stop.customer_address}<br/>TГҹв•‘Гәi: ${stop.cumulative_load_kg?.toFixed(0)} kg<br/>TT: ${stopStatusLabels[stop.status] || stop.status}`\r\n          )\r\n\r\n        bounds.push([stop.latitude, stop.longitude])\r\n        routeCoords.push([stop.latitude, stop.longitude])\r\n      })\r\n\r\n      // Return to depot\r\n      if (trip.warehouse_lat && trip.warehouse_lng) {\r\n        routeCoords.push([trip.warehouse_lat, trip.warehouse_lng])\r\n      }\r\n\r\n      // Draw route using OSRM road routing\r\n      if (routeCoords.length > 1) {\r\n        const coords = routeCoords.map(([lat, lng]) => `${lng},${lat}`).join(';')\r\n        fetch(`https://router.project-osrm.org/route/v1/driving/${coords}?overview=full&geometries=geojson`)\r\n          .then(res => res.json())\r\n          .then(data => {\r\n            if (data.code === 'Ok' && data.routes?.[0]?.geometry) {\r\n              const geoCoords = data.routes[0].geometry.coordinates.map(\r\n                (c: [number, number]) => [c[1], c[0]] as [number, number]\r\n              )\r\n              L.polyline(geoCoords, {\r\n                color: '#2563eb', weight: 4, opacity: 0.8,\r\n              }).addTo(map)\r\n            } else {\r\n              // Fallback: straight dashed lines if OSRM fails\r\n              L.polyline(routeCoords, {\r\n                color: '#2563eb', weight: 3, opacity: 0.7, dashArray: '8, 8',\r\n              }).addTo(map)\r\n            }\r\n          })\r\n          .catch(() => {\r\n            L.polyline(routeCoords, {\r\n              color: '#2563eb', weight: 3, opacity: 0.7, dashArray: '8, 8',\r\n            }).addTo(map)\r\n          })\r\n      }\r\n\r\n      // Fit bounds\r\n      if (bounds.length > 0) {\r\n        map.fitBounds(bounds, { padding: [40, 40] })\r\n      } else {\r\n        map.setView([20.95, 107.05], 12) // Default: QuГҹв•‘Гәng Ninh area\r\n      }\r\n    })\r\n\r\n    return () => {\r\n      cancelled = true\r\n      if (mapInstanceRef.current) {\r\n        mapInstanceRef.current.remove()\r\n        mapInstanceRef.current = null\r\n      }\r\n    }\r\n  }, [trip])\r\n\r\n  if (loading) return <div className=\"flex justify-center py-20\"><div className=\"animate-spin rounded-full h-10 w-10 border-b-2 border-brand-500\"></div></div>\r\n  if (!trip) return <div className=\"text-center py-20 text-gray-500\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y chuyГҹв•‘в”җn xe</div>\r\n\r\n  return (\r\n    <div>\r\n      <div className=\"flex items-center justify-between mb-6\">\r\n        <div>\r\n          <button onClick={() => router.back()} className=\"text-sm text-gray-500 hover:text-gray-700 mb-1\">\r\n            О“ГҘГү Quay lГҹв•‘Гӯi\r\n          </button>\r\n          <h1 className=\"text-2xl font-bold text-gray-800\">{trip.trip_number}</h1>\r\n        </div>\r\n        <div className=\"flex items-center gap-3\">\r\n          {tripActions[trip.status]?.map((act) => (\r\n            <button\r\n              key={act.next}\r\n              onClick={() => updateTripStatus(act.next)}\r\n              disabled={updating}\r\n              className={`px-4 py-2 rounded-lg text-sm font-medium text-white transition ${act.color} disabled:opacity-50`}\r\n            >\r\n              {updating ? '...' : act.label}\r\n            </button>\r\n          ))}\r\n          <span className={`px-3 py-1 rounded-full text-sm font-medium ${\r\n            trip.status === 'completed' ? 'bg-green-100 text-green-700' :\r\n            trip.status === 'in_transit' ? 'bg-yellow-100 text-yellow-700' :\r\n            trip.status === 'cancelled' ? 'bg-red-100 text-red-700' :\r\n            'bg-blue-100 text-blue-700'\r\n          }`}>\r\n            {statusLabels[trip.status] || trip.status}\r\n          </span>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Trip info */}\r\n      <div className=\"grid grid-cols-2 gap-6 mb-6\">\r\n        <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n          <h2 className=\"font-semibold mb-3\">Thв”ңв”Өng tin chuyГҹв•‘в”җn</h2>\r\n          <div className=\"space-y-2 text-sm\">\r\n            <div><span className=\"text-gray-500\">Xe:</span> <strong>{trip.vehicle_plate}</strong></div>\r\n            <div><span className=\"text-gray-500\">Tв”ңГЎi xГҹв•‘в”җ:</span> <strong>{trip.driver_name || '-'}</strong> {trip.driver_phone && <span className=\"text-gray-400\">({trip.driver_phone})</span>}</div>\r\n            <div><span className=\"text-gray-500\">Kho xuГҹв•‘Г‘t:</span> <strong>{trip.warehouse_name}</strong></div>\r\n            <div><span className=\"text-gray-500\">Ngв”ңГЎy giao:</span> <strong>{new Date(trip.planned_date).toLocaleDateString('vi-VN')}</strong></div>\r\n          </div>\r\n        </div>\r\n        <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n          <h2 className=\"font-semibold mb-3\">TГҹв•—ГІng quan</h2>\r\n          <div className=\"grid grid-cols-3 gap-4 text-center\">\r\n            <div>\r\n              <div className=\"text-2xl font-bold text-amber-700\">{trip.stops?.length || 0}</div>\r\n              <div className=\"text-xs text-gray-500\">в”ҖГүiГҹв•—Гўm giao</div>\r\n            </div>\r\n            <div>\r\n              <div className=\"text-2xl font-bold text-blue-700\">{trip.total_distance_km?.toFixed(1)}</div>\r\n              <div className=\"text-xs text-gray-500\">km</div>\r\n            </div>\r\n            <div>\r\n              <div className=\"text-2xl font-bold text-green-700\">{trip.total_weight_kg?.toFixed(0)}</div>\r\n              <div className=\"text-xs text-gray-500\">kg</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Map */}\r\n      <div className=\"bg-white rounded-xl shadow-sm p-4 mb-6\">\r\n        <h2 className=\"font-semibold mb-3\">BГҹв•‘Гәn в”ҖГҰГҹв•—Гҙ tuyГҹв•‘в”җn в”ҖГҰв•һв–‘Гҹв•—ВҘng</h2>\r\n        <div ref={mapRef} className=\"w-full h-[450px] rounded-lg border\" />\r\n      </div>\r\n\r\n      {/* Stops table */}\r\n      <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n        <h2 className=\"font-semibold mb-3\">LГҹв•—ГҜch trв”ңВјnh в”ҖГҰiГҹв•—Гўm giao ({trip.stops?.length || 0} в”ҖГҰiГҹв•—Гўm)</h2>\r\n        <table className=\"w-full text-sm\">\r\n          <thead className=\"bg-gray-50\">\r\n            <tr>\r\n              <th className=\"text-center py-2 px-3 w-10\">#</th>\r\n              <th className=\"text-left py-2 px-3\">Khв”ңГӯch hв”ңГЎng</th>\r\n              <th className=\"text-left py-2 px-3\">в”ҖГүГҹв•—ГҜa chГҹв•—Г«</th>\r\n              <th className=\"text-right py-2 px-3\">TГҹв•‘Гәi (kg)</th>\r\n              <th className=\"text-center py-2 px-3\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n              {trip.status === 'in_transit' && <th className=\"text-center py-2 px-3\">Thao tв”ңГӯc</th>}\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            {trip.stops?.map((stop) => (\r\n              <tr key={stop.id} className=\"border-t\">\r\n                <td className=\"py-2 px-3 text-center font-bold text-blue-600\">{stop.stop_order}</td>\r\n                <td className=\"py-2 px-3\">\r\n                  <div className=\"font-medium\">{stop.customer_name}</div>\r\n                </td>\r\n                <td className=\"py-2 px-3 text-gray-500\">{stop.customer_address}</td>\r\n                <td className=\"py-2 px-3 text-right\">{stop.cumulative_load_kg?.toFixed(0)}</td>\r\n                <td className=\"py-2 px-3 text-center\">\r\n                  <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${\r\n                    stop.status === 'delivered' ? 'bg-green-100 text-green-700' :\r\n                    stop.status === 'arrived' ? 'bg-blue-100 text-blue-700' :\r\n                    stop.status === 'failed' ? 'bg-red-100 text-red-700' :\r\n                    stop.status === 'skipped' ? 'bg-orange-100 text-orange-700' :\r\n                    'bg-gray-100 text-gray-600'\r\n                  }`}>\r\n                    {stopStatusLabels[stop.status] || stop.status}\r\n                  </span>\r\n                </td>\r\n                {trip.status === 'in_transit' && (\r\n                  <td className=\"py-2 px-3 text-center\">\r\n                    <div className=\"flex justify-center gap-2\">\r\n                      {stopActions[stop.status]?.map((act) => (\r\n                        <button\r\n                          key={act.action}\r\n                          onClick={() => updateStopStatus(stop.id, act.action)}\r\n                          disabled={updating}\r\n                          className={`text-xs font-medium ${act.color} disabled:opacity-50`}\r\n                        >\r\n                          {act.label}\r\n                        </button>\r\n                      ))}\r\n                    </div>\r\n                  </td>\r\n                )}\r\n              </tr>\r\n            ))}\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\trips\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'user' is assigned a value but never used.","line":36,"column":9,"nodeType":null,"messageId":"unusedVar","endLine":36,"endColumn":13},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":57,"column":14,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":57,"endColumn":17,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2289,2292],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2289,2292],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadTrips'. Either include it or remove the dependency array.","line":66,"column":36,"nodeType":"ArrayExpression","endLine":66,"endColumn":70,"suggestions":[{"desc":"Update the dependencies array to be: [filter, plannedDate, page, limit, loadTrips]","fix":{"range":[2563,2597],"text":"[filter, plannedDate, page, limit, loadTrips]"}}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":86,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":86,"endColumn":22,"suggestions":[{"messageId":"