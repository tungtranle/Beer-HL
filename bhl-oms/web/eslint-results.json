О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\ninterface GateStatus {\r\n  gate: string\r\n  status: 'pass' | 'fail' | 'warn' | 'skip' | 'unknown' | 'running'\r\n  duration_s: number\r\n  summary: string\r\n  run_at?: string\r\n}\r\n\r\ninterface FailDetail {\r\n  case_id: string\r\n  scenario?: string\r\n  message: string\r\n  expected?: string\r\n  actual?: string\r\n}\r\n\r\ninterface GoldenResult {\r\n  invariant_id: string\r\n  name: string\r\n  module: string\r\n  priority: 'critical' | 'high'\r\n  status: 'pass' | 'fail' | 'skip' | 'error'\r\n  total_cases: number\r\n  passed_cases: number\r\n  failed_cases: number\r\n  fail_details?: FailDetail[]\r\n  duration_ms: number\r\n  golden_file: string\r\n}\r\n\r\ninterface DecisionBrief {\r\n  verdict: 'SHIP' | 'CAUTION' | 'HOLD'\r\n  confidence: number\r\n  summary: string\r\n  blocking_issues: string[]\r\n  warnings: string[]\r\n  gates: GateStatus[]\r\n  run_at: string\r\n  evidence_id: string\r\n}\r\n\r\ninterface BusinessHealth {\r\n  orders_today: number\r\n  pending_approval: number\r\n  active_trips: number\r\n  pending_recon: number\r\n  open_discrepancies: number\r\n  failed_integrations: number\r\n  low_stock_alerts: number\r\n  db_conn_ok: boolean\r\n  redis_ok: boolean\r\n}\r\n\r\ninterface EvidenceRecord {\r\n  id: string\r\n  run_at: string\r\n  verdict: 'SHIP' | 'CAUTION' | 'HOLD'\r\n  confidence: number\r\n  golden_pass: number\r\n  golden_fail: number\r\n  blocking_count: number\r\n  warning_count: number\r\n  notes?: string\r\n}\r\n\r\ninterface OpenQuestion {\r\n  id: string\r\n  question: string\r\n  affects: string\r\n  block_ship: boolean\r\n  answer?: string\r\n  answered_at?: string\r\n}\r\n\r\ninterface AQFStatusResponse {\r\n  last_run_at?: string\r\n  brief?: DecisionBrief\r\n  golden_results: GoldenResult[]\r\n  health: BusinessHealth\r\n  evidence_log: EvidenceRecord[]\r\n  open_questions: OpenQuestion[]\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Helpers\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nasync function apiGet<T>(path: string): Promise<T | null> {\r\n  try {\r\n    const res = await fetch(API + path)\r\n    const json = await res.json()\r\n    return json.success ? json.data : null\r\n  } catch { return null }\r\n}\r\n\r\nasync function apiPost<T>(path: string, body?: unknown): Promise<T | null> {\r\n  try {\r\n    const res = await fetch(API + path, {\r\n      method: 'POST',\r\n      headers: { 'Content-Type': 'application/json' },\r\n      body: body ? JSON.stringify(body) : undefined,\r\n    })\r\n    const json = await res.json()\r\n    return json.success ? json.data : null\r\n  } catch { return null }\r\n}\r\n\r\nconst fmtDate = (s?: string) => s ? new Date(s).toLocaleString('vi-VN') : 'О“ГҮГ¶'\r\nconst fmtDuration = (ms: number) => ms < 1000 ? `${ms}ms` : `${(ms / 1000).toFixed(1)}s`\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Verdict Card О“ГҮГ¶ big, unmistakable\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction VerdictCard({ brief, running }: { brief?: DecisionBrief; running: boolean }) {\r\n  if (running) {\r\n    return (\r\n      <div className=\"bg-blue-50 border-2 border-blue-300 rounded-2xl p-6 flex items-center gap-4 animate-pulse\">\r\n        <div className=\"text-4xl\">О“Г…в”Ӯ</div>\r\n        <div>\r\n          <div className=\"text-xl font-bold text-blue-700\">в”ҖГүang chГҹв•‘Гӯy QA...</div>\r\n          <div className=\"text-blue-600 text-sm mt-1\">в”ҖГүang validate golden datasets vв”ңГЎ business health</div>\r\n        </div>\r\n      </div>\r\n    )\r\n  }\r\n\r\n  if (!brief) {\r\n    return (\r\n      <div className=\"bg-gray-50 border-2 border-dashed border-gray-300 rounded-2xl p-6 text-center\">\r\n        <div className=\"text-3xl mb-2\">вүЎЖ’Г„В»</div>\r\n        <div className=\"text-gray-600 font-medium\">Chв•һв–‘a cв”ңв”Ӯ kГҹв•‘в”җt quГҹв•‘Гә QA</div>\r\n        <div className=\"text-gray-400 text-sm mt-1\">BГҹв•‘Г‘m \"Run Full QA\" в”ҖГҰГҹв•—Гў bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu</div>\r\n      </div>\r\n    )\r\n  }\r\n\r\n  const styles = {\r\n    SHIP: {\r\n      bg: 'bg-emerald-50',\r\n      border: 'border-emerald-400',\r\n      badge: 'bg-emerald-500 text-white',\r\n      text: 'text-emerald-700',\r\n      icon: 'О“ВЈГ ',\r\n      bar: 'bg-emerald-500',\r\n    },\r\n    CAUTION: {\r\n      bg: 'bg-amber-50',\r\n      border: 'border-amber-400',\r\n      badge: 'bg-amber-500 text-white',\r\n      text: 'text-amber-700',\r\n      icon: 'О“ГңГЎвҲ©в••Г…',\r\n      bar: 'bg-amber-500',\r\n    },\r\n    HOLD: {\r\n      bg: 'bg-red-50',\r\n      border: 'border-red-400',\r\n      badge: 'bg-red-600 text-white',\r\n      text: 'text-red-700',\r\n      icon: 'вүЎЖ’ГңВҪ',\r\n      bar: 'bg-red-500',\r\n    },\r\n  }\r\n\r\n  const s = styles[brief.verdict]\r\n\r\n  return (\r\n    <div className={`${s.bg} border-2 ${s.border} rounded-2xl p-6`}>\r\n      <div className=\"flex items-start gap-4\">\r\n        <div className=\"text-5xl\">{s.icon}</div>\r\n        <div className=\"flex-1 min-w-0\">\r\n          <div className=\"flex items-center gap-3 flex-wrap\">\r\n            <span className={`${s.badge} text-2xl font-black px-4 py-1 rounded-xl tracking-wide`}>\r\n              {brief.verdict}\r\n            </span>\r\n            <span className={`text-3xl font-black ${s.text}`}>{brief.confidence}<span className=\"text-lg font-normal\">/100</span></span>\r\n          </div>\r\n          <p className={`mt-2 text-sm ${s.text} font-medium`}>{brief.summary}</p>\r\n\r\n          {/* Confidence bar */}\r\n          <div className=\"mt-3 bg-gray-200 rounded-full h-2.5 w-full max-w-sm\">\r\n            <div\r\n              className={`${s.bar} h-2.5 rounded-full transition-all duration-700`}\r\n              style={{ width: `${brief.confidence}%` }}\r\n            />\r\n          </div>\r\n\r\n          <div className=\"mt-2 text-xs text-gray-500\">\r\n            Evidence ID: <code className=\"font-mono\">{brief.evidence_id}</code> в”¬в•– {fmtDate(brief.run_at)}\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Blocking issues */}\r\n      {brief.blocking_issues?.length > 0 && (\r\n        <div className=\"mt-4 space-y-1\">\r\n          {brief.blocking_issues.map((issue, i) => (\r\n            <div key={i} className=\"flex items-start gap-2 text-sm text-red-700 bg-red-100 rounded-lg px-3 py-2\">\r\n              <span className=\"mt-0.5 shrink-0\">вүЎЖ’Г¶в”Ө</span>\r\n              <span>{issue}</span>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      )}\r\n\r\n      {/* Warnings */}\r\n      {brief.warnings?.length > 0 && (\r\n        <div className=\"mt-2 space-y-1\">\r\n          {brief.warnings.map((w, i) => (\r\n            <div key={i} className=\"flex items-start gap-2 text-sm text-amber-700 bg-amber-100 rounded-lg px-3 py-2\">\r\n              <span className=\"mt-0.5 shrink-0\">вүЎЖ’Ж’Гӯ</span>\r\n              <span>{w}</span>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Gate Status Row (G0-G4)\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction GateRow({ gates }: { gates: GateStatus[] }) {\r\n  const statusStyle = (s: string) => {\r\n    switch (s) {\r\n      case 'pass': return 'bg-emerald-100 text-emerald-700 border-emerald-300'\r\n      case 'fail': return 'bg-red-100 text-red-700 border-red-300'\r\n      case 'warn': return 'bg-amber-100 text-amber-700 border-amber-300'\r\n      case 'running': return 'bg-blue-100 text-blue-700 border-blue-300 animate-pulse'\r\n      default: return 'bg-gray-100 text-gray-500 border-gray-200'\r\n    }\r\n  }\r\n  const statusIcon = (s: string) => {\r\n    switch (s) {\r\n      case 'pass': return 'О“ВЈГ '\r\n      case 'fail': return 'О“ВҘГ®'\r\n      case 'warn': return 'О“ГңГЎвҲ©в••Г…'\r\n      case 'running': return 'О“Г…в”Ӯ'\r\n      default: return 'О“Г…в••вҲ©в••Г…'\r\n    }\r\n  }\r\n\r\n  const gateDesc: Record<string, string> = {\r\n    G0: 'Pre-commit',\r\n    G1: 'Infrastructure',\r\n    G2: 'Domain / Golden',\r\n    G3: 'E2E / UX',\r\n    G4: 'Production Watch',\r\n  }\r\n\r\n  return (\r\n    <div className=\"grid grid-cols-5 gap-2\">\r\n      {(gates.length > 0 ? gates : ['G0','G1','G2','G3','G4'].map(g => ({ gate: g, status: 'unknown', summary: 'О“ГҮГ¶', duration_s: 0 } as GateStatus))).map((g) => (\r\n        <div key={g.gate} className={`border rounded-xl p-3 text-center ${statusStyle(g.status)}`}>\r\n          <div className=\"text-lg font-black\">{g.gate}</div>\r\n          <div className=\"text-xs font-medium mt-0.5\">{gateDesc[g.gate] || g.gate}</div>\r\n          <div className=\"text-xl mt-1\">{statusIcon(g.status)}</div>\r\n          <div className=\"text-xs mt-1 leading-tight truncate\" title={g.summary}>{g.summary || g.status}</div>\r\n        </div>\r\n      ))}\r\n    </div>\r\n  )\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Golden Dataset Table\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction GoldenTable({ results }: { results: GoldenResult[] }) {\r\n  const [expanded, setExpanded] = useState<string | null>(null)\r\n\r\n  if (!results.length) {\r\n    return <div className=\"text-center text-gray-400 py-8\">Chв•һв–‘a cв”ңв”Ӯ kГҹв•‘в”җt quГҹв•‘Гә golden tests. BГҹв•‘Г‘m Run Full QA.</div>\r\n  }\r\n\r\n  const statusBadge = (s: string) => {\r\n    switch (s) {\r\n      case 'pass': return 'bg-emerald-100 text-emerald-700'\r\n      case 'fail': return 'bg-red-100 text-red-700'\r\n      case 'error': return 'bg-orange-100 text-orange-700'\r\n      default: return 'bg-gray-100 text-gray-500'\r\n    }\r\n  }\r\n\r\n  const priorityBadge = (p: string) =>\r\n    p === 'critical' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700'\r\n\r\n  return (\r\n    <div className=\"space-y-2\">\r\n      {results.map(r => (\r\n        <div key={r.invariant_id} className=\"border rounded-xl overflow-hidden bg-white\">\r\n          <button\r\n            className=\"w-full text-left px-4 py-3 flex items-center gap-3 hover:bg-gray-50 transition\"\r\n            onClick={() => setExpanded(expanded === r.invariant_id ? null : r.invariant_id)}\r\n          >\r\n            <span className={`text-xs font-bold px-2 py-0.5 rounded-full ${statusBadge(r.status)}`}>\r\n              {r.status.toUpperCase()}\r\n            </span>\r\n            <span className={`text-xs px-2 py-0.5 rounded-full ${priorityBadge(r.priority)}`}>\r\n              {r.priority}\r\n            </span>\r\n            <span className=\"font-medium text-sm flex-1\">{r.name}</span>\r\n            <span className=\"text-xs text-gray-400 shrink-0\">{r.module}</span>\r\n            <span className=\"text-xs text-gray-400 shrink-0\">\r\n              {r.passed_cases}/{r.total_cases} pass в”¬в•– {fmtDuration(r.duration_ms)}\r\n            </span>\r\n            <span className=\"text-gray-400 text-xs\">{expanded === r.invariant_id ? 'О“Г»в–“' : 'О“Г»в•қ'}</span>\r\n          </button>\r\n\r\n          {expanded === r.invariant_id && (\r\n            <div className=\"px-4 pb-4 border-t bg-gray-50\">\r\n              <div className=\"text-xs text-gray-500 mt-2 mb-2\">\r\n                <code className=\"bg-gray-200 px-1.5 py-0.5 rounded\">{r.invariant_id}</code>\r\n                {' '}в”¬в•–{' '}\r\n                <code className=\"bg-gray-200 px-1.5 py-0.5 rounded\">{r.golden_file}</code>\r\n              </div>\r\n\r\n              {/* Case progress bar */}\r\n              {r.total_cases > 0 && (\r\n                <div className=\"flex items-center gap-2 mb-3\">\r\n                  <div className=\"flex-1 bg-gray-200 rounded-full h-2\">\r\n                    <div\r\n                      className=\"bg-emerald-500 h-2 rounded-full\"\r\n                      style={{ width: `${(r.passed_cases / r.total_cases) * 100}%` }}\r\n                    />\r\n                  </div>\r\n                  <span className=\"text-xs text-gray-600\">{r.passed_cases}/{r.total_cases} cases pass</span>\r\n                </div>\r\n              )}\r\n\r\n              {/* Fail details */}\r\n              {r.fail_details && r.fail_details.length > 0 ? (\r\n                <div className=\"space-y-2\">\r\n                  {r.fail_details.map((d, i) => (\r\n                    <div key={i} className=\"bg-red-50 border border-red-200 rounded-lg p-3 text-xs\">\r\n                      <div className=\"font-bold text-red-700 mb-1\">[{d.case_id}] {d.scenario}</div>\r\n                      {d.message && <div className=\"text-red-600 mb-1\">О“ВҘГ® {d.message}</div>}\r\n                      {d.expected && <div className=\"text-gray-600\">Expected: <code className=\"bg-red-100 px-1 rounded\">{d.expected}</code></div>}\r\n                      {d.actual && <div className=\"text-gray-600 mt-0.5\">Actual: <code className=\"bg-red-100 px-1 rounded\">{d.actual}</code></div>}\r\n                    </div>\r\n                  ))}\r\n                </div>\r\n              ) : (\r\n                r.status === 'pass' && (\r\n                  <div className=\"text-emerald-600 text-xs font-medium\">О“ВЈГ  TГҹв•‘Г‘t cГҹв•‘Гә {r.total_cases} cases pass</div>\r\n                )\r\n              )}\r\n            </div>\r\n          )}\r\n        </div>\r\n      ))}\r\n    </div>\r\n  )\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Business Health Panel\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction HealthPanel({ health }: { health?: BusinessHealth }) {\r\n  if (!health) return <div className=\"text-gray-400 text-center py-6\">Chв•һв–‘a load health data</div>\r\n\r\n  const metric = (icon: string, label: string, value: number | string, color = 'text-gray-700', alert = false) => (\r\n    <div className={`bg-white rounded-xl border p-4 ${alert ? 'border-red-300 bg-red-50' : ''}`}>\r\n      <div className=\"flex items-center gap-2\">\r\n        <span className=\"text-xl\">{icon}</span>\r\n        <div>\r\n          <div className={`text-xl font-bold ${color}`}>{value}</div>\r\n          <div className=\"text-xs text-gray-500\">{label}</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  )\r\n\r\n  return (\r\n    <div className=\"space-y-4\">\r\n      {/* Connectivity */}\r\n      <div className=\"grid grid-cols-2 gap-3\">\r\n        <div className={`rounded-xl border p-3 flex items-center gap-2 ${health.db_conn_ok ? 'bg-emerald-50 border-emerald-300' : 'bg-red-50 border-red-300'}`}>\r\n          <span className=\"text-lg\">{health.db_conn_ok ? 'вүЎЖ’Ж’Гі' : 'вүЎЖ’Г¶в”Ө'}</span>\r\n          <div>\r\n            <div className=\"text-sm font-bold\">PostgreSQL</div>\r\n            <div className={`text-xs ${health.db_conn_ok ? 'text-emerald-600' : 'text-red-600'}`}>{health.db_conn_ok ? 'Connected' : 'DISCONNECTED'}</div>\r\n          </div>\r\n        </div>\r\n        <div className={`rounded-xl border p-3 flex items-center gap-2 ${health.redis_ok ? 'bg-emerald-50 border-emerald-300' : 'bg-amber-50 border-amber-300'}`}>\r\n          <span className=\"text-lg\">{health.redis_ok ? 'вүЎЖ’Ж’Гі' : 'вүЎЖ’Ж’Гӯ'}</span>\r\n          <div>\r\n            <div className=\"text-sm font-bold\">Redis</div>\r\n            <div className={`text-xs ${health.redis_ok ? 'text-emerald-600' : 'text-amber-600'}`}>{health.redis_ok ? 'Connected' : 'Unavailable'}</div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Business metrics */}\r\n      <div className=\"grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4\">\r\n        {metric('вүЎЖ’ГҙГҜ', 'в”ҖГүв•һГӯn hв”ңГЎng hв”ңв”Өm nay', health.orders_today)}\r\n        {metric('О“Г…в”Ӯ', 'ChГҹв•—ВҘ duyГҹв•—Г§t credit', health.pending_approval, health.pending_approval > 5 ? 'text-amber-600' : 'text-gray-700', health.pending_approval > 10)}\r\n        {metric('вүЎЖ’ГңВў', 'ChuyГҹв•‘в”җn в”ҖГҰang chГҹв•‘Гӯy', health.active_trips, 'text-blue-600')}\r\n        {metric('вүЎЖ’ГҙГЁ', 'ChГҹв•—ВҘ в”ҖГҰГҹв•—ГҰi soв”ңГӯt', health.pending_recon, health.pending_recon > 3 ? 'text-amber-600' : 'text-gray-700', health.pending_recon > 10)}\r\n        {metric('О“ГңГЎвҲ©в••Г…', 'Discrepancy mГҹв•—Ж’', health.open_discrepancies, health.open_discrepancies > 0 ? 'text-amber-600' : 'text-gray-700', health.open_discrepancies > 5)}\r\n        {metric('О“ВҘГ®', 'Integration failed', health.failed_integrations, health.failed_integrations > 0 ? 'text-red-600' : 'text-gray-700', health.failed_integrations > 0)}\r\n        {metric('вүЎЖ’ГҙВӘ', 'CГҹв•‘Гәnh bв”ңГӯo tГҹв•—Гҙn kho', health.low_stock_alerts, health.low_stock_alerts > 0 ? 'text-amber-600' : 'text-gray-700')}\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Evidence Log\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction EvidenceLog({ records }: { records: EvidenceRecord[] }) {\r\n  if (!records.length) {\r\n    return <div className=\"text-center text-gray-400 py-8\">Chв•һв–‘a cв”ңв”Ӯ evidence nв”ңГЎo. BГҹв•‘Г‘m Run Full QA в”ҖГҰГҹв•—Гў tГҹв•‘Гӯo evidence в”ҖГҰГҹв•‘Вәu tiв”ңВ¬n.</div>\r\n  }\r\n\r\n  const verdictStyle = (v: string) => {\r\n    switch (v) {\r\n      case 'SHIP': return 'bg-emerald-100 text-emerald-700'\r\n      case 'CAUTION': return 'bg-amber-100 text-amber-700'\r\n      default: return 'bg-red-100 text-red-700'\r\n    }\r\n  }\r\n\r\n  return (\r\n    <div className=\"overflow-x-auto\">\r\n      <table className=\"w-full text-sm\">\r\n        <thead>\r\n          <tr className=\"text-left text-xs text-gray-500 border-b\">\r\n            <th className=\"pb-2 pr-4\">ThГҹв•—ВҘi gian</th>\r\n            <th className=\"pb-2 pr-4\">Verdict</th>\r\n            <th className=\"pb-2 pr-4\">Confidence</th>\r\n            <th className=\"pb-2 pr-4\">Golden Pass/Fail</th>\r\n            <th className=\"pb-2 pr-4\">Blocking</th>\r\n            <th className=\"pb-2\">Evidence ID</th>\r\n          </tr>\r\n        </thead>\r\n        <tbody className=\"divide-y\">\r\n          {records.map(r => (\r\n            <tr key={r.id} className=\"hover:bg-gray-50\">\r\n              <td className=\"py-2 pr-4 text-gray-600 whitespace-nowrap\">{fmtDate(r.run_at)}</td>\r\n              <td className=\"py-2 pr-4\">\r\n                <span className={`text-xs font-bold px-2 py-0.5 rounded-full ${verdictStyle(r.verdict)}`}>{r.verdict}</span>\r\n              </td>\r\n              <td className=\"py-2 pr-4\">\r\n                <div className=\"flex items-center gap-2\">\r\n                  <div className=\"w-16 bg-gray-200 rounded-full h-1.5\">\r\n                    <div\r\n                      className={`h-1.5 rounded-full ${r.verdict === 'SHIP' ? 'bg-emerald-500' : r.verdict === 'CAUTION' ? 'bg-amber-500' : 'bg-red-500'}`}\r\n                      style={{ width: `${r.confidence}%` }}\r\n                    />\r\n                  </div>\r\n                  <span className=\"text-gray-700 font-medium\">{r.confidence}</span>\r\n                </div>\r\n              </td>\r\n              <td className=\"py-2 pr-4\">\r\n                <span className=\"text-emerald-600 font-medium\">{r.golden_pass}О“ВЈГҙ</span>\r\n                {r.golden_fail > 0 && <span className=\"text-red-600 font-medium ml-1\">{r.golden_fail}О“ВЈГ№</span>}\r\n              </td>\r\n              <td className=\"py-2 pr-4\">\r\n                {r.blocking_count > 0\r\n                  ? <span className=\"text-red-600 font-medium\">{r.blocking_count} issues</span>\r\n                  : <span className=\"text-gray-400\">О“ГҮГ¶</span>}\r\n              </td>\r\n              <td className=\"py-2 font-mono text-xs text-gray-400\">{r.id}</td>\r\n            </tr>\r\n          ))}\r\n        </tbody>\r\n      </table>\r\n    </div>\r\n  )\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Open Questions Panel\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction OpenQuestionsPanel({ questions, onAnswer }: { questions: OpenQuestion[]; onAnswer: () => void }) {\r\n  const [answering, setAnswering] = useState<string | null>(null)\r\n\r\n  const handleAnswer = async (id: string, answer: string) => {\r\n    setAnswering(id)\r\n    await apiPost('/answer', { id, answer })\r\n    setAnswering(null)\r\n    onAnswer()\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-3\">\r\n      {questions.map(q => (\r\n        <div key={q.id} className={`rounded-xl border p-4 ${q.block_ship && !q.answer ? 'border-red-300 bg-red-50' : 'border-gray-200 bg-white'}`}>\r\n          <div className=\"flex items-start gap-3\">\r\n            <div className=\"shrink-0\">\r\n              {q.answer\r\n                ? <span className=\"text-lg\">О“ВЈГ </span>\r\n                : q.block_ship\r\n                  ? <span className=\"text-lg\">вүЎЖ’ГңВҪ</span>\r\n                  : <span className=\"text-lg\">О“ВҘГҙ</span>\r\n              }\r\n            </div>\r\n            <div className=\"flex-1 min-w-0\">\r\n              <div className=\"flex items-center gap-2 flex-wrap\">\r\n                <span className=\"font-mono text-xs text-gray-500\">{q.id}</span>\r\n                {q.block_ship && <span className=\"text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full font-medium\">block ship</span>}\r\n                {q.answer && <span className=\"text-xs bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full font-medium\">answered: {q.answer}</span>}\r\n              </div>\r\n              <p className=\"text-sm text-gray-800 font-medium mt-1\">{q.question}</p>\r\n              <p className=\"text-xs text-gray-500 mt-0.5\">Affects: <code className=\"bg-gray-100 px-1 rounded\">{q.affects}</code></p>\r\n              {q.answered_at && <p className=\"text-xs text-gray-400 mt-0.5\">Answered: {fmtDate(q.answered_at)}</p>}\r\n\r\n              {!q.answer && (\r\n                <div className=\"flex gap-2 mt-3\">\r\n                  {(['yes', 'no', 'defer'] as const).map(a => (\r\n                    <button\r\n                      key={a}\r\n                      disabled={answering === q.id}\r\n                      onClick={() => handleAnswer(q.id, a)}\r\n                      className={`text-xs px-3 py-1.5 rounded-lg font-medium transition disabled:opacity-50\r\n                        ${a === 'yes' ? 'bg-emerald-100 text-emerald-700 hover:bg-emerald-200'\r\n                          : a === 'no' ? 'bg-red-100 text-red-700 hover:bg-red-200'\r\n                          : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}\r\n                    >\r\n                      {a === 'yes' ? 'О“ВЈГҙ Yes' : a === 'no' ? 'О“ВЈГ№ No' : 'О“ГҘГҶ Defer'}\r\n                    </button>\r\n                  ))}\r\n                </div>\r\n              )}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      ))}\r\n    </div>\r\n  )\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Run Control Panel\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction RunControl({ onRun, running }: { onRun: (section?: string) => void; running: boolean }) {\r\n  const btn = (label: string, icon: string, section?: string, color = 'bg-brand-500 hover:bg-brand-600 text-white') => (\r\n    <button\r\n      onClick={() => onRun(section)}\r\n      disabled={running}\r\n      className={`flex items-center gap-2 px-4 py-2.5 rounded-xl font-medium text-sm transition disabled:opacity-50 ${color}`}\r\n    >\r\n      <span>{icon}</span>\r\n      <span>{label}</span>\r\n    </button>\r\n  )\r\n\r\n  return (\r\n    <div className=\"bg-gray-50 rounded-xl border p-4\">\r\n      <h3 className=\"text-sm font-bold text-gray-700 mb-3\">вүЎЖ’ГІв•ЈвҲ©в••Г… Run Control</h3>\r\n      <div className=\"flex flex-wrap gap-2\">\r\n        {btn('Run Full QA', 'О“Г»в•ў', undefined, 'bg-blue-600 hover:bg-blue-700 text-white')}\r\n        {btn('Golden Tests Only', 'вүЎЖ’Г¶Вј', 'golden', 'bg-purple-100 hover:bg-purple-200 text-purple-700')}\r\n        {btn('Health Check', 'вүЎЖ’ГҶГЁ', 'health', 'bg-green-100 hover:bg-green-200 text-green-700')}\r\n      </div>\r\n      <div className=\"mt-3 text-xs text-gray-400 space-y-1\">\r\n        <div>G0 (pre-commit): <code className=\"bg-gray-200 px-1 rounded\">AQF_G0_CHECK.bat</code> О“ГҮГ¶ run from File Explorer</div>\r\n        <div>G3 (E2E Playwright): <code className=\"bg-gray-200 px-1 rounded\">cd web && npm run test:e2e</code></div>\r\n        <div>CI Gates (G1/G2/G3): push to GitHub О“ГҘГҶ Actions auto-trigger</div>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Main AQF Command Center Component\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\ntype View = 'overview' | 'golden' | 'health' | 'evidence' | 'questions'\r\n\r\nexport default function AQFCommandCenter() {\r\n  const [data, setData] = useState<AQFStatusResponse | null>(null)\r\n  const [loading, setLoading] = useState(false)\r\n  const [running, setRunning] = useState(false)\r\n  const [view, setView] = useState<View>('overview')\r\n  const [toast, setToast] = useState('')\r\n  const [autoRefresh, setAutoRefresh] = useState(false)\r\n\r\n  const showToast = (msg: string) => {\r\n    setToast(msg)\r\n    setTimeout(() => setToast(''), 4000)\r\n  }\r\n\r\n  const loadStatus = useCallback(async () => {\r\n    setLoading(true)\r\n    const result = await apiGet<AQFStatusResponse>('/status')\r\n    if (result) setData(result)\r\n    setLoading(false)\r\n  }, [])\r\n\r\n  const handleRun = async (section?: string) => {\r\n    setRunning(true)\r\n    let result: AQFStatusResponse | null = null\r\n    if (!section || section === 'full') {\r\n      const runResult = await apiPost<{ brief: DecisionBrief; golden_results: GoldenResult[]; health: BusinessHealth }>('/run')\r\n      if (runResult) {\r\n        result = {\r\n          last_run_at: runResult.brief.run_at,\r\n          brief: runResult.brief,\r\n          golden_results: runResult.golden_results,\r\n          health: runResult.health,\r\n          evidence_log: data?.evidence_log ?? [],\r\n          open_questions: data?.open_questions ?? [],\r\n        }\r\n        showToast(`О“ВЈГ  QA hoв”ңГЎn thв”ңГЎnh О“ГҮГ¶ Verdict: ${runResult.brief.verdict} (${runResult.brief.confidence}/100)`)\r\n      }\r\n    } else if (section === 'golden') {\r\n      const goldenResult = await apiGet<GoldenResult[]>('/golden')\r\n      if (goldenResult && data) {\r\n        result = { ...data, golden_results: goldenResult }\r\n        showToast(`О“ВЈГ  Golden tests done О“ГҮГ¶ ${goldenResult.filter(r => r.status === 'pass').length}/${goldenResult.length} pass`)\r\n      }\r\n    } else if (section === 'health') {\r\n      const healthResult = await apiGet<BusinessHealth>('/health')\r\n      if (healthResult && data) {\r\n        result = { ...data, health: healthResult }\r\n        showToast(`О“ВЈГ  Health check done`)\r\n      }\r\n    }\r\n    if (result) setData(result)\r\n    setRunning(false)\r\n  }\r\n\r\n  // Auto-refresh on mount and when autoRefresh is on\r\n  useEffect(() => {\r\n    loadStatus()\r\n  }, [loadStatus])\r\n\r\n  useEffect(() => {\r\n    if (!autoRefresh) return\r\n    const interval = setInterval(loadStatus, 30_000)\r\n    return () => clearInterval(interval)\r\n  }, [autoRefresh, loadStatus])\r\n\r\n  const views: { key: View; label: string; icon: string }[] = [\r\n    { key: 'overview', label: 'TГҹв•—ГІng quan', icon: 'вүЎЖ’Г„В»' },\r\n    { key: 'golden', label: 'Golden Tests', icon: 'вүЎЖ’Г¶Вј' },\r\n    { key: 'health', label: 'Business Health', icon: 'вүЎЖ’ГҶГЁ' },\r\n    { key: 'evidence', label: 'Evidence Log', icon: 'вүЎЖ’ГҙГҜ' },\r\n    { key: 'questions', label: 'Open Questions', icon: 'О“ВҘГҙ' },\r\n  ]\r\n\r\n  const goldenPass = data?.golden_results.filter(r => r.status === 'pass').length ?? 0\r\n  const goldenFail = data?.golden_results.filter(r => r.status === 'fail').length ?? 0\r\n\r\n  return (\r\n    <div className=\"space-y-4\">\r\n      {/* Toast */}\r\n      {toast && (\r\n        <div className=\"fixed top-4 right-4 bg-gray-900 text-white px-5 py-3 rounded-xl shadow-xl z-50 text-sm font-medium max-w-sm\">\r\n          {toast}\r\n        </div>\r\n      )}\r\n\r\n      {/* Header row */}\r\n      <div className=\"flex items-center justify-between flex-wrap gap-3\">\r\n        <div>\r\n          <h2 className=\"text-lg font-black text-gray-800\">О“ГңГӯ AQF Command Center</h2>\r\n          <p className=\"text-xs text-gray-500\">\r\n            {data?.last_run_at ? `LГҹв•‘Вәn cuГҹв•—ГҰi: ${fmtDate(data.last_run_at)}` : 'Chв•һв–‘a chГҹв•‘Гӯy QA'}\r\n            {data?.golden_results.length ? ` в”¬в•– ${goldenPass}/${data.golden_results.length} golden pass` : ''}\r\n          </p>\r\n        </div>\r\n        <div className=\"flex items-center gap-2\">\r\n          <label className=\"flex items-center gap-1.5 text-xs text-gray-500 cursor-pointer select-none\">\r\n            <input\r\n              type=\"checkbox\"\r\n              checked={autoRefresh}\r\n              onChange={e => setAutoRefresh(e.target.checked)}\r\n              className=\"rounded\"\r\n            />\r\n            Auto-refresh 30s\r\n          </label>\r\n          <button\r\n            onClick={loadStatus}\r\n            disabled={loading}\r\n            className=\"px-3 py-1.5 bg-gray-100 hover:bg-gray-200 rounded-lg text-xs font-medium transition disabled:opacity-50\"\r\n          >\r\n            {loading ? 'О“Г…в”Ӯ' : 'вүЎЖ’Г¶ГӨ'} Refresh\r\n          </button>\r\n          <button\r\n            onClick={() => handleRun()}\r\n            disabled={running}\r\n            className=\"px-4 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-bold transition disabled:opacity-50\"\r\n          >\r\n            {running ? 'О“Г…в”Ӯ Running...' : 'О“Г»в•ў Run Full QA'}\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Verdict + Gates */}\r\n      <VerdictCard brief={data?.brief} running={running} />\r\n      {data?.brief?.gates && <GateRow gates={data.brief.gates} />}\r\n\r\n      {/* Quick stats */}\r\n      {data && (\r\n        <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-2\">\r\n          <div className=\"bg-white border rounded-xl p-3 text-center\">\r\n            <div className=\"text-2xl font-black text-emerald-600\">{goldenPass}</div>\r\n            <div className=\"text-xs text-gray-500\">Golden Pass</div>\r\n          </div>\r\n          <div className=\"bg-white border rounded-xl p-3 text-center\">\r\n            <div className={`text-2xl font-black ${goldenFail > 0 ? 'text-red-600' : 'text-gray-300'}`}>{goldenFail}</div>\r\n            <div className=\"text-xs text-gray-500\">Golden Fail</div>\r\n          </div>\r\n          <div className=\"bg-white border rounded-xl p-3 text-center\">\r\n            <div className={`text-2xl font-black ${data.health.orders_today > 0 ? 'text-blue-600' : 'text-gray-400'}`}>{data.health.orders_today}</div>\r\n            <div className=\"text-xs text-gray-500\">Orders hв”ңв”Өm nay</div>\r\n          </div>\r\n          <div className=\"bg-white border rounded-xl p-3 text-center\">\r\n            <div className={`text-2xl font-black ${data.health.active_trips > 0 ? 'text-purple-600' : 'text-gray-400'}`}>{data.health.active_trips}</div>\r\n            <div className=\"text-xs text-gray-500\">Trips в”ҖГҰang chГҹв•‘Гӯy</div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Run control */}\r\n      <RunControl onRun={handleRun} running={running} />\r\n\r\n      {/* Sub-views */}\r\n      <div className=\"bg-white rounded-xl border overflow-hidden\">\r\n        <div className=\"flex gap-0 border-b overflow-x-auto\">\r\n          {views.map(v => (\r\n            <button\r\n              key={v.key}\r\n              onClick={() => setView(v.key)}\r\n              className={`px-4 py-3 text-sm font-medium whitespace-nowrap transition\r\n                ${view === v.key ? 'border-b-2 border-blue-600 text-blue-600 bg-blue-50' : 'text-gray-600 hover:bg-gray-50'}`}\r\n            >\r\n              {v.icon} {v.label}\r\n              {v.key === 'golden' && goldenFail > 0 && (\r\n                <span className=\"ml-1.5 bg-red-500 text-white text-xs rounded-full px-1.5 py-0.5\">{goldenFail}</span>\r\n              )}\r\n              {v.key === 'questions' && data?.open_questions.filter(q => q.block_ship && !q.answer).length\r\n                ? <span className=\"ml-1.5 bg-red-500 text-white text-xs rounded-full px-1.5 py-0.5\">!</span>\r\n                : null\r\n              }\r\n            </button>\r\n          ))}\r\n        </div>\r\n        <div className=\"p-4\">\r\n          {view === 'overview' && (\r\n            <div className=\"space-y-4\">\r\n              {data?.brief?.blocking_issues?.length ? (\r\n                <div>\r\n                  <h3 className=\"text-sm font-bold text-red-700 mb-2\">вүЎЖ’ГңВҪ Blocking Issues</h3>\r\n                  {data.brief.blocking_issues.map((issue, i) => (\r\n                    <div key={i} className=\"text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg px-3 py-2 mb-1\">{issue}</div>\r\n                  ))}\r\n                </div>\r\n              ) : data?.brief && (\r\n                <div className=\"text-emerald-600 text-sm font-medium\">О“ВЈГ  Khв”ңв”Өng cв”ңв”Ӯ blocking issues</div>\r\n              )}\r\n              {data?.brief?.warnings?.length ? (\r\n                <div>\r\n                  <h3 className=\"text-sm font-bold text-amber-700 mb-2\">О“ГңГЎвҲ©в••Г… Warnings</h3>\r\n                  {data.brief.warnings.map((w, i) => (\r\n                    <div key={i} className=\"text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 mb-1\">{w}</div>\r\n                  ))}\r\n                </div>\r\n              ) : null}\r\n              {!data && !loading && (\r\n                <div className=\"text-center py-8 text-gray-400\">\r\n                  <div className=\"text-4xl mb-2\">вүЎЖ’Г„В»</div>\r\n                  <div>BГҹв•‘Г‘m \"Run Full QA\" в”ҖГҰГҹв•—Гў bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu kiГҹв•—Гўm tra chГҹв•‘Г‘t lв•һв–‘Гҹв•—Гәng</div>\r\n                </div>\r\n              )}\r\n            </div>\r\n          )}\r\n          {view === 'golden' && <GoldenTable results={data?.golden_results ?? []} />}\r\n          {view === 'health' && <HealthPanel health={data?.health} />}\r\n          {view === 'evidence' && <EvidenceLog records={data?.evidence_log ?? []} />}\r\n          {view === 'questions' && (\r\n            <OpenQuestionsPanel\r\n              questions={data?.open_questions ?? []}\r\n              onAnswer={loadStatus}\r\n            />\r\n          )}\r\n        </div>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\test-portal\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'showToast' is defined but never used. Allowed unused args must match /^_/u.","line":509,"column":34,"nodeType":null,"messageId":"unusedVar","endLine":509,"endColumn":43},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'refresh' is defined but never used. Allowed unused args must match /^_/u.","line":509,"column":45,"nodeType":null,"messageId":"unusedVar","endLine":509,"endColumn":52}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState } from 'react'\r\nimport SearchableSelect from '@/lib/SearchableSelect'\r\nimport AQFCommandCenter from './aqf-command-center'\r\n\r\nconst API = '/api/test-portal'\r\n\r\n// ===== Types =====\r\ninterface Order {\r\n  id: string; order_number: string; customer_name: string; status: string\r\n  total_amount: number; delivery_date: string; atp_status: string; credit_status: string\r\n  created_at: string; confirm_token: string | null; confirm_status: string | null\r\n  confirm_expires: string | null; reject_reason: string | null\r\n}\r\ninterface OrderConfirmation {\r\n  id: string; order_id: string; order_number: string; customer_name: string\r\n  token: string; phone: string; status: string; total_amount: number\r\n  pdf_url: string | null; sent_at: string; confirmed_at: string | null\r\n  rejected_at: string | null; reject_reason: string | null\r\n  auto_confirmed_at: string | null; expires_at: string\r\n}\r\ninterface DeliveryConfirmation {\r\n  id: string; order_id: string; order_number: string; customer_name: string\r\n  token: string; phone: string; status: string; total_amount: number\r\n  sent_at: string; confirmed_at: string | null; disputed_at: string | null\r\n  dispute_reason: string | null; auto_confirmed_at: string | null\r\n}\r\ninterface StockRow {\r\n  product_id: string; product_name: string; product_sku: string\r\n  warehouse_id: string; warehouse_name: string; total_qty: number\r\n  reserved: number; available: number; batch_number: string; expiry_date: string\r\n}\r\ninterface CreditRow {\r\n  id: string; code: string; name: string; credit_limit: number\r\n  current_balance: number; available_limit: number\r\n}\r\ninterface Customer {\r\n  id: string; code: string; name: string; phone: string; address: string; credit_limit: number\r\n}\r\ninterface Product {\r\n  id: string; sku: string; name: string; price: number; deposit_price: number\r\n  weight_kg: number; volume_m3: number\r\n}\r\n\r\ntype Tab = 'aqf' | 'test-cases' | 'orders' | 'order-confirm' | 'delivery-confirm' | 'stock' | 'credit' | 'ops-audit' | 'create-order' | 'gps-sim' | 'drivers'\r\n\r\ninterface TimelineEvent {\r\n  id: string; event_type: string; actor_type: string; actor_name: string\r\n  title: string; detail: Record<string, unknown>; created_at: string\r\n}\r\n\r\ninterface OrderNote {\r\n  id: string; user_name: string; content: string; note_type: string\r\n  is_pinned: boolean; created_at: string\r\n}\r\n\r\ninterface OpsAuditData {\r\n  admin: {\r\n    permission_rules: number; overrides: number; active_sessions: number\r\n    routes: number; configs: number; credit_limits: number\r\n    recent_sessions: { id: string; user_name: string; ip_address: string; user_agent: string; last_seen_at: string; created_at: string; revoked_at?: string | null }[]\r\n  }\r\n  integration: {\r\n    pending: number; retrying: number; failed: number; resolved: number\r\n    recent: { id: string; adapter: string; operation: string; status: string; retry_count: number; max_retries: number; error_message: string; created_at: string }[]\r\n  }\r\n  reconciliation: {\r\n    total_recons: number; open_discrepancies: number; resolved_discrepancies: number; daily_closes: number\r\n    recent_discrepancies: { id: string; trip_number: string; disc_type: string; status: string; description: string; variance: number; deadline?: string | null; created_at: string }[]\r\n    recent_daily_closes: { id: string; close_date: string; warehouse_name: string; completed_trips: number; total_trips: number; total_discrepancies: number; resolved_discrepancies: number; total_revenue: number }[]\r\n  }\r\n  kpi: {\r\n    snapshots: number; issue_orders: number; cancellation_orders: number; redelivery_orders: number\r\n    recent_snapshots: { snapshot_date: string; warehouse_name: string; otd_rate: number; delivery_success_rate: number; total_orders: number; total_revenue: number }[]\r\n  }\r\n}\r\n\r\n// Scenario types from backend\r\ninterface ScenarioMeta {\r\n  id: string; title: string; description: string; category: string\r\n  roles: string[]; steps: ScenarioStep[]; data_summary: string\r\n  gps_scenario?: string; preview_data: ScenarioDataPoint[]\r\n}\r\ninterface ScenarioStep {\r\n  role: string; page: string; action: string; expected: string\r\n}\r\ninterface ScenarioDataPoint {\r\n  label: string; value: string\r\n}\r\n\r\nconst tabs: { key: Tab; label: string; icon: string }[] = [\r\n  { key: 'aqf', label: 'AQF Command Center', icon: 'О“ГңГӯ' },\r\n  { key: 'test-cases', label: 'KГҹв•—ГҜch bГҹв•‘Гәn test', icon: 'вүЎЖ’Г„В»' },\r\n  { key: 'orders', label: 'в”ҖГүв•һГӯn hв”ңГЎng', icon: 'вүЎЖ’ГҙГҜ' },\r\n  { key: 'order-confirm', label: 'Xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰв•һГӯn (Zalo)', icon: 'вүЎЖ’Гҙв–’' },\r\n  { key: 'delivery-confirm', label: 'Xв”ңГӯc nhГҹв•‘ВЎn giao hв”ңГЎng', icon: 'вүЎЖ’ГңВў' },\r\n  { key: 'stock', label: 'TГҹв•—Гҙn kho / ATP', icon: 'вүЎЖ’ГҙВӘ' },\r\n  { key: 'credit', label: 'Dв•һв–‘ nГҹв•—Гә / Tв”ңВЎn dГҹв•—Г‘ng', icon: 'вүЎЖ’ГҶв–‘' },\r\n  { key: 'ops-audit', label: 'Ops & Audit', icon: 'вүЎЖ’ВәВЎ' },\r\n  { key: 'create-order', label: 'TГҹв•‘Гӯo в”ҖГҰв•һГӯn test', icon: 'О“вӮ§ГІ' },\r\n  { key: 'gps-sim', label: 'GiГҹв•‘Гә lГҹв•‘ВЎp GPS', icon: 'вүЎЖ’ГҙГӯ' },\r\n  { key: 'drivers', label: 'Tв”ңГЎi xГҹв•‘в”җ', icon: 'вүЎЖ’ГңВў' },\r\n]\r\n\r\nconst statusBadge = (status: string) => {\r\n  const m: Record<string, string> = {\r\n    pending_customer_confirm: 'bg-yellow-100 text-yellow-800',\r\n    pending_approval: 'bg-orange-100 text-orange-800',\r\n    confirmed: 'bg-green-100 text-green-800',\r\n    delivered: 'bg-blue-100 text-blue-800',\r\n    cancelled: 'bg-red-100 text-red-800',\r\n    sent: 'bg-yellow-100 text-yellow-700',\r\n    auto_confirmed: 'bg-blue-100 text-blue-700',\r\n    rejected: 'bg-red-100 text-red-700',\r\n    disputed: 'bg-red-100 text-red-700',\r\n    draft: 'bg-gray-100 text-gray-700',\r\n  }\r\n  return m[status] || 'bg-gray-100 text-gray-600'\r\n}\r\n\r\nconst statusLabel: Record<string, string> = {\r\n  pending_customer_confirm: 'ChГҹв•—ВҘ KH xв”ңГӯc nhГҹв•‘ВЎn',\r\n  pending_approval: 'ChГҹв•—ВҘ duyГҹв•—Г§t credit',\r\n  confirmed: 'в”ҖГүв”ңГә xв”ңГӯc nhГҹв•‘ВЎn',\r\n  delivered: 'в”ҖГүв”ңГә giao',\r\n  cancelled: 'в”ҖГүв”ңГә hГҹв•—Вәy',\r\n  sent: 'ChГҹв•—ВҘ xв”ңГӯc nhГҹв•‘ВЎn',\r\n  auto_confirmed: 'TГҹв•—в–’ в”ҖГҰГҹв•—Г–ng xв”ңГӯc nhГҹв•‘ВЎn',\r\n  rejected: 'KH tГҹв•—ВҪ chГҹв•—ГҰi',\r\n  disputed: 'KhiГҹв•‘в”җu nГҹв•‘Гӯi',\r\n  draft: 'Nhв”ңГӯp',\r\n}\r\n\r\nconst fmtMoney = (n: number) => n?.toLocaleString('vi-VN') + 'в”ҖГҰ'\r\nconst fmtDate = (s: string) => s ? new Date(s).toLocaleString('vi-VN') : '-'\r\n\r\nasync function api<T>(path: string, opts?: RequestInit): Promise<T | null> {\r\n  try {\r\n    const res = await fetch(API + path, opts)\r\n    const json = await res.json()\r\n    return json.success ? json.data : null\r\n  } catch { return null }\r\n}\r\n\r\nexport default function TestPortalPage() {\r\n  const [tab, setTab] = useState<Tab>('test-cases')\r\n  const [refreshKey, setRefreshKey] = useState(0)\r\n  const [resetting, setResetting] = useState(false)\r\n  const [toast, setToast] = useState('')\r\n  const [preferredGPSScenario, setPreferredGPSScenario] = useState('')\r\n\r\n  const refresh = () => setRefreshKey(k => k + 1)\r\n  const showToast = (msg: string) => { setToast(msg); setTimeout(() => setToast(''), 3000) }\r\n\r\n  const handleReset = async () => {\r\n    if (!confirm('Xв”ңв”Ӯa toв”ңГЎn bГҹв•—Г– dГҹв•—В» liГҹв•—Г§u test?\\n\\n(GiГҹв•—В» lГҹв•‘Гӯi: NPP, SГҹв•‘Гәn phГҹв•‘вҢҗm, Kho, TГҹв•—Гҙn kho)')) return\r\n    setResetting(true)\r\n    const res = await api<{ message: string }>('/reset-data', { method: 'POST' })\r\n    showToast(res?.message || 'в”ҖГүв”ңГә reset dГҹв•—В» liГҹв•—Г§u')\r\n    setResetting(false)\r\n    refresh()\r\n  }\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-gray-50\">\r\n      {/* Header */}\r\n      <div className=\"bg-amber-700 text-white py-4 px-6 shadow-md\">\r\n        <div className=\"max-w-7xl mx-auto flex items-center justify-between\">\r\n          <div>\r\n            <h1 className=\"text-2xl font-bold\">вүЎЖ’ВәВ¬ Test Portal О“ГҮГ¶ BHL OMS</h1>\r\n            <p className=\"text-amber-200 text-sm mt-1\">Module test nghiГҹв•—Г§p vГҹв•—Г‘, xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰв•һГӯn hв”ңГЎng, tГҹв•—Гҙn kho, dв•һв–‘ nГҹв•—Гә</p>\r\n          </div>\r\n          <div className=\"flex gap-3\">\r\n            <button onClick={refresh}\r\n              className=\"px-4 py-2 bg-brand-500 hover:bg-brand-400 rounded-lg text-sm font-medium transition\">\r\n              вүЎЖ’Г¶ГӨ Refresh\r\n            </button>\r\n            <button onClick={handleReset} disabled={resetting}\r\n              className=\"px-4 py-2 bg-red-600 hover:bg-red-500 rounded-lg text-sm font-medium transition disabled:opacity-50\">\r\n              {resetting ? 'О“Г…в”Ӯ в”ҖГүang xв”ңв”Ӯa...' : 'вүЎЖ’Г№ГҰвҲ©в••Г… Reset Data'}\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {toast && (\r\n        <div className=\"fixed top-4 right-4 bg-green-600 text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-bounce\">\r\n          {toast}\r\n        </div>\r\n      )}\r\n\r\n      <div className=\"max-w-7xl mx-auto px-6 mt-4\">\r\n        <div className=\"flex gap-1 flex-wrap bg-white rounded-xl p-1 shadow-sm\">\r\n          {tabs.map(t => (\r\n            <button key={t.key} onClick={() => setTab(t.key)}\r\n              className={`flex-1 min-w-[140px] px-3 py-2.5 rounded-lg text-sm font-medium transition\r\n                ${tab === t.key ? 'bg-brand-500 text-white shadow' : 'text-gray-600 hover:bg-gray-100'}`}>\r\n              {t.icon} {t.label}\r\n            </button>\r\n          ))}\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"max-w-7xl mx-auto px-6 py-4\">\r\n        {tab === 'aqf' && <AQFCommandCenter />}\r\n        {tab === 'test-cases' && <TestCasesTab setTab={setTab} setPreferredGPSScenario={setPreferredGPSScenario} showToast={showToast} refresh={refresh} />}\r\n        {tab === 'orders' && <OrdersTab refreshKey={refreshKey} showToast={showToast} refresh={refresh} />}\r\n        {tab === 'order-confirm' && <OrderConfirmTab refreshKey={refreshKey} showToast={showToast} refresh={refresh} />}\r\n        {tab === 'delivery-confirm' && <DeliveryConfirmTab refreshKey={refreshKey} />}\r\n        {tab === 'stock' && <StockTab refreshKey={refreshKey} />}\r\n        {tab === 'credit' && <CreditTab refreshKey={refreshKey} />}\r\n        {tab === 'ops-audit' && <OpsAuditTab refreshKey={refreshKey} />}\r\n        {tab === 'create-order' && <CreateOrderTab showToast={showToast} refresh={refresh} />}\r\n        {tab === 'gps-sim' && <GPSSimTab refreshKey={refreshKey} showToast={showToast} preferredScenario={preferredGPSScenario} />}\r\n        {tab === 'drivers' && <DriversTab />}\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nfunction TestCasesTab({ setTab, setPreferredGPSScenario, showToast, refresh }: { setTab: (t: Tab) => void; setPreferredGPSScenario: (scenarioId: string) => void; showToast: (m: string) => void; refresh: () => void }) {\r\n  const [scenarios, setScenarios] = useState<ScenarioMeta[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [loadError, setLoadError] = useState('')\r\n  const [loadingId, setLoadingId] = useState<string | null>(null)\r\n  const [activeScenario, setActiveScenario] = useState<ScenarioMeta | null>(null)\r\n  const [expandedId, setExpandedId] = useState<string | null>(null)\r\n  const [filterCat, setFilterCat] = useState<string>('all')\r\n  const [completedSteps, setCompletedSteps] = useState<Record<string, boolean>>({})\r\n\r\n  useEffect(() => {\r\n    setLoading(true)\r\n    setLoadError('')\r\n    api<ScenarioMeta[]>('/scenarios')\r\n      .then((data) => {\r\n        if (data === null) {\r\n          setScenarios([])\r\n          setLoadError('Frontend dang chay nhung backend Test Portal tren cong 8080 chua len, nen chua tai duoc kich ban va du lieu test.')\r\n          return\r\n        }\r\n        const nextScenarios = (data || []).sort((a, b) => a.id.localeCompare(b.id, undefined, { numeric: true }))\r\n        setScenarios(nextScenarios)\r\n      })\r\n      .finally(() => setLoading(false))\r\n  }, [])\r\n\r\n  const categories = ['all', ...Array.from(new Set(scenarios.map(s => s.category)))]\r\n  const filtered = filterCat === 'all' ? scenarios : scenarios.filter(s => s.category === filterCat)\r\n\r\n  const handleLoadScenario = async (scenarioId: string) => {\r\n    if (!confirm(`NГҹв•‘Гӯp dГҹв•—В» liГҹв•—Г§u cho kГҹв•—ГҜch bГҹв•‘Гәn ${scenarioId}?\\n\\nThao tв”ңГӯc nв”ңГЎy sГҹв•‘в•ң Xв”ңГҙA toв”ңГЎn bГҹв•—Г– dГҹв•—В» liГҹв•—Г§u nghiГҹв•—Г§p vГҹв•—Г‘ (в”ҖГҰв•һГӯn, chuyГҹв•‘в”җn, в”ҖГҰГҹв•—ГҰi soв”ңГӯt...) vв”ңГЎ nГҹв•‘Гӯp dГҹв•—В» liГҹв•—Г§u mГҹв•—Вўi phв”ңв•Ј hГҹв•—Гәp vГҹв•—Вўi kГҹв•—ГҜch bГҹв•‘Гәn.`)) return\r\n    setLoadingId(scenarioId)\r\n    const res = await api<{ scenario_id: string; status: string; message: string }>('/load-scenario', {\r\n      method: 'POST',\r\n      headers: { 'Content-Type': 'application/json' },\r\n      body: JSON.stringify({ scenario_id: scenarioId })\r\n    })\r\n    setLoadingId(null)\r\n    if (res) {\r\n      showToast(res.message)\r\n      const sc = scenarios.find(s => s.id === scenarioId)\r\n      setActiveScenario(sc || null)\r\n      setExpandedId(scenarioId)\r\n      setPreferredGPSScenario(sc?.gps_scenario || '')\r\n      setCompletedSteps({})\r\n      refresh()\r\n      return\r\n    }\r\n    showToast('О“ВҘГ® LГҹв•—Г№i nГҹв•‘Гӯp dГҹв•—В» liГҹв•—Г§u О“ГҮГ¶ kiГҹв•—Гўm tra backend Test Portal')\r\n  }\r\n\r\n  const toggleStep = (key: string) => {\r\n    setCompletedSteps(prev => ({ ...prev, [key]: !prev[key] }))\r\n  }\r\n\r\n  const catColor: Record<string, string> = {\r\n    E2E: 'bg-red-100 text-red-700 border-red-200',\r\n    CREDIT: 'bg-orange-100 text-orange-700 border-orange-200',\r\n    ATP: 'bg-purple-100 text-purple-700 border-purple-200',\r\n    ZALO: 'bg-blue-100 text-blue-700 border-blue-200',\r\n    TMS: 'bg-emerald-100 text-emerald-700 border-emerald-200',\r\n    DRIVER: 'bg-cyan-100 text-cyan-700 border-cyan-200',\r\n    WMS: 'bg-teal-100 text-teal-700 border-teal-200',\r\n    RECON: 'bg-indigo-100 text-indigo-700 border-indigo-200',\r\n  }\r\n\r\n  const catIcon: Record<string, string> = {\r\n    E2E: 'вүЎЖ’Г¶ГӨ', CREDIT: 'вүЎЖ’ГҶв”Ӯ', ATP: 'вүЎЖ’ГҙВӘ', ZALO: 'вүЎЖ’Гҙв–’',\r\n    TMS: 'вүЎЖ’Г№в•‘вҲ©в••Г…', DRIVER: 'вүЎЖ’ГңВў', WMS: 'вүЎЖ’Г…ВЎ', RECON: 'вүЎЖ’ГҙГЁ',\r\n  }\r\n\r\n  const roleIcon: Record<string, string> = {\r\n    dvkh: 'вүЎЖ’ГҰвҢҗО“ГҮГ¬вүЎЖ’ГҶв•қ', accountant: 'вүЎЖ’Вәв•ӣ', dispatcher: 'вүЎЖ’Г№в•‘вҲ©в••Г…', warehouse: 'вүЎЖ’ГҙВӘ',\r\n    security: 'вүЎЖ’ВўГӯвҲ©в••Г…', driver: 'вүЎЖ’ГңВў', management: 'вүЎЖ’ГҙГЁ', admin: 'О“ГңГ–вҲ©в••Г…',\r\n  }\r\n\r\n  if (loading) return <Spinner />\r\n\r\n  return (\r\n    <div className=\"space-y-4\">\r\n      <div className=\"bg-gradient-to-r from-gray-900 to-gray-800 text-white rounded-xl p-6\">\r\n        <div className=\"flex items-start justify-between\">\r\n          <div>\r\n            <h3 className=\"font-bold text-xl mb-2\">вүЎЖ’Г„В» KГҹв•—ГҜch bГҹв•‘Гәn Test О“ГҮГ¶ ChГҹв•—Г¬n & NГҹв•‘Гӯp dГҹв•—В» liГҹв•—Г§u</h3>\r\n            <p className=\"text-gray-300 text-sm\">\r\n              Test Portal khв”ңв”Өng cв”ңв–“n nhв”ңв•‘ng sГҹв•‘в•Ўn dГҹв•—В» liГҹв•—Г§u test trong frontend.\r\n              <br />ChГҹв•—Г« khi bГҹв•‘Гӯn nhГҹв•‘Г‘n <strong>&quot;NГҹв•‘Гӯp data&quot;</strong> thв”ңВј hГҹв•—Г§ thГҹв•—ГҰng mГҹв•—Вўi reset dГҹв•—В» liГҹв•—Г§u nghiГҹв•—Г§p vГҹв•—Г‘ cв”јвҢҗ vв”ңГЎ nГҹв•‘Гӯp bГҹв•—Г– data test tв•һв–‘в•һГӯng Гҹв•—вҢҗng tГҹв•—ВҪ backend.\r\n            </p>\r\n          </div>\r\n        </div>\r\n\r\n        {activeScenario && (\r\n          <div className=\"mt-4 bg-green-500/20 border border-green-400/30 rounded-lg p-3 flex items-center gap-3\">\r\n            <span className=\"relative flex h-3 w-3\">\r\n              <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75\" />\r\n              <span className=\"relative inline-flex rounded-full h-3 w-3 bg-green-400\" />\r\n            </span>\r\n            <span className=\"text-green-200 text-sm\">\r\n              в”ҖГүang test: <strong className=\"text-white\">{activeScenario.id} О“ГҮГ¶ {activeScenario.title}</strong>\r\n            </span>\r\n          </div>\r\n        )}\r\n\r\n        <div className=\"flex gap-2 mt-4 flex-wrap\">\r\n          {categories.map(c => (\r\n            <button key={c} onClick={() => setFilterCat(c)}\r\n              className={`px-3 py-1.5 rounded-full text-xs font-medium transition ${\r\n                filterCat === c ? 'bg-white text-gray-900' : 'bg-white/10 text-gray-300 hover:bg-white/20'\r\n              }`}>\r\n              {c === 'all' ? 'вүЎЖ’ГҙГҜ TГҹв•‘Г‘t cГҹв•‘Гә' : `${catIcon[c] || 'вүЎЖ’ГҙГј'} ${c}`}\r\n            </button>\r\n          ))}\r\n        </div>\r\n      </div>\r\n\r\n      {loadError && (\r\n        <div className=\"rounded-xl border border-red-200 bg-red-50 p-5 text-red-900\">\r\n          <h3 className=\"font-bold text-base\">Backend Test Portal chua chay</h3>\r\n          <p className=\"mt-2 text-sm leading-6\">{loadError}</p>\r\n          <p className=\"mt-2 text-sm leading-6\">\r\n            Cach don gian nhat: vao thu muc <strong>bhl-oms</strong> va bam dup file <strong>START_TEST_PORTAL.bat</strong>.\r\n          </p>\r\n          <p className=\"mt-2 text-sm leading-6\">\r\n            Khi backend len lai, bam <strong>Refresh</strong> de tai danh sach kich ban.\r\n          </p>\r\n        </div>\r\n      )}\r\n\r\n      {!loadError && !filtered.length && (\r\n        <EmptyState text=\"Chв•һв–‘a cв”ңв”Ӯ kГҹв•—ГҜch bГҹв•‘Гәn nв”ңГЎo в”ҖГҰв•һв–‘Гҹв•—Гәc trГҹв•‘Гә vГҹв•—Гј tГҹв•—ВҪ backend. Hв”ңГәy kiГҹв•—Гўm tra Test Portal backend hoГҹв•‘в•–c cГҹв•‘Г‘u hв”ңВјnh ENABLE_TEST_PORTAL.\" />\r\n      )}\r\n\r\n      {filtered.map(sc => {\r\n        const isExpanded = expandedId === sc.id\r\n        const isActive = activeScenario?.id === sc.id\r\n        const isLoading = loadingId === sc.id\r\n        const totalSteps = sc.steps.length\r\n        const doneSteps = sc.steps.filter((_, i) => completedSteps[`${sc.id}-${i}`]).length\r\n\r\n        return (\r\n          <div key={sc.id} className={`bg-white rounded-xl shadow-sm border-2 overflow-hidden transition-all ${\r\n            isActive ? 'border-green-400 ring-2 ring-green-100' : 'border-gray-100 hover:border-gray-200'\r\n          }`}>\r\n            <button\r\n              onClick={() => setExpandedId(isExpanded ? null : sc.id)}\r\n              className=\"w-full px-5 py-4 flex items-center gap-3 hover:bg-gray-50 transition text-left\"\r\n            >\r\n              <span className={`px-2.5 py-1 rounded-lg text-xs font-bold border ${catColor[sc.category] || 'bg-gray-100 text-gray-600 border-gray-200'}`}>\r\n                {catIcon[sc.category] || 'вүЎЖ’ГҙГј'} {sc.category}\r\n              </span>\r\n              <span className=\"font-mono text-sm text-gray-400\">{sc.id}</span>\r\n              <div className=\"flex-1 min-w-0\">\r\n                <span className=\"font-semibold text-gray-900\">{sc.title}</span>\r\n                {!isExpanded && <p className=\"text-xs text-gray-400 mt-0.5 truncate\">{sc.description}</p>}\r\n              </div>\r\n              <div className=\"hidden md:flex gap-1 mr-2 flex-shrink-0\">\r\n                {Array.from(new Set(sc.roles)).slice(0, 4).map((r, i) => (\r\n                  <span key={i} className=\"w-7 h-7 rounded-full bg-gray-100 flex items-center justify-center text-sm\" title={r}>{roleIcon[r] || 'вүЎЖ’ГҰГұ'}</span>\r\n                ))}\r\n              </div>\r\n              <svg className={`w-5 h-5 text-gray-400 transition-transform flex-shrink-0 ${isExpanded ? 'rotate-180' : ''}`}\r\n                fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\r\n                <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M19 9l-7 7-7-7\" />\r\n              </svg>\r\n            </button>\r\n\r\n            {isExpanded && (\r\n              <div className=\"border-t\">\r\n                <div className=\"px-5 py-4 bg-gradient-to-r from-orange-50 to-amber-50 flex items-center justify-between gap-4\">\r\n                  <div className=\"flex-1\">\r\n                    <p className=\"text-sm text-gray-700\">{sc.description}</p>\r\n                    <p className=\"text-xs text-gray-500 mt-1\">вүЎЖ’ГҙГЁ {sc.data_summary}</p>\r\n                  </div>\r\n                  <button\r\n                    onClick={(e) => { e.stopPropagation(); handleLoadScenario(sc.id) }}\r\n                    disabled={isLoading}\r\n                    className={`px-6 py-3 rounded-xl text-base font-bold transition flex items-center gap-2 flex-shrink-0 shadow-md ${\r\n                      isActive ? 'bg-green-600 text-white hover:bg-green-700' : 'bg-[#F68634] text-white hover:bg-[#e5762a]'\r\n                    } disabled:opacity-50`}>\r\n                    {isLoading ? <><span className=\"animate-spin\">О“Г…в”Ӯ</span> в”ҖГүang nГҹв•‘Гӯp...</> : isActive ? <><span>О“ВЈГ </span> NГҹв•‘Гӯp lГҹв•‘Гӯi data</> : <><span>О“Г»в•ўвҲ©в••Г…</span> NГҹв•‘Гӯp data cho kГҹв•—ГҜch bГҹв•‘Гәn nв”ңГЎy</>}\r\n                  </button>\r\n                </div>\r\n\r\n                <div className=\"px-5 pb-5 bg-gray-50 space-y-4 pt-4\">\r\n                  <div className=\"bg-blue-50 border border-blue-200 rounded-lg p-4\">\r\n                    <h4 className=\"text-xs font-bold text-blue-700 uppercase mb-2\">вүЎЖ’ГҙГЁ DГҹв•—В» liГҹв•—Г§u sГҹв•‘в•ң в”ҖГҰв•һв–‘Гҹв•—Гәc nГҹв•‘Гӯp</h4>\r\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-2\">\r\n                      {sc.preview_data.map((dp, i) => (\r\n                        <div key={i} className=\"flex gap-2 text-sm\">\r\n                          <span className=\"text-blue-500 font-medium min-w-[80px]\">{dp.label}:</span>\r\n                          <span className=\"text-blue-900\">{dp.value}</span>\r\n                        </div>\r\n                      ))}\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div>\r\n                    <div className=\"flex items-center justify-between mb-2\">\r\n                      <h4 className=\"text-xs font-bold text-gray-500 uppercase\">вүЎЖ’ГҙВҘ Cв”ңГӯc bв•һв–‘Гҹв•—Вўc thГҹв•—в–’c hiГҹв•—Г§n ({doneSteps}/{totalSteps})</h4>\r\n                      {isActive && totalSteps > 0 && (\r\n                        <div className=\"flex items-center gap-2\">\r\n                          <div className=\"w-24 bg-gray-200 rounded-full h-1.5\">\r\n                            <div className=\"bg-green-500 h-1.5 rounded-full transition-all\" style={{ width: `${(doneSteps / totalSteps) * 100}%` }} />\r\n                          </div>\r\n                          <span className=\"text-xs text-gray-500\">{Math.round((doneSteps / totalSteps) * 100)}%</span>\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n                    <div className=\"space-y-2\">\r\n                      {sc.steps.map((s, i) => {\r\n                        const stepKey = `${sc.id}-${i}`\r\n                        const isDone = completedSteps[stepKey]\r\n                        return (\r\n                          <div key={i} className={`flex gap-3 items-start rounded-lg p-3 border transition ${isDone ? 'bg-green-50 border-green-200' : 'bg-white border-gray-200'}`}>\r\n                            {isActive ? (\r\n                              <button onClick={() => toggleStep(stepKey)}\r\n                                className={`w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 transition text-xs font-bold ${isDone ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-500 hover:bg-gray-300'}`}>\r\n                                {isDone ? 'О“ВЈГҙ' : i + 1}\r\n                              </button>\r\n                            ) : (\r\n                              <span className=\"bg-amber-100 text-amber-700 font-bold text-xs rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0\">{i + 1}</span>\r\n                            )}\r\n                            <div className=\"flex-1\">\r\n                              <div className=\"flex items-center gap-2 mb-1\">\r\n                                <span className=\"w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs\" title={s.role}>{roleIcon[s.role] || 'вүЎЖ’ГҰГұ'}</span>\r\n                                <span className=\"text-xs text-gray-400 font-medium\">{s.role}</span>\r\n                                <span className=\"text-xs text-gray-300\">О“ГҘГҶ</span>\r\n                                <span className=\"text-xs text-gray-400 font-mono\">{s.page}</span>\r\n                              </div>\r\n                              <p className={`text-sm font-medium ${isDone ? 'text-green-700 line-through' : 'text-gray-800'}`}>{s.action}</p>\r\n                              {s.expected && <p className=\"text-xs text-green-600 mt-1\">О“ВЈГҙ KГҹв•—в”Ӯ vГҹв•—Г¬ng: {s.expected}</p>}\r\n                            </div>\r\n                          </div>\r\n                        )\r\n                      })}\r\n                    </div>\r\n                  </div>\r\n\r\n                  {sc.gps_scenario && (\r\n                    <div className=\"bg-emerald-50 border border-emerald-200 rounded-lg p-3 flex items-center justify-between\">\r\n                      <span className=\"text-sm text-emerald-700\">вүЎЖ’ГҙГӯ KГҹв•—ГҜch bГҹв•‘Гәn GPS: <strong>{sc.gps_scenario}</strong></span>\r\n                      <button onClick={() => { setPreferredGPSScenario(sc.gps_scenario || ''); setTab('gps-sim') }}\r\n                        className=\"px-3 py-1.5 bg-emerald-600 text-white rounded-lg text-xs font-medium hover:bg-emerald-700 transition\">\r\n                        MГҹв•—Ж’ GPS Simulator О“ГҘГҶ\r\n                      </button>\r\n                    </div>\r\n                  )}\r\n\r\n                  <div className=\"flex gap-2 pt-2 border-t flex-wrap\">\r\n                    <button onClick={() => setTab('ops-audit')}\r\n                      className=\"px-3 py-1.5 bg-slate-700 text-white rounded-lg text-xs font-medium hover:bg-slate-800 transition\">\r\n                      вүЎЖ’ВәВЎ Ops & Audit\r\n                    </button>\r\n                    {sc.roles.includes('dvkh') && (\r\n                      <button onClick={() => setTab('create-order')}\r\n                        className=\"px-3 py-1.5 bg-[#F68634] text-white rounded-lg text-xs font-medium hover:bg-[#e5762a] transition\">\r\n                        О“вӮ§ГІ TГҹв•‘Гӯo в”ҖГҰв•һГӯn test\r\n                      </button>\r\n                    )}\r\n                    <button onClick={() => setTab('orders')}\r\n                      className=\"px-3 py-1.5 bg-gray-600 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition\">\r\n                      вүЎЖ’ГҙГҜ в”ҖГүв•һГӯn hв”ңГЎng\r\n                    </button>\r\n                    <button onClick={() => setTab('order-confirm')}\r\n                      className=\"px-3 py-1.5 bg-brand-500 text-white rounded-lg text-xs font-medium hover:bg-brand-600 transition\">\r\n                      вүЎЖ’Гҙв–’ Zalo\r\n                    </button>\r\n                    <button onClick={() => setTab('stock')}\r\n                      className=\"px-3 py-1.5 bg-green-600 text-white rounded-lg text-xs font-medium hover:bg-green-700 transition\">\r\n                      вүЎЖ’ГҙВӘ TГҹв•—Гҙn kho\r\n                    </button>\r\n                    <button onClick={() => setTab('credit')}\r\n                      className=\"px-3 py-1.5 bg-orange-600 text-white rounded-lg text-xs font-medium hover:bg-orange-700 transition\">\r\n                      вүЎЖ’ГҶв–‘ Dв•һв–‘ nГҹв•—Гә\r\n                    </button>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            )}\r\n          </div>\r\n        )\r\n      })}\r\n    </div>\r\n  )\r\n}\r\n\r\n// ===== Tab: Orders =====\r\nfunction OrdersTab({ refreshKey, showToast, refresh }: { refreshKey: number; showToast: (msg: string) => void; refresh: () => void }) {\r\n  const [items, setItems] = useState<Order[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n\r\n  useEffect(() => {\r\n    setLoading(true)\r\n    api<Order[]>('/orders').then(d => { setItems(d || []); setLoading(false) })\r\n  }, [refreshKey])\r\n\r\n  if (loading) return <Spinner />\r\n  if (!items.length) return <EmptyState text=\"Chв•һв–‘a cв”ңв”Ӯ в”ҖГҰв•һГӯn hв”ңГЎng test nв”ңГЎo. Hв”ңГәy nГҹв•‘Гӯp kГҹв•—ГҜch bГҹв•‘Гәn hoГҹв•‘в•–c tГҹв•‘Гӯo в”ҖГҰв•һГӯn test mГҹв•—Вўi.\" />\r\n\r\n  return (\r\n    <div className=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n      <div className=\"px-6 py-4 border-b bg-gray-50\">\r\n        <h2 className=\"font-bold text-lg\">вүЎЖ’ГҙГҜ в”ҖГүв•һГӯn hв”ңГЎng test ({items.length})</h2>\r\n        <p className=\"text-sm text-gray-500 mt-1\">Danh sв”ңГӯch в”ҖГҰв•һГӯn hв”ңГЎng в”ҖГҰang cв”ңв”Ӯ trong mв”ңв”Өi trв•һв–‘Гҹв•—ВҘng Test Portal.</p>\r\n      </div>\r\n      <div className=\"overflow-x-auto\">\r\n        <table className=\"w-full text-sm\">\r\n          <thead className=\"bg-gray-50 text-gray-500 uppercase text-xs\">\r\n            <tr>\r\n              <th className=\"px-4 py-3 text-left\">Mв”ңГә в”ҖГҰв•һГӯn</th>\r\n              <th className=\"px-4 py-3 text-left\">Khв”ңГӯch hв”ңГЎng</th>\r\n              <th className=\"px-4 py-3 text-left\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n              <th className=\"px-4 py-3 text-right\">TГҹв•—ГІng tiГҹв•—Гјn</th>\r\n              <th className=\"px-4 py-3 text-left\">ATP</th>\r\n              <th className=\"px-4 py-3 text-left\">Credit</th>\r\n              <th className=\"px-4 py-3 text-left\">Ngв”ңГЎy giao</th>\r\n              <th className=\"px-4 py-3 text-left\">TГҹв•‘Гӯo lв”ңв•‘c</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody className=\"divide-y\">\r\n            {items.map(item => (\r\n              <tr key={item.id} className=\"hover:bg-amber-50\">\r\n                <td className=\"px-4 py-3 font-mono text-amber-700\">{item.order_number}</td>\r\n                <td className=\"px-4 py-3\">{item.customer_name}</td>\r\n                <td className=\"px-4 py-3\">\r\n                  <span className={`px-2 py-1 rounded-full text-xs font-medium ${statusBadge(item.status)}`}>\r\n                    {statusLabel[item.status] || item.status}\r\n                  </span>\r\n                </td>\r\n                <td className=\"px-4 py-3 text-right font-medium\">{fmtMoney(item.total_amount)}</td>\r\n                <td className=\"px-4 py-3 text-xs text-gray-600\">{item.atp_status || '-'}</td>\r\n                <td className=\"px-4 py-3 text-xs text-gray-600\">{item.credit_status || '-'}</td>\r\n                <td className=\"px-4 py-3 text-xs text-gray-600\">{fmtDate(item.delivery_date)}</td>\r\n                <td className=\"px-4 py-3 text-xs text-gray-600\">{fmtDate(item.created_at)}</td>\r\n              </tr>\r\n            ))}\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\n// ===== Tab: Order Confirmations =====\r\nfunction OrderConfirmTab({ refreshKey, showToast, refresh }: { refreshKey: number; showToast: (m: string) => void; refresh: () => void }) {\r\n  const [items, setItems] = useState<OrderConfirmation[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [acting, setActing] = useState<string | null>(null)\r\n\r\n  useEffect(() => {\r\n    setLoading(true)\r\n    api<OrderConfirmation[]>('/order-confirmations').then(d => { setItems(d || []); setLoading(false) })\r\n  }, [refreshKey])\r\n\r\n  const handleConfirm = async (token: string) => {\r\n    setActing(token)\r\n    const res = await fetch(`/api/order-confirm/${token}/confirm`, { method: 'POST' })\r\n    const json = await res.json()\r\n    showToast(json.success ? 'О“ВЈГ  в”ҖГүв•һГӯn hв”ңГЎng в”ҖГҰв”ңГә xв”ңГӯc nhГҹв•‘ВЎn!' : `О“ВҘГ® ${json.error?.message || 'LГҹв•—Г№i'}`)\r\n    setActing(null)\r\n    refresh()\r\n  }\r\n\r\n  const handleReject = async (token: string) => {\r\n    const reason = prompt('Lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi:')\r\n    if (!reason) return\r\n    setActing(token)\r\n    const res = await fetch(`/api/order-confirm/${token}/reject`, {\r\n      method: 'POST', headers: { 'Content-Type': 'application/json' },\r\n      body: JSON.stringify({ reason })\r\n    })\r\n    const json = await res.json()\r\n    showToast(json.success ? 'О“ВҘГ® в”ҖГүв•һГӯn hв”ңГЎng в”ҖГҰв”ңГә tГҹв•—ВҪ chГҹв•—ГҰi!' : `LГҹв•—Г№i: ${json.error?.message}`)\r\n    setActing(null)\r\n    refresh()\r\n  }\r\n\r\n  if (loading) return <Spinner />\r\n  if (!items.length) return <EmptyState text=\"Chв•һв–‘a cв”ңв”Ӯ xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰв•һГӯn hв”ңГЎng nв”ңГЎo. TГҹв•‘Гӯo в”ҖГҰв•һГӯn test trв•һв–‘Гҹв•—Вўc.\" />\r\n\r\n  return (\r\n    <div className=\"space-y-4\">\r\n      <div className=\"bg-blue-50 border border-blue-200 rounded-xl p-4\">\r\n        <h3 className=\"font-bold text-blue-700 mb-2\">вүЎЖ’Гҙв–’ Mв”ңв”Ө phГҹв•—Г…ng xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰв•һГӯn hв”ңГЎng qua Zalo</h3>\r\n        <p className=\"text-sm text-blue-600\">\r\n          Sau khi DVKH tГҹв•‘Гӯo в”ҖГҰв•һГӯn О“ГҘГҶ Zalo gГҹв•—ВЎi link cho KH О“ГҘГҶ KH nhГҹв•‘Г‘n Xв”ңГӯc nhГҹв•‘ВЎn hoГҹв•‘в•–c TГҹв•—ВҪ chГҹв•—ГҰi.\r\n          <br />NГҹв•‘в”җu 2h khв”ңв”Өng phГҹв•‘Гәn hГҹв•—Гҙi О“ГҘГҶ tГҹв•—в–’ в”ҖГҰГҹв•—Г–ng xв”ңГӯc nhГҹв•‘ВЎn.\r\n          <br />NhГҹв•‘Г‘n nв”ңв•‘t bв”ңВ¬n dв•һв–‘Гҹв•—Вўi в”ҖГҰГҹв•—Гў mв”ңв”Ө phГҹв•—Г…ng hв”ңГЎnh в”ҖГҰГҹв•—Г–ng cГҹв•—Вәa khв”ңГӯch hв”ңГЎng.\r\n        </p>\r\n      </div>\r\n\r\n      {items.map(item => (\r\n        <div key={item.id} className=\"bg-white rounded-xl shadow-sm p-5 border-l-4 border-amber-500\">\r\n          <div className=\"flex items-center justify-between mb-3\">\r\n            <div>\r\n              <span className=\"font-mono font-bold text-amber-700 text-lg\">{item.order_number}</span>\r\n              <span className=\"ml-3 text-gray-500\">{item.customer_name}</span>\r\n            </div>\r\n            <span className={`px-3 py-1 rounded-full text-sm font-medium ${statusBadge(item.status)}`}>\r\n              {statusLabel[item.status] || item.status}\r\n            </span>\r\n          </div>\r\n\r\n          <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3 text-sm mb-4\">\r\n            <div><span className=\"text-gray-500\">TГҹв•—ГІng tiГҹв•—Гјn:</span> <span className=\"font-bold\">{fmtMoney(item.total_amount)}</span></div>\r\n            <div><span className=\"text-gray-500\">Sв”ҖГүT:</span> {item.phone}</div>\r\n            <div><span className=\"text-gray-500\">GГҹв•—ВЎi lв”ңв•‘c:</span> {fmtDate(item.sent_at)}</div>\r\n            <div><span className=\"text-gray-500\">HГҹв•‘в”җt hГҹв•‘Гӯn:</span>\r\n              <span className={new Date(item.expires_at) < new Date() ? 'text-red-600 font-medium' : ''}>\r\n                {' '}{fmtDate(item.expires_at)}\r\n              </span>\r\n            </div>\r\n            {item.confirmed_at && <div><span className=\"text-gray-500\">Xв”ңГӯc nhГҹв•‘ВЎn lв”ңв•‘c:</span> <span className=\"text-green-600\">{fmtDate(item.confirmed_at)}</span></div>}\r\n            {item.rejected_at && <div><span className=\"text-gray-500\">TГҹв•—ВҪ chГҹв•—ГҰi lв”ңв•‘c:</span> <span className=\"text-red-600\">{fmtDate(item.rejected_at)}</span></div>}\r\n            {item.reject_reason && <div className=\"col-span-2\"><span className=\"text-gray-500\">Lв”ңв•ң do:</span> <span className=\"text-red-600\">{item.reject_reason}</span></div>}\r\n            {item.auto_confirmed_at && <div><span className=\"text-gray-500\">TГҹв•—в–’ в”ҖГҰГҹв•—Г–ng XN:</span> <span className=\"text-blue-600\">{fmtDate(item.auto_confirmed_at)}</span></div>}\r\n          </div>\r\n\r\n          {item.status === 'sent' && (\r\n            <div className=\"flex gap-3 pt-3 border-t\">\r\n              <button onClick={() => handleConfirm(item.token)} disabled={acting === item.token}\r\n                className=\"flex-1 py-2.5 bg-green-600 text-white rounded-lg font-medium hover:bg-green-700 disabled:opacity-50 transition\">\r\n                {acting === item.token ? 'О“Г…в”Ӯ...' : 'О“ВЈГ  Xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰв•һГӯn hв”ңГЎng (vai KH)'}\r\n              </button>\r\n              <button onClick={() => handleReject(item.token)} disabled={acting === item.token}\r\n                className=\"flex-1 py-2.5 bg-red-600 text-white rounded-lg font-medium hover:bg-red-700 disabled:opacity-50 transition\">\r\n                {acting === item.token ? 'О“Г…в”Ӯ...' : 'О“ВҘГ® TГҹв•—ВҪ chГҹв•—ГҰi в”ҖГҰв•һГӯn hв”ңГЎng (vai KH)'}\r\n              </button>\r\n            </div>\r\n          )}\r\n        </div>\r\n      ))}\r\n    </div>\r\n  )\r\n}\r\n\r\n// ===== Tab: Delivery Confirmations =====\r\nfunction DeliveryConfirmTab({ refreshKey }: { refreshKey: number }) {\r\n  const [items, setItems] = useState<DeliveryConfirmation[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n\r\n  useEffect(() => {\r\n    setLoading(true)\r\n    api<DeliveryConfirmation[]>('/delivery-confirmations').then(d => { setItems(d || []); setLoading(false) })\r\n  }, [refreshKey])\r\n\r\n  if (loading) return <Spinner />\r\n  if (!items.length) return <EmptyState text=\"Chв•һв–‘a cв”ңв”Ӯ xв”ңГӯc nhГҹв•‘ВЎn giao hв”ңГЎng nв”ңГЎo.\" />\r\n\r\n  return (\r\n    <div className=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n      <div className=\"px-6 py-4 border-b bg-gray-50\">\r\n        <h2 className=\"font-bold text-lg\">вүЎЖ’ГңВў Xв”ңГӯc nhГҹв•‘ВЎn giao hв”ңГЎng О“ГҮГ¶ Zalo ({items.length})</h2>\r\n        <p className=\"text-sm text-gray-500 mt-1\">Sau tв”ңГЎi xГҹв•‘в”җ giao hв”ңГЎng О“ГҘГҶ Zalo gГҹв•—ВЎi NPP О“ГҘГҶ NPP xв”ңГӯc nhГҹв•‘ВЎn/khiГҹв•‘в”җu nГҹв•‘Гӯi (24h auto)</p>\r\n      </div>\r\n      <div className=\"overflow-x-auto\">\r\n        <table className=\"w-full text-sm\">\r\n          <thead className=\"bg-gray-50 text-gray-500 uppercase text-xs\">\r\n            <tr>\r\n              <th className=\"px-4 py-3 text-left\">Mв”ңГә в”ҖГҰв•һГӯn</th>\r\n              <th className=\"px-4 py-3 text-left\">Khв”ңГӯch hв”ңГЎng</th>\r\n              <th className=\"px-4 py-3 text-left\">Sв”ҖГүT</th>\r\n              <th className=\"px-4 py-3 text-left\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n              <th className=\"px-4 py-3 text-right\">TГҹв•—ГІng tiГҹв•—Гјn</th>\r\n              <th className=\"px-4 py-3 text-left\">GГҹв•—ВЎi lв”ңв•‘c</th>\r\n              <th className=\"px-4 py-3 text-left\">XN/KhiГҹв•‘в”җu nГҹв•‘Гӯi</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody className=\"divide-y\">\r\n            {items.map(item => (\r\n              <tr key={item.id} className=\"hover:bg-amber-50\">\r\n                <td className=\"px-4 py-3 font-mono text-amber-700\">{item.order_number}</td>\r\n                <td className=\"px-4 py-3\">{item.customer_name}</td>\r\n                <td className=\"px-4 py-3 text-gray-500\">{item.phone}</td>\r\n                <td className=\"px-4 py-3\">\r\n                  <span className={`px-2 py-1 rounded-full text-xs font-medium ${statusBadge(item.status)}`}>\r\n                    {statusLabel[item.status] || item.status}\r\n                  </span>\r\n                </td>\r\n                <td className=\"px-4 py-3 text-right\">{fmtMoney(item.total_amount)}</td>\r\n                <td className=\"px-4 py-3 text-xs text-gray-500\">{fmtDate(item.sent_at)}</td>\r\n                <td className=\"px-4 py-3 text-xs\">\r\n                  {item.confirmed_at && <span className=\"text-green-600\">{fmtDate(item.confirmed_at)}</span>}\r\n                  {item.disputed_at && <span className=\"text-red-600\">{fmtDate(item.disputed_at)}: {item.dispute_reason}</span>}\r\n                  {item.auto_confirmed_at && <span className=\"text-blue-600\">Auto: {fmtDate(item.auto_confirmed_at)}</span>}\r\n                </td>\r\n              </tr>\r\n            ))}\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\n// ===== Tab: Stock =====\r\nfunction StockTab({ refreshKey }: { refreshKey: number }) {\r\n  const [items, setItems] = useState<StockRow[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n\r\n  useEffect(() => {\r\n    setLoading(true)\r\n    api<StockRow[]>('/stock').then(d => { setItems(d || []); setLoading(false) })\r\n  }, [refreshKey])\r\n\r\n  if (loading) return <Spinner />\r\n  if (!items.length) return <EmptyState text=\"Chв•һв–‘a cв”ңв”Ӯ dГҹв•—В» liГҹв•—Г§u tГҹв•—Гҙn kho.\" />\r\n\r\n  // Group by warehouse\r\n  const grouped: Record<string, StockRow[]> = {}\r\n  items.forEach(i => {\r\n    const k = i.warehouse_name || 'Unknown'\r\n    if (!grouped[k]) grouped[k] = []\r\n    grouped[k].push(i)\r\n  })\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <div className=\"bg-green-50 border border-green-200 rounded-xl p-4\">\r\n        <h3 className=\"font-bold text-green-700 mb-1\">вүЎЖ’ГҙВӘ TГҹв•—Гҙn kho / ATP (Available-To-Promise)</h3>\r\n        <p className=\"text-sm text-green-600\">\r\n          Available = TГҹв•—ГІng - Reserved. Khi tГҹв•‘Гӯo в”ҖГҰв•һГӯn О“ГҘГҶ Reserved tв”ҖГўng. Khi hГҹв•—Вәy в”ҖГҰв•һГӯn О“ГҘГҶ Reserved giГҹв•‘Гәm.\r\n        </p>\r\n      </div>\r\n\r\n      {Object.entries(grouped).map(([wh, rows]) => (\r\n        <div key={wh} className=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n          <div className=\"px-6 py-3 bg-gray-50 border-b\">\r\n            <h3 className=\"font-bold\">вүЎЖ’Г…ВЎ {wh}</h3>\r\n          </div>\r\n          <div className=\"overflow-x-auto\">\r\n            <table className=\"w-full text-sm\">\r\n              <thead className=\"bg-gray-50 text-gray-500 uppercase text-xs\">\r\n                <tr>\r\n                  <th className=\"px-4 py-3 text-left\">SKU</th>\r\n                  <th className=\"px-4 py-3 text-left\">SГҹв•‘Гәn phГҹв•‘вҢҗm</th>\r\n                  <th className=\"px-4 py-3 text-right\">TГҹв•—ГІng</th>\r\n                  <th className=\"px-4 py-3 text-right\">в”ҖГүв”ңГә в”ҖГҰГҹв•‘в•–t</th>\r\n                  <th className=\"px-4 py-3 text-right\">KhГҹв•‘Гә dГҹв•—Г‘ng (ATP)</th>\r\n                  <th className=\"px-4 py-3 text-left\">Lв”ңв”Ө</th>\r\n                  <th className=\"px-4 py-3 text-left\">HГҹв•‘Гӯn sГҹв•—ВЎ dГҹв•—Г‘ng</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody className=\"divide-y\">\r\n                {rows.map((s, i) => (\r\n                  <tr key={i} className=\"hover:bg-amber-50\">\r\n                    <td className=\"px-4 py-2 font-mono text-xs\">{s.product_sku}</td>\r\n                    <td className=\"px-4 py-2\">{s.product_name}</td>\r\n                    <td className=\"px-4 py-2 text-right font-medium\">{s.total_qty}</td>\r\n                    <td className=\"px-4 py-2 text-right text-orange-600\">{s.reserved}</td>\r\n                    <td className={`px-4 py-2 text-right font-bold ${s.available <= 0 ? 'text-red-600' : 'text-green-600'}`}>\r\n                      {s.available}\r\n                    </td>\r\n                    <td className=\"px-4 py-2 text-xs text-gray-500\">{s.batch_number || '-'}</td>\r\n                    <td className=\"px-4 py-2 text-xs text-gray-500\">{s.expiry_date || '-'}</td>\r\n                  </tr>\r\n                ))}\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      ))}\r\n    </div>\r\n  )\r\n}\r\n\r\n// ===== Tab: Credit =====\r\nfunction CreditTab({ refreshKey }: { refreshKey: number }) {\r\n  const [items, setItems] = useState<CreditRow[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n\r\n  useEffect(() => {\r\n    setLoading(true)\r\n    api<CreditRow[]>('/credit-balances').then(d => { setItems(d || []); setLoading(false) })\r\n  }, [refreshKey])\r\n\r\n  if (loading) return <Spinner />\r\n  if (!items.length) return <EmptyState text=\"Chв•һв–‘a cв”ңв”Ӯ dГҹв•—В» liГҹв•—Г§u dв•һв–‘ nГҹв•—Гә.\" />\r\n\r\n  return (\r\n    <div className=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n      <div className=\"px-6 py-4 border-b bg-gray-50\">\r\n        <h2 className=\"font-bold text-lg\">вүЎЖ’ГҶв–‘ Dв•һв–‘ nГҹв•—Гә & HГҹв•‘Гӯn mГҹв•—вҢҗc tв”ңВЎn dГҹв•—Г‘ng NPP</h2>\r\n        <p className=\"text-sm text-gray-500 mt-1\">\r\n          Khi Available {'<'} TГҹв•—ГІng tiГҹв•—Гјn в”ҖГҰв•һГӯn hв”ңГЎng О“ГҘГҶ в”ҖГүв•һГӯn chuyГҹв•—Гўn pending_approval О“ГҘГҶ KГҹв•‘в”җ toв”ңГӯn duyГҹв•—Г§t\r\n        </p>\r\n      </div>\r\n      <div className=\"overflow-x-auto\">\r\n        <table className=\"w-full text-sm\">\r\n          <thead className=\"bg-gray-50 text-gray-500 uppercase text-xs\">\r\n            <tr>\r\n              <th className=\"px-4 py-3 text-left\">Mв”ңГә NPP</th>\r\n              <th className=\"px-4 py-3 text-left\">Tв”ңВ¬n NPP</th>\r\n              <th className=\"px-4 py-3 text-right\">HГҹв•‘Гӯn mГҹв•—вҢҗc</th>\r\n              <th className=\"px-4 py-3 text-right\">Dв•һв–‘ nГҹв•—Гә hiГҹв•—Г§n tГҹв•‘Гӯi</th>\r\n              <th className=\"px-4 py-3 text-right\">KhГҹв•‘Гә dГҹв•—Г‘ng</th>\r\n              <th className=\"px-4 py-3 text-left\">Tв”ңВјnh trГҹв•‘Гӯng</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody className=\"divide-y\">\r\n            {items.map(c => {\r\n              const pct = c.credit_limit > 0 ? (c.current_balance / c.credit_limit * 100) : 0\r\n              return (\r\n                <tr key={c.id} className=\"hover:bg-amber-50\">\r\n                  <td className=\"px-4 py-3 font-mono text-amber-700\">{c.code}</td>\r\n                  <td className=\"px-4 py-3\">{c.name}</td>\r\n                  <td className=\"px-4 py-3 text-right\">{fmtMoney(c.credit_limit)}</td>\r\n                  <td className=\"px-4 py-3 text-right text-orange-600\">{fmtMoney(c.current_balance)}</td>\r\n                  <td className={`px-4 py-3 text-right font-bold ${c.available_limit < 0 ? 'text-red-600' : 'text-green-600'}`}>\r\n                    {fmtMoney(c.available_limit)}\r\n                  </td>\r\n                  <td className=\"px-4 py-3\">\r\n                    <div className=\"w-24 bg-gray-200 rounded-full h-2\">\r\n                      <div\r\n                        className={`h-2 rounded-full ${pct > 90 ? 'bg-red-500' : pct > 70 ? 'bg-yellow-500' : 'bg-green-500'}`}\r\n                        style={{ width: `${Math.min(pct, 100)}%` }}\r\n                      />\r\n                    </div>\r\n                    <span className=\"text-xs text-gray-500\">{pct.toFixed(0)}%</span>\r\n                  </td>\r\n                </tr>\r\n              )\r\n            })}\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\n// ===== Tab: Create Order =====\r\nfunction CreateOrderTab({ showToast, refresh }: { showToast: (m: string) => void; refresh: () => void }) {\r\n  const [customers, setCustomers] = useState<Customer[]>([])\r\n  const [products, setProducts] = useState<Product[]>([])\r\n  const [selectedCustomer, setSelectedCustomer] = useState('')\r\n  const [selectedWarehouse, setSelectedWarehouse] = useState('')\r\n  const [orderItems, setOrderItems] = useState<{ productId: string; quantity: number }[]>([{ productId: '', quantity: 10 }])\r\n  const [submitting, setSubmitting] = useState(false)\r\n  const [result, setResult] = useState<Record<string, unknown> | null>(null)\r\n  const [warehouses, setWarehouses] = useState<{ id: string; name: string }[]>([])\r\n\r\n  useEffect(() => {\r\n    api<Customer[]>('/customers').then(d => setCustomers(d || []))\r\n    api<Product[]>('/products').then(d => setProducts(d || []))\r\n    // Get warehouses from stock data\r\n    api<StockRow[]>('/stock').then(d => {\r\n      if (!d) return\r\n      const whMap = new Map<string, string>()\r\n      d.forEach(s => whMap.set(s.warehouse_id, s.warehouse_name))\r\n      setWarehouses(Array.from(whMap.entries()).map(([id, name]) => ({ id, name })))\r\n    })\r\n  }, [])\r\n\r\n  const addItem = () => setOrderItems(prev => [...prev, { productId: '', quantity: 10 }])\r\n  const removeItem = (idx: number) => setOrderItems(prev => prev.filter((_, i) => i !== idx))\r\n\r\n  const handleSubmit = async () => {\r\n    if (!selectedCustomer || !selectedWarehouse || !orderItems.some(i => i.productId && i.quantity > 0)) {\r\n      showToast('Vui lв”ңв–“ng chГҹв•—Г¬n khв”ңГӯch hв”ңГЎng, kho vв”ңГЎ sГҹв•‘Гәn phГҹв•‘вҢҗm')\r\n      return\r\n    }\r\n    setSubmitting(true)\r\n    setResult(null)\r\n    const body = {\r\n      customer_id: selectedCustomer,\r\n      warehouse_id: selectedWarehouse,\r\n      items: orderItems.filter(i => i.productId && i.quantity > 0).map(i => ({\r\n        product_id: i.productId, quantity: i.quantity\r\n      }))\r\n    }\r\n    const res = await api<Record<string, unknown>>('/create-test-order', {\r\n      method: 'POST', headers: { 'Content-Type': 'application/json' },\r\n      body: JSON.stringify(body)\r\n    })\r\n    if (res) {\r\n      setResult(res)\r\n      showToast(`О“ВЈГ  TГҹв•‘Гӯo в”ҖГҰв•һГӯn thв”ңГЎnh cв”ңв”Өng: ${res.order_number}`)\r\n      refresh()\r\n    } else {\r\n      showToast('О“ВҘГ® LГҹв•—Г№i tГҹв•‘Гӯo в”ҖГҰв•һГӯn - kiГҹв•—Гўm tra console')\r\n    }\r\n    setSubmitting(false)\r\n  }\r\n\r\n  const totalAmount = orderItems.reduce((sum, item) => {\r\n    const p = products.find(pr => pr.id === item.productId)\r\n    return sum + (p ? p.price * item.quantity : 0)\r\n  }, 0)\r\n\r\n  const selectedCust = customers.find(c => c.id === selectedCustomer)\r\n\r\n  return (\r\n    <div className=\"max-w-2xl mx-auto space-y-6\">\r\n      <div className=\"bg-amber-50 border border-amber-200 rounded-xl p-4\">\r\n        <h3 className=\"font-bold text-amber-700 mb-1\">О“вӮ§ГІ TГҹв•‘Гӯo в”ҖГҰв•һГӯn test nhanh</h3>\r\n        <p className=\"text-sm text-amber-600\">\r\n          TГҹв•‘Гӯo в”ҖГҰв•һГӯn hв”ңГЎng trГҹв•—в–’c tiГҹв•‘в”җp qua DB (bypass business validation). в”ҖГүв•һГӯn sГҹв•‘в•ң Гҹв•—Ж’ trГҹв•‘Гӯng thв”ңГӯi pending_customer_confirm\r\n          hoГҹв•‘в•–c pending_approval (nГҹв•‘в”җu vв•һв–‘Гҹв•—Гәt credit).\r\n        </p>\r\n      </div>\r\n\r\n      <div className=\"bg-white rounded-xl shadow-sm p-6 space-y-4\">\r\n        {/* Customer */}\r\n        <div>\r\n          <label className=\"block text-sm font-medium text-gray-700 mb-1\">Khв”ңГӯch hв”ңГЎng (NPP)</label>\r\n          <SearchableSelect\r\n            options={customers.map(c => ({\r\n              value: c.id,\r\n              label: `${c.code} О“ГҮГ¶ ${c.name}`,\r\n              sublabel: `HM: ${fmtMoney(c.credit_limit)} | ${c.phone || ''} | ${c.address?.substring(0, 50) || ''}`\r\n            }))}\r\n            value={selectedCustomer}\r\n            onChange={setSelectedCustomer}\r\n            placeholder=\"вүЎЖ’Г¶Г¬ Tв”ңВјm NPP theo mв”ңГә hoГҹв•‘в•–c tв”ңВ¬n...\"\r\n          />\r\n          {selectedCust && (\r\n            <p className=\"text-xs text-gray-500 mt-1\">\r\n              вүЎЖ’ГҙвӮ§ {selectedCust.phone || 'N/A'} | вүЎЖ’ГҙГ¬ {selectedCust.address?.substring(0, 60) || 'N/A'}\r\n            </p>\r\n          )}\r\n        </div>\r\n\r\n        {/* Warehouse */}\r\n        <div>\r\n          <label className=\"block text-sm font-medium text-gray-700 mb-1\">Kho xuГҹв•‘Г‘t</label>\r\n          <select value={selectedWarehouse} onChange={e => setSelectedWarehouse(e.target.value)}\r\n            className=\"w-full border rounded-lg px-3 py-2 text-sm\">\r\n            <option value=\"\">-- ChГҹв•—Г¬n kho --</option>\r\n            {warehouses.map(w => (\r\n              <option key={w.id} value={w.id}>{w.name}</option>\r\n            ))}\r\n          </select>\r\n        </div>\r\n\r\n        {/* Items */}\r\n        <div>\r\n          <label className=\"block text-sm font-medium text-gray-700 mb-2\">SГҹв•‘Гәn phГҹв•‘вҢҗm</label>\r\n          {orderItems.map((item, idx) => (\r\n            <div key={idx} className=\"flex gap-2 mb-2\">\r\n              <div className=\"flex-1\">\r\n                <SearchableSelect\r\n                  options={products.map(p => ({\r\n                    value: p.id,\r\n                    label: `${p.sku} О“ГҮГ¶ ${p.name}`,\r\n                    sublabel: `${fmtMoney(p.price)}/thв”ңв•Јng`\r\n                  }))}\r\n                  value={item.productId}\r\n                  onChange={val => setOrderItems(prev => prev.map((it, i) => i === idx ? { ...it, productId: val } : it))}\r\n                  placeholder=\"вүЎЖ’Г¶Г¬ Tв”ңВјm sГҹв•‘Гәn phГҹв•‘вҢҗm...\"\r\n                />\r\n              </div>\r\n              <input type=\"number\" min=\"1\" value={item.quantity || ''}\r\n                onChange={e => setOrderItems(prev => prev.map((it, i) => i === idx ? { ...it, quantity: Number(e.target.value) || 0 } : it))}\r\n                className=\"w-24 border rounded-lg px-3 py-2 text-sm text-center\"\r\n              />\r\n              {orderItems.length > 1 && (\r\n                <button onClick={() => removeItem(idx)} className=\"text-red-500 hover:text-red-700 px-2\">О“ВЈГІ</button>\r\n              )}\r\n            </div>\r\n          ))}\r\n          <button onClick={addItem} className=\"text-sm text-amber-600 hover:text-amber-800 mt-1\">+ Thв”ңВ¬m sГҹв•‘Гәn phГҹв•‘вҢҗm</button>\r\n        </div>\r\n\r\n        {/* Summary */}\r\n        <div className=\"bg-gray-50 rounded-lg p-4\">\r\n          <div className=\"flex justify-between text-lg font-bold\">\r\n            <span>TГҹв•—ГІng tiГҹв•—Гјn:</span>\r\n            <span className=\"text-amber-700\">{fmtMoney(totalAmount)}</span>\r\n          </div>\r\n          {selectedCust && (\r\n            <p className={`text-sm mt-1 ${totalAmount > selectedCust.credit_limit ? 'text-red-600 font-medium' : 'text-green-600'}`}>\r\n              {totalAmount > selectedCust.credit_limit\r\n                ? `О“ГңГЎвҲ©в••Г… Vв•һв–‘Гҹв•—Гәt hГҹв•‘Гӯn mГҹв•—вҢҗc! (${fmtMoney(selectedCust.credit_limit)}) О“ГҘГҶ в”ҖГүв•һГӯn sГҹв•‘в•ң pending_approval`\r\n                : `О“ВЈГ  Trong hГҹв•‘Гӯn mГҹв•—вҢҗc (${fmtMoney(selectedCust.credit_limit)})`\r\n              }\r\n            </p>\r\n          )}\r\n        </div>\r\n\r\n        <button onClick={handleSubmit} disabled={submitting}\r\n          className=\"w-full py-3 bg-brand-500 text-white rounded-lg font-bold text-lg hover:bg-brand-600 disabled:opacity-50 transition\">\r\n          {submitting ? 'О“Г…в”Ӯ в”ҖГүang tГҹв•‘Гӯo...' : 'вүЎЖ’ВўГҶ TГҹв•‘Гӯo в”ҖГҰв•һГӯn hв”ңГЎng test'}\r\n        </button>\r\n\r\n        {result && (\r\n          <div className=\"bg-green-50 border border-green-300 rounded-lg p-4\">\r\n            <h4 className=\"font-bold text-green-700 mb-2\">О“ВЈГ  в”ҖГүв•һГӯn в”ҖГҰв”ңГә tГҹв•‘Гӯo thв”ңГЎnh cв”ңв”Өng!</h4>\r\n            <pre className=\"text-xs text-green-800 overflow-x-auto\">{JSON.stringify(result, null, 2)}</pre>\r\n          </div>\r\n        )}\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nfunction OpsAuditTab({ refreshKey }: { refreshKey: number }) {\r\n  const [ops, setOps] = useState<OpsAuditData | null>(null)\r\n  const [orders, setOrders] = useState<Order[]>([])\r\n  const [selectedOrderId, setSelectedOrderId] = useState('')\r\n  const [timeline, setTimeline] = useState<TimelineEvent[]>([])\r\n  const [notes, setNotes] = useState<OrderNote[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [timelineLoading, setTimelineLoading] = useState(false)\r\n\r\n  useEffect(() => {\r\n    setLoading(true)\r\n    Promise.all([\r\n      api<OpsAuditData>('/ops-audit'),\r\n      api<Order[]>('/orders'),\r\n    ]).then(([opsData, ordersData]) => {\r\n      setOps(opsData)\r\n      const nextOrders = ordersData || []\r\n      setOrders(nextOrders)\r\n      setSelectedOrderId(prev => prev || nextOrders[0]?.id || '')\r\n    }).finally(() => setLoading(false))\r\n  }, [refreshKey])\r\n\r\n  useEffect(() => {\r\n    if (!selectedOrderId) {\r\n      setTimeline([])\r\n      setNotes([])\r\n      return\r\n    }\r\n    setTimelineLoading(true)\r\n    Promise.all([\r\n      api<TimelineEvent[]>(`/orders/${selectedOrderId}/timeline`),\r\n      api<OrderNote[]>(`/orders/${selectedOrderId}/notes`),\r\n    ]).then(([timelineData, notesData]) => {\r\n      setTimeline(timelineData || [])\r\n      setNotes(notesData || [])\r\n    }).finally(() => setTimelineLoading(false))\r\n  }, [selectedOrderId])\r\n\r\n  if (loading) return <Spinner />\r\n  if (!ops) return <EmptyState text=\"Chв•һв–‘a lГҹв•‘Г‘y в”ҖГҰв•һв–‘Гҹв•—Гәc dГҹв•—В» liГҹв•—Г§u Ops & Audit.\" />\r\n\r\n  const selectedOrder = orders.find(order => order.id === selectedOrderId)\r\n  const dlqBadge: Record<string, string> = {\r\n    pending: 'bg-amber-100 text-amber-700',\r\n    retrying: 'bg-blue-100 text-blue-700',\r\n    failed: 'bg-red-100 text-red-700',\r\n    resolved: 'bg-green-100 text-green-700',\r\n  }\r\n  const noteBadge: Record<string, string> = {\r\n    internal: 'bg-slate-100 text-slate-700',\r\n    driver_note: 'bg-cyan-100 text-cyan-700',\r\n    npp_feedback: 'bg-violet-100 text-violet-700',\r\n    system: 'bg-amber-100 text-amber-700',\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <div className=\"bg-slate-900 text-white rounded-xl p-6\">\r\n        <h3 className=\"text-xl font-bold mb-2\">вүЎЖ’ВәВЎ Ops & Audit Coverage</h3>\r\n        <p className=\"text-slate-300 text-sm\">\r\n          Tab nв”ңГЎy gom cв”ңГӯc vв”ңв•Јng trв•һв–‘Гҹв•—Вўc в”ҖГҰв”ңГіy Test Portal chв•һв–‘a chГҹв•‘Гӯm sв”ңГіu: order timeline/notes, integration DLQ,\r\n          reconciliation, daily close, KPI snapshot vв”ңГЎ admin smoke counters.\r\n        </p>\r\n      </div>\r\n\r\n      <div className=\"grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-3\">\r\n        {[\r\n          { label: 'RBAC rules', value: ops.admin.permission_rules, tone: 'bg-slate-100 text-slate-800' },\r\n          { label: 'Overrides', value: ops.admin.overrides, tone: 'bg-indigo-100 text-indigo-800' },\r\n          { label: 'Active sessions', value: ops.admin.active_sessions, tone: 'bg-cyan-100 text-cyan-800' },\r\n          { label: 'DLQ failed', value: ops.integration.failed, tone: 'bg-red-100 text-red-800' },\r\n          { label: 'Open disc', value: ops.reconciliation.open_discrepancies, tone: 'bg-orange-100 text-orange-800' },\r\n          { label: 'Redelivery', value: ops.kpi.redelivery_orders, tone: 'bg-emerald-100 text-emerald-800' },\r\n        ].map(card => (\r\n          <div key={card.label} className={`rounded-xl p-4 ${card.tone}`}>\r\n            <p className=\"text-xs uppercase tracking-wide opacity-70\">{card.label}</p>\r\n            <p className=\"text-2xl font-bold mt-2\">{card.value}</p>\r\n          </div>\r\n        ))}\r\n      </div>\r\n\r\n      <div className=\"grid grid-cols-1 xl:grid-cols-2 gap-6\">\r\n        <div className=\"bg-white rounded-xl shadow-sm p-5 space-y-4\">\r\n          <div className=\"flex items-center justify-between gap-3 flex-wrap\">\r\n            <div>\r\n              <h3 className=\"text-lg font-semibold\">вүЎЖ’ГҙВЈ Order Timeline & Notes</h3>\r\n              <p className=\"text-sm text-gray-500\">ChГҹв•—Г¬n в”ҖГҰв•һГӯn в”ҖГҰГҹв•—Гў soi event log vв”ңГЎ ghi chв”ңв•‘ ghim.</p>\r\n            </div>\r\n            <select value={selectedOrderId} onChange={e => setSelectedOrderId(e.target.value)} className=\"border rounded-lg px-3 py-2 text-sm min-w-[260px]\">\r\n              <option value=\"\">-- ChГҹв•—Г¬n в”ҖГҰв•һГӯn hв”ңГЎng --</option>\r\n              {orders.map(order => (\r\n                <option key={order.id} value={order.id}>{order.order_number} О“ГҮГі {order.customer_name}</option>\r\n              ))}\r\n            </select>\r\n          </div>\r\n\r\n          {selectedOrder && (\r\n            <div className=\"rounded-lg border bg-gray-50 p-3 text-sm\">\r\n              <div className=\"flex items-center gap-2 flex-wrap\">\r\n                <span className=\"font-mono text-amber-700 font-semibold\">{selectedOrder.order_number}</span>\r\n                <span className={`px-2 py-0.5 rounded-full text-xs font-medium ${statusBadge(selectedOrder.status)}`}>{statusLabel[selectedOrder.status] || selectedOrder.status}</span>\r\n                <span className=\"text-gray-500\">{selectedOrder.customer_name}</span>\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {timelineLoading ? <Spinner /> : (\r\n            <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\r\n              <div>\r\n                <h4 className=\"text-xs font-bold text-gray-500 uppercase mb-2\">Timeline events</h4>\r\n                <div className=\"space-y-2 max-h-[420px] overflow-y-auto pr-1\">\r\n                  {timeline.map(event => (\r\n                    <div key={event.id} className=\"rounded-lg border p-3 bg-white\">\r\n                      <div className=\"flex items-center justify-between gap-2\">\r\n                        <span className=\"text-xs font-mono text-gray-400\">{event.event_type}</span>\r\n                        <span className=\"text-xs text-gray-400\">{fmtDate(event.created_at)}</span>\r\n                      </div>\r\n                      <p className=\"font-medium text-sm text-gray-900 mt-1\">{event.title}</p>\r\n                      <p className=\"text-xs text-gray-500 mt-1\">{event.actor_name || event.actor_type}</p>\r\n                    </div>\r\n                  ))}\r\n                  {timeline.length === 0 && <EmptyState text=\"в”ҖГүв•һГӯn nв”ңГЎy chв•һв–‘a cв”ңв”Ӯ entity_events.\" />}\r\n                </div>\r\n              </div>\r\n\r\n              <div>\r\n                <h4 className=\"text-xs font-bold text-gray-500 uppercase mb-2\">Order notes</h4>\r\n                <div className=\"space-y-2 max-h-[420px] overflow-y-auto pr-1\">\r\n                  {notes.map(note => (\r\n                    <div key={note.id} className=\"rounded-lg border p-3 bg-white\">\r\n                      <div className=\"flex items-center gap-2 flex-wrap\">\r\n                        <span className={`px-2 py-0.5 rounded text-xs font-medium ${noteBadge[note.note_type] || 'bg-gray-100 text-gray-700'}`}>{note.note_type}</span>\r\n                        {note.is_pinned && <span className=\"px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700\">PIN</span>}\r\n                        <span className=\"text-xs text-gray-400 ml-auto\">{fmtDate(note.created_at)}</span>\r\n                      </div>\r\n                      <p className=\"text-sm text-gray-900 mt-2\">{note.content}</p>\r\n                      <p className=\"text-xs text-gray-500 mt-1\">{note.user_name}</p>\r\n                    </div>\r\n                  ))}\r\n                  {notes.length === 0 && <EmptyState text=\"в”ҖГүв•һГӯn nв”ңГЎy chв•һв–‘a cв”ңв”Ӯ note.\" />}\r\n                </div>\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n\r\n        <div className=\"space-y-6\">\r\n          <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n            <h3 className=\"text-lg font-semibold mb-3\">вүЎЖ’Г¶Г® Integration DLQ</h3>\r\n            <div className=\"grid grid-cols-2 md:grid-cols-4 gap-2 mb-4 text-sm\">\r\n              <div className=\"rounded-lg bg-amber-50 p-3\"><p className=\"text-xs text-amber-600\">Pending</p><p className=\"text-xl font-bold text-amber-700\">{ops.integration.pending}</p></div>\r\n              <div className=\"rounded-lg bg-blue-50 p-3\"><p className=\"text-xs text-blue-600\">Retrying</p><p className=\"text-xl font-bold text-blue-700\">{ops.integration.retrying}</p></div>\r\n              <div className=\"rounded-lg bg-red-50 p-3\"><p className=\"text-xs text-red-600\">Failed</p><p className=\"text-xl font-bold text-red-700\">{ops.integration.failed}</p></div>\r\n              <div className=\"rounded-lg bg-green-50 p-3\"><p className=\"text-xs text-green-600\">Resolved</p><p className=\"text-xl font-bold text-green-700\">{ops.integration.resolved}</p></div>\r\n            </div>\r\n            <div className=\"space-y-2\">\r\n              {ops.integration.recent.map(item => (\r\n                <div key={item.id} className=\"rounded-lg border bg-gray-50 p-3\">\r\n                  <div className=\"flex items-center gap-2 flex-wrap\">\r\n                    <span className={`px-2 py-0.5 rounded text-xs font-medium ${dlqBadge[item.status] || 'bg-gray-100 text-gray-700'}`}>{item.status}</span>\r\n                    <span className=\"font-medium text-sm\">{item.adapter} в”¬в•– {item.operation}</span>\r\n                    <span className=\"text-xs text-gray-400 ml-auto\">{fmtDate(item.created_at)}</span>\r\n                  </div>\r\n                  <p className=\"text-xs text-gray-500 mt-1\">Retry {item.retry_count}/{item.max_retries}</p>\r\n                  <p className=\"text-sm text-gray-700 mt-1\">{item.error_message || 'Khв”ңв”Өng cв”ңв”Ӯ error message'}</p>\r\n                </div>\r\n              ))}\r\n              {ops.integration.recent.length === 0 && <EmptyState text=\"Chв•һв–‘a cв”ңв”Ӯ DLQ entries.\" />}\r\n            </div>\r\n          </div>\r\n\r\n          <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n            <h3 className=\"text-lg font-semibold mb-3\">вүЎЖ’Вәв•ӣ Reconciliation & KPI</h3>\r\n            <div className=\"grid grid-cols-2 gap-3 mb-4 text-sm\">\r\n              <div className=\"rounded-lg bg-orange-50 p-3\"><p className=\"text-xs text-orange-600\">Open discrepancy</p><p className=\"text-xl font-bold text-orange-700\">{ops.reconciliation.open_discrepancies}</p></div>\r\n              <div className=\"rounded-lg bg-emerald-50 p-3\"><p className=\"text-xs text-emerald-600\">Resolved discrepancy</p><p className=\"text-xl font-bold text-emerald-700\">{ops.reconciliation.resolved_discrepancies}</p></div>\r\n              <div className=\"rounded-lg bg-sky-50 p-3\"><p className=\"text-xs text-sky-600\">Daily closes</p><p className=\"text-xl font-bold text-sky-700\">{ops.reconciliation.daily_closes}</p></div>\r\n              <div className=\"rounded-lg bg-violet-50 p-3\"><p className=\"text-xs text-violet-600\">KPI snapshots</p><p className=\"text-xl font-bold text-violet-700\">{ops.kpi.snapshots}</p></div>\r\n            </div>\r\n\r\n            <div className=\"space-y-2 mb-4\">\r\n              {ops.reconciliation.recent_discrepancies.map(item => (\r\n                <div key={item.id} className=\"rounded-lg border p-3 bg-gray-50\">\r\n                  <div className=\"flex items-center gap-2 flex-wrap\">\r\n                    <span className=\"font-medium text-sm\">{item.trip_number}</span>\r\n                    <span className=\"px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-700\">{item.disc_type}</span>\r\n                    <span className={`px-2 py-0.5 rounded text-xs font-medium ${item.status === 'resolved' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>{item.status}</span>\r\n                    <span className=\"text-xs text-gray-400 ml-auto\">{fmtDate(item.created_at)}</span>\r\n                  </div>\r\n                  <p className=\"text-sm text-gray-700 mt-1\">{item.description}</p>\r\n                  <p className=\"text-xs text-gray-500 mt-1\">Variance: {fmtMoney(item.variance)}</p>\r\n                </div>\r\n              ))}\r\n            </div>\r\n\r\n            <div className=\"overflow-x-auto border rounded-lg\">\r\n              <table className=\"w-full text-sm\">\r\n                <thead className=\"bg-gray-50 text-gray-500 text-xs uppercase\">\r\n                  <tr>\r\n                    <th className=\"px-3 py-2 text-left\">Ngв”ңГЎy</th>\r\n                    <th className=\"px-3 py-2 text-left\">Kho</th>\r\n                    <th className=\"px-3 py-2 text-right\">OTD</th>\r\n                    <th className=\"px-3 py-2 text-right\">Success</th>\r\n                    <th className=\"px-3 py-2 text-right\">в”ҖГүв•һГӯn</th>\r\n                    <th className=\"px-3 py-2 text-right\">Doanh thu</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody className=\"divide-y\">\r\n                  {ops.kpi.recent_snapshots.map((item, idx) => (\r\n                    <tr key={`${item.snapshot_date}-${idx}`}>\r\n                      <td className=\"px-3 py-2\">{item.snapshot_date}</td>\r\n                      <td className=\"px-3 py-2\">{item.warehouse_name}</td>\r\n                      <td className=\"px-3 py-2 text-right\">{item.otd_rate.toFixed(1)}%</td>\r\n                      <td className=\"px-3 py-2 text-right\">{item.delivery_success_rate.toFixed(1)}%</td>\r\n                      <td className=\"px-3 py-2 text-right\">{item.total_orders}</td>\r\n                      <td className=\"px-3 py-2 text-right\">{fmtMoney(item.total_revenue)}</td>\r\n                    </tr>\r\n                  ))}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          </div>\r\n\r\n          <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n            <h3 className=\"text-lg font-semibold mb-3\">вүЎЖ’ВўГӯвҲ©в••Г… Admin smoke</h3>\r\n            <div className=\"grid grid-cols-2 gap-3 text-sm mb-4\">\r\n              <div className=\"rounded-lg bg-gray-50 p-3\">Configs: <strong>{ops.admin.configs}</strong></div>\r\n              <div className=\"rounded-lg bg-gray-50 p-3\">Credit limits: <strong>{ops.admin.credit_limits}</strong></div>\r\n              <div className=\"rounded-lg bg-gray-50 p-3\">Routes: <strong>{ops.admin.routes}</strong></div>\r\n              <div className=\"rounded-lg bg-gray-50 p-3\">Sessions: <strong>{ops.admin.active_sessions}</strong></div>\r\n            </div>\r\n            <div className=\"space-y-2\">\r\n              {ops.admin.recent_sessions.map(item => (\r\n                <div key={item.id} className=\"rounded-lg border p-3 bg-gray-50 text-sm\">\r\n                  <div className=\"flex items-center gap-2 flex-wrap\">\r\n                    <span className=\"font-medium\">{item.user_name}</span>\r\n                    {item.revoked_at ? <span className=\"px-2 py-0.5 rounded text-xs bg-red-100 text-red-700\">revoked</span> : <span className=\"px-2 py-0.5 rounded text-xs bg-green-100 text-green-700\">active</span>}\r\n                    <span className=\"text-xs text-gray-400 ml-auto\">{fmtDate(item.last_seen_at)}</span>\r\n                  </div>\r\n                  <p className=\"text-xs text-gray-500 mt-1\">{item.ip_address || 'N/A'} в”¬в•– {item.user_agent || 'N/A'}</p>\r\n                </div>\r\n              ))}\r\n              {ops.admin.recent_sessions.length === 0 && <EmptyState text=\"Chв•һв–‘a cв”ңв”Ӯ active session nв”ңГЎo в”ҖГҰГҹв•—Гў soi.\" />}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\n// ===== Shared Components =====\r\n// ===== Tab: GPS Simulation =====\r\ninterface GPSScenario {\r\n  id: string; name: string; description: string; category: string\r\n  vehicle_count: number; duration: string\r\n  routes?: { name: string; waypoints: { lat: number; lng: number; name: string }[] }[]\r\n}\r\ninterface GPSVehicle {\r\n  id: string; plate: string; type: string; driver_name: string; trip_status: string\r\n}\r\ninterface GPSSimStatusData {\r\n  running: boolean; scenario_id?: string; scenario_name?: string\r\n  vehicle_count?: number; started_at?: string; tick_count?: number\r\n  vehicle_states?: { vehicle_id: string; plate: string; lat: number; lng: number; speed: number; heading: number; status: string; waypoint_idx: number }[]\r\n}\r\n\r\nfunction GPSSimTab({ refreshKey, showToast, preferredScenario }: { refreshKey: number; showToast: (m: string) => void; preferredScenario: string }) {\r\n  const [scenarios, setScenarios] = useState<GPSScenario[]>([])\r\n  const [vehicles, setVehicles] = useState<GPSVehicle[]>([])\r\n  const [selectedScenario, setSelectedScenario] = useState<string>('')\r\n  const [selectedVehicles, setSelectedVehicles] = useState<string[]>([])\r\n  const [intervalMs, setIntervalMs] = useState(3000)\r\n  const [status, setStatus] = useState<GPSSimStatusData | null>(null)\r\n  const [loading, setLoading] = useState(false)\r\n  const [autoRefresh, setAutoRefresh] = useState(false)\r\n\r\n  useEffect(() => {\r\n    api<GPSScenario[]>('/gps/scenarios').then(d => d && setScenarios(d))\r\n    api<GPSVehicle[]>('/gps/vehicles').then(d => d && setVehicles(d))\r\n    api<GPSSimStatusData>('/gps/status').then(d => d && setStatus(d))\r\n  }, [refreshKey])\r\n\r\n  useEffect(() => {\r\n    if (preferredScenario) setSelectedScenario(preferredScenario)\r\n  }, [preferredScenario])\r\n\r\n  // Auto-refresh status every 3s while running\r\n  useEffect(() => {\r\n    if (!autoRefresh) return\r\n    const iv = setInterval(async () => {\r\n      const s = await api<GPSSimStatusData>('/gps/status')\r\n      if (s) setStatus(s)\r\n      if (s && !s.running) setAutoRefresh(false)\r\n    }, 3000)\r\n    return () => clearInterval(iv)\r\n  }, [autoRefresh])\r\n\r\n  const handleStart = async () => {\r\n    if (!selectedScenario) { showToast('ChГҹв•—Г¬n kГҹв•—ГҜch bГҹв•‘Гәn trв•һв–‘Гҹв•—Вўc'); return }\r\n    setLoading(true)\r\n    const res = await api<{ message: string }>('/gps/start', {\r\n      method: 'POST',\r\n      headers: { 'Content-Type': 'application/json' },\r\n      body: JSON.stringify({\r\n        scenario_id: selectedScenario,\r\n        vehicle_ids: selectedVehicles.length > 0 ? selectedVehicles : undefined,\r\n        interval_ms: intervalMs,\r\n      }),\r\n    })\r\n    setLoading(false)\r\n    if (res) {\r\n      showToast(res.message)\r\n      setAutoRefresh(true)\r\n      const s = await api<GPSSimStatusData>('/gps/status')\r\n      if (s) setStatus(s)\r\n    }\r\n  }\r\n\r\n  const handleStop = async () => {\r\n    setLoading(true)\r\n    const res = await api<{ message: string }>('/gps/stop', { method: 'POST' })\r\n    setLoading(false)\r\n    if (res) showToast(res.message)\r\n    setAutoRefresh(false)\r\n    const s = await api<GPSSimStatusData>('/gps/status')\r\n    if (s) setStatus(s)\r\n  }\r\n\r\n  const toggleVehicle = (id: string) => {\r\n    setSelectedVehicles(prev => prev.includes(id) ? prev.filter(v => v !== id) : [...prev, id])\r\n  }\r\n\r\n  const sc = scenarios.find(s => s.id === selectedScenario)\r\n  const catColor: Record<string, string> = {\r\n    delivery: 'bg-green-100 text-green-700', anomaly: 'bg-red-100 text-red-700',\r\n    performance: 'bg-blue-100 text-blue-700',\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* Status banner */}\r\n      {status?.running && (\r\n        <div className=\"bg-green-50 border border-green-200 rounded-xl p-4 flex items-center justify-between\">\r\n          <div className=\"flex items-center gap-3\">\r\n            <span className=\"relative flex h-3 w-3\">\r\n              <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75\" />\r\n              <span className=\"relative inline-flex rounded-full h-3 w-3 bg-green-500\" />\r\n            </span>\r\n            <div>\r\n              <p className=\"font-semibold text-green-800\">в”ҖГүang chГҹв•‘Гӯy: {status.scenario_name}</p>\r\n              <p className=\"text-sm text-green-600\">\r\n                {status.vehicle_count} xe в”¬в•– Tick #{status.tick_count} в”¬в•– BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu: {status.started_at ? fmtDate(status.started_at) : '-'}\r\n              </p>\r\n            </div>\r\n          </div>\r\n          <button onClick={handleStop} disabled={loading}\r\n            className=\"px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-500 text-sm font-medium disabled:opacity-50\">\r\n            О“Г…в•ЈвҲ©в••Г… DГҹв•—ВҪng\r\n          </button>\r\n        </div>\r\n      )}\r\n\r\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\r\n        {/* Left column: Scenario selection */}\r\n        <div className=\"lg:col-span-2 space-y-4\">\r\n          <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n            <h3 className=\"text-lg font-semibold mb-4\">вүЎЖ’ГҙГӯ ChГҹв•—Г¬n kГҹв•—ГҜch bГҹв•‘Гәn giГҹв•‘Гә lГҹв•‘ВЎp</h3>\r\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\r\n              {scenarios.map(s => (\r\n                <button key={s.id} onClick={() => setSelectedScenario(s.id)}\r\n                  className={`text-left p-4 rounded-lg border-2 transition ${\r\n                    selectedScenario === s.id ? 'border-amber-500 bg-amber-50' : 'border-gray-200 hover:border-gray-300'\r\n                  }`}>\r\n                  <div className=\"flex items-center gap-2 mb-1\">\r\n                    <span className={`px-2 py-0.5 rounded text-xs font-medium ${catColor[s.category] || 'bg-gray-100 text-gray-600'}`}>\r\n                      {s.category}\r\n                    </span>\r\n                    <span className=\"text-xs text-gray-400\">{s.duration}</span>\r\n                  </div>\r\n                  <p className=\"font-medium text-gray-900\">{s.name}</p>\r\n                  <p className=\"text-sm text-gray-500 mt-1\">{s.description}</p>\r\n                  {s.vehicle_count > 0 && <p className=\"text-xs text-gray-400 mt-1\">вүЎЖ’ГңВў {s.vehicle_count} xe mГҹв•‘в•–c в”ҖГҰГҹв•—ГҜnh</p>}\r\n                </button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Route preview */}\r\n          {sc?.routes && sc.routes.length > 0 && (\r\n            <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n              <h3 className=\"text-lg font-semibold mb-3\">вүЎЖ’Г№в•‘вҲ©в••Г… TuyГҹв•‘в”җn в”ҖГҰв•һв–‘Гҹв•—ВҘng trong kГҹв•—ГҜch bГҹв•‘Гәn</h3>\r\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\r\n                {sc.routes.map((r, i) => (\r\n                  <div key={i} className=\"border rounded-lg p-3\">\r\n                    <p className=\"font-medium text-sm\">{r.name}</p>\r\n                    <div className=\"mt-2 space-y-1\">\r\n                      {r.waypoints?.map((wp, j) => (\r\n                        <div key={j} className=\"flex items-center gap-2 text-xs text-gray-600\">\r\n                          <span className={`w-5 h-5 rounded-full flex items-center justify-center text-white text-[10px] font-bold ${\r\n                            j === 0 ? 'bg-green-500' : j === (r.waypoints?.length || 0) - 1 ? 'bg-red-500' : 'bg-amber-500'\r\n                          }`}>{j + 1}</span>\r\n                          {wp.name}\r\n                        </div>\r\n                      ))}\r\n                    </div>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n\r\n        {/* Right column: Controls + Vehicle selection */}\r\n        <div className=\"space-y-4\">\r\n          {/* Controls */}\r\n          <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n            <h3 className=\"text-lg font-semibold mb-4\">О“ГңГ–вҲ©в••Г… Cв”ңГЎi в”ҖГҰГҹв•‘в•–t</h3>\r\n\r\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\">TГҹв•‘Вәn suГҹв•‘Г‘t GPS (ms)</label>\r\n            <input type=\"range\" min={1000} max={10000} step={500} value={intervalMs}\r\n              onChange={e => setIntervalMs(Number(e.target.value))}\r\n              className=\"w-full mb-1\" />\r\n            <p className=\"text-xs text-gray-500 mb-4\">{intervalMs}ms ({(intervalMs / 1000).toFixed(1)}s mГҹв•—Г№i update)</p>\r\n\r\n            <div className=\"flex gap-2\">\r\n              <button onClick={handleStart} disabled={loading || !selectedScenario || status?.running === true}\r\n                className=\"flex-1 py-2.5 bg-green-600 text-white rounded-lg hover:bg-green-500 text-sm font-medium disabled:opacity-50 transition\">\r\n                {loading ? 'О“Г…в”Ӯ...' : 'О“Г»в•ўвҲ©в••Г… BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu'}\r\n              </button>\r\n              <button onClick={handleStop} disabled={loading || !status?.running}\r\n                className=\"flex-1 py-2.5 bg-red-600 text-white rounded-lg hover:bg-red-500 text-sm font-medium disabled:opacity-50 transition\">\r\n                О“Г…в•ЈвҲ©в••Г… DГҹв•—ВҪng\r\n              </button>\r\n            </div>\r\n\r\n            <a href=\"/dispatcher\" target=\"_blank\" rel=\"noopener noreferrer\"\r\n              className=\"block text-center mt-3 text-sm text-amber-600 hover:text-amber-700 font-medium\">\r\n              вүЎЖ’Г№в•‘вҲ©в••Г… MГҹв•—Ж’ Control Tower в”ҖГҰГҹв•—Гў xem bГҹв•‘Гәn в”ҖГҰГҹв•—Гҙ О“ГҘГҶ\r\n            </a>\r\n          </div>\r\n\r\n          {/* Vehicle selection */}\r\n          <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n            <h3 className=\"text-sm font-semibold mb-3\">вүЎЖ’ГңВў ChГҹв•—Г¬n xe (tuГҹв•—в”Ӯ chГҹв•—Г¬n)</h3>\r\n            <p className=\"text-xs text-gray-500 mb-3\">Khв”ңв”Өng chГҹв•—Г¬n = dв”ңв•Јng xe mГҹв•‘в•–c в”ҖГҰГҹв•—ГҜnh tГҹв•—ВҪ DB</p>\r\n            <div className=\"max-h-64 overflow-y-auto space-y-1\">\r\n              {vehicles.map(v => (\r\n                <label key={v.id} className=\"flex items-center gap-2 p-2 hover:bg-gray-50 rounded cursor-pointer\">\r\n                  <input type=\"checkbox\" checked={selectedVehicles.includes(v.id)}\r\n                    onChange={() => toggleVehicle(v.id)} className=\"rounded\" />\r\n                  <div className=\"flex-1 min-w-0\">\r\n                    <p className=\"text-sm font-medium truncate\">{v.plate}</p>\r\n                    <p className=\"text-xs text-gray-500\">{v.driver_name} в”¬в•– {v.trip_status === 'has_trip' ? 'вүЎЖ’Ж’Гі Cв”ңв”Ӯ trip' : 'О“ГңВ¬ RГҹв•‘Гәnh'}</p>\r\n                  </div>\r\n                </label>\r\n              ))}\r\n              {vehicles.length === 0 && <p className=\"text-xs text-gray-400 text-center py-4\">Khв”ңв”Өng cв”ңв”Ӯ xe</p>}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Live vehicle states */}\r\n          {status?.running && status.vehicle_states && status.vehicle_states.length > 0 && (\r\n            <div className=\"bg-white rounded-xl shadow-sm p-5\">\r\n              <h3 className=\"text-sm font-semibold mb-3\">вүЎЖ’ГҙГ¬ TrГҹв•‘Гӯng thв”ңГӯi xe</h3>\r\n              <div className=\"space-y-2\">\r\n                {status.vehicle_states.map(vs => {\r\n                  const stColor: Record<string, string> = {\r\n                    moving: 'bg-green-100 text-green-700', delivering: 'bg-amber-100 text-amber-700',\r\n                    idle: 'bg-gray-100 text-gray-600', lost_signal: 'bg-red-100 text-red-700',\r\n                  }\r\n                  return (\r\n                    <div key={vs.vehicle_id} className=\"flex items-center gap-2 text-sm p-2 rounded-lg bg-gray-50\">\r\n                      <span className={`px-2 py-0.5 rounded text-xs font-medium ${stColor[vs.status] || 'bg-gray-100'}`}>\r\n                        {vs.status}\r\n                      </span>\r\n                      <span className=\"font-medium\">{vs.plate}</span>\r\n                      <span className=\"text-gray-400 text-xs ml-auto\">\r\n                        {vs.speed.toFixed(0)} km/h в”¬в•– WP {vs.waypoint_idx}\r\n                      </span>\r\n                    </div>\r\n                  )\r\n                })}\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nfunction Spinner() {\r\n  return (\r\n    <div className=\"flex justify-center py-20\">\r\n      <div className=\"animate-spin rounded-full h-12 w-12 border-b-2 border-brand-500\" />\r\n    </div>\r\n  )\r\n}\r\n\r\nfunction EmptyState({ text }: { text: string }) {\r\n  return (\r\n    <div className=\"text-center py-20 text-gray-500\">\r\n      <div className=\"text-4xl mb-3\">вүЎЖ’ГҙВЎ</div>\r\n      <p>{text}</p>\r\n    </div>\r\n  )\r\n}\r\n\r\n// ===== Tab: Tв”ңГЎi xГҹв•‘в”җ & Tв”ңГЎi khoГҹв•‘Гәn =====\r\ninterface DriverInfo {\r\n  id: string; full_name: string; phone: string; license_number: string | null\r\n  status: string; warehouse_id: string; user_id: string\r\n}\r\n\r\nfunction DriversTab() {\r\n  const [drivers, setDrivers] = useState<DriverInfo[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n\r\n  useEffect(() => {\r\n    api<DriverInfo[]>('/drivers')\r\n      .then(d => setDrivers(d || []))\r\n      .finally(() => setLoading(false))\r\n  }, [])\r\n\r\n  const getWarehouseName = (whId: string) => {\r\n    if (whId?.includes('0001')) return 'вүЎЖ’Г…ВЎ Kho HГҹв•‘Гӯ Long'\r\n    if (whId?.includes('0002')) return 'вүЎЖ’Г…ВЎ Kho HГҹв•‘Гәi Phв”ңв–“ng'\r\n    return whId || '-'\r\n  }\r\n\r\n  if (loading) return <div className=\"flex justify-center py-10\"><div className=\"animate-spin rounded-full h-8 w-8 border-b-2 border-brand-500\" /></div>\r\n\r\n  return (\r\n    <div>\r\n      <div className=\"bg-amber-50 border border-amber-200 rounded-xl p-5 mb-6\">\r\n        <h3 className=\"font-bold text-amber-800 text-lg mb-3\">вүЎЖ’ГҙГҜ Hв•һв–‘Гҹв•—Вўng dГҹв•‘ВҪn test vГҹв•—Вўi dГҹв•—В» liГҹв•—Г§u do Test Portal nГҹв•‘Гӯp</h3>\r\n        <div className=\"space-y-2 text-sm text-amber-900\">\r\n          <p><strong>Bв•һв–‘Гҹв•—Вўc 1:</strong> Vв”ңГЎo tab KГҹв•—ГҜch bГҹв•‘Гәn test vв”ңГЎ nhГҹв•‘Г‘n <strong>NГҹв•‘Гӯp data</strong> cho scenario cГҹв•‘Вәn kiГҹв•—Гўm thГҹв•—ВЎ.</p>\r\n          <p><strong>Bв•һв–‘Гҹв•—Вўc 2:</strong> NГҹв•‘в”җu scenario sinh chuyГҹв•‘в”җn giao hв”ңГЎng, в”ҖГҰГҹв•—ГҰi chiГҹв•‘в”җu danh sв”ңГӯch tв”ңГЎi xГҹв•‘в”җ thГҹв•—в–’c tГҹв•‘в”җ Гҹв•—Ж’ bГҹв•‘Гәng bв”ңВ¬n dв•һв–‘Гҹв•—Вўi.</p>\r\n          <p><strong>Bв•һв–‘Гҹв•—Вўc 3:</strong> Phв”ңГіn cв”ңв”Өng hoГҹв•‘в•–c kiГҹв•—Гўm tra chuyГҹв•‘в”җn Гҹв•—Ж’ cв”ңГӯc mв”ңГЎn hв”ңВјnh nghiГҹв•—Г§p vГҹв•—Г‘ tв•һв–‘в•һГӯng 