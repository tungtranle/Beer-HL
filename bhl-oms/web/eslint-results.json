verflow-hidden\">\r\n                <table className=\"w-full text-sm\">\r\n                  <thead className=\"bg-gray-50\">\r\n                    <tr>\r\n                      <th className=\"text-left py-3 px-4\">LoГҹв•‘Гӯi xe</th>\r\n                      <th className=\"text-right py-3 px-4\">Tiв”ңВ¬u thГҹв•—Г‘ (L/km)</th>\r\n                      <th className=\"text-right py-3 px-4\">Giв”ңГӯ nhiв”ңВ¬n liГҹв•—Г§u (О“Г©ВҪ/L)</th>\r\n                      <th className=\"text-center py-3 px-4\">HГҹв•‘Гӯng thu phв”ңВЎ</th>\r\n                      <th className=\"text-right py-3 px-4\">Chi phв”ңВЎ/km (О“Г©ВҪ)</th>\r\n                      <th className=\"text-center py-3 px-4\">Thao tв”ңГӯc</th>\r\n                    </tr>\r\n                  </thead>\r\n                  <tbody>\r\n                    {vehicleDefaults.map(d => {\r\n                      const fuelPerKm = d.fuel_consumption_per_km * d.fuel_price_per_liter\r\n                      return (\r\n                        <VehicleDefaultRow key={d.id} item={d} fuelPerKm={fuelPerKm} onSave={saveVehicleDefault} saving={saving} />\r\n                      )\r\n                    })}\r\n                    {vehicleDefaults.length === 0 && (\r\n                      <tr><td colSpan={6} className=\"text-center py-8 text-gray-400\">Chв•һв–‘a cв”ңв”Ӯ в”ҖГҰГҹв•—ГҜnh mГҹв•—вҢҗc xe.</td></tr>\r\n                    )}\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {/* TAB: Driver Rates */}\r\n          {tab === 'driver-rates' && (\r\n            <div>\r\n              <div className=\"flex justify-between items-center mb-4\">\r\n                <div>\r\n                  <h2 className=\"text-lg font-semibold\">вүЎЖ’ГҰГұ PhГҹв•—Г‘ cГҹв•‘Г‘p tв”ңГЎi xГҹв•‘в”җ</h2>\r\n                  <p className=\"text-sm text-gray-500 mt-1\">PhГҹв•—Г‘ cГҹв•‘Г‘p tв”ңВЎnh theo km di chuyГҹв•—Гўn vв”ңГЎ mГҹв•—вҢҗc tГҹв•—ГҰi thiГҹв•—Гўu/ng