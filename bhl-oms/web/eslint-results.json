    ))}\r\n                    </div>\r\n                  </div>\r\n                )}\r\n\r\n                {/* Security actions */}\r\n                {!securityDone && handoverStatus !== 'rejected' && (\r\n                  <div className=\"border-t pt-4\">\r\n                    {!showRejectForm ? (\r\n                      <div className=\"flex gap-3\">\r\n                        <button\r\n                          onClick={securityConfirm}\r\n                          disabled={confirming}\r\n                          className=\"flex-1 h-14 bg-green-600 text-white rounded-xl font-bold text-lg hover:bg-green-700 transition disabled:opacity-50\"\r\n                        >\r\n                          {confirming ? 'в”ҖГүang xГҹв•—ВЎ lв”ңв•ң...' : 'О“ВЈГ  Xв”ңГӯc nhГҹв•‘ВЎn О“ГҮГ¶ Cho qua cГҹв•—ГІng'}\r\n                        </button>\r\n                        <button\r\n                          onClick={() => setShowRejectForm(true)}\r\n                          className=\"px-6 h-14 bg-red-100 text-red-700 rounded-xl font-medium hover:bg-red-200 transition\"\r\n                        >\r\n                          О“ВҘГ® TГҹв•—ВҪ chГҹв•—ГҰi\r\n                        </button>\r\n                      </div>\r\n                    ) : (\r\n                      <div>\r\n                        <label className=\"block text-sm font-medium text-red-700 mb-2\">Lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi</label>\r\n                        <textarea\r\n                          value={rejectReason}\r\n                          onChange={e => setRejectReason(e.target.value)}\r\n                          placeholder=\"NhГҹв•‘ВЎp lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi...\"\r\n                          className=\"w-full border border-red-300 rounded-lg px-3 py-2 text-base mb-3 bg-red-50\"\r\n                          rows={2}\r\n                        />\r\n                        <div className=\"flex gap-3\">\r\n                          <button\r\n                            onClick={securityReject}\r\n                            disabled={confirming || !rejectReason.trim()}\r\n                            className=\"flex-1 h-14 bg-red-600 text-white rounded-xl font-bold hover:bg-red-700 transition disabled:opacity-50\"\r\n                          >\r\n                            {confirming ? 'в”ҖГүang xГҹв•—ВЎ lв”ңв•ң...' : 'О“ВҘГ® Xв”ңГӯc nhГҹв•‘ВЎn tГҹв•—ВҪ chГҹв•—ГҰi'}\r\n                          </button>\r\n                          <button\r\n                            onClick={() => setShowRejectForm(false)}\r\n                            className=\"px-6 h-14 border rounded-xl text-gray-600 hover:bg-gray-50 transition\"\r\n                          >\r\n                            HГҹв•—Вәy\r\n                          </button>\r\n                        </div>\r\n                      </div>\r\n                    )}\r\n                  </div>\r\n                )}\r\n              </>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\handover-a\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":75,"column":23,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":75,"endColumn":26,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2839,2842],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2839,2842],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":80,"column":22,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":80,"endColumn":