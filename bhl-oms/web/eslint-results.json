t need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":670,"column":51,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":670,"endColumn":54,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[30156,30159],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[30156,30159],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":766,"column":54,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":766,"endColumn":57,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[35451,35454],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[35451,35454],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":777,"column":52,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":777,"endColumn":55,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[36083,36086],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[36083,36086],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":22,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState, useCallback } from 'react'\r\nimport Link from 'next/link'\r\nimport { useSearchParams } from 'next/navigation'\r\nimport { apiFetch, getUser } from '@/lib/api'\r\nimport { orderStatusLabels, orderStatusColors, formatVND } from '@/lib/status-config'\r\nimport { StatusChip } from '@/components/ui/StatusChip'\r\nimport { Pagination } from '@/components/ui/Pagination'\r\nimport { toast } from '@/lib/useToast'\r\nimport { handleError } from '@/lib/handleError'\r\nimport { useDataRefresh } from '@/lib/notifications'\r\n\r\ninterface Order {\r\n  id: string\r\n  order_number: string\r\n  customer_id: string\r\n  customer_name: string\r\n  customer_phone?: string\r\n  status: string\r\n  delivery_date: string\r\n  total_amount: number\r\n  atp_status: string\r\n  credit_status: string\r\n  created_at: string\r\n  reject_reason?: string\r\n  zalo_status?: string\r\n  trip_id?: string\r\n  vehicle_plate?: string\r\n  driver_name?: string\r\n  is_urgent?: boolean\r\n}\r\n\r\ninterface ControlDeskStats {\r\n  draft: number\r\n  pending_customer_confirm: number\r\n  pending_approval: number\r\n  confirmed: number\r\n  shipment_created: number\r\n  in_transit: number\r\n  delivering: number\r\n  delivered: number\r\n  partially_delivered: number\r\n  failed: number\r\n  cancelled: number\r\n  rejected: number\r\n  on_credit: number\r\n  total: number\r\n}\r\n\r\n// Status labels and colors imported from @/lib/status-config\r\nconst statusColors = orderStatusColors\r\nconst statusLabels = orderStatusLabels\r\n\r\ntype ViewTab = 'all' | 'exceptions' | 'redelivery'\r\n\r\nexport default function OrdersPage() {\r\n  const [orders, setOrders] = useState<Order[]>([])\r\n  const [stats, setStats] = useState<ControlDeskStats | null>(null)\r\n  const [loading, setLoading] = useState(true)\r\n  const [searchQuery, setSearchQuery] = useState('')\r\n  const [isSearching, setIsSearching] = useState(false)\r\n  const searchParams = useSearchParams()\r\n  const [statusFilter, setStatusFilter] = useState(searchParams.get('status') || '')\r\n  const [deliveryDate, setDeliveryDate] = useState(searchParams.get('delivery_date') || '')\r\n  const [cutoffGroup, setCutoffGroup] = useState(searchParams.get('cutoff_group') || '')\r\n  const [page, setPage] = useState(1)\r\n  const [limit, setLimit] = useState(20)\r\n  const [totalRows, setTotalRows] = useState(0)\r\n  const [viewTab, setViewTab] = useState<ViewTab>('all')\r\n  const [sidebarCustomer, setSidebarCustomer] = useState<any>(null)\r\n  const [sidebarOrders, setSidebarOrders] = useState<Order[]>([])\r\n  const [sidebarLoading, setSidebarLoading] = useState(false)\r\n  const [sidebarHealth, setSidebarHealth] = useState<any>(null)\r\n  const [sidebarForecast, setSidebarForecast] = useState<any[]>([])\r\n  const [showImportModal, setShowImportModal] = useState(false)\r\n  const [importFile, setImportFile] = useState<File | null>(null)\r\n  const [importing, setImporting] = useState(false)\r\n  const [importResult, setImportResult] = useState<any>(null)\r\n  const currentUser = getUser()\r\n\r\n  const handleExport = async () => {\r\n    try {\r\n      const res = await fetch('/api/orders/export', {\r\n        headers: { 'Authorization': `Bearer ${localStorage.getItem('bhl_token')}` },\r\n      })\r\n      if (!res.ok) throw new Error('Export failed')\r\n      const blob = await res.blob()\r\n      const url = URL.createObjectURL(blob)\r\n      const a = document.createElement('a')\r\n      a.href = url\r\n      a.download = `don-hang-${new Date().toISOString().slice(0,10)}.xlsx`\r\n      a.click()\r\n      URL.revokeObjectURL(url)\r\n      toast.success('в”ҖГүв”ңГә tГҹв•‘Гәi xuГҹв•—ГҰng file Excel')\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i xuГҹв•‘Г‘t Excel: ' + err.message)\r\n    }\r\n  }\r\n\r\n  const handleDownloadTemplate = async () => {\r\n    try {\r\n      const res = await fetch('/api/orders/import/template', {\r\n        headers: { 'Authorization': `Bearer ${localStorage.getItem('bhl_token')}` },\r\n      })\r\n      if (!res.ok) throw new Error('Download failed')\r\n      const blob = await res.blob()\r\n      const url = URL.createObjectURL(blob)\r\n      const a = document.createElement('a')\r\n      a.href = url\r\n      a.download = 'mau-import-don-hang.xlsx'\r\n      a.click()\r\n      URL.revokeObjectURL(url)\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i tГҹв•‘Гәi mГҹв•‘ВҪu: ' + err.message)\r\n    }\r\n  }\r\n\r\n  const handleImport = async () => {\r\n    if (!importFile) return\r\n    setImporting(true)\r\n    setImportResult(null)\r\n    try {\r\n      const formData = new FormData()\r\n      formData.append('file', importFile)\r\n      const res = await fetch('/api/orders/import', {\r\n        method: 'POST',\r\n        headers: { 'Authorization': `Bearer ${localStorage.getItem('bhl_token')}` },\r\n        body: formData,\r\n      })\r\n      const json = await res.json()\r\n      if (!res.ok) throw new Error(json.error || 'Import failed')\r\n      setImportResult(json.data)\r\n      if (json.data.error_count === 0) {\r\n        toast.success(`в”ҖГүв”ңГә import thв”ңГЎnh cв”ңв”Өng ${json.data.success_count} в”ҖГҰв•һГӯn hв”ңГЎng`)\r\n      } else {\r\n        toast.error(`Import: ${json.data.success_count} thв”ңГЎnh cв”ңв”Өng, ${json.data.error_count} lГҹв•—Г№i`)\r\n      }\r\n      loadOrders()\r\n      loadStats()\r\n    } catch (err: any) {\r\n      toast.error('LГҹв•—Г№i import: ' + err.message)\r\n    } finally {\r\n      setImporting(false)\r\n    }\r\n  }\r\n\r\n  const loadStats = async () => {\r\n    try {\r\n      const res: any = await apiFetch('/orders/control-desk/stats')\r\n      setStats(res.data)\r\n    } catch (err) {\r\n      handleError(err, { userMessage: 'Khв”ңв”Өng tГҹв•‘Гәi в”ҖГҰв•һв–‘Гҹв•—Гәc thГҹв•—ГҰng kв”ңВ¬ в”ҖГҰв•һГӯn hв”ңГЎng' })\r\n    }\r\n  }\r\n\r\n  // Auto-refresh when order status changes via WebSocket\r\n  useDataRefresh('order', () => { loadOrders(); loadStats() })\r\n\r\n  const loadOrders = async () => {\r\n    setLoading(true)\r\n    try {\r\n      const params = new URLSearchParams()\r\n      if (statusFilter) params.set('status', statusFilter)\r\n      if (deliveryDate) params.set('delivery_date', deliveryDate)\r\n      if (cutoffGroup) params.set('cutoff_group', cutoffGroup)\r\n      params.set('page', String(page))\r\n      params.set('limit', String(limit))\r\n      const res: any = await apiFetch(`/orders?${params}`)\r\n      setOrders(res.data || [])\r\n      setTotalRows(res.meta?.total ?? (res.data?.length || 0))\r\n    } catch (err) {\r\n      handleError(err, { userMessage: 'Khв”ңв”Өng tГҹв•‘Гәi в”ҖГҰв•һв–‘Гҹв•—Гәc danh sв”ңГӯch в”ҖГҰв•һГӯn' })\r\n    } finally {\r\n      setLoading(false)\r\n    }\r\n  }\r\n\r\n  const searchOrders = useCallback(async (q: string) => {\r\n    if (q.length < 2) return\r\n    setIsSearching(true)\r\n    setLoading(true)\r\n    try {\r\n      const res: any = await apiFetch(`/orders/search?q=${encodeURIComponent(q)}&limit=50`)\r\n      setOrders(res.data || [])\r\n    } catch (err) {\r\n      handleError(err, { userMessage: 'Tв”ңВјm kiГҹв•‘в”җm в”ҖГҰв•һГӯn hв”ңГЎng thГҹв•‘Г‘t bГҹв•‘Гӯi' })\r\n    } finally {\r\n      setLoading(false)\r\n    }\r\n  }, [])\r\n\r\n  useEffect(() => {\r\n    loadStats()\r\n  }, [])\r\n\r\n  useEffect(() => {\r\n    if (!isSearching) {\r\n      loadOrders()\r\n    }\r\n  }, [statusFilter, deliveryDate, cutoffGroup, page, limit])\r\n\r\n  // Reset to first page when filters change\r\n  useEffect(() => {\r\n    setPage(1)\r\n  }, [statusFilter, deliveryDate, cutoffGroup])\r\n\r\n  useEffect(() => {\r\n    if (!searchQuery) {\r\n      setIsSearching(false)\r\n      loadOrders()\r\n      return\r\n    }\r\n    const timer = setTimeout(() => searchOrders(searchQuery), 400)\r\n    return () => clearTimeout(timer)\r\n  }, [searchQuery])\r\n\r\n  const openCustomerSidebar = async (customerId: string) => {\r\n    setSidebarLoading(true)\r\n    setSidebarCustomer(null)\r\n    setSidebarHealth(null)\r\n    setSidebarForecast([])\r\n    try {\r\n      const [custRes, ordersRes]: any[] = await Promise.all([\r\n        apiFetch(`/customers/${customerId}`),\r\n        apiFetch(`/orders?customer_id=${customerId}&limit=20`),\r\n      ])\r\n      setSidebarCustomer(custRes.data)\r\n      setSidebarOrders(ordersRes.data || [])\r\n      // F2: NPP Health Score (graceful fail О“ГҮГ¶ available after ML service launch)\r\n      apiFetch<any>(`/customers/${customerId}/health`)\r\n        .then((r: any) => setSidebarHealth(r.data))\r\n        .catch(() => {})\r\n      // F1: Demand Intelligence forecast (graceful fail О“ГҮГ¶ available after Demand ML)\r\n      apiFetch<any>(`/customers/${customerId}/forecast`)\r\n        .then((r: any) => setSidebarForecast(r.data || []))\r\n        .catch(() => {})\r\n    } catch (err) { handleError(err, { userMessage: 'Khв”ңв”Өng tГҹв•‘Гәi в”ҖГҰв•һв–‘Гҹв•—Гәc chi tiГҹв•‘в”җt NPP' }) }\r\n    finally { setSidebarLoading(false) }\r\n  }\r\n\r\n  const handleApprove = async (orderId: string) => {\r\n    try {\r\n      await apiFetch(`/orders/${orderId}/approve`, { method: 'POST' })\r\n      toast.success('в”ҖГүв”ңГә duyГҹв•—Г§t в”ҖГҰв•һГӯn hв”ңГЎng')\r\n      loadOrders()\r\n      loadStats()\r\n    } catch (err: any) {\r\n      toast.error(err.message)\r\n    }\r\n  }\r\n\r\n  const handleCancel = async (orderId: string) => {\r\n    if (!confirm('BГҹв•‘Гӯn cв”ңв”Ӯ chГҹв•‘В»c muГҹв•—ГҰn hГҹв•—Вәy в”ҖГҰв•һГӯn hв”ңГЎng nв”ңГЎy?')) return\r\n    try {\r\n      await apiFetch(`/orders/${orderId}/cancel`, { method: 'POST' })\r\n      toast.success('в”ҖГүв”ңГә hГҹв•—Вәy в”ҖГҰв•һГӯn hв”ңГЎng')\r\n      loadOrders()\r\n      loadStats()\r\n    } catch (err: any) {\r\n      toast.error(err.message)\r\n    }\r\n  }\r\n\r\n  const handleCardClick = (statuses: string[]) => {\r\n    setSearchQuery('')\r\n    setIsSearching(false)\r\n    setStatusFilter(statuses.length === 1 ? statuses[0] : '')\r\n    setViewTab('all')\r\n  }\r\n\r\n  // Derived stats for 7 summary cards\r\n  const inDelivery = stats ? stats.confirmed + stats.shipment_created + stats.in_transit + stats.delivering : 0\r\n  const issues = stats ? stats.failed + stats.rejected + stats.partially_delivered : 0\r\n\r\n  const summaryCards = stats ? [\r\n    { label: 'MГҹв•—Вўi', count: stats.draft, color: 'border-gray-300 bg-gray-50', textColor: 'text-gray-700', icon: 'вүЎЖ’ГҙВҘ', statuses: ['draft'] },\r\n    { label: 'ChГҹв•—ВҘ KH', count: stats.pending_customer_confirm, color: 'border-amber-300 bg-amber-50', textColor: 'text-amber-700', icon: 'О“Г…в”Ӯ', statuses: ['pending_customer_confirm'] },\r\n    { label: 'ChГҹв•—ВҘ duyГҹв•—Г§t', count: stats.pending_approval, color: 'border-yellow-300 bg-yellow-50', textColor: 'text-yellow-700', icon: 'вүЎЖ’Г¶ГҰ', statuses: ['pending_approval'] },\r\n    { label: 'в”ҖГүang giao', count: inDelivery, color: 'border-blue-300 bg-blue-50', textColor: 'text-blue-700', icon: 'вүЎЖ’ГңВў', statuses: ['confirmed', 'shipment_created', 'in_transit', 'delivering'] },\r\n    { label: 'в”ҖГүв”ңГә giao', count: stats.delivered, color: 'border-green-300 bg-green-50', textColor: 'text-green-700', icon: 'О“ВЈГ ', statuses: ['delivered'] },\r\n    { label: 'Cв”ңв”Ӯ vГҹв•‘Г‘n в”ҖГҰГҹв•—Гј', count: issues, color: 'border-red-300 bg-red-50', textColor: 'text-red-700', icon: 'О“ГңГЎвҲ©в••Г…', statuses: ['failed', 'rejected', 'partially_delivered'] },\r\n    { label: 'HГҹв•—Вәy/NГҹв•—Гә', count: stats.cancelled + stats.on_credit, color: 'border-gray-300 bg-gray-50', textColor: 'text-gray-500', icon: 'вүЎЖ’ГңВҪ', statuses: ['cancelled', 'on_credit'] },\r\n  ] : []\r\n\r\n  // Filter orders by view tab\r\n  const filteredOrders = orders.filter(o => {\r\n    if (viewTab === 'exceptions') return ['failed', 'rejected', 'partially_delivered'].includes(o.status)\r\n    if (viewTab === 'redelivery') return o.status === 'confirmed' && o.order_number.includes('-')  // re-delivery orders\r\n    return true\r\n  })\r\n\r\n  return (\r\n    <div>\r\n      {/* Header */}\r\n      <div className=\"flex items-center justify-between mb-6\">\r\n        <div className=\"flex items-center gap-3\">\r\n          <h1 className=\"text-2xl font-bold text-gray-800\">QuГҹв•‘Гәn lв”ңв•ң в”ҖГҰв•һГӯn hв”ңГЎng</h1>\r\n          <button onClick={() => { loadOrders(); loadStats() }} className=\"p-1.5 rounded-lg hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition\" title=\"Lв”ңГЎm mГҹв•—Вўi\">\r\n            <svg className=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15\" /></svg>\r\n          </button>\r\n        </div>\r\n        <div className=\"flex items-center gap-2\">\r\n          <button\r\n            onClick={handleExport}\r\n            className=\"px-3 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition text-sm font-medium\"\r\n            title=\"XuГҹв•‘Г‘t Excel\"\r\n          >\r\n            вүЎЖ’ГҙГ‘ XuГҹв•‘Г‘t Excel\r\n          </button>\r\n          <button\r\n            onClick={() => { setShowImportModal(true); setImportFile(null); setImportResult(null) }}\r\n            className=\"px-3 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition text-sm font-medium\"\r\n            title=\"Import в”ҖГҰв•һГӯn tГҹв•—ВҪ Excel\"\r\n          >\r\n            вүЎЖ’ГҙГұ Import Excel\r\n          </button>\r\n          <Link\r\n            href=\"/dashboard/orders/new\"\r\n            className=\"px-4 py-2 bg-brand-500 text-white rounded-lg hover:bg-brand-600 transition text-sm font-medium\"\r\n          >\r\n            О“вӮ§ГІ TГҹв•‘Гӯo в”ҖГҰв•һГӯn hв”ңГЎng mГҹв•—Вўi\r\n          </Link>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Summary Cards */}\r\n      {stats && (\r\n        <div className=\"grid grid-cols-7 gap-3 mb-4\">\r\n          {summaryCards.map((card) => (\r\n            <button\r\n              key={card.label}\r\n              onClick={() => handleCardClick(card.statuses)}\r\n              className={`border rounded-xl p-3 text-left transition hover:shadow-md ${card.color}`}\r\n            >\r\n              <div className=\"flex items-center justify-between mb-1\">\r\n                <span className=\"text-lg\">{card.icon}</span>\r\n                <span className={`text-2xl font-bold ${card.textColor}`}>{card.count}</span>\r\n              </div>\r\n              <p className={`text-xs font-medium ${card.textColor}`}>{card.label}</p>\r\n            </button>\r\n          ))}\r\n        </div>\r\n      )}\r\n\r\n      {/* Search + Filter Bar */}\r\n      <div className=\"bg-white rounded-xl shadow-sm p-4 mb-4 space-y-3\">\r\n        {/* Search */}\r\n        <div className=\"relative\">\r\n          <input\r\n            type=\"text\"\r\n            value={searchQuery}\r\n            onChange={(e) => setSearchQuery(e.target.value)}\r\n            placeholder=\"вүЎЖ’Г¶Г¬ Tв”ңВјm kiГҹв•‘в”җm: tв”ңВ¬n KH, Sв”ҖГүT, mв”ңГә в”ҖГҰв•һГӯn, biГҹв•—Гўn sГҹв•—ГҰ xe...\"\r\n            className=\"w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500\"\r\n          />\r\n          {searchQuery && (\r\n            <button\r\n              onClick={() => setSearchQuery('')}\r\n              className=\"absolute right-3 top-2.5 text-gray-400 hover:text-gray-600 text-sm\"\r\n            >\r\n              О“ВЈГІ\r\n            </button>\r\n          )}\r\n        </div>\r\n\r\n        {/* Status Filter Tabs */}\r\n        {!isSearching && (\r\n          <div className=\"flex gap-2 flex-wrap\">\r\n            {['', 'draft', 'pending_customer_confirm', 'confirmed', 'pending_approval', 'in_transit', 'delivered', 'cancelled'].map((s) => (\r\n              <button\r\n                key={s}\r\n                onClick={() => setStatusFilter(s)}\r\n                className={`px-3 py-1.5 text-xs rounded-lg transition ${\r\n                  statusFilter === s\r\n                    ? 'bg-brand-500 text-white'\r\n                    : 'bg-gray-100 text-gray-600 hover:bg-gray-200'\r\n                }`}\r\n              >\r\n                {s === '' ? 'TГҹв•‘Г‘t cГҹв•‘Гә' : statusLabels[s] || s}\r\n              </button>\r\n            ))}\r\n          </div>\r\n        )}\r\n\r\n        {/* Advanced Filters: delivery date + cutoff group */}\r\n        {!isSearching && (\r\n          <div className=\"flex gap-2 flex-wrap items-center text-xs\">\r\n            <label className=\"flex items-center gap-1 text-gray-600\">\r\n              Ngв”ңГЎy giao\r\n              <input\r\n                type=\"date\"\r\n                value={deliveryDate}\r\n                onChange={(e) => setDeliveryDate(e.target.value)}\r\n                className=\"border border-gray-200 rounded px-2 py-1 text-xs\"\r\n              />\r\n            </label>\r\n            <label className=\"flex items-center gap-1 text-gray-600\">\r\n              Cut-off\r\n              <select\r\n                value={cutoffGroup}\r\n                onChange={(e) => setCutoffGroup(e.target.value)}\r\n                className=\"border border-gray-200 rounded px-2 py-1 text-xs bg-white\"\r\n              >\r\n                <option value=\"\">TГҹв•‘Г‘t cГҹв•‘Гә</option>\r\n                <option value=\"before_16h\">Trв•һв–‘Гҹв•—Вўc 16h (giao trong ngв”ңГЎy)</option>\r\n                <option value=\"after_16h\">Sau 16h (giao T+1)</option>\r\n              </select>\r\n            </label>\r\n            {(deliveryDate || cutoffGroup) && (\r\n              <button\r\n                onClick={() => { setDeliveryDate(''); setCutoffGroup('') }}\r\n                className=\"text-brand-600 hover:underline\"\r\n              >\r\n                Xв”ңв”Ӯa lГҹв•—Г¬c\r\n              </button>\r\n            )}\r\n          </div>\r\n        )}\r\n\r\n        {/* View Tabs: All / Exceptions / Re-delivery */}\r\n        <div className=\"flex gap-1 border-b border-gray-100\">\r\n          {([\r\n            { key: 'all', label: 'TГҹв•‘Г‘t cГҹв•‘Гә' },\r\n            { key: 'exceptions', label: 'О“ГңГЎвҲ©в••Г… NgoГҹв•‘Гӯi lГҹв•—Г§' },\r\n            { key: 'redelivery', label: 'вүЎЖ’Г¶ГӨ Giao lГҹв•‘Гӯi' },\r\n          ] as const).map((tab) => (\r\n            <button\r\n              key={tab.key}\r\n              onClick={() => setViewTab(tab.key)}\r\n              className={`px-4 py-2 text-xs font-medium transition border-b-2 -mb-px ${\r\n                viewTab === tab.key\r\n                  ? 'border-brand-500 text-brand-600'\r\n                  : 'border-transparent text-gray-500 hover:text-gray-700'\r\n              }`}\r\n            >\r\n              {tab.label}\r\n            </button>\r\n          ))}\r\n        </div>\r\n      </div>\r\n\r\n      {/* Orders Table О“ГҮГ¶ Enriched */}\r\n      <div className=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n        <table className=\"w-full text-sm\">\r\n          <thead className=\"bg-gray-50 text-gray-600\">\r\n            <tr>\r\n              <th className=\"text-left py-3 px-3\">SГҹв•—ГҰ в”ҖГҰв•һГӯn</th>\r\n              <th className=\"text-left py-3 px-3\">Khв”ңГӯch hв”ңГЎng</th>\r\n              <th className=\"text-left py-3 px-3\">Ngв”ңГЎy giao</th>\r\n              <th className=\"text-right py-3 px-3\">TГҹв•—ГІng tiГҹв•—Гјn</th>\r\n              <th className=\"text-center py-3 px-3\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n              <th className=\"text-left py-3 px-3\">Xe / Tв”ңГЎi xГҹв•‘в”җ</th>\r\n              <th className=\"text-center py-3 px-3\">Hв”ңГЎnh в”ҖГҰГҹв•—Г–ng</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody className=\"divide-y divide-gray-100\">\r\n            {loading ? (\r\n              <tr>\r\n                <td colSpan={7} className=\"py-8 text-center text-gray-400\">\r\n                  в”ҖГүang tГҹв•‘Гәi...\r\n                </td>\r\n              </tr>\r\n            ) : filteredOrders.length === 0 ? (\r\n              <tr>\r\n                <td colSpan={7} className=\"py-12 text-center\">\r\n                  <p className=\"text-gray-400 mb-2\">\r\n                    {viewTab === 'exceptions' ? 'О“ВЈГ  Khв”ңв”Өng cв”ңв”Ӯ в”ҖГҰв•һГӯn ngoГҹв•‘Гӯi lГҹв•—Г§ nв”ңГЎo О“ГҮГ¶ tГҹв•‘Г‘t cГҹв•‘Гә в”ҖГҰв•һГӯn в”ҖГҰang xГҹв•—ВЎ lв”ңв•ң bв”ңВјnh thв•һв–‘Гҹв•—ВҘng' :\r\n                     viewTab === 'redelivery' ? 'О“ВЈГ  Khв”ңв”Өng cв”ңв”Ӯ в”ҖГҰв•һГӯn giao bГҹв•—ГІ sung nв”ңГЎo' :\r\n                     isSearching ? `Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y kГҹв•‘в”җt quГҹв•‘Гә cho \"${searchQuery}\"` :\r\n                     'Chв•һв–‘a cв”ңв”Ӯ в”ҖГҰв•һГӯn hв”ңГЎng nв”ңГЎo О“ГҮГ¶ tГҹв•‘Гӯo в”ҖГҰв•һГӯn mГҹв•—Вўi tГҹв•—ВҪ nв”ңв•‘t \"+ TГҹв•‘Гӯo в”ҖГҰв•һГӯn\" phв”ңВЎa trв”ңВ¬n'}\r\n                  </p>\r\n                  {viewTab !== 'all' && (\r\n                    <button onClick={() => setViewTab('all')} className=\"text-brand-500 text-xs hover:underline\">\r\n                      Xem tГҹв•‘Г‘t cГҹв•‘Гә в”ҖГҰв•һГӯn hв”ңГЎng\r\n                    </button>\r\n                  )}\r\n                </td>\r\n              </tr>\r\n            ) : (\r\n              filteredOrders.map((order) => (\r\n                <tr key={order.id} className=\"hover:bg-gray-50\">\r\n                  <td className=\"py-3 px-3\">\r\n                    <div className=\"flex items-center gap-1\">\r\n                      {order.is_urgent && (\r\n                        <span className=\"inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-100 text-red-700\" title=\"Giao gГҹв•‘Г‘p\">О“ГңГӯ GГҹв•‘Г‘p</span>\r\n                      )}\r\n                      <Link href={`/dashboard/orders/${order.id}`} className=\"font-mono text-xs text-blue-600 hover:underline\">\r\n                        {order.order_number}\r\n                      </Link>\r\n                    </div>\r\n                  </td>\r\n                  <td className=\"py-3 px-3\">\r\n                    <button onClick={() => openCustomerSidebar(order.customer_id)}\r\n                      className=\"text-sm text-blue-600 hover:underline text-left\">{order.customer_name}</button>\r\n                    {order.customer_phone && (\r\n                      <div className=\"text-xs text-gray-400\">{order.customer_phone}</div>\r\n                    )}\r\n                  </td>\r\n                  <td className=\"py-3 px-3 text-xs\">{order.delivery_date}</td>\r\n                  <td className=\"py-3 px-3 text-right text-xs font-medium\">{formatVND(order.total_amount)}</td>\r\n                  <td className=\"py-3 px-3 text-center\">\r\n                    <StatusChip status={order.status} role={currentUser?.role} />\r\n                  </td>\r\n                  <td className=\"py-3 px-3\">\r\n                    {order.vehicle_plate || order.driver_name ? (\r\n                      <div>\r\n                        {order.vehicle_plate && <div className=\"text-xs font-mono\">{order.vehicle_plate}</div>}\r\n                        {order.driver_name && <div className=\"text-xs text-gray-500\">{order.driver_name}</div>}\r\n                      </div>\r\n                    ) : (\r\n                      <span className=\"text-xs text-gray-300\">О“ГҮГ¶</span>\r\n                    )}\r\n                  </td>\r\n                  <td className=\"py-3 px-3 text-center space-x-1\">\r\n                    <Link\r\n                      href={`/dashboard/orders/${order.id}`}\r\n                      className=\"text-blue-600 hover:underline text-xs\"\r\n                    >\r\n                      Chi tiГҹв•‘в”җt\r\n                    </Link>\r\n                    {['draft', 'confirmed', 'pending_approval'].includes(order.status) && (\r\n                      <Link\r\n                        href={`/dashboard/orders/${order.id}/edit`}\r\n                        className=\"text-brand-600 hover:underline text-xs\"\r\n                      >\r\n                        SГҹв•—ВЎa\r\n                      </Link>\r\n                    )}\r\n                    {order.status === 'pending_approval' && (\r\n                      <button\r\n                        onClick={() => handleApprove(order.id)}\r\n                        className=\"text-green-600 hover:underline text-xs\"\r\n                      >\r\n                        DuyГҹв•—Г§t\r\n                      </button>\r\n                    )}\r\n                    {['draft', 'confirmed', 'pending_approval'].includes(order.status) && (\r\n                      <button\r\n                        onClick={() => handleCancel(order.id)}\r\n                        className=\"text-red-600 hover:underline text-xs\"\r\n                      >\r\n                        HГҹв•—Вәy\r\n                      </button>\r\n                    )}\r\n                  </td>\r\n                </tr>\r\n              ))\r\n            )}\r\n          </tbody>\r\n        </table>\r\n\r\n        {/* Footer: pagination */}\r\n        {!loading && totalRows > 0 && !isSearching && (\r\n          <Pagination\r\n            page={page}\r\n            limit={limit}\r\n            total={totalRows}\r\n            onPageChange={setPage}\r\n            onLimitChange={(n) => { setLimit(n); setPage(1) }}\r\n            className=\"border-t bg-gray-50\"\r\n          />\r\n        )}\r\n        {/* When searching, just show simple count */}\r\n        {!loading && filteredOrders.length > 0 && isSearching && (\r\n          <div className=\"px-4 py-2 bg-gray-50 text-xs text-gray-500 border-t\">\r\n            HiГҹв•—Гўn thГҹв•—ГҜ {filteredOrders.length} kГҹв•‘в”җt quГҹв•‘Гә tв”ңВјm kiГҹв•‘в”җm\r\n          </div>\r\n        )}\r\n      </div>\r\n\r\n      {/* Customer Context Sidebar (slide-in) */}\r\n      {(sidebarCustomer || sidebarLoading) && (\r\n        <div className=\"fixed inset-0 z-40 flex justify-end\">\r\n          <div className=\"absolute inset-0 bg-black/20\" onClick={() => { setSidebarCustomer(null); setSidebarLoading(false) }} />\r\n          <div className=\"relative w-96 bg-white shadow-xl overflow-y-auto animate-slide-in-right\">\r\n            <div className=\"sticky top-0 bg-white border-b p-4 flex items-center justify-between z-10\">\r\n              <h3 className=\"font-bold text-lg\">вүЎЖ’Г…В¬ Thв”ңв”Өng tin khв”ңГӯch hв”ңГЎng</h3>\r\n              <button onClick={() => { setSidebarCustomer(null); setSidebarLoading(false) }} className=\"text-gray-400 hover:text-gray-600 text-xl\">в”ңГ№</button>\r\n            </div>\r\n            {sidebarLoading ? (\r\n              <div className=\"flex justify-center py-20\">\r\n                <div className=\"animate-spin rounded-full h-8 w-8 border-b-2 border-brand-500\" />\r\n              </div>\r\n            ) : sidebarCustomer && (\r\n              <div className=\"p-4 space-y-4\">\r\n                {/* Customer info + Health Score hero */}\r\n                <div className=\"space-y-2\">\r\n                  <div className=\"flex items-start justify-between gap-2\">\r\n                    <div>\r\n                      <div className=\"text-xl font-bold\">{sidebarCustomer.name}</div>\r\n                      <div className=\"text-sm text-gray-500\">{sidebarCustomer.code}</div>\r\n                    </div>\r\n                    {/* F2: NPP Health Score badge */}\r\n                    {sidebarHealth ? (\r\n                      <div className={`flex flex-col items-center px-3 py-1.5 rounded-xl border ${\r\n                        sidebarHealth.score >= 70 ? 'bg-emerald-50 border-emerald-200' :\r\n                        sidebarHealth.score >= 40 ? 'bg-amber-50 border-amber-200' :\r\n                        'bg-red-50 border-red-200'\r\n                      }`}>\r\n                        <span className={`text-xl font-bold leading-none ${\r\n                          sidebarHealth.score >= 70 ? 'text-emerald-700' :\r\n                          sidebarHealth.score >= 40 ? 'text-amber-700' : 'text-red-700'\r\n                        }`}>{sidebarHealth.score}</span>\r\n                        <span className=\"text-[9px] font-semibold uppercase tracking-wide mt-0.5 text-gray-500\">Health</span>\r\n                      </div>\r\n                    ) : (\r\n                      <div className=\"flex flex-col items-center px-3 py-1.5 rounded-xl border border-dashed border-gray-200 bg-gray-50\">\r\n                        <span className=\"text-xl leading-none text-gray-300\">О“ГҮГ¶</span>\r\n                        <span className=\"text-[9px] font-semibold uppercase tracking-wide mt-0.5 text-gray-400\">Score</span>\r\n                      </div>\r\n                    )}\r\n                  </div>\r\n                  {sidebarCustomer.phone && <div className=\"text-sm\">вүЎЖ’ГҙвӮ§ {sidebarCustomer.phone}</div>}\r\n                  {sidebarCustomer.address && <div className=\"text-sm text-gray-600\">вүЎЖ’ГҙГ¬ {sidebarCustomer.address}</div>}\r\n                </div>\r\n\r\n                {/* F2: Churn risk detail */}\r\n                {sidebarHealth && sidebarHealth.score < 40 && (\r\n                  <div className=\"flex items-center gap-2 text-xs text-red-700 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\r\n                    <span className=\"text-base\">вүЎЖ’ГңВҝ</span>\r\n                    <div>\r\n                      <p className=\"font-semibold\">Nguy cв•һГӯ rГҹв•—ВҘi bГҹв•—Г… cao</p>\r\n                      <p className=\"text-red-500\">{sidebarHealth.recency_days ? `Im lГҹв•‘в•–ng ${sidebarHealth.recency_days} ngв”ңГЎy О“ГҮГ¶ ` : ''}в”ҖГүiГҹв•—Гўm giГҹв•‘Гәm {sidebarHealth.score_drop_7d || 0} trong 7 ngв”ңГЎy</p>\r\n                    </div>\r\n                  </div>\r\n                )}\r\n                {sidebarHealth && sidebarHealth.score >= 40 && sidebarHealth.score < 70 && (\r\n                  <div className=\"flex items-center gap-2 text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2\">\r\n                    <span className=\"text-base\">О“ГңГЎвҲ©в••Г…</span>\r\n                    <p>NPP cГҹв•‘Вәn theo dв”ңв•Ўi О“ГҮГ¶ hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng giГҹв•‘Гәm so vГҹв•—Вўi trung bв”ңВјnh</p>\r\n                  </div>\r\n                )}\r\n                {sidebarCustomer.credit_limit != null && (\r\n                  <div className=\"bg-gray-50 rounded-lg p-3 space-y-2\">\r\n                    <h4 className=\"text-sm font-medium\">вүЎЖ’ГҶв–‘ HГҹв•‘Гӯn mГҹв•—вҢҗc tв”ңВЎn dГҹв•—Г‘ng</h4>\r\n                    <div className=\"flex justify-between text-sm\">\r\n                      <span className=\"text-gray-500\">HГҹв•‘Гӯn mГҹв•—вҢҗc</span>\r\n                      <span className=\"font-medium\">{formatVND(sidebarCustomer.credit_limit)}</span>\r\n                    </div>\r\n                    <div className=\"flex justify-between text-sm\">\r\n                      <span className=\"text-gray-500\">в”ҖГүв”ңГә dв”ңв•Јng</span>\r\n                      <span className=\"font-medium text-red-600\">{formatVND(sidebarCustomer.current_balance || 0)}</span>\r\n                    </div>\r\n                    <div className=\"flex justify-between text-sm\">\r\n                      <span className=\"text-gray-500\">Cв”ңв–“n lГҹв•‘Гӯi</span>\r\n                      <span className=\"font-medium text-green-600\">\r\n                        {formatVND((sidebarCustomer.credit_limit || 0) - (sidebarCustomer.current_balance || 0))}\r\n                      </span>\r\n                    </div>\r\n                    <div className=\"bg-gray-200 rounded-full h-2 overflow-hidden\">\r\n                      <div className={`h-full ${(sidebarCustomer.current_balance / sidebarCustomer.credit_limit) > 0.8 ? 'bg-red-500' : 'bg-green-500'}`}\r\n                        style={{ width: `${Math.min(100, (sidebarCustomer.current_balance || 0) / Math.max(sidebarCustomer.credit_limit, 1) * 100)}%` }} />\r\n                    </div>\r\n                  </div>\r\n                )}\r\n\r\n                {/* F1: Demand Intelligence */}\r\n                <div className=\"rounded-xl border border-gray-100 overflow-hidden\">\r\n                  <div className=\"flex items-center justify-between px-3 py-2 bg-gradient-to-r from-blue-50 to-indigo-50 border-b border-gray-100\">\r\n                    <div className=\"flex items-center gap-1.5 text-xs font-semibold text-blue-700\">\r\n                      <span>вүЎЖ’Г¶В«</span> DГҹв•—в–’ bв”ңГӯo nhu cГҹв•‘Вәu tuГҹв•‘Вәn tГҹв•—Вўi\r\n                    </div>\r\n                    {sidebarForecast.length === 0 && (\r\n                      <span className=\"text-[10px] text-blue-400 bg-blue-100 px-1.5 py-0.5 rounded-full\">SГҹв•‘В»p ra mГҹв•‘В»t</span>\r\n                    )}\r\n                  </div>\r\n                  {sidebarForecast.length > 0 ? (\r\n                    <div className=\"divide-y divide-gray-50\">\r\n                      {sidebarForecast.map((item: any) => (\r\n                        <div key={item.sku_id} className=\"flex items-center justify-between px-3 py-2\">\r\n                          <span className=\"text-xs text-gray-700 truncate flex-1 pr-2\">{item.sku_name}</span>\r\n                          <div className=\"flex items-center gap-1.5 shrink-0\">\r\n                            <span className=\"text-xs font-bold text-brand-600\">~{item.predicted_qty} {item.unit}</span>\r\n                            {item.delta_pct !== undefined && (\r\n                              <span className={`text-[10px] font-semibold px-1 rounded ${\r\n                                item.delta_pct > 0 ? 'text-emerald-700 bg-emerald-50' : 'text-red-600 bg-red-50'\r\n                              }`}>\r\n                                {item.delta_pct > 0 ? 'О“ГҘГҰ' : 'О“ГҘГҙ'}{Math.abs(item.delta_pct)}%\r\n                              </span>\r\n                            )}\r\n                          </div>\r\n                        </div>\r\n                      ))}\r\n                    </div>\r\n                  ) : (\r\n                    <div className=\"px-3 py-4 text-center text-xs text-gray-400 space-y-1\">\r\n                      <p>Demand AI в”ҖГҰang hГҹв•—Г¬c tГҹв•—ВҪ lГҹв•—ГҜch sГҹв•—ВЎ в”ҖГҰв•һГӯn hв”ңГЎng</p>\r\n                      <p className=\"text-[10px] text-gray-300\">SГҹв•‘в•ң hiГҹв•—Гўn thГҹв•—ГҜ sau khi module AI Demand khГҹв•—Ж’i в”ҖГҰГҹв•—Г–ng</p>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n\r\n                {/* Order history */}\r\n                <div>\r\n                  <h4 className=\"text-sm font-medium mb-2\">вүЎЖ’ГҙГҜ в”ҖГүв•һГӯn hв”ңГЎng gГҹв•‘Вәn в”ҖГҰв”ңГіy ({sidebarOrders.length})</h4>\r\n                  {sidebarOrders.length === 0 ? (\r\n                    <p className=\"text-sm text-gray-400\">Chв•һв–‘a cв”ңв”Ӯ в”ҖГҰв•һГӯn hв”ңГЎng nв”ңГЎo</p>\r\n                  ) : (\r\n                    <div className=\"space-y-2\">\r\n                      {sidebarOrders.map(o => (\r\n                        <Link key={o.id} href={`/dashboard/orders/${o.id}`}\r\n                          className=\"block bg-gray-50 rounded-lg p-2 hover:bg-gray-100 transition\">\r\n                          <div className=\"flex justify-between items-center\">\r\n                            <span className=\"text-xs font-mono text-blue-600\">{o.order_number}</span>\r\n                            <span className={`px-1.5 py-0.5 rounded text-xs ${statusColors[o.status] || 'bg-gray-100'}`}>\r\n                              {statusLabels[o.status] || o.status}\r\n                            </span>\r\n                          </div>\r\n                          <div className=\"flex justify-between text-xs text-gray-500 mt-1\">\r\n                            <span>{o.delivery_date}</span>\r\n                            <span>{formatVND(o.total_amount)}</span>\r\n                          </div>\r\n                        </Link>\r\n                      ))}\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Import Excel Modal */}\r\n      {showImportModal && (\r\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center\">\r\n          <div className=\"absolute inset-0 bg-black/30\" onClick={() => setShowImportModal(false)} />\r\n          <div className=\"relative bg-white rounded-2xl shadow-xl w-full max-w-lg p-6\">\r\n            <div className=\"flex items-center justify-between mb-4\">\r\n              <h2 className=\"text-lg font-bold\">вүЎЖ’ГҙГұ Import в”ҖГҰв•һГӯn hв”ңГЎng tГҹв•—ВҪ Excel</h2>\r\n              <button onClick={() => setShowImportModal(false)} className=\"text-gray-400 hover:text-gray-600 text-xl\">в”ңГ№</button>\r\n            </div>\r\n\r\n            <div className=\"space-y-4\">\r\n              {/* Template download */}\r\n              <div className=\"bg-blue-50 border border-blue-200 rounded-lg p-3\">\r\n                <p className=\"text-sm text-blue-700 mb-2\">TГҹв•‘Гәi file mГҹв•‘ВҪu в”ҖГҰГҹв•—Гў biГҹв•‘в”җt в”ҖГҰв”ңв•‘ng в”ҖГҰГҹв•—ГҜnh dГҹв•‘Гӯng import:</p>\r\n                <button\r\n                  onClick={handleDownloadTemplate}\r\n                  className=\"text-sm text-blue-600 hover:underline font-medium\"\r\n                >\r\n                  вүЎЖ’ГҙГӨ TГҹв•‘Гәi file mГҹв•‘ВҪu (.xlsx)\r\n                </button>\r\n              </div>\r\n\r\n              {/* File upload */}\r\n              <div>\r\n                <label className=\"block text-sm font-medium text-gray-700 mb-1\">ChГҹв•—Г¬n file Excel</label>\r\n                <input\r\n                  type=\"file\"\r\n                  accept=\".xlsx,.xls\"\r\n                  onChange={(e) => setImportFile(e.target.files?.[0] || null)}\r\n                  className=\"w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-brand-500 file:text-white hover:file:bg-brand-600\"\r\n                />\r\n              </div>\r\n\r\n              {/* Import result */}\r\n              {importResult && (\r\n                <div className={`rounded-lg p-3 text-sm ${importResult.error_count > 0 ? 'bg-red-50 border border-red-200' : 'bg-green-50 border border-green-200'}`}>\r\n                  <p className=\"font-medium mb-1\">\r\n                    KГҹв•‘в”җt quГҹв•‘Гә: {importResult.success_count}/{importResult.total_rows} dв”ңв–“ng thв”ңГЎnh cв”ңв”Өng\r\n                  </p>\r\n                  {importResult.errors?.length > 0 && (\r\n                    <div className=\"mt-2 max-h-40 overflow-y-auto space-y-1\">\r\n                      {importResult.errors.map((err: any, i: number) => (\r\n                        <p key={i} className=\"text-xs text-red-600\">\r\n                          Dв”ңв–“ng {err.row}, cГҹв•—Г–t &quot;{err.column}&quot;: {err.message}\r\n                          {err.value && <span className=\"text-gray-500\"> (giв”ңГӯ trГҹв•—ГҜ: {err.value})</span>}\r\n                        </p>\r\n                      ))}\r\n                    </div>\r\n                  )}\r\n                  {importResult.orders?.length > 0 && (\r\n                    <div className=\"mt-2\">\r\n                      <p className=\"text-xs text-green-700 font-medium\">в”ҖГүв•һГӯn в”ҖГҰв”ңГә tГҹв•‘Гӯo:</p>\r\n                      {importResult.orders.map((o: any, i: number) => (\r\n                        <p key={i} className=\"text-xs text-green-600\">{o.order_number} О“ГҮГ¶ {o.customer_code}</p>\r\n                      ))}\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              )}\r\n\r\n              {/* Actions */}\r\n              <div className=\"flex justify-end gap-2\">\r\n                <button\r\n                  onClick={() => setShowImportModal(false)}\r\n                  className=\"px-4 py-2 text-sm text-gray-600 hover:text-gray-800\"\r\n                >\r\n                  в”ҖГүв”ңв”Ӯng\r\n                </button>\r\n                <button\r\n                  onClick={handleImport}\r\n                  disabled={!importFile || importing}\r\n                  className=\"px-4 py-2 bg-brand-500 text-white rounded-lg hover:bg-brand-600 transition text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed\"\r\n                >\r\n                  {importing ? 'в”ҖГүang import...' : 'вүЎЖ’ГҙГұ Import'}\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":87,"column":14,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":87,"endColumn":17,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2692,2695],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2692,2695],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\n/**\r\n * Dashboard root О“ГҮГ¶ role-aware home with KPI tiles + workflow next-steps.\r\n *\r\n * Reference: UX_AUDIT_REPORT.md в”¬Вә2 (Dashboard root redesign)\r\n *\r\n * UX features:\r\n *  - Greeting \"Chв”ңГЎo buГҹв•—ГІi sв”ңГӯng, {name}\" personalized\r\n *  - 4-5 KPI tiles via KpiCard primitive (no emoji, real icons)\r\n *  - \"ViГҹв•—Г§c cГҹв•‘Вәn lв”ңГЎm hв”ңв”Өm nay\" priority list (role-specific quick actions)\r\n *  - Quy trв”ңВјnh nghiГҹв•—Г§p vГҹв•—Г‘ as numbered horizontal steps with hover description\r\n *  - Skeleton loading state\r\n */\r\n\r\nimport { useEffect, useMemo, useState } from 'react'\r\nimport { useRouter } from 'next/navigation'\r\nimport {\r\n  ClipboardList, Package, Truck, Beer, Store, ClockArrowDown, AlertTriangle,\r\n  CircleDollarSign, BarChart3, ArrowRight, Sparkles, type LucideIcon,\r\n} from 'lucide-react'\r\nimport { apiFetch, getUser } from '@/lib/api'\r\nimport { formatVND } from '@/lib/status-config'\r\nimport { handleError } from '@/lib/handleError'\r\nimport { PageHeader } from '@/components/ui/PageHeader'\r\nimport { KpiCard } from '@/components/ui/KpiCard'\r\nimport { Card, CardHeader } from '@/components/ui/Card'\r\nimport { SkeletonGrid } from '@/components/ui/Skeleton'\r\n\r\ninterface Stats {\r\n  total_orders: number\r\n  orders_today: number\r\n  orders_confirmed: number\r\n  pending_shipments: number\r\n  active_trips: number\r\n  completed_trips_today: number\r\n  delivery_rate: number\r\n  revenue_today: number\r\n  pending_discrepancies: number\r\n  pending_approvals: number\r\n  total_products: number\r\n  total_customers: number\r\n}\r\n\r\ntype CardCfg = {\r\n  label: string\r\n  value: React.ReactNode\r\n  icon: LucideIcon\r\n  tone: 'brand' | 'info' | 'success' | 'warning' | 'danger' | 'neutral'\r\n  href: string\r\n  hint?: string\r\n  pulse?: boolean\r\n}\r\n\r\nfunction greeting() {\r\n  const h = new Date().getHours()\r\n  if (h < 11) return { period: 'sв”ңГӯng', emoji: 'О“ГҝГҮвҲ©в••Г…' }\r\n  if (h < 14) return { period: 'trв•һв–‘a', emoji: 'вүЎЖ’Г®ГұвҲ©в••Г…' }\r\n  if (h < 18) return { period: 'chiГҹв•—Гјu', emoji: 'вүЎЖ’Г®Г ' }\r\n  return { period: 'tГҹв•—ГҰi', emoji: 'вүЎЖ’Г®Г–' }\r\n}\r\n\r\nconst ROLE_LABEL: Record<string, string> = {\r\n  admin: 'QuГҹв•‘Гәn trГҹв•—ГҜ viв”ңВ¬n',\r\n  dispatcher: 'в”ҖГүiГҹв•—Гјu phГҹв•—ГҰi viв”ңВ¬n',\r\n  accountant: 'KГҹв•‘в”җ toв”ңГӯn',\r\n  dvkh: 'DГҹв•—ГҜch vГҹв•—Г‘ khв”ңГӯch hв”ңГЎng',\r\n  management: 'Ban giв”ңГӯm в”ҖГҰГҹв•—ГҰc',\r\n  warehouse_handler: 'ThГҹв•—Вә kho',\r\n  security: 'BГҹв•‘Гәo vГҹв•—Г§',\r\n  workshop: 'TГҹв•—ГІ vГҹв•—Г…',\r\n}\r\n\r\nexport default function DashboardPage() {\r\n  const router = useRouter()\r\n  const [stats, setStats] = useState<Stats | null>(null)\r\n  const [loading, setLoading] = useState(true)\r\n  const [user, setUser] = useState<{ full_name?: string; role?: string } | null>(null)\r\n\r\n  useEffect(() => {\r\n    const u = getUser()\r\n    if (u?.role === 'driver') {\r\n      router.replace('/dashboard/driver')\r\n      return\r\n    }\r\n    setUser(u)\r\n    apiFetch<any>('/dashboard/stats')\r\n      .then((res) => setStats(res.data))\r\n      .catch((err) => handleError(err, { userMessage: 'Khв”ңв”Өng tГҹв•‘Гәi в”ҖГҰв•һв–‘Гҹв•—Гәc sГҹв•—ГҰ liГҹв•—Г§u tГҹв•—ГІng quan' }))\r\n      .finally(() => setLoading(false))\r\n  }, [router])\r\n\r\n  const role = user?.role || ''\r\n  const { period, emoji } = greeting()\r\n\r\n  const cards: CardCfg[] = useMemo(() => {\r\n    const base: CardCfg = {\r\n      label: 'TГҹв•—ГІng в”ҖГҰв•һГӯn hв”ңГЎng', value: stats?.total_orders ?? 'О“ГҮГ¶',\r\n      icon: ClipboardList, tone: 'info', href: '/dashboard/orders',\r\n      hint: stats ? `${stats.orders_today} mГҹв•—Вўi hв”ңв”Өm nay` : undefined,\r\n    }\r\n    if (['admin', 'dispatcher'].includes(role)) {\r\n      return [\r\n        base,\r\n        { label: 'в”ҖГүв•һГӯn chГҹв•—ВҘ giao', value: stats?.pending_shipments ?? 'О“ГҮГ¶', icon: Package, tone: 'warning', href: '/dashboard/orders?status=confirmed' },\r\n        { label: 'ChuyГҹв•‘в”җn в”ҖГҰang chГҹв•‘Гӯy', value: stats?.active_trips ?? 'О“ГҮГ¶', icon: Truck, tone: 'success', href: '/dashboard/trips', hint: stats ? `Hoв”ңГЎn tГҹв•‘Г‘t hв”ңв”Өm nay: ${stats.completed_trips_today}` : undefined },\r\n        { label: 'SГҹв•‘Гәn phГҹв•‘вҢҗm', value: stats?.total_products ?? 'О“ГҮГ¶', icon: Beer, tone: 'brand', href: '/dashboard/products' },\r\n        { label: 'Khв”ңГӯch hв”ңГЎng (NPP)', value: stats?.total_customers ?? 'О“ГҮГ¶', icon: Store, tone: 'neutral', href: '/dashboard/customers' },\r\n      ]\r\n    }\r\n    if (role === 'accountant') {\r\n      const overdue = (stats?.pending_approvals ?? 0) > 0\r\n      return [\r\n        base,\r\n        { label: 'в”ҖГүв•һГӯn chГҹв•—ВҘ duyГҹв•—Г§t', value: stats?.pending_approvals ?? 'О“ГҮГ¶', icon: ClockArrowDown, tone: overdue ? 'danger' : 'warning', href: '/dashboard/approvals', hint: 'T+1 SLA', pulse: overdue },\r\n        { label: 'Sai lГҹв•—Г§ch chв•һв–‘a xГҹв•—ВЎ lв”ңв•ң', value: stats?.pending_discrepancies ?? 'О“ГҮГ¶', icon: AlertTriangle, tone: 'danger', href: '/dashboard/reconciliation' },\r\n        { label: 'Doanh thu hв”ңв”Өm nay', value: formatVND(stats?.revenue_today ?? 0), icon: CircleDollarSign, tone: 'success', href: '/dashboard/reconciliation/daily-close' },\r\n        { label: 'ChuyГҹв•‘в”җn в”ҖГҰang chГҹв•‘Гӯy', value: stats?.active_trips ?? 'О“ГҮГ¶', icon: Truck, tone: 'info', href: '/dashboard/trips' },\r\n      ]\r\n    }\r\n    if (role === 'dvkh') {\r\n      return [\r\n        base,\r\n        { label: 'в”ҖГүв•һГӯn chГҹв•—ВҘ giao', value: stats?.pending_shipments ?? 'О“ГҮГ¶', icon: Package, tone: 'warning', href: '/dashboard/orders?status=confirmed' },\r\n        { label: 'SГҹв•‘Гәn phГҹв•‘вҢҗm', value: stats?.total_products ?? 'О“ГҮГ¶', icon: Beer, tone: 'brand', href: '/dashboard/products' },\r\n        { label: 'Khв”ңГӯch hв”ңГЎng (NPP)', value: stats?.total_customers ?? 'О“ГҮГ¶', icon: Store, tone: 'neutral', href: '/dashboard/customers' },\r\n      ]\r\n    }\r\n    if (role === 'management') {\r\n      return [\r\n        { label: 'Doanh thu hв”ңв”Өm nay', value: formatVND(stats?.revenue_today ?? 0), icon: CircleDollarSign, tone: 'success', href: '/dashboard/kpi' },\r\n        { label: 'TГҹв•—в•– lГҹв•—Г§ giao thв”ңГЎnh cв”ңв”Өng', value: stats?.delivery_rate ? `${stats.delivery_rate.toFixed(1)}%` : 'О“ГҮГ¶', icon: BarChart3, tone: 'info', href: '/dashboard/kpi' },\r\n        { label: 'ChuyГҹв•‘в”җn в”ҖГҰang chГҹв•‘Гӯy', value: stats?.active_trips ?? 'О“ГҮГ¶', icon: Truck, tone: 'brand', href: '/dashboard/trips' },\r\n        { label: 'Sai lГҹв•—Г§ch chв•һв–‘a xГҹв•—ВЎ lв”ңв•ң', value: stats?.pending_discrepancies ?? 'О“ГҮГ¶', icon: AlertTriangle, tone: 'danger', href: '/dashboard/reconciliation' },\r\n        { label: 'Khв”ңГӯch hв”ңГЎng (NPP)', value: stats?.total_customers ?? 'О“ГҮГ¶', icon: Store, tone: 'neutral', href: '/dashboard/customers' },\r\n      ]\r\n    }\r\n    return [\r\n      base,\r\n      { label: 'в”ҖГүв•һГӯn chГҹв•—ВҘ giao', value: stats?.pending_shipments ?? 'О“ГҮГ¶', icon: Package, tone: 'warning', href: '/dashboard/orders?status=confirmed' },\r\n      { label: 'ChuyГҹв•‘в”җn в”ҖГҰang chГҹв•‘Гӯy', value: stats?.active_trips ?? 'О“ГҮГ¶', icon: Truck, tone: 'success', href: '/dashboard/trips' },\r\n      { label: 'SГҹв•‘Гәn phГҹв•‘вҢҗm', value: stats?.total_products ?? 'О“ГҮГ¶', icon: Beer, tone: 'brand', href: '/dashboard/products' },\r\n      { label: 'Khв”ңГӯch hв”ңГЎng (NPP)', value: stats?.total_customers ?? 'О“ГҮГ¶', icon: Store, tone: 'neutral', href: '/dashboard/customers' },\r\n    ]\r\n  }, [stats, role])\r\n\r\n  // Workflow steps\r\n  const workflow = [\r\n    { n: 1, label: 'TГҹв•‘Гӯo в”ҖГҰв•һГӯn', desc: 'NhГҹв•‘ВЎp в”ҖГҰв•һГӯn hв”ңГЎng tГҹв•—ВҪ NPP', href: '/dashboard/orders/new', tone: 'bg-sky-50 text-sky-700 ring-sky-200' },\r\n    { n: 2, label: 'KiГҹв•—Гўm tra ATP', desc: 'HГҹв•‘Гӯn mГҹв•—вҢҗc nГҹв•—Гә + tГҹв•—Гҙn kho', href: '/dashboard/orders/new', tone: 'bg-amber-50 text-amber-700 ring-amber-200' },\r\n    { n: 3, label: 'LГҹв•‘ВЎp kГҹв•‘в”җ hoГҹв•‘Гӯch', desc: 'VRP gom chuyГҹв•‘в”җn tГҹв•—ГҰi в•һв–‘u', href: '/dashboard/planning', tone: 'bg-emerald-50 text-emerald-700 ring-emerald-200' },\r\n    { n: 4, label: 'Theo dв”ңв•Ўi chuyГҹв•‘в”җn', desc: 'BГҹв•‘Гәn в”ҖГҰГҹв•—Гҙ + GPS realtime', href: '/dashboard/trips', tone: 'bg-violet-50 text-violet-700 ring-violet-200' },\r\n    { n: 5, label: 'в”ҖГүГҹв•—ГҰi soв”ңГӯt', desc: 'Sai lГҹв•—Г§ch + chГҹв•—ГҰt sГҹв•—ГІ T+1', href: '/dashboard/reconciliation', tone: 'bg-rose-50 text-rose-700 ring-rose-200' },\r\n  ]\r\n\r\n  return (\r\n    <div className=\"max-w-[1400px] mx-auto\">\r\n      <PageHeader\r\n        title={`Chв”ңГЎo buГҹв•—ГІi ${period} ${emoji}, ${user?.full_name?.split(' ').slice(-1)[0] || 'bГҹв•‘Гӯn'}`}\r\n        subtitle={role ? `BГҹв•‘Гәng в”ҖГҰiГҹв•—Гјu khiГҹв•—Гўn О“ГҮГ¶ ${ROLE_LABEL[role] ?? role}` : 'BГҹв•‘Гәng в”ҖГҰiГҹв•—Гјu khiГҹв•—Гўn'}\r\n      />\r\n\r\n      {/* KPI tiles */}\r\n      {loading ? (\r\n        <SkeletonGrid count={5} cols={4} />\r\n      ) : (\r\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-4 mb-8\">\r\n          {cards.map((c) => (\r\n            <KpiCard\r\n              key={c.label}\r\n              label={c.label}\r\n              value={c.value}\r\n              icon={c.icon}\r\n              tone={c.tone}\r\n              href={c.href}\r\n              hint={c.hint}\r\n              pulse={c.pulse}\r\n            />\r\n          ))}\r\n        </div>\r\n      )}\r\n\r\n      {/* Workflow */}\r\n      <Card variant=\"default\" padding=\"lg\" className=\"mb-6\">\r\n        <CardHeader\r\n          title=\"Quy trв”ңВјnh nghiГҹв•—Г§p vГҹв•—Г‘\"\r\n          subtitle=\"BГҹв•‘Г‘m vв”ңГЎo tГҹв•—ВҪng bв•һв–‘Гҹв•—Вўc в”ҖГҰГҹв•—Гў chuyГҹв•—Гўn в”ҖГҰГҹв•‘в”җn mв”ңГЎn hв”ңВјnh tв•һв–‘в•һГӯng Гҹв•—вҢҗng\"\r\n          action={\r\n            <span className=\"inline-flex items-center gap-1.5 text-xs text-brand-700 bg-brand-50 px-2.5 py-1 rounded-full ring-1 ring-brand-100\">\r\n              <Sparkles className=\"h-3 w-3\" /> Hв•һв–‘Гҹв•—Вўng dГҹв•‘ВҪn nhanh\r\n            </span>\r\n          }\r\n        />\r\n        <ol className=\"grid grid-cols-2 md:grid-cols-5 gap-3\">\r\n          {workflow.map((s, i) => (\r\n            <li key={s.n} className=\"relative\">\r\n              <button\r\n                onClick={() => router.push(s.href)}\r\n                className={`group w-full text-left p-3 rounded-xl ring-1 ${s.tone} hover:shadow-md hover:-translate-y-0.5 transition`}\r\n              >\r\n                <div className=\"flex items-center justify-between mb-1.5\">\r\n                  <span className=\"grid h-7 w-7 place-items-center rounded-full bg-white/80 text-xs font-bold tabular-nums\">\r\n                    {s.n}\r\n                  </span>\r\n                  <ArrowRight className=\"h-3.5 w-3.5 opacity-0 group-hover:opacity-100 transition\" />\r\n                </div>\r\n                <p className=\"text-sm font-semibold\">{s.label}</p>\r\n                <p className=\"text-xs opacity-70 mt-0.5\">{s.desc}</p>\r\n              </button>\r\n              {i < workflow.length - 1 && (\r\n                <div className=\"hidden md:block absolute top-1/2 -right-2 -translate-y-1/2 text-slate-300 pointer-events-none\" aria-hidden>\r\n                  <ArrowRight className=\"h-3 w-3\" />\r\n                </div>\r\n              )}\r\n            </li>\r\n          ))}\r\n        </ol>\r\n      </Card>\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Beer HL\\bhl-oms\\web\\src\\app\\dashboard\\pda-scanner\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'getUser' is defined but never used.","line":5,"column":20,"nodeType":null,"messageId":"unusedVar","endLine":5,"endColumn":27},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":60,"column":18,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":60,"endColumn":21,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1864,1867],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1864,1867],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":74,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":74,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2486,2489],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2486,2489],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":98,"column":43,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":98,"endColumn":46,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3128,3131],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3128,3131],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useRef, useState, useCallback } from 'react'\r\nimport Link from 'next/link'\r\nimport { apiFetch, getUser } from '@/lib/api'\r\n\r\ninterface ScanResult {\r\n  barcode: string\r\n  product_name: string\r\n  product_sku: string\r\n  lot_number: string | null\r\n  quantity: number\r\n  scanned_at: string\r\n}\r\n\r\nexport default function PDABarcodeScannerPage() {\r\n  const videoRef = useRef<HTMLVideoElement>(null)\r\n  const canvasRef = useRef<HTMLCanvasElement>(null)\r\n  const [scanning, setScanning] = useState(false)\r\n  const [lastScan, setLastScan] = useState<ScanResult | null>(null)\r\n  const [scanHistory, setScanHistory] = useState<ScanResult[]>([])\r\n  const [manualInput, setManualInput] = useState('')\r\n  const [error, setError] = useState('')\r\n  const [cameraAvailable, setCameraAvailable] = useState(true)\r\n  const streamRef = useRef<MediaStream | null>(null)\r\n\r\n  const startCamera = useCallback(async () => {\r\n    try {\r\n      const stream = await navigator.mediaDevices.getUserMedia({\r\n        video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } }\r\n      })\r\n      streamRef.current = stream\r\n      if (videoRef.current) {\r\n        videoRef.current.srcObject = stream\r\n        await videoRef.current.play()\r\n      }\r\n      setScanning(true)\r\n      setCameraAvailable(true)\r\n    } catch {\r\n      setCameraAvailable(false)\r\n      setError('Khв”ңв”Өng thГҹв•—Гў truy cГҹв•‘ВЎp camera. Vui lв”ңв–“ng nhГҹв•‘ВЎp mв”ңГә barcode thГҹв•—Вә cв”ңв”Өng.')\r\n    }\r\n  }, [])\r\n\r\n  const stopCamera = useCallback(() => {\r\n    if (streamRef.current) {\r\n      streamRef.current.getTracks().forEach(t => t.stop())\r\n      streamRef.current = null\r\n    }\r\n    setScanning(false)\r\n  }, [])\r\n\r\n  useEffect(() => {\r\n    return () => { stopCamera() }\r\n  }, [stopCamera])\r\n\r\n  const lookupBarcode = async (barcode: string) => {\r\n    setError('')\r\n    try {\r\n      const res: any = await apiFetch('/warehouse/barcode-scan', {\r\n        method: 'POST',\r\n        body: JSON.stringify({ barcode: barcode.trim(), warehouse_id: '' }),\r\n      })\r\n      const result: ScanResult = {\r\n        barcode: barcode.trim(),\r\n        product_name: res.data?.product_name || 'Unknown',\r\n        product_sku: res.data?.product_sku || barcode,\r\n        lot_number: res.data?.lot_number || null,\r\n        quantity: res.data?.quantity || 0,\r\n        scanned_at: new Date().toLocaleTimeString('vi-VN'),\r\n      }\r\n      setLastScan(result)\r\n      setScanHistory(prev => [result, ...prev.slice(0, 49)])\r\n    } catch (err: any) {\r\n      setError(err.message || 'Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y sГҹв•‘Гәn phГҹв•‘вҢҗm')\r\n    }\r\n  }\r\n\r\n  const handleManualSubmit = (e: React.FormEvent) => {\r\n    e.preventDefault()\r\n    if (manualInput.trim()) {\r\n      lookupBarcode(manualInput.trim())\r\n      setManualInput('')\r\n    }\r\n  }\r\n\r\n  // BarcodeDetector API (Chrome 83+)\r\n  useEffect(() => {\r\n    if (!scanning || !videoRef.current) return\r\n\r\n    let active = true\r\n    const detectBarcode = async () => {\r\n      if (!active || !videoRef.current) return\r\n\r\n      // Try BarcodeDetector API if available\r\n      if ('BarcodeDetector' in window) {\r\n        try {\r\n          const detector = new (window as any).BarcodeDetector({\r\n            formats: ['ean_13', 'ean_8', 'code_128', 'code_39', 'qr_code']\r\n          })\r\n          const barcodes = await detector.detect(videoRef.current)\r\n          if (barcodes.length > 0 && active) {\r\n            const value = barcodes[0].rawValue\r\n            lookupBarcode(value)\r\n            // Pause briefly after scan\r\n            await new Promise(r => setTimeout(r, 2000))\r\n          }\r\n        } catch { /* detection failed, retry */ }\r\n      }\r\n\r\n      if (active) requestAnimationFrame(detectBarcode)\r\n    }\r\n\r\n    const timer = setTimeout(detectBarcode, 500)\r\n    return () => { active = false; clearTimeout(timer) }\r\n  }, [scanning])\r\n\r\n  return (\r\n    <div className=\"max-w-lg mx-auto p-4 space-y-4\">\r\n      {/* Header */}\r\n      <div className=\"flex items-center gap-3\">\r\n        <Link href=\"/dashboard\" className=\"text-2xl\">О“ГҘГү</Link>\r\n        <h1 className=\"text-xl font-bold\">вүЎЖ’Гҙв–’ PDA Barcode Scanner</h1>\r\n      </div>\r\n\r\n      {/* Camera View */}\r\n      {cameraAvailable && (\r\n        <div className=\"relative bg-black rounded-lg overflow-hidden\">\r\n          <video ref={videoRef} className=\"w-full\" playsInline muted />\r\n          <canvas ref={canvasRef} className=\"hidden\" />\r\n\r\n          {/* Scan Frame Overlay */}\r\n          {scanning && (\r\n            <div className=\"absolute inset-0 flex items-center justify-center\">\r\n              <div className=\"w-64 h-40 border-2 border-green-400 rounded-lg opacity-75\">\r\n                <div className=\"absolute top-0 left-0 w-8 h-8 border-t-4 border-l-4 border-green-400 rounded-tl-lg\" />\r\n                <div className=\"absolute top-0 right-0 w-8 h-8 border-t-4 border-r-4 border-green-400 rounded-tr-lg\" />\r\n                <div className=\"absolute bottom-0 left-0 w-8 h-8 border-b-4 border-l-4 border-green-400 rounded-bl-lg\" />\r\n                <div className=\"absolute bottom-0 right-0 w-8 h-8 border-b-4 border-r-4 border-green-400 rounded-br-lg\" />\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n      )}\r\n\r\n      {/* Camera Toggle */}\r\n      <button\r\n        onClick={scanning ? stopCamera : startCamera}\r\n        className={`w-full py-2.5 rounded-lg font-medium ${\r\n          scanning\r\n            ? 'bg-red-600 text-white hover:bg-red-700'\r\n            : 'bg-brand-500 text-white hover:bg-brand-600'\r\n        }`}>\r\n        {scanning ? 'О“Г…в•Ј DГҹв•—ВҪng camera' : 'вүЎЖ’Гҙв•– BГҹв•‘ВЎt camera quв”ңвҢҗt'}\r\n      </button>\r\n\r\n      {/* Manual Input */}\r\n      <form onSubmit={handleManualSubmit} className=\"flex gap-2\">\r\n        <input\r\n          type=\"text\"\r\n          value={manualInput}\r\n          onChange={e => setManualInput(e.target.value)}\r\n 