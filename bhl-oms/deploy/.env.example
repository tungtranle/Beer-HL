# BHL OMS — Production Environment Variables
# Copy to /opt/bhl-oms/.env and fill in real values

# Database
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Grafana
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA

# Integration (set to false when real APIs available)
INTEGRATION_MOCK=true

# Bravo ERP
BRAVO_URL=https://bravo.bhl.vn/api
BRAVO_API_KEY=

# DMS
DMS_URL=https://dms.bhl.vn/api
DMS_API_KEY=

# Zalo OA
ZALO_BASE_URL=https://openapi.zalo.me
ZALO_OA_TOKEN=
ZALO_OA_ID=
