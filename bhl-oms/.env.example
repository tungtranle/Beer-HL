# Environment
ENV=development

# Database
DB_URL=postgres://bhl:bhl_dev@localhost:5432/bhl_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT RS256 Keys
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Server
SERVER_PORT=8080

# VRP Solver
VRP_SOLVER_URL=http://localhost:8090

# OSRM
OSRM_URL=http://localhost:5000
